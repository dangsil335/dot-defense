    ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.globalAlpha = Math.min(1, glowI);
    const ig = ctx.createRadialGradient(0, 0, 0, 0, 0, s * 0.42);
    ig.addColorStop(0, '#fff'); ig.addColorStop(0.4, eyeColor || '#ff2a5a'); ig.addColorStop(1, 'rgba(0,0,0,0)');
    ctx.fillStyle = ig; ctx.beginPath(); ctx.ellipse(0, 0, s * 0.2, s * 0.58 * blink, 0, 0, Math.PI * 2); ctx.fill();
    ctx.restore();
    ctx.fillStyle = '#050005'; ctx.beginPath(); ctx.ellipse(0, 0, s * 0.06, s * 0.4 * blink, 0, 0, Math.PI * 2); ctx.fill();
    // 궤도 위성 눈 3개
    for (let k = 0; k < 3; k++) {
      const a = _t * 0.02 + k * (Math.PI * 2 / 3); const ox = Math.cos(a) * s * 0.82, oy = Math.sin(a) * s * 0.82;
      ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.globalAlpha = Math.min(1, glowI);
      const eg2 = ctx.createRadialGradient(ox, oy, 0, ox, oy, s * 0.17);
      eg2.addColorStop(0, `rgba(${ergb},0.9)`); eg2.addColorStop(1, 'rgba(0,0,0,0)');
      ctx.fillStyle = eg2; ctx.beginPath(); ctx.arc(ox, oy, s * 0.17, 0, Math.PI * 2); ctx.fill();
      ctx.restore();
