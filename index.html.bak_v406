    star: { name: '별 · 셀레네', fb: '🔮', art: 'star', color: '#88ccff', events: [
      () => ({ title: '⭐ 별자리 점', text: '"별이 세 갈래 길을 비추는군요. 어느 빛을 따르시겠어요?"',
        choices: [
          { label: '⚔ 힘의 별', desc: `데미지 +${_evP(14)}% 영구`, resolve() { const p = _evDmg(14); return `⚔ 데미지 +${p}% 영구!`; } },
          { label: '💰 황금의 별', desc: `획득 골드 +${_evP(15)}% 영구`, resolve() { const p = _evGold(15); return `💰 획득 골드 +${p}% 영구!`; } },
          { label: '👹 사냥의 별', desc: `보스 데미지 +${_evP(20)}% 영구`, resolve() { const p = _evBoss(20); return `👹 보스 데미지 +${p}% 영구!`; } },
        ] }),
