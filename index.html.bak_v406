  }
  // ☀ 초신성 코어 — 코로나 플레어 + 구체 별 + 흑점 + 핫코어
  function drawSupernovaShape(ctx, s, fill, edge, eyeGlow, eyeColor) {
    const _t = (typeof state !== 'undefined' && state && state.t) || 0;
    const pulse = 1 + Math.sin(_t * 0.1) * 0.06;
    const _f = (fill || '#ff9a3a').replace('#', ''); const fn = parseInt(_f, 16); const frgb = `${(fn >> 16) & 255},${(fn >> 8) & 255},${fn & 255}`;
    const _e = (eyeColor || '#fff0a0').replace('#', ''); const _en = parseInt(_e, 16); const ergb = `${(_en >> 16) & 255},${(_en >> 8) & 255},${_en & 255}`;
    // 코로나 플레어 (가산 회전)
    ctx.save(); ctx.globalCompositeOperation = 'lighter';
    for (let k = 0; k < 12; k++) {
      const a = k * Math.PI / 6 + _t * 0.01, len = s * (1.5 + 0.3 * Math.sin(_t * 0.08 + k));
      const grd = ctx.createLinearGradient(0, 0, Math.cos(a) * len, Math.sin(a) * len);
      grd.addColorStop(0, `rgba(${frgb},0.4)`); grd.addColorStop(1, `rgba(${frgb},0)`);
      ctx.strokeStyle = grd; ctx.lineWidth = (k % 2 ? 2 : 4);
      ctx.beginPath(); ctx.moveTo(Math.cos(a) * s * 0.6, Math.sin(a) * s * 0.6); ctx.lineTo(Math.cos(a) * len, Math.sin(a) * len); ctx.stroke();
    }
    const hg = ctx.createRadialGradient(0, 0, s * 0.3, 0, 0, s * 1.5);
    hg.addColorStop(0, `rgba(${frgb},0.28)`); hg.addColorStop(1, `rgba(${frgb},0)`);
    ctx.fillStyle = hg; ctx.beginPath(); ctx.arc(0, 0, s * 1.5, 0, Math.PI * 2); ctx.fill();
    ctx.restore();
    // 별 본체 (구체 음영)
    const R = s * 1.0 * pulse;
    const bg = ctx.createRadialGradient(-R * 0.2, -R * 0.2, R * 0.1, 0, 0, R);
    bg.addColorStop(0, '#fff8e0'); bg.addColorStop(0.4, lightenHex(fill, 0.15)); bg.addColorStop(0.8, fill); bg.addColorStop(1, darkenHex(fill, 0.42));
    ctx.fillStyle = bg; ctx.beginPath(); ctx.arc(0, 0, R, 0, Math.PI * 2); ctx.fill();
    // 흑점
    ctx.fillStyle = darkenHex(fill, 0.45); ctx.globalAlpha = 0.5;
    const spots = [[R * 0.25, -R * 0.1], [-R * 0.3, R * 0.2], [R * 0.1, R * 0.35]];
    for (const [sx, sy] of spots) { ctx.beginPath(); ctx.arc(sx, sy, R * 0.12, 0, Math.PI * 2); ctx.fill(); }
    ctx.globalAlpha = 1;
    // 핫코어 (가산 맥동)
    ctx.save(); ctx.globalCompositeOperation = 'lighter';
    const cp = 0.6 + 0.4 * Math.sin(_t * 0.12);
    const hc = ctx.createRadialGradient(0, 0, 0, 0, 0, R * 0.6);
    hc.addColorStop(0, `rgba(255,255,255,${0.75 * cp})`); hc.addColorStop(0.5, `rgba(${ergb},${0.45 * cp})`); hc.addColorStop(1, 'rgba(0,0,0,0)');
    ctx.fillStyle = hc; ctx.beginPath(); ctx.arc(0, 0, R * 0.6, 0, Math.PI * 2); ctx.fill();
    ctx.restore();
  }
  const SPECIAL_BOSS_DEFS = {
    leviathan: { name: '우주 레비아탄', icon: '🦈', color: '#3aa0d0', edge: '#16415c', eye: '#7dffff',
                 gimmick: 'split', draw: drawLeviathanShape, hpMul: 1.15 },
    reaper:    { name: '우주 사신',     icon: '💀', color: '#9a6ad0', edge: '#3a1f5c', eye: '#ff7ac0',
                 gimmick: 'seal',  draw: drawReaperShape, hpMul: 1.0 },
    kraken:    { name: '우주 크라켄',   icon: '🐙', color: '#6a3ac0', edge: '#2a1550', eye: '#a0e0ff',
                 gimmick: 'devour', draw: drawKrakenShape, hpMul: 1.1 },
    crystal:   { name: '수정 군주',     icon: '💎', color: '#5ec8dc', edge: '#1a4a5c', eye: '#e6ffff',
                 gimmick: 'shieldPhase', draw: drawCrystalShape, hpMul: 1.2 },
    voidEye:   { name: '공허의 눈',     icon: '👁', color: '#3a2a5c', edge: '#160e2c', eye: '#ff5ad0',
                 gimmick: 'blink', draw: drawVoidEyeShape, hpMul: 1.0 },
    supernova: { name: '초신성 코어',   icon: '☀', color: '#ff9a3a', edge: '#7a3410', eye: '#fff0a0',
                 gimmick: 'deathNova', draw: drawSupernovaShape, hpMul: 1.05 },
    // ☠ R100 전용 최종보스 — 거대·고체력·3페이즈
    abaddon:   { name: '종말 · 아바돈',  icon: '☠', color: '#1e0a2e', edge: '#08020e', eye: '#ff2a5a',
                 gimmick: 'finale', draw: drawAbaddonShape, hpMul: 2.8, sizeMul: 1.7, isFinal: true },
  };
  const SPECIAL_BOSS_IDS = Object.keys(SPECIAL_BOSS_DEFS).filter(k => !SPECIAL_BOSS_DEFS[k].isFinal);  // 아바돈은 랜덤 풀 제외 (R100 전용)

  // 🌌 v267 — 특수 보스 등장 연출 (3초). 정신없지 않게 부드러운 페이드 위주.
  //   타임라인 (180프레임 = 3초):
  //     0~40  : 화면 어두워짐 (vignette 페이드인)
  //     30~110: 거대 그림자 아래→중앙 부상 + 안광 2~3회 은은한 펄스
  //     110~155: 그림자 스르륵 페이드아웃
  //     130~175: 보스 이름 경고 텍스트 펄스
  //   탭하면 스킵 (introSkip)
  const BOSS_INTRO_DUR = 120;   // 🎬 v315 — 2초 (짧은 등장 연출 → 보스가 라운드 시작 직후 합류, 때릴 시간 ↑). 기존 9초는 너무 늦게 등장했음
  function updateBossIntro() {
    if (!state.bossIntro) return;
    // 스킵 시 빠르게 마무리 (남은 프레임 가속) — 보스 스폰 시점도 당겨짐
    if (state.bossIntro.skip) state.bossIntro.frame += 6;
    else state.bossIntro.frame++;
    if (state.bossIntro.frame >= BOSS_INTRO_DUR) {
      state.bossIntro = null;   // 연출 종료 (보스는 bossSpawns 시점에 정상 등장)
    }
  }
  // 🎬 v326 — 특수 보스별 고유 등장 연출. 정규화 진행도 p(0~1) 기반 → 길이 바뀌어도 안정.
  function _introEc(def) { const h = (def.eye || '#ffffff').replace('#', ''); const n = parseInt(h, 16); return `${(n >> 16) & 255},${(n >> 8) & 255},${n & 255}`; }
  // 🦈 레비아탄 — 화면 밖에서 헤엄쳐 들어오는 거대 그림자 + 물살 자국
  function introLeviathan(f, p, fade, def, ec) {
    const ease = p * p * (3 - 2 * p);
    const x = W * 0.14 + (CX - W * 0.14) * ease + Math.sin(f * 0.05) * W * 0.05 * (1 - ease);
    const y = H * 0.92 + (CY - H * 0.92) * ease;
    const scale = 0.32 + ease * 1.45;
    const ang = Math.atan2(CY - y, CX - x);
    const eg = 0.4 + ease * 1.0 + 0.3 * Math.sin(f * 0.3);
    // 물살 자국 (뒤로 퍼지는 호)
    ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.globalAlpha = 0.18 * ease * fade;
    ctx.strokeStyle = `rgba(${ec},0.5)`; ctx.lineWidth = 2;
    for (let k = 1; k <= 3; k++) { ctx.beginPath(); ctx.arc(x - Math.cos(ang) * 30 * k, y - Math.sin(ang) * 30 * k, 18 * k + 10, ang - 0.6, ang + 0.6); ctx.stroke(); }
    ctx.restore();
    ctx.save(); ctx.globalAlpha = Math.min(1, 0.35 + ease) * fade; ctx.translate(x, y); ctx.rotate(ang + Math.PI / 2);
    def.draw(ctx, 46 * scale, '#06080f', '#0e1426', eg, def.eye); ctx.restore();
  }
  // 💀 사신 — 아래에서 스르륵 떠오르는 후드 그림자 + 낫 섬광 가로 스윕
  function introReaper(f, p, fade, def, ec) {
    const ease = p * p * (3 - 2 * p);
    const y = H * 1.06 - (H * 1.06 - CY) * ease;
    const x = CX + Math.sin(p * Math.PI * 2) * W * 0.04;
    const scale = 0.6 + ease * 1.15;
    const eg = (p > 0.4 ? (p - 0.4) / 0.6 : 0) * 1.3 + 0.2 * Math.sin(f * 0.3);
    ctx.save(); ctx.globalAlpha = Math.min(1, ease * 1.3) * fade; ctx.translate(x, y);
    def.draw(ctx, 46 * scale, '#06070f', '#0e0a1a', eg, def.eye); ctx.restore();
    // 낫 섬광 — 대각선 빛줄기 한 번 스윕
    if (p > 0.42 && p < 0.7) { const sp = (p - 0.42) / 0.28; const lx = W * sp; ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.globalAlpha = Math.sin(sp * Math.PI) * 0.7 * fade; ctx.strokeStyle = 'rgba(225,235,255,0.95)'; ctx.lineWidth = 3; ctx.beginPath(); ctx.moveTo(lx - 50, CY - 70); ctx.lineTo(lx + 50, CY + 70); ctx.stroke(); ctx.restore(); }
  }
  // 🐙 크라켄 — 화면 가장자리 어둠에서 촉수들이 안쪽으로 뻗어옴 → 중앙 안광 점등
  function introKraken(f, p, fade, def, ec) {
    const ease = p * p * (3 - 2 * p);
    const D = Math.max(W, H) * 0.62;
    ctx.save(); ctx.lineCap = 'round';
    const NT = 6;
    for (let i = 0; i < NT; i++) {
      const a = i * Math.PI * 2 / NT + 0.4;
      const reach = Math.max(0, Math.min(1, ease * 1.35 - i * 0.04));
      if (reach <= 0) continue;
      const ox = CX + Math.cos(a) * D, oy = CY + Math.sin(a) * D;
      const tipx = ox + (CX - ox) * reach * 0.82, tipy = oy + (CY - oy) * reach * 0.82;
      const wob = Math.sin(f * 0.05 + i) * 70 * (1 - reach * 0.5);
      const midx = (ox + tipx) / 2 + Math.cos(a + 1.5) * wob, midy = (oy + tipy) / 2 + Math.sin(a + 1.5) * wob;
      ctx.globalAlpha = Math.min(1, reach * 1.5) * fade;
      ctx.strokeStyle = '#08060f'; ctx.lineWidth = 30 * (0.45 + reach * 0.55);
      ctx.beginPath(); ctx.moveTo(ox, oy); ctx.quadraticCurveTo(midx, midy, tipx, tipy); ctx.stroke();
      // 빨판 글로우 (촉수 따라 점점이)
      ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.globalAlpha = reach * 0.4 * fade; ctx.fillStyle = `rgba(${ec},0.7)`;
      for (let k = 1; k <= 3; k++) { const tt = k / 4; const sx = ox + (tipx - ox) * tt, sy = oy + (tipy - oy) * tt; ctx.beginPath(); ctx.arc(sx, sy, 3, 0, Math.PI * 2); ctx.fill(); }
      ctx.restore();
    }
    ctx.lineCap = 'butt'; ctx.restore();
    // 중앙 안광 2개 — 어둠 속에서 점등 (후반)
    if (p > 0.5) {
      const ep = (p - 0.5) / 0.5; ctx.save(); ctx.globalCompositeOperation = 'lighter';
      for (const sx of [-22, 22]) {
        ctx.globalAlpha = ep * (0.6 + 0.4 * Math.sin(f * 0.3)) * fade;
        const g = ctx.createRadialGradient(CX + sx, CY, 0, CX + sx, CY, 26);
        g.addColorStop(0, `rgba(${ec},0.9)`); g.addColorStop(1, `rgba(${ec},0)`);
        ctx.fillStyle = g; ctx.beginPath(); ctx.arc(CX + sx, CY, 26, 0, Math.PI * 2); ctx.fill();
      }
      ctx.restore();
    }
  }
  // 💎 수정 군주 — 바닥에서 결정이 솟아오르며 조립 + 빛 굴절 반짝임
  function introCrystal(f, p, fade, def, ec) {
    const ease = p * p * (3 - 2 * p);
    ctx.save(); ctx.translate(CX, CY);
    // 솟아오르는 파편들 (방사)
    for (let i = 0; i < 8; i++) {
      const a = i * Math.PI / 4 + 0.2; const d = ease * 110; const rp = Math.max(0, Math.min(1, ease * 1.3 - i * 0.03));
      if (rp <= 0) continue;
      ctx.save(); ctx.translate(Math.cos(a) * d, Math.sin(a) * d); ctx.rotate(a); ctx.globalAlpha = rp * fade;
      const sh = 16 * rp; ctx.fillStyle = lightenHex(def.color, 0.1); ctx.beginPath(); ctx.moveTo(0, -sh); ctx.lineTo(sh * 0.5, 0); ctx.lineTo(0, sh); ctx.lineTo(-sh * 0.5, 0); ctx.closePath(); ctx.fill();
      ctx.restore();
    }
    // 중앙 결정 본체 (솟아오름)
    ctx.globalAlpha = Math.min(1, ease * 1.3) * fade; ctx.scale(1, ease);
    def.draw(ctx, 44 * (0.5 + ease * 0.6), def.color, def.edge, ease, def.eye);
    ctx.restore();
    // 빛 굴절 번쩍 (p~0.5)
    if (p > 0.4 && p < 0.62) { const sp = (p - 0.4) / 0.22; ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.globalAlpha = Math.sin(sp * Math.PI) * 0.5 * fade; ctx.strokeStyle = `rgba(${ec},0.9)`; ctx.lineWidth = 2; for (let i = 0; i < 4; i++) { const a = i * Math.PI / 2 + sp; ctx.beginPath(); ctx.moveTo(CX + Math.cos(a) * 30, CY + Math.sin(a) * 30); ctx.lineTo(CX + Math.cos(a) * 160, CY + Math.sin(a) * 160); ctx.stroke(); } ctx.restore(); }
  }
  // 👁 공허의 눈 — 어둠 속에서 눈꺼풀이 갈라지며 눈이 떠짐 + 고리 가동
  function introVoidEye(f, p, fade, def, ec) {
    const open = Math.min(1, p / 0.62);              // 세로 개안 진행
    const eg = open * 1.3 + 0.2 * Math.sin(f * 0.3);
    ctx.save(); ctx.translate(CX, CY);
    // 개안 마스크 (세로로 열리는 타원 클립)
    ctx.save();
    ctx.beginPath(); ctx.ellipse(0, 0, 84, 84 * Math.max(0.04, open), 0, 0, Math.PI * 2); ctx.clip();
    ctx.globalAlpha = fade;
    def.draw(ctx, 50, def.color, def.edge, eg, def.eye);
    ctx.restore();
    // 눈꺼풀 가장자리 빛선 (위/아래)
    const lidY = 84 * Math.max(0.04, open);
    ctx.globalCompositeOperation = 'lighter'; ctx.globalAlpha = (1 - open * 0.4) * 0.6 * fade;
    ctx.strokeStyle = `rgba(${ec},0.8)`; ctx.lineWidth = 2;
    ctx.beginPath(); ctx.ellipse(0, 0, 84, lidY, 0, Math.PI, Math.PI * 2); ctx.stroke();
    ctx.beginPath(); ctx.ellipse(0, 0, 84, lidY, 0, 0, Math.PI); ctx.stroke();
    ctx.restore();
  }
  // ☠ 종말·아바돈 — 전용 강림 시네마틱: 붉은 심박 전조 → 아래에서 부상·개안 → 섬광·충격파 → 타이틀 슬램
  function introAbaddon(f, p, fade, def, ec) {
    ctx.save(); ctx.translate(CX, CY);
    // 1) 전조 — 붉은 심장박동 + 균열 광선
    if (p < 0.45) {
      const hb = Math.pow(Math.abs(Math.sin(f * 0.12)), 3);
      ctx.save(); ctx.globalCompositeOperation = 'lighter';
      const g = ctx.createRadialGradient(0, 0, 0, 0, 0, 220);
      g.addColorStop(0, `rgba(${ec},${(0.10 + 0.34 * hb) * Math.min(1, p / 0.12) * fade})`); g.addColorStop(1, 'rgba(0,0,0,0)');
      ctx.fillStyle = g; ctx.fillRect(-W, -H, W * 2, H * 2);
      ctx.strokeStyle = `rgba(${ec},${0.28 * hb * fade})`; ctx.lineWidth = 2;
      for (let i = 0; i < 8; i++) { const a = i * Math.PI / 4 + f * 0.002; ctx.beginPath(); ctx.moveTo(0, 0); ctx.lineTo(Math.cos(a) * (60 + hb * 130), Math.sin(a) * (60 + hb * 130)); ctx.stroke(); }
      ctx.restore();
    }
    // 2) 강림 — 아래에서 부상 + 코어 점화
    if (p >= 0.3 && p < 0.84) {
      const rp = Math.min(1, (p - 0.3) / 0.5);
      ctx.save(); ctx.translate(0, (1 - rp) * 190); ctx.scale(0.6 + rp * 0.55, 0.6 + rp * 0.55);
      ctx.globalAlpha = Math.min(1, rp * 1.7) * fade;
      def.draw(ctx, 54, def.color, def.edge, rp * 1.4, def.eye);
      ctx.restore();
    }
    // 3) 개안 완성 → 섬광 + 충격파
    if (p >= 0.78 && p < 0.93) {
      const cp = (p - 0.78) / 0.15;
      if (cp < 0.35) { ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.globalAlpha = (1 - cp / 0.35) * 0.6 * fade; ctx.fillStyle = '#ffe0e8'; ctx.fillRect(-W, -H, W * 2, H * 2); ctx.restore(); }
      ctx.save(); ctx.globalCompositeOperation = 'lighter'; const rr = cp * Math.max(W, H) * 0.55;
      ctx.strokeStyle = `rgba(${ec},${0.7 * (1 - cp) * fade})`; ctx.lineWidth = 5 * (1 - cp) + 1; ctx.beginPath(); ctx.arc(0, 0, rr, 0, Math.PI * 2); ctx.stroke(); ctx.restore();
    }
    // 4) 타이틀 슬램
    if (p >= 0.62) {
      const tp = Math.min(1, (p - 0.62) / 0.12), slam = 1 + (1 - tp) * 0.6;
      ctx.save(); ctx.globalAlpha = tp * fade; ctx.scale(slam, slam); ctx.textAlign = 'center';
      ctx.shadowColor = def.eye; ctx.shadowBlur = 26; ctx.fillStyle = '#fff'; ctx.font = 'bold 38px Jua, sans-serif'; ctx.fillText('종말 · 아바돈', 0, -6);
      ctx.shadowBlur = 0; ctx.fillStyle = `rgba(${ec},${tp})`; ctx.font = 'bold 14px Jua, sans-serif'; ctx.fillText('— THE END —', 0, 22);
      ctx.restore();
    }
    ctx.restore();
    ctx.textAlign = 'start';
    if (f === Math.round(BOSS_INTRO_DUR * 0.3)) shake(10, 16);
    if (f === Math.round(BOSS_INTRO_DUR * 0.78)) shake(26, 30);
  }
  // ☀ 초신성 코어 — 빛 수렴(붕괴) → 섬광 → 별 점화 + 충격파
  function introSupernova(f, p, fade, def, ec) {
    ctx.save(); ctx.translate(CX, CY);
    if (p < 0.5) {
      const cp = p / 0.5; ctx.globalCompositeOperation = 'lighter';
      // 외곽에서 중앙으로 수렴하는 광선
      ctx.strokeStyle = `rgba(${ec},${0.5 * cp * fade})`; ctx.lineWidth = 2;
      for (let i = 0; i < 16; i++) { const a = i * Math.PI / 8; const r0 = 220 * (1 - cp) + 50, r1 = 30; ctx.beginPath(); ctx.moveTo(Math.cos(a) * (r0 + 50), Math.sin(a) * (r0 + 50)); ctx.lineTo(Math.cos(a) * r1, Math.sin(a) * r1); ctx.stroke(); }
      // 응축 코어
      const g = ctx.createRadialGradient(0, 0, 0, 0, 0, 50 + cp * 30); g.addColorStop(0, `rgba(255,255,235,${cp * fade})`); g.addColorStop(1, 'rgba(0,0,0,0)');
      ctx.fillStyle = g; ctx.beginPath(); ctx.arc(0, 0, 80, 0, Math.PI * 2); ctx.fill();
    } else {
      const cp = (p - 0.5) / 0.5; ctx.globalCompositeOperation = 'lighter';
      // 섬광 (짧고 강하게, 0.45 상한)
      if (cp < 0.3) { ctx.globalAlpha = (1 - cp / 0.3) * 0.45 * fade; ctx.fillStyle = '#fff6dc'; ctx.fillRect(-W, -H, W * 2, H * 2); ctx.globalAlpha = 1; }
      // 충격파 링
      const rr = cp * Math.max(W, H) * 0.5; ctx.strokeStyle = `rgba(${ec},${0.6 * (1 - cp) * fade})`; ctx.lineWidth = 4 * (1 - cp) + 1; ctx.beginPath(); ctx.arc(0, 0, rr, 0, Math.PI * 2); ctx.stroke();
      // 별 점화
      ctx.globalCompositeOperation = 'source-over'; ctx.globalAlpha = Math.min(1, cp * 1.5) * fade;
      def.draw(ctx, 46, def.color, def.edge, cp, def.eye);
    }
    ctx.restore();
  }
  function drawBossIntro() {
    const bi = state.bossIntro;
    if (!bi) return;
    const def = SPECIAL_BOSS_DEFS[bi.special];
    if (!def) return;
    const f = bi.frame;
    const p = Math.min(1, f / BOSS_INTRO_DUR);     // 0~1 정규화 진행도
    const fade = p > 0.85 ? Math.max(0, 1 - (p - 0.85) / 0.15) : 1;   // 끝 페이드아웃
    const ec = _introEc(def);
    ctx.save();
    // 공통 비네팅 (다가오는 분위기)
    let vig = 0;
    if (p < 0.25) vig = (p / 0.25) * 0.32; else if (p > 0.8) vig = Math.max(0, 0.32 * (1 - (p - 0.8) / 0.2)); else vig = 0.32;
    if (vig > 0) { const vg = ctx.createRadialGradient(CX, CY, Math.min(W, H) * 0.32, CX, CY, Math.max(W, H) * 0.72); vg.addColorStop(0, 'rgba(3,4,10,0)'); vg.addColorStop(1, `rgba(3,4,10,${vig})`); ctx.fillStyle = vg; ctx.fillRect(0, 0, W, H); }
    // 보스별 고유 연출
    if (bi.special === 'leviathan') introLeviathan(f, p, fade, def, ec);
    else if (bi.special === 'reaper') introReaper(f, p, fade, def, ec);
    else if (bi.special === 'kraken') introKraken(f, p, fade, def, ec);
    else if (bi.special === 'crystal') introCrystal(f, p, fade, def, ec);
    else if (bi.special === 'voidEye') introVoidEye(f, p, fade, def, ec);
    else if (bi.special === 'supernova') introSupernova(f, p, fade, def, ec);
    else if (bi.special === 'abaddon') introAbaddon(f, p, fade, def, ec);
    else { ctx.save(); ctx.globalAlpha = Math.min(1, p * 1.5) * fade; ctx.translate(CX, CY); def.draw(ctx, 46, '#06070f', '#101428', p * 1.2, def.eye); ctx.restore(); }
    // 공통 경고 텍스트 (상단) — 아바돈은 전용 타이틀 슬램이 따로 있어 생략
    if (p >= 0.3 && bi.special !== 'abaddon') {
      const tp = Math.min(1, (p - 0.3) / 0.2) * fade; const pulse = 0.7 + 0.3 * Math.sin(f * 0.18);
      ctx.textAlign = 'center'; ctx.fillStyle = def.eye; ctx.shadowColor = def.eye; ctx.shadowBlur = 18; ctx.font = 'bold 22px Jua, sans-serif';
      ctx.globalAlpha = tp * pulse; ctx.fillText(bi.special === 'abaddon' ? `☠ 최종 — ${def.name} 강림` : `⚠ ${def.icon} ${def.name} 접근 중...`, CX, 40); ctx.shadowBlur = 0; ctx.globalAlpha = 1;
    }
    ctx.restore();
    ctx.textAlign = 'start';
  }

  // 🎬 v268 — 보스 등장 변환 (스르륵 커지며 페이드인, 살짝 overshoot)
  function bossSpawnFx(e) {
    const se = state.t - (e.spawnT || 0);
    const DUR = 32;
    if (se >= DUR || !e.spawnT) return null;
    const p = se / DUR;
    const eased = 1 - Math.pow(1 - p, 3);
    let scale = 0.35 + eased * 0.71 + Math.sin(p * Math.PI) * 0.08;  // 0.35 → ~1.08 → 1.0
    return { scale, alpha: Math.min(1, p * 1.6) };
  }
  function drawBossE(e, x, y, slow) {
    // 🌌 v267 — 특수 보스 전용 외형
    if (e.special && SPECIAL_BOSS_DEFS[e.special]) {
      const def = SPECIAL_BOSS_DEFS[e.special];
      const s = e.size * 0.7;   // 🦈 v279 — 크기 축소 (레비아탄/사신 외형이 세로로 퍼져 너무 컸음 → 일반 보스 수준)
      ctx.save(); ctx.translate(x, y);
      // 🦈 v278 — 레비아탄: 위에서 본 상어 → 진행 방향(중앙 향함)으로 회전 (머리가 코어 쪽)
      //   사신은 유령(부유)이라 방향 무관 → 회전 X
      if (e.special === 'leviathan') {
        const angC = Math.atan2(CY - y, CX - x);
        ctx.rotate(angC + Math.PI / 2);   // 머리(-y)를 중앙 방향으로
      }
      // 🎬 등장 애니메이션
      const fx = bossSpawnFx(e);
      if (fx) { ctx.globalAlpha = fx.alpha; ctx.scale(fx.scale, fx.scale); }
      // 🌌 외곽 글로우 헤일로 (가산, 부드러운 다단계 — 존재감)
      const pulse = 1 + Math.sin(state.t * 0.08) * 0.12;
      const _ha = (fx ? fx.alpha : 1);
      let _gc;
      if (slow) { _gc = '136,187,238'; }
      else { const _eh = (def.eye || '#ffffff').replace('#',''); const _en = parseInt(_eh, 16); _gc = `${(_en>>16)&255},${(_en>>8)&255},${_en&255}`; }
      ctx.save(); ctx.globalCompositeOperation = 'lighter';
      const _glow = ctx.createRadialGradient(0, 0, s * 0.3, 0, 0, s * 1.85 * pulse);
      _glow.addColorStop(0, `rgba(${_gc},${0.22 * _ha})`); _glow.addColorStop(0.5, `rgba(${_gc},${0.10 * _ha})`); _glow.addColorStop(1, `rgba(${_gc},0)`);
      ctx.fillStyle = _glow; ctx.beginPath(); ctx.arc(0, 0, s * 1.85 * pulse, 0, Math.PI*2); ctx.fill();
      ctx.restore();
      ctx.globalAlpha = fx ? fx.alpha : 1;
      // 👁 점멸 무적 중 — 깜빡임
      if (e.blinkInvulnUntil && e.blinkInvulnUntil > state.t) ctx.globalAlpha *= 0.35 + 0.3 * Math.sin(state.t * 0.9);
      const bodyColor = slow ? '#4a6a88' : def.color;
      const _eg = 0.55 + 0.45 * Math.sin(state.t * 0.12);   // 👁 인게임에서도 눈이 살아있게 (펄스 안광)
      def.draw(ctx, s, bodyColor, def.edge, _eg, def.eye);
      // 💎 수정 군주 — 결정 보호막 활성 중 방벽 링 (육각 + 원형 글로우)
      if (e.shieldPhaseUntil && e.shieldPhaseUntil > state.t) {
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        const sa = 0.5 + 0.3 * Math.sin(state.t * 0.2);
        ctx.strokeStyle = `rgba(180,240,255,${0.55 * sa})`; ctx.lineWidth = 2.5;
        ctx.beginPath();
        for (let k = 0; k < 6; k++) { const a = k * Math.PI / 3 + state.t * 0.02; const px = Math.cos(a) * s * 1.7, py = Math.sin(a) * s * 1.7; k ? ctx.lineTo(px, py) : ctx.moveTo(px, py); }
        ctx.closePath(); ctx.stroke();
        ctx.strokeStyle = `rgba(230,255,255,${0.3 * sa})`; ctx.lineWidth = 1.2; ctx.beginPath(); ctx.arc(0, 0, s * 1.55, 0, Math.PI * 2); ctx.stroke();
        ctx.restore();
      }
      ctx.restore();
      return;
    }
    const s = e.size;
    ctx.save(); ctx.translate(x, y);
    // 🎬 등장 애니메이션 (일반 보스도)
    const fx = bossSpawnFx(e);
    if (fx) { ctx.globalAlpha = fx.alpha; ctx.scale(fx.scale, fx.scale); }
    ctx.rotate(e.rotation);
    // 외곽 글로우 헤일로 (가산, 부드러운 다단계 — 존재감 + 바닥에 빛이 깔리는 느낌)
    const pulse = 1 + Math.sin(state.t * 0.09) * 0.12;
    const _hc = slow ? '120,180,240' : '255,70,95';
    ctx.save(); ctx.globalCompositeOperation = 'lighter';
    const _halo = ctx.createRadialGradient(0, 0, s*0.3, 0, 0, s*1.9*pulse);
    _halo.addColorStop(0, `rgba(${_hc},0.22)`); _halo.addColorStop(0.5, `rgba(${_hc},0.10)`); _halo.addColorStop(1, `rgba(${_hc},0)`);
    ctx.fillStyle = _halo; ctx.beginPath(); ctx.arc(0, 0, s*1.9*pulse, 0, Math.PI*2); ctx.fill();
    ctx.restore();
    // 색상
    const base = slow ? '#385878' : '#601a28';
    const edge = slow ? '#1c2d44' : '#2a0a12';
    const lite = slow ? '#6e98ba' : '#9a3042';
    const ecol = slow ? '170,210,255' : '255,90,110';
    // 외곽 장갑 스파이크 링 (8방향)
    ctx.fillStyle = edge;
    for (let k = 0; k < 8; k++) {
      ctx.save(); ctx.rotate(k * Math.PI / 4);
      ctx.beginPath(); ctx.moveTo(-s*0.16, -s*1.02); ctx.lineTo(s*0.16, -s*1.02); ctx.lineTo(0, -s*1.32); ctx.closePath(); ctx.fill();
      ctx.restore();
    }
    // 8각형 본체 (라디얼 음영 — 입체)
    const oct = () => { ctx.beginPath(); ctx.moveTo(-s+4,-s); ctx.lineTo(s-4,-s); ctx.lineTo(s,-s+4); ctx.lineTo(s,s-4); ctx.lineTo(s-4,s); ctx.lineTo(-s+4,s); ctx.lineTo(-s,s-4); ctx.lineTo(-s,-s+4); ctx.closePath(); };
    const bgr = ctx.createRadialGradient(-s*0.35, -s*0.35, s*0.1, 0, 0, s*1.2);
    bgr.addColorStop(0, lite); bgr.addColorStop(0.6, base); bgr.addColorStop(1, edge);
    oct(); ctx.fillStyle = bgr; ctx.fill();
    oct(); ctx.strokeStyle = edge; ctx.lineWidth = 2; ctx.stroke();
    // 내부 패널 링 + 리벳 4개 (메카 디테일)
    ctx.strokeStyle = `rgba(${ecol},0.30)`; ctx.lineWidth = 1;
    ctx.beginPath(); ctx.arc(0, 0, s*0.62, 0, Math.PI*2); ctx.stroke();
    ctx.fillStyle = edge;
    for (let k = 0; k < 4; k++) { const a = k*Math.PI/2 + Math.PI/4; ctx.beginPath(); ctx.arc(Math.cos(a)*s*0.74, Math.sin(a)*s*0.74, s*0.09, 0, Math.PI*2); ctx.fill(); }
    // 회전 코어 링 (가산, 독립 회전 — 위협적 에너지)
    ctx.save(); ctx.rotate(-e.rotation + state.t * 0.03); ctx.globalCompositeOperation = 'lighter';
    ctx.strokeStyle = `rgba(${ecol},0.6)`; ctx.lineWidth = 2;
    for (let k = 0; k < 3; k++) { const a0 = k * 2.1 + state.t * 0.02; ctx.beginPath(); ctx.arc(0, 0, s*0.46, a0, a0 + 1.3); ctx.stroke(); }
    ctx.restore();
    // 중앙 안광 (펄스 글로우)
    const ep = 0.6 + 0.4 * Math.sin(state.t * 0.12);
    ctx.save(); ctx.globalCompositeOperation = 'lighter';
    const eg = ctx.createRadialGradient(0, 0, 0, 0, 0, s*0.42);
    eg.addColorStop(0, `rgba(255,255,255,${0.85*ep})`); eg.addColorStop(0.4, `rgba(${ecol},${0.7*ep})`); eg.addColorStop(1, `rgba(${ecol},0)`);
    ctx.fillStyle = eg; ctx.beginPath(); ctx.arc(0, 0, s*0.42, 0, Math.PI*2); ctx.fill();
    ctx.restore();
    ctx.fillStyle = '#fff'; ctx.beginPath(); ctx.arc(0, 0, s*0.1, 0, Math.PI*2); ctx.fill();
    ctx.restore();
  }

  function drawEnemies() {
    for (const e of state.enemies) {
      // 회전 업데이트 (개체별 rotSpeed 적용)
      e.rotation = (e.rotation || 0) + (e.rotSpeed || 0);
      const [x, y] = enemyXY(e);
      const slow = e.slowFrames > 0;
      // 🌑 발밑 그림자 (접지감)
      castShadow(x, y + e.size * 0.5, e.size * (e.isBoss ? 1.5 : 1.2), e.isBoss ? 0.34 : 0.26);
      // 타입별 디스패치
      if (e.isBoss)               drawBossE(e, x, y, slow);
      else if (e.type === 'ice')  drawIceE(e, x, y, slow);
      else if (e.type === 'drone')   drawDroneE(e, x, y, slow);
      else if (e.type === 'plasma')  drawPlasmaE(e, x, y, slow);
      else if (e.type === 'crystal') drawCrystalE(e, x, y, slow);
      else                        drawAsteroidE(e, x, y, slow);
      // ✨ 피격 흰 플래시 (가산) — 타격감
      // 🚀 캐시된 플래시 스프라이트 — 피격 적마다 매 프레임 그라디언트 생성 제거
      if (e.hitFlash && e.hitFlash > state.t) {
        const fa = (e.hitFlash - state.t) / 3;
        const fr = e.size * 1.3;
        ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.globalAlpha = fa * 0.55;
        ctx.drawImage(_hitFlashSprite(), x - fr, y - fr, fr * 2, fr * 2);
        ctx.restore(); ctx.globalAlpha = 1;
      }
      // HP 바 (둥근 + 배경 트랙)
      if (e.hp < e.maxHp) {
        const w = e.size*2, bx = x - e.size, by = y - e.size - 6, bh = e.isBoss ? 3.5 : 2.5;
        ctx.fillStyle = 'rgba(10,6,10,0.7)'; rr(bx - 1, by - 1, w + 2, bh + 2, (bh+2)/2); ctx.fill();
        const hw = Math.max(0, w * (e.hp/e.maxHp));
        if (hw > 0.5) {
          ctx.fillStyle = e.isBoss ? '#ff3355' : '#ff8a98'; rr(bx, by, hw, bh, bh/2); ctx.fill();
          if (e.isBoss) { ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.globalAlpha = 0.45; ctx.fillStyle = '#ff7788'; rr(bx, by, hw, bh, bh/2); ctx.fill(); ctx.restore(); ctx.globalAlpha = 1; }
        }
      }
      // 특수 행동 픽토그램 (식별 쉽게)
      const iy = y - e.size - 12;
      if (e.behavior === 'shielded' && e.shieldHp > 0) {
        // 보호막 — 적을 감싸는 펄스 링 (유지)
        ctx.strokeStyle = `rgba(136, 204, 255, ${0.4 + 0.3 * Math.sin(state.t * 0.15)})`;
        ctx.lineWidth = 2; ctx.beginPath(); ctx.arc(x, y, e.size + 4, 0, Math.PI*2); ctx.stroke();
      } else if (e.behavior === 'regen') {
        // 재생 — 초록 십자 (글로우)
        ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.fillStyle = '#88ff9a';
        ctx.fillRect(x - 4, iy - 1, 8, 2.2); ctx.fillRect(x - 1, iy - 4, 2.2, 8); ctx.restore();
      } else if (e.behavior === 'splitter' && !e.isChild) {
        // 분열 — 한 점에서 갈라지는 두 화살
        ctx.strokeStyle = '#ffb070'; ctx.lineWidth = 1.6; ctx.lineCap = 'round';
        ctx.beginPath(); ctx.moveTo(x, iy + 3); ctx.lineTo(x - 4, iy - 3); ctx.moveTo(x, iy + 3); ctx.lineTo(x + 4, iy - 3); ctx.stroke();
        ctx.lineCap = 'butt';
      } else if (e.behavior === 'charger') {
        // 돌진 — 이중 쉐브론 (속도감)
        ctx.strokeStyle = '#ff7070'; ctx.lineWidth = 1.6; ctx.lineCap = 'round';
        for (const ox of [-2, 2]) { ctx.beginPath(); ctx.moveTo(x + ox - 3, iy - 3); ctx.lineTo(x + ox, iy); ctx.lineTo(x + ox - 3, iy + 3); ctx.stroke(); }
        ctx.lineCap = 'butt';
      }
    }
  }
  let _bossHpGrad = null; // 🚀 보스 HP바 그라디언트 캐시
  function drawBossUI() {
    const boss = state.enemies.find(e => e.isBoss);
    if (!boss) return;
    const w = 320, h = 14;
    const x = (W - w) / 2, y = 16;
    // 트랙 (둥근)
    ctx.fillStyle = 'rgba(20,8,12,0.85)'; rr(x - 3, y - 3, w + 6, h + 6, (h+6)/2); ctx.fill();
    // 체력 (둥근 + 그라데 + 글로우)
    const hw = Math.max(0, w * (boss.hp / boss.maxHp));
    if (hw > 1) {
      // 🚀 좌표·색 전부 상수 — 1회 생성 후 재사용
      if (!_bossHpGrad) { _bossHpGrad = ctx.createLinearGradient(x, y, x, y + h); _bossHpGrad.addColorStop(0, '#ff5a72'); _bossHpGrad.addColorStop(1, '#cc1733'); }
      ctx.fillStyle = _bossHpGrad; rr(x, y, hw, h, h/2); ctx.fill();
      ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.globalAlpha = 0.35; ctx.fillStyle = '#ff8090'; rr(x, y, hw, h*0.45, h*0.22); ctx.fill(); ctx.restore();
    }
    ctx.strokeStyle = 'rgba(255,120,140,0.4)'; ctx.lineWidth = 1; rr(x - 3, y - 3, w + 6, h + 6, (h+6)/2); ctx.stroke();
    ctx.fillStyle = '#fff'; ctx.textAlign = 'center';
    ctx.font = 'bold 11px Jua, sans-serif';
    ctx.fillText(`BOSS  ${boss.hp} / ${boss.maxHp}`, W/2, y + 10);
    ctx.textAlign = 'start';
  }
  // 🌟 색상별 발광 오브 스프라이트 캐시 (radial gradient를 매 프레임 새로 만들지 않게 — 성능)
  const _glowSprite = {};
  function getGlowSprite(col) {
    if (_glowSprite[col]) return _glowSprite[col];
    const S = 32, c = document.createElement('canvas'); c.width = c.height = S;
    const g = c.getContext('2d');
    const rg = g.createRadialGradient(S/2, S/2, 0, S/2, S/2, S/2);
    // 🌙 v315 — 흰 코어 살짝 낮춤(0.9) + 색을 더 일찍 채움 → 겹쳐도 눈부심 완화
    rg.addColorStop(0, 'rgba(255,255,255,0.9)'); rg.addColorStop(0.28, col); rg.addColorStop(1, 'rgba(0,0,0,0)');
    g.fillStyle = rg; g.beginPath(); g.arc(S/2, S/2, S/2, 0, Math.PI*2); g.fill();
    _glowSprite[col] = c; return c;
  }
  // ✨ 피격 플래시 전용 스프라이트 — 원본 그라디언트 스톱(0.9/0.3/0)과 동일하게 베이크
  let _hitFlashCv = null;
  function _hitFlashSprite() {
    if (_hitFlashCv) return _hitFlashCv;
    const S = 64, c = document.createElement('canvas'); c.width = c.height = S;
    const g2 = c.getContext('2d');
    const rg = g2.createRadialGradient(S/2, S/2, 0, S/2, S/2, S/2);
    rg.addColorStop(0, 'rgba(255,255,255,0.9)'); rg.addColorStop(0.55, 'rgba(255,255,255,0.3)'); rg.addColorStop(1, 'rgba(255,255,255,0)');
    g2.fillStyle = rg; g2.beginPath(); g2.arc(S/2, S/2, S/2, 0, Math.PI*2); g2.fill();
    _hitFlashCv = c; return c;
  }
  // 🌟 글로우 에너지 빔/검 — 넓은 발광 + 흰 코어 (가산 합성). 빔류 능력 비주얼 통일 업그레이드.
  function glowBeam(x1, y1, x2, y2, col, coreW, alpha) {
    alpha = (alpha == null) ? 1 : alpha;
    ctx.save();
    ctx.globalCompositeOperation = 'lighter';
    ctx.lineCap = 'round';
    ctx.strokeStyle = col;
    const line = () => { ctx.beginPath(); ctx.moveTo(x1, y1); ctx.lineTo(x2, y2); ctx.stroke(); };
    ctx.globalAlpha = 0.20 * alpha; ctx.lineWidth = coreW * 2.6; line();   // 🌙 은은한 글로우
    ctx.globalAlpha = 0.48 * alpha; ctx.lineWidth = coreW * 1.4; line();
    ctx.globalAlpha = 0.9 * alpha;  ctx.strokeStyle = '#ffffff'; ctx.lineWidth = Math.max(1.4, coreW * 0.45); line();
    ctx.restore();
  }
  function drawBullets() {
    ctx.save();
    ctx.globalCompositeOperation = 'lighter';   // 가산 발광 — 에너지 탄환처럼 빛나고 겹치면 밝아짐
    for (const b of state.bullets) {
      const s = b.size || 2;
      const col = b.color || '#a0b8d8';
      const sp = getGlowSprite(col);
      const r = s * 3.2;
      // 속도 반대방향 꼬리 트레일 (몇 단계 점점 작고 옅게)
      if (b.vx !== undefined && (b.vx || b.vy)) {
        for (let k = 1; k <= 3; k++) {
          ctx.globalAlpha = 0.18 / k;   // 🌙 은은한 꼬리
          const tr = r * (1 - k * 0.18);
          ctx.drawImage(sp, b.x - b.vx * k * 0.9 - tr, b.y - b.vy * k * 0.9 - tr, tr*2, tr*2);
        }
      }
      // 발광 오브 본체
      ctx.globalAlpha = 1;
      ctx.drawImage(sp, b.x - r, b.y - r, r*2, r*2);
    }
    ctx.restore();
  }
  function drawAbilities() {
    // 🏰 TD 모드: 각 배치 타워별로 CX/CY 스왑 후 draw 호출
    if (state.mode === 'defense') {
      for (const tower of (state.towers || [])) {
        const oldCX = CX, oldCY = CY;
        CX = tower.x; CY = tower.y;
        try {
          const def = ABILITY_DEFS[tower.ab.id];
          if (def && def.draw) def.draw(tower.ab);
        } catch (e) { console.warn('tower draw error', tower.ab.id, e); }
        CX = oldCX; CY = oldCY;
      }
      drawDefenseTowers();
      return;
    }
    // 표준 모드: 중앙 타워의 능력들 그리기
    for (const ab of state.tower.abilities) {
      const def = ABILITY_DEFS[ab.id];
      if (def.draw) def.draw(ab);
    }
  }
  // 🏰 TD 능력별 타워 이모지 — 직관적 시각 표현
  // SR/SSR(isGachaUnique)은 별도 표시 (왕관 마크 + 무지개 테)
  const TD_TOWER_GLYPH = {
    // 기본 타워
    multi:        '🎯',
    nova:         '💫',
    sword:        '⚔',
    frost:        '❄',
    starfall:     '☄',
    fireball:     '🔥',
    laser:        '🔆',
    chain:        '⚡',
    sniper:       '🎯',
    rocket:       '🚀',
    arrow:        '➤',
    boomerang:    '↺',
    shotgun:      '💢',
    poison:       '☠',
    bomb:         '💣',
    blackhole:    '🌀',
    lightning:    '⚡',
    railgun:      '🔫',
    drone:        '✈',
    spear:        '🔱',
    // 가챠 SR/SSR
    floatorpedo:  '🌊',
    sunspot:      '🌞',
    gravity:      '🪐',
    cherrysword:  '🌸',
    moonshot:     '🌙',
    starsong:     '✨',
    timebutterfly:'🦋',
  };

  // 🏰 TD 배치 타워 본체 그리기 — 능력별 고유 외형
  // 시각 규칙:
  //   - 원본 능력이 SR/SSR(isGachaUnique)이면 진화 후에도 원본 능력의 외형 유지
  //   - 원본이 일반 능력이면 현재 능력에 맞춰 외형 변경
  function drawDefenseTowers() {
    for (const tower of (state.towers || [])) {
      const c = cellCenter(tower.col, tower.row);
      const currDef = ABILITY_DEFS[tower.ab.id];
      if (!currDef) continue;
      // 원본 능력 (구버전 호환: originalAbilityId 없으면 현재 ID 사용)
      const origId = tower.originalAbilityId || tower.ab.id;
      const origDef = ABILITY_DEFS[origId] || currDef;
      const isOriginalUnique = !!origDef.isGachaUnique;
      // 시각 정의 — SR/SSR이면 원본 잠금, 아니면 현재 능력 사용
      const def = isOriginalUnique ? origDef : currDef;
      const visualId = isOriginalUnique ? origId : tower.ab.id;
      const col = def.color || '#7ad7ff';
      const isUnique = !!def.isGachaUnique;
      const isCombo = !!def.isCombo || (!isOriginalUnique && !!currDef.isCombo);
      const isTriple = !!def.isTriple || (!isOriginalUnique && !!currDef.isTriple);
      const tier = isTriple ? 3 : (isCombo ? 2 : (isUnique ? 4 : 1));
      const R = 21;

      // ───── 1) 그림자 / 발판 글로우 ─────
      ctx.save();
      ctx.globalAlpha = 0.25;
      ctx.fillStyle = col;
      ctx.beginPath();
      ctx.ellipse(c.x, c.y + 18, R * 0.85, 4, 0, 0, Math.PI * 2);
      ctx.fill();
      ctx.restore();

      // ───── 2) 펄스 외곽 링 (color tinted) ─────
      const ringPulse = 0.35 + 0.25 * Math.sin(state.t * 0.06 + (tower.col + tower.row));
      ctx.strokeStyle = `rgba(${hexToRgb(col)}, ${ringPulse})`;
      ctx.lineWidth = 1.5;
      ctx.beginPath();
      ctx.arc(c.x, c.y, R + 2, 0, Math.PI * 2);
      ctx.stroke();

      // ───── 3) 펜타곤/헥사 베이스 (티어별 형태) ─────
      const sides = tier === 1 ? 4 : (tier === 2 ? 6 : 8);
      const baseRot = tier >= 3 ? state.t * 0.005 : Math.PI / sides;
      ctx.fillStyle = '#1c2230';
      ctx.beginPath();
      for (let i = 0; i < sides; i++) {
        const a = baseRot + (i * Math.PI * 2) / sides;
        const px = c.x + Math.cos(a) * R;
        const py = c.y + Math.sin(a) * R;
        if (i === 0) ctx.moveTo(px, py); else ctx.lineTo(px, py);
      }
      ctx.closePath();
      ctx.fill();
      // 베이스 림 (색상 강조)
      ctx.strokeStyle = col;
      ctx.lineWidth = tier >= 3 ? 2 : 1.5;
      ctx.stroke();

      // ───── 4) 내부 코어 (그라데이션) ─────
      const coreGrad = ctx.createRadialGradient(c.x - 4, c.y - 4, 1, c.x, c.y, R - 4);
      coreGrad.addColorStop(0, lightenHex(col, 0.4));
      coreGrad.addColorStop(0.6, col);
      coreGrad.addColorStop(1, darkenHex(col, 0.55));
      ctx.fillStyle = coreGrad;
      ctx.beginPath();
      ctx.arc(c.x, c.y, R - 6, 0, Math.PI * 2);
      ctx.fill();

      // ───── 5) 회전 디테일 (티어 2+ 만) ─────
      if (tier >= 2) {
        const rot = state.t * (tier === 4 ? 0.025 : tier === 3 ? 0.018 : 0.012);
        const orbits = tier === 4 ? 4 : tier === 3 ? 3 : 2;
        for (let i = 0; i < orbits; i++) {
          const a = rot + (i * Math.PI * 2) / orbits;
          const ox = c.x + Math.cos(a) * (R - 4);
          const oy = c.y + Math.sin(a) * (R - 4);
          ctx.fillStyle = lightenHex(col, 0.5);
          ctx.beginPath();
          ctx.arc(ox, oy, tier === 4 ? 2.2 : 1.8, 0, Math.PI * 2);
          ctx.fill();
        }
      }

      // ───── 6) 중앙 능력 아이콘 (PNG) ─────
      // visualId 의 PNG가 로드되어 있으면 그림 → 모든 능력에 ./icons/abilities/N.png 매핑됨
      // 로드 실패/없으면 drawAbilityIcon이 자동 fallback (색 박스 + 첫글자)
      const iconSize = (R - 5) * 2;   // 베이스 내부에 맞춤
      const ix = c.x - iconSize / 2;
      const iy = c.y - iconSize / 2;
      drawAbilityIcon(visualId, ix, iy, iconSize);

      // ───── 7) 유니크/콤보 티어 마커 ─────
      if (isUnique || isTriple) {
        // 왕관 (SR/SSR/Triple)
        ctx.font = 'bold 10px Jua, sans-serif';
        ctx.fillStyle = isTriple ? '#ffd060' : '#ffe070';
        ctx.fillText(isTriple ? '👑' : '♛', c.x, c.y - R + 4);
      } else if (isCombo) {
        // 콤보 표식
        ctx.font = 'bold 9px Jua, sans-serif';
        ctx.fillStyle = '#c084ff';
        ctx.fillText('⚙', c.x, c.y - R + 4);
      }

      // ───── 8) 레벨 핍 (점 N개) ─────
      const lv = tower.ab.level;
      const maxLv = maxLvFor(tower.ab.id);
      const pipsN = Math.min(lv, maxLv);
      const pipW = 3, pipGap = 1.5;
      const totalW = pipsN * pipW + Math.max(0, pipsN - 1) * pipGap;
      const startPx = c.x - totalW / 2;
      const pipY = c.y + R - 2;
      for (let i = 0; i < pipsN; i++) {
        ctx.fillStyle = (lv >= maxLv) ? '#ffd060' : col;
        ctx.fillRect(startPx + i * (pipW + pipGap), pipY, pipW, pipW);
      }

      // ───── 9) MAX 표시 ─────
      if (lv >= maxLv) {
        ctx.font = 'bold 8px Jua, sans-serif';
        ctx.fillStyle = '#ffd060';
        ctx.fillText('MAX', c.x, c.y + R + 8);
      }

      ctx.textAlign = 'start';
    }
    // 🎯 선택된 타워의 사거리 표시 (인라인 패널 열린 상태)
    if (state.selectedTower) {
      const t = state.selectedTower;
      const range = getAbilityRange(t.ab.id, t.ab.level);
      if (range === Infinity) {
        // 무제한 사거리: 캔버스 가장자리 점선 + "전 맵" 라벨
        ctx.save();
        ctx.strokeStyle = 'rgba(255, 212, 121, 0.45)';
        ctx.lineWidth = 2;
        ctx.setLineDash([8, 6]);
        ctx.strokeRect(2, 2, W - 4, H - 4);
        ctx.setLineDash([]);
        ctx.fillStyle = '#ffd479';
        ctx.font = 'bold 11px Jua, sans-serif';
        ctx.textAlign = 'center';
        ctx.fillText('∞ 전 맵 사거리', t.x, t.y - 28);
        ctx.textAlign = 'start';
        ctx.restore();
      } else if (range > 0) {
        ctx.save();
        ctx.strokeStyle = 'rgba(122, 215, 255, 0.65)';
        ctx.fillStyle = 'rgba(122, 215, 255, 0.07)';
        ctx.lineWidth = 1.5;
        ctx.setLineDash([6, 4]);
        ctx.beginPath();
        ctx.arc(t.x, t.y, range, 0, Math.PI * 2);
        ctx.fill();
        ctx.stroke();
        ctx.setLineDash([]);
        ctx.restore();
      }
    }
    // 🎯 선택된 슬롯 (배치 전): 사거리 미리보기는 생략 (능력 미정)
    //    대신 슬롯 자체에 강조 표시
    if (state.selectedSlot) {
      const sc = cellCenter(state.selectedSlot.col, state.selectedSlot.row);
      ctx.save();
      ctx.strokeStyle = `rgba(255, 212, 121, ${0.5 + 0.3 * Math.sin(state.t * 0.15)})`;
      ctx.lineWidth = 2.5;
      ctx.beginPath();
      ctx.arc(sc.x, sc.y, TD.cellW * 0.38, 0, Math.PI * 2);
      ctx.stroke();
      ctx.restore();
    }
  }
  // 🎯 무제한 사거리 능력 ID — 저격, 체인, 낙하, 시간/중력/번개 등 글로벌 또는 장거리 특수
  const TD_UNLIMITED_RANGE_IDS = new Set([
    // 저격류
    'sniper', 'scholarSnipe', 'headshot', 'purgeShot',
    // 장거리 광선
    'railgun', 'siegeBeam', 'twinBeam', 'beam', 'laser', 'plasmaBeam',
    // 체인 번개
    'chain', 'chainStorm', 'luckyChain', 'plasmaCataclysm', 'absoluteThunder', 'thunder',
    // 낙하 (전 맵)
    'meteor', 'cosmicCollapse', 'stellarCollapse', 'swordRain',
    // 시간 효과
    'timeStop', 'timePrison', 'eternalMoment', 'voidStop',
    // 중력/공허 (전 맵 끌어당김)
    'blackhole', 'voidField', 'voidNova', 'voidIceVortex', 'gravityWell', 'pullField',
    // 글로벌 폭풍
    'solarStorm', 'echoStorm',
    // 관통/돌격
    'piercer', 'piercingChain',
    // SSR 글로벌
    'celestialSymphony', 'starSong', 'cosmicChorus',
    // 시공나비 — 시간 능력
    'timeButterfly',
    // ⭐ SSR 별 해금 히든 능력 (전 맵 효과)
    'celestialEcho', 'sirensSong', 'temporalLoop', 'paradoxFreeze',
    // ⭐ SR 별 해금 히든 능력 (전 맵 효과)
    'petalStorm', 'cherrySingularity', 'lunarRain', 'eclipsePiercer',
  ]);
  // 🎯 능력별 표적 사거리 — TD 모드 사거리 캡 + 시각 표시용
  // def.range(lv) 가 정의돼있으면 사용, 아니면 능력 타입/티어별 기본값
  // 무제한 능력은 Infinity (캡 해제)
  function getAbilityRange(abilityId, level) {
    const def = ABILITY_DEFS[abilityId];
    if (!def) return 0;
    if (def.isPassive) return 0;
    if (TD_UNLIMITED_RANGE_IDS.has(abilityId)) return Infinity;
    if (typeof def.range === 'function') return def.range(level || 1);
    // 티어별 기본
    if (def.isTriple) return 320;
    if (def.isCombo)  return 280;
    return 240;  // 기본 액티브
  }

  // 🚀 hex 파싱 결과 메모이제이션 — 매 프레임 매 타워에서 반복 호출되는 핫 패스.
  //    캐시 키: hex 문자열 + amt 값. 캐시 미스 시에만 parseInt × 3.
  const _hexToRgbCache = Object.create(null);
  const _lightenHexCache = Object.create(null);
  const _darkenHexCache = Object.create(null);
  // hex → 'r, g, b'
  function hexToRgb(hex) {
    let v = _hexToRgbCache[hex];
    if (v !== undefined) return v;
    const h = hex.replace('#', '');
    const r = parseInt(h.substr(0,2), 16);
    const g = parseInt(h.substr(2,2), 16);
    const b = parseInt(h.substr(4,2), 16);
    v = `${r}, ${g}, ${b}`;
    _hexToRgbCache[hex] = v;
    return v;
  }
  function lightenHex(hex, amt) {
    const key = hex + '|' + amt;
    let v = _lightenHexCache[key];
    if (v !== undefined) return v;
    const h = hex.replace('#', '');
    const r = Math.min(255, parseInt(h.substr(0,2), 16) + Math.floor(255 * amt));
    const g = Math.min(255, parseInt(h.substr(2,2), 16) + Math.floor(255 * amt));
    const b = Math.min(255, parseInt(h.substr(4,2), 16) + Math.floor(255 * amt));
    v = `rgb(${r}, ${g}, ${b})`;
    _lightenHexCache[key] = v;
    return v;
  }
  function darkenHex(hex, amt) {
    const key = hex + '|' + amt;
    let v = _darkenHexCache[key];
    if (v !== undefined) return v;
    const h = hex.replace('#', '');
    const r = Math.max(0, Math.floor(parseInt(h.substr(0,2), 16) * (1 - amt)));
    const g = Math.max(0, Math.floor(parseInt(h.substr(2,2), 16) * (1 - amt)));
    const b = Math.max(0, Math.floor(parseInt(h.substr(4,2), 16) * (1 - amt)));
    v = `rgb(${r}, ${g}, ${b})`;
    _darkenHexCache[key] = v;
    return v;
  }
  function drawParticles() {
    ctx.save();
    ctx.globalCompositeOperation = 'lighter';   // 가산 발광 — 모든 능력 피격 스파크가 빛남
    for (const p of state.particles) {
      const lf = Math.max(0, p.life / 20);
      if (lf <= 0) continue;
      ctx.globalAlpha = lf * 0.9;
      const sp = getGlowSprite(p.color || '#ffffff');
      const r = 2 + lf * 4;
      ctx.drawImage(sp, p.x - r, p.y - r, r*2, r*2);
    }
    ctx.restore();
    ctx.globalAlpha = 1;
  }
  function drawComboFlash() {
    if (state.comboFlash <= 0) return;
    const a = state.comboFlash / 30;
    // 풀스크린 번쩍임 → 가장자리 비네팅으로 변경 (밤에 눈 부담 ↓)
    const grad = ctx.createRadialGradient(CX, CY, CX * 0.5, CX, CY, CX * 1.2);
    grad.addColorStop(0, 'rgba(0, 0, 0, 0)');
    grad.addColorStop(1, state.comboFlashColor);
    ctx.fillStyle = grad;
    ctx.globalAlpha = a * 0.30;
    ctx.fillRect(0, 0, W, H);
    ctx.globalAlpha = 1;
  }
  function drawOverlay() {
    // ⏸ 일시정지 — 현재 라운드/점수 미리 표시 (v225)
    if (paused && !state.gameOver) {
      ctx.fillStyle = 'rgba(0,0,0,0.55)'; ctx.fillRect(0,0,W,H);
      ctx.textAlign='center';
      // PAUSED 큰 텍스트
      ctx.fillStyle = '#fff'; ctx.font='bold 30px Jua, sans-serif';
      ctx.fillText('PAUSED', CX, CY - 36);
      // 현재 상황 표시
      ctx.fillStyle = '#cfd6e3'; ctx.font='14px Jua, sans-serif';
      const ascSuf = (state.ascension && state.ascension > 0) ? ` ⚡${state.ascension}` : '';
      ctx.fillText(`라운드 ${state.round}${ascSuf}`, CX, CY - 8);
      ctx.fillStyle = '#ffd479'; ctx.font='bold 16px Jua, sans-serif';
      ctx.fillText(state.score.toLocaleString() + ' 점', CX, CY + 14);
      // 재개 힌트
      ctx.fillStyle = '#7a8090'; ctx.font='12px Jua, sans-serif';
      ctx.fillText('Space 로 재개', CX, CY + 42);
      ctx.textAlign='start';
    }
    // 💀 게임오버/승리 화면 — 애니메이션 적용 (v225)
    if (state.gameOver) {
      const startT = state.gameOverAnimStart || 0;
      const nowT = (typeof performance !== 'undefined' && performance.now) ? performance.now() : Date.now();
      const elapsed = Math.max(0, (nowT - startT) / 1000);   // 초 단위

      // 페이드 배경 (0~0.3초 fade-in)
      const bgAlpha = Math.min(0.78, elapsed * 2.6);
      ctx.fillStyle = `rgba(0,0,0,${bgAlpha})`;
      ctx.fillRect(0,0,W,H);

      // 타이틀 페이드인 + 살짝 zoom (0-0.4초)
      const titleProgress = Math.min(1, elapsed / 0.4);
      const titleAlpha = titleProgress;
      const titleScale = 1.0 + (1 - titleProgress) * 0.25;   // 1.25 → 1.0
      ctx.save();
      ctx.globalAlpha = titleAlpha;
      ctx.translate(CX, CY - 56);
      ctx.scale(titleScale, titleScale);
      ctx.textAlign='center';
      const titleColor = state.gameWin ? '#ffe070' : '#ff8a98';
      ctx.fillStyle = titleColor;
      ctx.shadowColor = titleColor;
      ctx.shadowBlur = 18 * titleAlpha;
      ctx.font='bold 42px Jua, sans-serif';
      const titleText = state.gameWin
        ? (state.endless ? '♾ ENDLESS END' : 'VICTORY')
        : 'GAME OVER';
      ctx.fillText(titleText, 0, 0);
      ctx.shadowBlur = 0;
      ctx.restore();

      // ✨ NEW RECORD 배지 (신기록일 때만, 타이틀 안정 후)
      if (state.isNewRecord && elapsed > 0.4) {
        const pulseT = (elapsed - 0.4) * 2;
        const pulseAlpha = 0.7 + 0.3 * Math.sin(pulseT * Math.PI * 1.2);
        ctx.save();
        ctx.globalAlpha = pulseAlpha;
        ctx.textAlign='center';
        ctx.fillStyle = '#88ff88';
        ctx.shadowColor = '#88ff88';
        ctx.shadowBlur = 12;
        ctx.font='bold 14px Jua, sans-serif';
        ctx.fillText('NEW RECORD', CX, CY - 22);
        ctx.shadowBlur = 0;
        ctx.restore();
      } else if (state.gameOverReason && elapsed > 0.5) {
        // 사유 텍스트 (신기록 없을 때만)
        const reasonAlpha = Math.min(1, (elapsed - 0.5) / 0.3);
        ctx.save();
        ctx.globalAlpha = reasonAlpha;
        ctx.textAlign='center';
        ctx.fillStyle = state.gameWin ? '#fff080' : '#ffaaaa';
        ctx.font='14px Jua, sans-serif';
        ctx.fillText(state.gameOverReason, CX, CY - 22);
        ctx.restore();
      }

      // 라운드 + 점수 카운트업 (0.5~1.4초)
      const statsAlpha = Math.min(1, Math.max(0, (elapsed - 0.4) / 0.3));
      ctx.save();
      ctx.globalAlpha = statsAlpha;
      ctx.textAlign='center';
      ctx.fillStyle = '#fff'; ctx.font='16px Jua, sans-serif';
      const lastRound = (state.endless || !state.gameWin) ? state.round : MAX_ROUND;
      const roundTxt = state.endless ? `♾ 도달 R${lastRound}` : `도달 라운드: ${lastRound}`;
      // 점수 카운트업 (0.5~1.5초)
      const countProgress = Math.max(0, Math.min(1, (elapsed - 0.5) / 1.0));
      // easeOutCubic — 천천히 멈춤
      const eased = 1 - Math.pow(1 - countProgress, 3);
      const displayScore = Math.floor(state.score * eased);
      ctx.fillText(`${roundTxt}   점수: ${displayScore.toLocaleString()}`, CX, CY + 14);
      ctx.restore();
      // 보상 통계 — 점수 카운트업 끝난 후 (1.5초 후) 한꺼번에 페이드인
      const rewardsAlpha = Math.min(1, Math.max(0, (elapsed - 1.3) / 0.4));
      ctx.save();
      ctx.globalAlpha = rewardsAlpha;
      ctx.textAlign='center';
      let lineY = CY + 38;
      // 남은 골드 → 점수 환산 표시
      if (state.goldBonusScore && state.goldBonusScore > 0) {
        ctx.fillStyle = '#ffd479'; ctx.font='12px Jua, sans-serif';
        ctx.fillText(`💰 남은 골드 ${state.goldRemaining}G → +${state.goldBonusScore.toLocaleString()}점`, CX, lineY);
        lineY += 16;
      }
      // 🏆 v262 — 난이도 클리어 보너스 표시 (점수 뛴 이유 명확화)
      if (state.diffBonusMul && state.diffBonusMul > 1) {
        ctx.fillStyle = '#ff88ff'; ctx.font='bold 13px Jua, sans-serif';
        ctx.fillText(`⚡ ${ascensionLabel(state.ascension)} 보너스 ×${state.diffBonusMul.toFixed(1)}`, CX, lineY);
        lineY += 17;
      }
      if (state.stardustEarned) {
        ctx.fillStyle = '#ffd479'; ctx.font='14px Jua, sans-serif';
        ctx.fillText(`+${state.stardustEarned} ★ 스타더스트 획득`, CX, lineY);
        lineY += 18;
      }
      if (state.newAscensionUnlocked) {
        ctx.fillStyle = '#ff80ff'; ctx.font='bold 16px Jua, sans-serif';
        ctx.fillText(`✨ 승천 ${state.newAscensionUnlocked} 해금!`, CX, lineY);
        lineY += 20;
      }
      if (state.crystalsEarned) {
        ctx.fillStyle = '#88ccff'; ctx.font='bold 14px Jua, sans-serif';
        ctx.fillText(`+${state.crystalsEarned} 💎 결정 획득`, CX, lineY);
        lineY += 18;
        // 사유 표시 (최대 3줄)
        if (state.crystalReasons && state.crystalReasons.length > 0) {
          ctx.fillStyle = '#88ccff'; ctx.font='10px Jua, sans-serif';
          for (const r of state.crystalReasons.slice(0, 3)) {
            ctx.fillText(`· ${r}`, CX, lineY);
            lineY += 13;
          }
        }
      }
      if (state.achievementsEarned && state.achievementsEarned.length > 0) {
        ctx.fillStyle = '#52e07a'; ctx.font='12px Jua, sans-serif';
        ctx.fillText(`🏅 신규 업적 ${state.achievementsEarned.length}개 (+${state.achievementStardust} ★)`, CX, lineY);
        lineY += 16;
        for (const ach of state.achievementsEarned.slice(0, 3)) {
          ctx.fillStyle = '#aaffaa'; ctx.font='10px Jua, sans-serif';
          ctx.fillText(`· ${ach.name}: ${ach.desc}`, CX, lineY);
          lineY += 13;
        }
      }
      if (state.repeatStardust > 0) {
        ctx.fillStyle = '#88ccff'; ctx.font='12px Jua, sans-serif';
        ctx.fillText(`🔁 반복 업적: +${state.repeatStardust} ★`, CX, lineY);
        lineY += 16;
      }
      ctx.restore();   // 보상 페이드인 그룹 종료

      // 버튼 영역 — 보상 끝난 후 (1.6초 후) 페이드인
      const btnAlpha = Math.min(1, Math.max(0, (elapsed - 1.6) / 0.3));
      ctx.save();
      ctx.globalAlpha = btnAlpha;
      // 다시하기 / 딜량 통계 / 메인메뉴 버튼 (캔버스 클릭 + R / ESC 단축키도 유지)
      const btnW = 124, btnH = 44, btnGap = 10;
      const totalBtnW = btnW * 3 + btnGap * 2;
      const btnYg = Math.min(lineY + 24, H - btnH - 24);
      const btnX1 = CX - totalBtnW / 2;
      const btnX2 = btnX1 + btnW + btnGap;
      const btnX3 = btnX2 + btnW + btnGap;
      // 다시하기 (강조 — 골드)
      ctx.fillStyle = '#2a2418';
      ctx.fillRect(btnX1, btnYg, btnW, btnH);
      ctx.strokeStyle = '#ffd479';
      ctx.lineWidth = 2;
      ctx.strokeRect(btnX1, btnYg, btnW, btnH);
      ctx.fillStyle = '#ffd479';
      ctx.font = 'bold 14px Jua, sans-serif';
      ctx.textAlign = 'center';
      ctx.fillText('↻ 다시 하기', btnX1 + btnW / 2, btnYg + 27);
      // 📊 딜량 통계
      ctx.fillStyle = '#10202c';
      ctx.fillRect(btnX2, btnYg, btnW, btnH);
      ctx.strokeStyle = '#88e0ff';
      ctx.lineWidth = 2;
      ctx.strokeRect(btnX2, btnYg, btnW, btnH);
      ctx.fillStyle = '#88e0ff';
      ctx.font = 'bold 14px Jua, sans-serif';
      ctx.fillText('📊 딜량 통계', btnX2 + btnW / 2, btnYg + 27);
      // 메인메뉴
      ctx.fillStyle = '#1a1f2b';
      ctx.fillRect(btnX3, btnYg, btnW, btnH);
      ctx.strokeStyle = '#5870a0';
      ctx.lineWidth = 2;
      ctx.strokeRect(btnX3, btnYg, btnW, btnH);
      ctx.fillStyle = '#cfd6e3';
      ctx.font = '14px Jua, sans-serif';
      ctx.fillText('🏠 메인 메뉴', btnX3 + btnW / 2, btnYg + 27);
      state._retryBtn    = { x: btnX1, y: btnYg, w: btnW, h: btnH };
      state._dmgStatsBtn = { x: btnX2, y: btnYg, w: btnW, h: btnH };
      state._menuBtn     = { x: btnX3, y: btnYg, w: btnW, h: btnH };
      // 단축키 안내 (작게)
      ctx.fillStyle = '#5a6068';
      ctx.font = '10px Jua, sans-serif';
      ctx.fillText('R = 다시하기  ·  ESC = 메인 메뉴', CX, btnYg + btnH + 16);
      ctx.restore();   // 버튼 페이드인 그룹 종료
      ctx.textAlign='start';
    } else {
      state._retryBtn = null;
      state._menuBtn = null;
      state._dmgStatsBtn = null;
    }
  }
  // 🌟 블룸(발광) — 월드를 축소+블러 후 가산 합성. 밝은 부분만 자연스럽게 빛남(어두운 곳은 거의 영향 없음)
  let _bloomCv = null, _bctx = null, _bloomFrame = 0, _bloomReady = false;
  function applyBloom() {
    try {
      const q = IS_MOBILE ? 0.26 : 0.42;   // 블룸 해상도 ↓ (렉 완화 — 데스크톱도 낮춤)
      const bw = Math.max(1, Math.round(W * q)), bh = Math.max(1, Math.round(H * q));
      if (!_bloomCv) { _bloomCv = document.createElement('canvas'); _bctx = _bloomCv.getContext('2d'); }
      if (_bloomCv.width !== bw || _bloomCv.height !== bh) { _bloomCv.width = bw; _bloomCv.height = bh; _bloomReady = false; }
      // 🌟 선택적 블룸 — brightness/contrast로 어두운 부분을 검정으로 눌러 "밝은 이펙트만" 추출 후 블러.
      //   → 배경은 가산해도 0(안 번짐=눈 편함), 효과만 강하게 빛남(세련된 네온 글로우).
      // 🔥 모바일 과열 완화 — 가장 비싼 연산(필터+풀캔버스 드로우)은 격프레임만 재계산.
      //   합성(아래 drawImage)은 매 프레임 → 글로우는 깜빡임 없이 안정적으로 보임.
      _bloomFrame++;
      if (!_bloomReady || (_bloomFrame % (IS_MOBILE ? 3 : 2)) === 0) {   // 무거운 블러 재계산 throttle: 모바일 3프레임·데스크톱 2프레임마다 (합성은 매 프레임 → 글로우 안정)
        _bctx.clearRect(0, 0, bw, bh);
        _bctx.filter = 'brightness(1.2) contrast(2.7) blur(' + (IS_MOBILE ? 4 : 6) + 'px)';
        _bctx.drawImage(canvas, 0, 0, bw, bh);
        _bctx.filter = 'none';
        _bloomReady = true;
      }
      ctx.save();
      ctx.globalCompositeOperation = 'lighter';
      ctx.globalAlpha = IS_MOBILE ? 0.36 : 0.46;   // 🌙 v315 — 겹침 시 눈부심 완화 (0.55/0.7 → 0.36/0.46)
      ctx.drawImage(_bloomCv, 0, 0, W, H);
      ctx.restore();
    } catch (e) {}
  }
  // 🎬 비네팅 — 가장자리 어둡게 (월드에만, UI 전에)
  // 🚀 오프스크린 1회 베이크 — 매 프레임 풀스크린 라디얼 그라디언트 평가 제거 (W/H는 640 고정)
  let _vignetteCv = null;
  function drawVignette() {
    try {
      if (!_vignetteCv) {
        const c = document.createElement('canvas'); c.width = W * DPR; c.height = H * DPR;
        const g2 = c.getContext('2d'); g2.scale(DPR, DPR);
        const g = g2.createRadialGradient(W/2, H/2, W*0.34, W/2, H/2, W*0.74);
        g.addColorStop(0, 'rgba(0,0,0,0)'); g.addColorStop(1, 'rgba(0,0,0,0.34)');
        g2.fillStyle = g; g2.fillRect(0, 0, W, H);
        _vignetteCv = c;
      }
      ctx.drawImage(_vignetteCv, 0, 0, W, H);
    } catch (e) {}
  }
  function render() {
    // 🚀 배경 베이스가 불투명 풀캔버스 채우기라 clearRect는 중복 풀스크린 패스 — 제거.
    //    대신 이전 프레임에서 샌 알파/블렌드 상태만 방어적으로 리셋.
    ctx.globalAlpha = 1; ctx.globalCompositeOperation = 'source-over';
    // 배경 — 흔들림 영향 없음 (별/행성/성운 안정)
    drawBackground();
    // 🌌 v272 — 특수 보스 등장 연출 (배경 레이어 — 게임 월드 아래라 적/타워가 그림자 위에 그려짐 = "뒤에서 다가옴")
    drawBossIntro();

    // 게임 월드 — 흔들림 적용 (타워/적/탄환/파티클/데미지 숫자)
    const sk = state.shakeStrength;
    if (sk > 0.1) {
      ctx.save();
      ctx.translate((Math.random() - 0.5) * sk, (Math.random() - 0.5) * sk);
    }
    drawArena();
    drawTower();
    drawEnemies();
    drawAbilities();
    drawBullets();
    drawParticles();
    drawMotifFx();          // 🎭 가챠 캐릭터 개성 모티프
    drawDamageNumbers();
    if (sk > 0.1) ctx.restore();

    // 🌟 포스트 — 블룸(발광) + 비네팅 (월드 위, UI 아래라 UI는 선명)
    applyBloom();
    drawVignette();

    // UI / 오버레이 — 안정 (콤보 플래시, 카드, 보스 HP, 게임오버)
    drawComboFlash();
    drawComboReveal();
    drawWaveClear();
    drawBossUI();
    drawThunderStrikes(); // ⚡ 천둥의 신 번개 줄기
    drawEffects();        // 🎬 v220 — 보스 워닝/HP 위급/클리어 sweep
    drawRelicHUD();
    drawOverlay();
    drawLevelUpModal();
    drawRelicOffering();
    drawEndlessOffer();
  }

  // 🎬 v220 — 절제된 시각 효과 (눈 안 아프게 부드럽게)
  function drawEffects() {
    // 🛡 v238 — 라운드 클리어 골드 sweep 제거 (눈 피로 원인).
    //   클리어 알림은 drawWaveClear() 의 "R5 CLEAR!" 텍스트로 충분.

    // 1) 본진 HP 위급 — 가장자리 빨간 vignette pulse (디펜스 모드)
    if (state.mode === 'defense' && state.towerHP > 0 && state.towerMaxHP > 0) {
      const hpPct = state.towerHP / state.towerMaxHP;
      if (hpPct < 0.30) {
        const phase = (state.t || 0) * 0.04;
        const baseAlpha = hpPct < 0.10 ? 0.30 : 0.18;
        const alpha = baseAlpha * (0.6 + 0.4 * Math.sin(phase));
        const grad = ctx.createRadialGradient(CX, CY, Math.min(W, H) * 0.35, CX, CY, Math.max(W, H) * 0.7);
        grad.addColorStop(0, 'rgba(255, 80, 100, 0)');
        grad.addColorStop(1, `rgba(255, 50, 80, ${alpha})`);
        ctx.fillStyle = grad;
        ctx.fillRect(0, 0, W, H);
      }
    }
    // 2) 보스 등장 워닝 — 텍스트만 (어두워지는 vignette 제거 — 시야 방해)
    if (state.bossWarning) {
      const t = 1 - state.bossWarning.life / 50;
      let alpha;
      if (t < 0.4) alpha = t / 0.4;
      else if (t < 0.7) alpha = 1;
      else alpha = (1 - t) / 0.3;
      alpha = Math.max(0, Math.min(1, alpha));
      // 텍스트만 (vignette 제거)
      ctx.save();
      ctx.globalAlpha = alpha;
      ctx.textAlign = 'center';
      ctx.font = 'bold 32px Jua, sans-serif';
      ctx.fillStyle = '#ff5b6e';
      ctx.shadowColor = 'rgba(255, 91, 110, 0.6)';
      ctx.shadowBlur = 12;
      ctx.fillText('⚠ BOSS', CX, CY - 14);
      ctx.shadowBlur = 0;
      ctx.font = '12px Jua, sans-serif';
      ctx.fillStyle = '#ffaaaa';
      ctx.fillText('보스 등장', CX, CY + 10);
      ctx.restore();
      ctx.textAlign = 'start';
    }
  }
  // ⚡ 천둥의 신 — 번개 줄기 시각 효과
  function drawThunderStrikes() {
    if (!state.thunderStrikes || state.thunderStrikes.length === 0) return;
    for (const t of state.thunderStrikes) {
      const alpha = t.life / 12;
      ctx.globalAlpha = alpha;
      ctx.strokeStyle = '#ffe070';
      ctx.lineWidth = 3;
      ctx.beginPath();
      // 화면 상단에서 적까지 지그재그 번개
      let x = t.x, y = 0;
      ctx.moveTo(x, y);
      while (y < t.y) {
        y += 15;
        x = t.x + (Math.random() - 0.5) * 20;
        ctx.lineTo(x, y);
      }
      ctx.stroke();
      // 가는 백색 코어
      ctx.strokeStyle = '#ffffff';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(t.x, 0);
      ctx.lineTo(t.x, t.y);
      ctx.stroke();
      // 충돌 지점 폭발 글로우
      ctx.fillStyle = '#ffe070';
      ctx.beginPath();
      ctx.arc(t.x, t.y, 12 * alpha, 0, Math.PI * 2);
      ctx.fill();
    }
    ctx.globalAlpha = 1;
  }

  // 💎 유물 상세 모달
  function openRelicDetail() {
    if (!state || !state.activeRelics || state.activeRelics.length === 0) return;
    buildRelicDetail();
    openModalAnimated(document.getElementById('relicDetailModal'));
    paused = true; // 읽는 동안 일시정지
    const pauseBtn = document.getElementById('pauseBtn');
    if (pauseBtn) pauseBtn.textContent = '▶ 재개';
  }
  function closeRelicDetail() {
    closeModalAnimated(document.getElementById('relicDetailModal'));
    // paused는 유저가 명시적으로 일시정지한 게 아니므로 풀어줌
    paused = false;
    const pauseBtn = document.getElementById('pauseBtn');
    if (pauseBtn) pauseBtn.textContent = '⏸ 일시정지';
  }
  function buildRelicDetail() {
    const list = document.getElementById('relic-detail-list');
    const countEl = document.getElementById('relic-detail-count');
    list.innerHTML = '';
    const relics = state.activeRelics || [];
    countEl.textContent = `${relics.length}개`;

    // 등급별 그룹화 (legendary → epic → rare → common)
    const order = ['legendary', 'epic', 'rare', 'common'];
    const byRarity = { common: [], rare: [], epic: [], legendary: [] };
    for (const r of relics) byRarity[r.rarity].push(r);

    for (const rar of order) {
      const group = byRarity[rar];
      if (group.length === 0) continue;
      const rarInfo = RELIC_RARITY[rar];
      // 등급 헤더
      const header = document.createElement('div');
      header.style.cssText = `font-size:12px; color:${rarInfo.color}; font-weight:bold; margin:10px 0 4px; padding:4px 8px; border-left:3px solid ${rarInfo.color}; background:rgba(255,255,255,0.03);`;
      header.textContent = `${rarInfo.label} (${group.length})`;
      list.appendChild(header);
      // 각 유물 카드
      for (const r of group) {
        const card = document.createElement('div');
        card.style.cssText = `display:flex; gap:10px; padding:10px 12px; background:#141822; border-left:4px solid ${rarInfo.color}; border-radius:4px; margin-bottom:6px; align-items:center;`;
        // 🌟 v241 — 유물 스택 표시
        const stackBadge = (r.stacks && r.stacks > 0)
          ? `<span style="background:linear-gradient(135deg,#aa88ff,#88ccff); color:#fff; font-size:11px; padding:2px 7px; border-radius:8px; margin-left:6px; font-weight:bold;">+${r.stacks}</span>`
          : '';
        // 🖼 v247 — 이미지 우선, 없으면 emoji 폴백
        card.innerHTML = `
          <div style="flex-shrink:0; width:36px; height:36px; display:flex; align-items:center; justify-content:center;">
            ${getRelicImageHtml(r.id, 36)}
          </div>
          <div style="flex:1; min-width:0;">
            <div style="font-size:14px; font-weight:bold; color:${rarInfo.color}; margin-bottom:2px;">${r.name}${stackBadge}</div>
            <div style="font-size:12px; color:#c8cdd8; line-height:1.4;">${r.desc}</div>
          </div>
        `;
        list.appendChild(card);
      }
    }
  }
  document.getElementById('relicDetailClose').onclick = closeRelicDetail;
  document.getElementById('relicDetailModal').onclick = (e) => {
    if (e.target.id === 'relicDetailModal') closeRelicDetail();
  };

  // ===== 📊 딜량 통계 모달 =====
  function openDamageStats() {
    renderDamageStats();
    openModalAnimated(document.getElementById('dmgStatsModal'));
  }
  function closeDamageStats() {
    closeModalAnimated(document.getElementById('dmgStatsModal'));
  }
  function renderDamageStats() {
    const list = document.getElementById('dmg-stats-list');
    list.innerHTML = '';
    const stats = (state && state.abilityDamageStats) || {};
    // 보유 능력 + 통계가 잡힌 모든 능력 합집합 (정렬: 데미지 내림차순)
    const ownedIds = new Set((state && state.tower && state.tower.abilities || []).map(a => a.id));
    const ids = new Set([...Object.keys(stats), ...ownedIds]);
    const rows = [...ids].map(id => ({
      id,
      dmg: Math.floor(stats[id] || 0),
      def: ABILITY_DEFS[id],
      level: (state.tower.abilities.find(a => a.id === id) || {}).level || 0,
    })).filter(r => r.def);
    rows.sort((a, b) => b.dmg - a.dmg);
    if (rows.length === 0) {
      list.innerHTML = '<div style="text-align:center; color:#7a8090; padding:24px; font-size:13px;">기록된 데미지가 없습니다.</div>';
      return;
    }
    const max = Math.max(1, ...rows.map(r => r.dmg));
    const totalDmg = rows.reduce((s, r) => s + r.dmg, 0);
    // 요약
    const header = document.createElement('div');
    header.style.cssText = 'font-size:12px; color:#9aa3b3; padding:4px 8px 10px; border-bottom:1px solid #2a2f3a; margin-bottom:8px;';
    header.textContent = `총 누적 데미지: ${totalDmg.toLocaleString()} · 능력 ${rows.length}개`;
    list.appendChild(header);
    for (const r of rows) {
      const def = r.def;
      const color = def.color || '#88e0ff';
      const pct = (r.dmg / max) * 100;
      const sharePct = totalDmg > 0 ? ((r.dmg / totalDmg) * 100).toFixed(1) : '0';
      const tierTag = def.isTriple ? '<span style="color:#ff66ee; font-size:10px; margin-left:4px;">[TRIPLE]</span>'
                    : def.isCombo  ? '<span style="color:#ffaa55; font-size:10px; margin-left:4px;">[COMBO]</span>'
                    : '';
      const lvlTxt = r.level > 0 ? `Lv${r.level}` : '<span style="color:#666;">(잃음)</span>';
      const row = document.createElement('div');
      row.style.cssText = 'margin-bottom:8px;';
      row.innerHTML = `
        <div style="display:flex; justify-content:space-between; align-items:baseline; margin-bottom:3px;">
          <div style="font-size:13px; color:${color};">${def.name} ${tierTag} <span style="color:#9aa3b3; font-size:11px; margin-left:4px;">${lvlTxt}</span></div>
          <div style="font-size:12px; color:#cfd6e3;"><b>${r.dmg.toLocaleString()}</b> <span style="color:#7a8090;">(${sharePct}%)</span></div>
        </div>
        <div style="background:#141822; border-radius:3px; height:14px; overflow:hidden; position:relative;">
          <div style="background:${color}; height:100%; width:${pct}%; transition:width 0.3s;"></div>
        </div>
      `;
      list.appendChild(row);
    }
  }
  document.getElementById('dmgStatsClose').onclick = closeDamageStats;
  document.getElementById('dmgStatsModal').onclick = (e) => {
    if (e.target.id === 'dmgStatsModal') closeDamageStats();
  };

  // ===== 🏰 TD 모드 타워 배치/강화 모달 =====
  // 🎴 슬롯 클릭 → 3장 카드 모달 (슬롯별 카드 캐싱)
  function openTowerPlaceModal(slot) {
    state.selectedSlot = slot;
    state.selectedTower = null;
    // 슬롯별 카드 캐시 — 재오픈해도 같은 카드 (무한 리롤 방지)
    state.tdSlotDraws = state.tdSlotDraws || {};
    const key = `${slot.col}-${slot.row}`;
    if (!state.tdSlotDraws[key]) {
      state.tdSlotDraws[key] = tdRollWeightedCards(3);
    }
    document.getElementById('td-modal-title').textContent = `🏰 타워 배치 — (${slot.col}, ${slot.row})`;
    renderTowerPlaceCards();
    openModalAnimated(document.getElementById('tdTowerModal'));
  }
  // 🎴 풀에서 N장의 카드를 중복 없이 무작위로 뽑기 (단순 균등)
  function tdRollCards(numCards) {
    const pool = getPlaceableTowers();
    if (pool.length === 0) return [];
    const shuffled = [...pool];
    for (let i = shuffled.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
    }
    return shuffled.slice(0, Math.min(numCards, shuffled.length));
  }
  // 🎴 능력 ID → 캐릭터 ID 매핑 (가챠 캐릭터 고유 능력만)
  // 🚀 abilityId → charId 맵 1회 빌드 — damageEnemy(모든 히트)마다 Object.keys 배열 할당 + 선형 탐색하던 것 제거
  //    startAbilities는 런타임에 불변이므로 무효화 불필요. 첫 매치 우선(원본 순회 순서와 동일).
  let _abilityCharMap = null;
  function findCharByAbility(abilityId) {
    if (typeof CHARACTERS === 'undefined') return null;
    if (!_abilityCharMap) {
      _abilityCharMap = Object.create(null);
      for (const charId of Object.keys(CHARACTERS)) {
        const ch = CHARACTERS[charId];
        if (ch && ch.startAbilities) {
          for (const aid of ch.startAbilities) { if (!(aid in _abilityCharMap)) _abilityCharMap[aid] = charId; }
        }
      }
    }
    return _abilityCharMap[abilityId] || null;
  }
  // 🎴 능력 ID → 가챠 등급 ('R' / 'SR' / 'SSR' / null)
  function abilityGachaTier(abilityId) {
    const def = ABILITY_DEFS[abilityId];
    if (!def || !def.isGachaUnique) return null;
    const charId = findCharByAbility(abilityId);
    if (!charId || typeof GACHA_POOL === 'undefined') return null;
    if (GACHA_POOL.SSR && GACHA_POOL.SSR.indexOf(charId) >= 0) return 'SSR';
    if (GACHA_POOL.SR  && GACHA_POOL.SR.indexOf(charId)  >= 0) return 'SR';
    if (GACHA_POOL.R   && GACHA_POOL.R.indexOf(charId)   >= 0) return 'R';
    return null;
  }
  // 🎴 티어별 가중치 무작위 뽑기 — SSR 운빨 변동 완화
  // 가중치: 기본/해금 65%, 가챠 R 20%, 가챠 SR 10%, 가챠 SSR 5%
  // 해당 등급에 후보가 없으면 다음 등급으로 폴백 → 기본 풀로 안전 보장
  function tdRollWeightedCards(numCards) {
    const pool = getPlaceableTowers();
    if (pool.length === 0) return [];
    // 등급별 분류
    const buckets = { basic: [], r: [], sr: [], ssr: [] };
    for (const id of pool) {
      const d = ABILITY_DEFS[id];
      if (!d) continue;
      const tier = abilityGachaTier(id);
      if (tier === 'SSR') buckets.ssr.push(id);
      else if (tier === 'SR') buckets.sr.push(id);
      else if (tier === 'R')  buckets.r.push(id);
      else buckets.basic.push(id);   // 가챠 아닌 능력 또는 분류 실패 → 기본
    }
    // 가중치 — 합 = 100
    const weights = [
      { key: 'basic', w: 65 },
      { key: 'r',     w: 20 },
      { key: 'sr',    w: 10 },
      { key: 'ssr',   w:  5 },
    ];
    function pickOne(exclude) {
      // 가중 누적 + 비어있는 버킷은 가중치 0으로 처리
      const active = weights.filter(b => buckets[b.key].some(id => !exclude.has(id)));
      if (active.length === 0) return null;
      const totalW = active.reduce((s, b) => s + b.w, 0);
      let r = Math.random() * totalW;
      let chosen = active[active.length - 1].key;
      for (const b of active) {
        if (r < b.w) { chosen = b.key; break; }
        r -= b.w;
      }
      const candidates = buckets[chosen].filter(id => !exclude.has(id));
      return candidates[Math.floor(Math.random() * candidates.length)];
    }
    const result = [];
    const used = new Set();
    for (let i = 0; i < numCards; i++) {
      const id = pickOne(used);
      if (!id) break;
      result.push(id);
      used.add(id);
    }
    return result;
  }
  // 💰 누적 뽑기 비용 — 클래식 randomAcquireCost 와 유사
  //   0회: 0G (첫 뽑기는 무료)
  //   이후: 30 + n*25 + n²*3 (n=뽑기 횟수)
  function tdDrawCost(n) {
    n = (n !== undefined) ? n : (state.tdDrawCount || 0);
    if (n <= 0) return 0;
    return Math.ceil(30 + n * 25 + n * n * 3);
  }
  // 호환용 alias — 진화 비용 계산 등에서 사용될 수 있음
  function tdPlaceCost(n) { return tdDrawCost(n); }
  // 🎴 패널의 뽑기 버튼 라벨 갱신
  function refreshTDDrawBtn() {
    const btn = document.getElementById('tdDrawBtn');
    if (!btn) return;
    if (!state || state.mode !== 'defense') {
      btn.style.display = 'none';
      return;
    }
    btn.style.display = '';
    if (state.tdHeldCard) {
      const d = ABILITY_DEFS[state.tdHeldCard];
      btn.textContent = `🎴 ${d ? d.name : '?'} 들고있음 · 클릭으로 버리기`;
      btn.classList.add('holding');
      btn.disabled = false;
    } else {
      const cost = tdDrawCost();
      btn.textContent = `🎴 타워 뽑기 (${cost}G)`;
      btn.classList.remove('holding');
      btn.disabled = state.gold < cost;
    }
  }
  function openTowerUpgradeModal(tower) {
    state.selectedTower = tower;
    state.selectedSlot = null;
    const def = ABILITY_DEFS[tower.ab.id];
    document.getElementById('td-modal-title').textContent = `⚡ ${def.name} Lv${tower.ab.level}`;
    renderTowerUpgradeList();
    openModalAnimated(document.getElementById('tdTowerModal'));
  }
  function closeTowerModal() {
    closeModalAnimated(document.getElementById('tdTowerModal'));
    state.selectedSlot = null;
    state.selectedTower = null;
  }
  // 배치 가능 타워 목록 — 해금된 액티브 능력
  // 🏰 TD 모드 시작 시 무조건 해금된 5종 (기본 타워풀)
  const TD_STARTER_TOWERS = ['multi', 'nova', 'sword', 'frost', 'starfall'];
  function getPlaceableTowers() {
    // 1) 시작 타워 (항상 해금)
    const set = new Set(TD_STARTER_TOWERS);
    // 2) 업적/도감으로 해금된 액티브 능력 추가
    const haveIds = getUnlockedAbilityIds();
    for (const id of haveIds) {
      const d = ABILITY_DEFS[id];
      if (d && !d.isPassive && !d.isCombo && id !== 'shot' && !d.isGachaUnique) {
        set.add(id);
      }
    }
    // 3) 가챠 보유 캐릭터의 고유 능력도 해금
    const unlockedChars = META.gachaUnlocked || {};
    for (const charId in unlockedChars) {
      if (!unlockedChars[charId]) continue;
      const ch = CHARACTERS[charId];
      if (ch && ch.startAbilities) {
        for (const ab of ch.startAbilities) {
          const d = ABILITY_DEFS[ab];
          if (d && !d.isPassive) set.add(ab);
        }
      }
    }
    // 4) ⭐ 별 등급 해금 능력 (SSR 4★/8★ 히든)
    for (const id of getStarUnlockedAbilities()) {
      const d = ABILITY_DEFS[id];
      if (d && !d.isPassive) set.add(id);
    }
    // 5) shot 제외 (기본 타워는 능력 X)
    set.delete('shot');
    // 등급 정렬: 베이직 → 가챠
    return [...set].sort((a, b) => {
      const da = ABILITY_DEFS[a], db = ABILITY_DEFS[b];
      const ta = da.isGachaUnique ? 2 : 1;
      const tb = db.isGachaUnique ? 2 : 1;
      if (ta !== tb) return ta - tb;
      return (da.baseCost || 0) - (db.baseCost || 0);
    });
  }
  // 🎴 슬롯별 3카드 모달 (1장 선택 → 즉시 슬롯에 배치)
  function renderTowerPlaceCards() {
    const list = document.getElementById('td-tower-list');
    list.innerHTML = '';
    const slot = state.selectedSlot;
    if (!slot) return;
    const key = `${slot.col}-${slot.row}`;
    const cards = (state.tdSlotDraws && state.tdSlotDraws[key]) || [];
    if (cards.length === 0) {
      list.innerHTML = '<div style="text-align:center; color:#7a8090; padding:20px; font-size:12px;">해금된 타워가 없습니다</div>';
      return;
    }
    // 💰 비용 정보
    const placeCount = state.tdDrawCount || 0;
    const cost = tdDrawCost(placeCount);
    const nextCost = tdDrawCost(placeCount + 1);
    const canAfford = state.gold >= cost;
    const info = document.createElement('div');
    info.style.cssText = 'font-size:11px; color:#9aa3b3; padding:2px 6px 6px; border-bottom:1px solid #2a2f3a; margin-bottom:6px; display:flex; justify-content:space-between; gap:8px; flex-wrap:wrap;';
    info.innerHTML = `
      <span>💰 보유 ${state.gold}G</span>
      <span style="color:${canAfford ? '#ffd479' : '#ff8866'}; font-weight:bold;">이번 ${cost}G</span>
      <span style="color:#7a8090; font-size:10px;">다음 ${nextCost}G</span>
    `;
    list.appendChild(info);
    // 3장 카드
    const cardRow = document.createElement('div');
    cardRow.style.cssText = 'display:flex; gap:4px;';
    for (const id of cards) {
      const d = ABILITY_DEFS[id];
      if (!d) continue;
      // 등급 / 라벨 결정
      const gachaTier = abilityGachaTier(id);   // 'R' / 'SR' / 'SSR' / null
      let tierLabel, tierColor, rarityClass = '';
      if (gachaTier === 'SSR') { tierLabel = '🎰 SSR'; tierColor = '#ff80ff'; rarityClass = 'td-card-ssr'; }
      else if (gachaTier === 'SR')  { tierLabel = '🎰 SR';  tierColor = '#ffaa55'; rarityClass = 'td-card-sr'; }
      else if (gachaTier === 'R')   { tierLabel = '🎰 R';   tierColor = '#88e0ff'; rarityClass = 'td-card-r'; }
      else if (d.isTriple)         { tierLabel = '⚡ 트리플'; tierColor = '#ffd060'; }
      else if (d.isCombo)          { tierLabel = '🔥 콤보'; tierColor = '#c084ff'; }
      else                          { tierLabel = '🏠 기본'; tierColor = '#9aa3b3'; }
      // 🖼 아이콘: SR/SSR 은 캐릭터 이미지, 나머지는 능력 PNG
      let iconHtml = '';
      const useCharImg = (gachaTier === 'SR' || gachaTier === 'SSR');
      if (useCharImg) {
        const charId = findCharByAbility(id);
        const charSrc = charId ? getCharacterImageSrc(charId) : null;
        if (charSrc) {
          iconHtml = `<img src="${charSrc}" style="width:56px;height:56px;image-rendering:pixelated;flex-shrink:0;object-fit:contain;background:transparent;" onerror="this.style.display='none'">`;
        }
      }
      if (!iconHtml) {
        const iconPath = getIconPath(id);
        iconHtml = iconPath
          ? `<img src="${iconPath}" style="width:40px;height:40px;image-rendering:pixelated;flex-shrink:0;" onerror="this.outerHTML='<div style=\\'font-size:24px;color:${d.color || '#fff'};\\'>'+'${d.name.charAt(0)}'+'</div>'">`
          : `<div style="font-size:24px;color:${d.color || '#fff'};">${d.name.charAt(0)}</div>`;
      }
      const card = document.createElement('button');
      card.className = `td-draw-card ${rarityClass}`;
      card.disabled = !canAfford;
      card.style.cssText = `flex:1; min-width:0; display:flex; flex-direction:column; align-items:center; gap:3px; padding:8px 4px; background:#141822; border:1px solid ${d.color || '#7ad7ff'}; border-top:3px solid ${tierColor}; border-radius:5px; cursor:${canAfford ? 'pointer' : 'not-allowed'}; opacity:${canAfford ? 1 : 0.5}; color:inherit; font:inherit; text-align:center; position:relative;`;
      card.innerHTML = `
        ${iconHtml}
        <div style="font-size:11px; font-weight:bold; color:${d.color || '#fff'}; line-height:1.1;">${d.name}</div>
        <div style="font-size:9px; color:${tierColor}; line-height:1; font-weight:bold;">${tierLabel}</div>
        <div style="font-size:9px; color:#9aa3b3; line-height:1.2; max-height:22px; overflow:hidden;">${d.desc(1)}</div>
      `;
      card.onclick = () => {
        if (!canAfford) return;
        const sk = `${slot.col}-${slot.row}`;
        state.gold -= cost;
        state.tdDrawCount = (state.tdDrawCount || 0) + 1;
        placeTower(slot, id, cost);   // placeTower 가 placedCost 기록
        // 슬롯 카드 캐시 비우기 (사용 완료)
        if (state.tdSlotDraws) delete state.tdSlotDraws[sk];
        closeTowerModal();
      };
      cardRow.appendChild(card);
    }
    list.appendChild(cardRow);
    // 하단 안내
    const hint = document.createElement('div');
    hint.style.cssText = 'font-size:10px; color:#7a8090; padding:6px 4px 0; text-align:center;';
    hint.textContent = '🃏 65% 기본 · 20% R · 10% SR · 5% SSR · 판매 후 재오픈 시 새 카드';
    list.appendChild(hint);
  }

  // 🏚 (구) 슬롯별 카드 렌더링 — 더 이상 사용 안 함 (호환용 stub만 유지)
  function renderTowerPlaceList() {
    const list = document.getElementById('td-tower-list');
    list.innerHTML = '';
    const slot = state.selectedSlot;
    if (!slot) return;
    const key = `${slot.col}-${slot.row}`;
    const cards = (state.tdSlotDraws && state.tdSlotDraws[key]) || [];
    if (cards.length === 0) {
      list.innerHTML = '<div style="text-align:center; color:#7a8090; padding:20px; font-size:12px;">해금된 타워가 없습니다.</div>';
      return;
    }
    // 💰 비용 정보 — 이번 비용 + 다음 비용 미리보기
    const placeCount = state.tdDrawCount || 0;
    const cost = tdPlaceCost(placeCount);
    const nextCost = tdPlaceCost(placeCount + 1);
    const canAfford = state.gold >= cost;
    const info = document.createElement('div');
    info.style.cssText = 'font-size:11px; color:#9aa3b3; padding:2px 6px 6px; border-bottom:1px solid #2a2f3a; margin-bottom:6px; display:flex; justify-content:space-between; gap:8px; flex-wrap:wrap;';
    info.innerHTML = `
      <span>💰 보유 ${state.gold}G</span>
      <span style="color:${canAfford ? '#ffd479' : '#ff8866'}; font-weight:bold;">이번 ${cost}G</span>
      <span style="color:#7a8090; font-size:10px;">다음 ${nextCost}G</span>
    `;
    list.appendChild(info);
    // 🎴 3장 카드 가로 배치
    const cardRow = document.createElement('div');
    cardRow.style.cssText = 'display:flex; gap:4px;';
    for (const id of cards) {
      const d = ABILITY_DEFS[id];
      if (!d) continue;
      const iconPath = getIconPath(id);
      const tierLabel = d.isTriple ? '⚡ 트리플' : (d.isCombo ? '🔥 콤보' : (d.isGachaUnique ? '🎰 가챠' : '🏠 기본'));
      const tierColor = d.isTriple ? '#ffd060' : (d.isCombo ? '#c084ff' : (d.isGachaUnique ? '#ffaa55' : '#88e0ff'));
      const card = document.createElement('button');
      card.style.cssText = `flex:1; min-width:0; display:flex; flex-direction:column; align-items:center; gap:3px; padding:8px 4px; background:#141822; border:1px solid ${canAfford ? (d.color || '#7ad7ff') : '#2a2f3a'}; border-top:3px solid ${d.color || '#7ad7ff'}; border-radius:5px; cursor:${canAfford ? 'pointer' : 'not-allowed'}; opacity:${canAfford ? 1 : 0.45}; color:inherit; font:inherit; text-align:center;`;
      const iconHtml = iconPath
        ? `<img src="${iconPath}" style="width:40px;height:40px;image-rendering:pixelated;flex-shrink:0;" onerror="this.outerHTML='<div style=\\'font-size:24px;color:${d.color || '#fff'};\\'>'+'${d.name.charAt(0)}'+'</div>'">`
        : `<div style="font-size:24px;color:${d.color || '#fff'};">${d.name.charAt(0)}</div>`;
      card.innerHTML = `
        ${iconHtml}
        <div style="font-size:11px; font-weight:bold; color:${d.color || '#fff'}; line-height:1.1;">${d.name}</div>
        <div style="font-size:9px; color:${tierColor}; line-height:1;">${tierLabel}</div>
        <div style="font-size:9px; color:#9aa3b3; line-height:1.2; max-height:22px; overflow:hidden;">${d.desc(1)}</div>
      `;
      card.disabled = !canAfford;
      card.onclick = () => {
        if (!canAfford) return;
        placeTower(state.selectedSlot, id, cost);
        // 슬롯 카드 캐시 비우기 (배치 완료) — 판매 후 재오픈 시 새 카드
        if (state.tdSlotDraws) delete state.tdSlotDraws[key];
        closeTowerModal();
      };
      cardRow.appendChild(card);
    }
    list.appendChild(cardRow);
    // 안내 문구
    const hint = document.createElement('div');
    hint.style.cssText = 'font-size:10px; color:#7a8090; padding:6px 4px 0; text-align:center;';
    hint.textContent = '랜덤 3장 중 하나를 선택 · 판매 후 재오픈하면 새 카드';
    list.appendChild(hint);
  }
  function renderTowerUpgradeList() {
    const list = document.getElementById('td-tower-list');
    list.innerHTML = '';
    const tower = state.selectedTower;
    if (!tower) return;
    const def = ABILITY_DEFS[tower.ab.id];
    // 능력 설명
    const info = document.createElement('div');
    info.style.cssText = 'padding:6px 8px; background:#141822; border-left:3px solid ' + (def.color || '#7ad7ff') + '; border-radius:5px; margin-bottom:6px;';
    info.innerHTML = `
      <div style="font-size:12px; color:${def.color || '#fff'}; font-weight:bold;">${def.name} <span style="color:#cfd6e3;">Lv${tower.ab.level}</span> <span style="float:right; color:#7a8090; font-weight:normal;">💰 ${state.gold}G</span></div>
      <div style="font-size:10px; color:#cfd6e3; margin-top:2px;">${def.desc(tower.ab.level)}</div>
    `;
    list.appendChild(info);
    // 강화/진화/판매 버튼 — 가로로 배치
    const atMax = isAtMax(tower.ab);
    const btnRow = document.createElement('div');
    btnRow.style.cssText = 'display:flex; gap:4px; margin-bottom:4px;';
    if (!atMax) {
      const cost = enhanceCost(tower.ab);
      const canAfford = state.gold >= cost;
      const upBtn = document.createElement('button');
      upBtn.style.cssText = `flex:2; padding:8px; background:${canAfford ? '#2a3a18' : '#1a1f2b'}; border:1px solid ${canAfford ? '#88ff88' : '#2a2f3a'}; border-radius:5px; cursor:${canAfford ? 'pointer' : 'not-allowed'}; opacity:${canAfford ? 1 : 0.5}; color:${canAfford ? '#88ff88' : '#666'}; font:inherit; font-weight:bold; font-size:12px;`;
      upBtn.textContent = `⬆ 강화 Lv${tower.ab.level + 1} (${cost}G)`;
      upBtn.disabled = !canAfford;
      upBtn.onclick = () => {
        if (!canAfford) return;
        upgradeTower(tower, cost);
        renderTowerUpgradeList();
      };
      btnRow.appendChild(upBtn);
    } else {
      // MAX → 진화 버튼 (가로 인라인)
      const evolveResults = getEvolutionResults(tower.ab.id);
      if (evolveResults.length > 0) {
        const curIsCombo = !!def.isCombo;
        const curIsTriple = !!def.isTriple;
        // 진화 비용 — 일반→콤보 1.0×, 콤보→트리플 2.5×, 트리플 이상 5× (실질 종착)
        const tierMul = curIsTriple ? 5 : (curIsCombo ? 2.5 : 1.0);
        const evolveCost = Math.ceil((tower.placedCost || 100) * tierMul);
        const canAfford = state.gold >= evolveCost;
        const evolveBtn = document.createElement('button');
        evolveBtn.style.cssText = `flex:2; padding:8px; background:${canAfford ? '#2a2418' : '#141822'}; border:1px solid ${canAfford ? '#ffd479' : '#2a2f3a'}; border-radius:5px; cursor:${canAfford ? 'pointer' : 'not-allowed'}; opacity:${canAfford ? 1 : 0.5}; color:${canAfford ? '#ffd479' : '#666'}; font:inherit; font-weight:bold; font-size:12px;`;
        evolveBtn.innerHTML = `🎲 진화 ${evolveCost}G <span style="font-size:9px; opacity:0.8;">(${evolveResults.length}종 랜덤)</span>`;
        evolveBtn.disabled = !canAfford;
        evolveBtn.onclick = () => {
          if (!canAfford) return;
          evolveTower(tower, evolveCost);
          closeTowerModal();
        };
        btnRow.appendChild(evolveBtn);
      } else {
        const end = document.createElement('div');
        end.style.cssText = 'flex:2; padding:8px; text-align:center; color:#ffd479; font-size:11px; background:#1a1f2b; border:1px solid #ffd479; border-radius:5px;';
        end.textContent = '✨ MAX · 진화 종착점';
        btnRow.appendChild(end);
      }
    }
    // 판매 버튼 (가로 인라인)
    const sellRefund = Math.ceil((tower.placedCost || 50) * 0.5);
    const sellInlineBtn = document.createElement('button');
    sellInlineBtn.style.cssText = 'flex:1; padding:8px; background:#2a1a1a; border:1px solid #ff8866; border-radius:5px; cursor:pointer; color:#ff8866; font:inherit; font-size:11px;';
    sellInlineBtn.textContent = `🗑 판매 +${sellRefund}G`;
    sellInlineBtn.onclick = () => {
      sellTower(tower, sellRefund);
      closeTowerModal();
    };
    btnRow.appendChild(sellInlineBtn);
    list.appendChild(btnRow);
    // MAX 시 진화 후보 칩 (좁게)
    if (atMax) {
      const evolveResults2 = getEvolutionResults(tower.ab.id);
      if (evolveResults2.length > 0) {
        const previewWrap = document.createElement('div');
        previewWrap.style.cssText = 'display:flex; flex-wrap:wrap; gap:3px; padding:4px 2px 0;';
        for (const resultId of evolveResults2) {
          const rdef = ABILITY_DEFS[resultId];
          if (!rdef) continue;
          const chip = document.createElement('div');
          chip.style.cssText = `font-size:9px; color:${rdef.color || '#cfd6e3'}; background:#141822; border:1px solid ${rdef.color || '#2a2f3a'}; border-radius:8px; padding:1px 6px;`;
          chip.textContent = (rdef.isTriple ? '⚡' : '🔥') + ' ' + rdef.name;
          previewWrap.appendChild(chip);
        }
        list.appendChild(previewWrap);
      }
    }
    // 판매 버튼은 이미 가로 row에 포함됨 — 아래 추가 없음
  }
  // 🎲 TD 진화 후보 검색 — 능력 ID가 들어가는 모든 콤보 레시피의 결과 능력들
  // (파트너 보유 여부와 무관 — 단순 가능한 결과 목록)
  function getEvolutionResults(abilityId) {
    const seen = new Set();
    const results = [];
    for (const recipe of COMBO_RECIPES) {
      if (recipe.parts.indexOf(abilityId) >= 0 && !seen.has(recipe.combo)) {
        seen.add(recipe.combo);
        results.push(recipe.combo);
      }
    }
    return results;
  }
  // 🎲 TD 진화 실행 — 가능한 결과 중 랜덤 하나로 변환
  function evolveTower(tower, cost) {
    const results = getEvolutionResults(tower.ab.id);
    if (results.length === 0) return;
    state.gold -= cost;
    const pickedId = results[Math.floor(Math.random() * results.length)];
    const def = ABILITY_DEFS[pickedId];
    const newAb = { id: pickedId, level: 1 };
    if (def && def.init) def.init(newAb);
    tower.ab = newAb;
    // 진화 시각 효과
    state.comboFlash = 40;
    state.comboFlashColor = def.color || '#ffd479';
    state.comboReveal = { id: pickedId, level: 1, life: def.isTriple ? 90 : 60 };
    shake(15, 18);
    SFX.combo();
    toast(`🎲 진화! → ${def.name}`);
  }
  function placeTower(slot, abilityId, cost) {
    // 💰 골드는 뽑기 시점에 이미 차감됨 — placeTower 의 cost 는 0
    if (cost > 0) state.gold -= cost;
    const def = ABILITY_DEFS[abilityId];
    const ab = { id: abilityId, level: 1 };
    if (def.init) def.init(ab);
    const c = cellCenter(slot.col, slot.row);
    state.towers.push({
      col: slot.col, row: slot.row,
      x: c.x, y: c.y,
      ab,
      originalAbilityId: abilityId,   // 시각 잠금용 — 가챠 SR/SSR은 진화 후에도 외형 유지
      placedCost: cost,
    });
    SFX.combo();
  }
  function upgradeTower(tower, cost) {
    state.gold -= cost;
    tower.ab.level += 1;
    SFX.click();
  }
  function sellTower(tower, refund) {
    state.gold += refund;
    const idx = state.towers.indexOf(tower);
    if (idx >= 0) state.towers.splice(idx, 1);
    SFX.click();
  }
  document.getElementById('tdTowerModalClose').onclick = closeTowerModal;
  // 인라인 패널이므로 외부 클릭 닫기 불필요 — 캔버스 클릭으로 다른 슬롯/타워 선택하거나 ✕ 버튼

  // 💎 보유 유물 HUD — 좌하단 작은 아이콘 (시각 보조용)
  // 상세 확인은 패널의 "💎 유물 N개 보기" 버튼으로
  function drawRelicHUD() {
    if (!state.activeRelics || state.activeRelics.length === 0) return;
    const size = 22;            // 🖼 v247 — 이미지 잘 보이게 약간 키움 (18→22)
    const gap = 3;
    const startX = 8;
    const startY = H - size - 8;
    for (let i = 0; i < state.activeRelics.length; i++) {
      const r = state.activeRelics[i];
      const rar = RELIC_RARITY[r.rarity];
      const x = startX + (i % 14) * (size + gap);
      const y = startY - Math.floor(i / 14) * (size + gap);
      // 배경 + 테두리
      ctx.fillStyle = '#0a0d14';
      ctx.fillRect(x, y, size, size);
      ctx.strokeStyle = rar.color;
      ctx.lineWidth = 1.5;
      ctx.strokeRect(x + 0.5, y + 0.5, size - 1, size - 1);
      // 🖼 v247 — 이미지 우선, 없으면 emoji
      drawRelicIcon(ctx, r.id, x + 2, y + 2, size - 4);
    }
    ctx.textBaseline = 'alphabetic';
    ctx.textAlign = 'start';
  }

  // 💎 유물 제안 모달 — 카드와 차별: 수직 제단형, 등급별 강렬한 글로우
  function drawRelicOffering() {
    if (!state.relicOffering || state.relicOffering.length === 0) return;
    // 어두운 배경 + 신비한 입자 효과
    ctx.fillStyle = 'rgba(0,0,0,0.86)';
    ctx.fillRect(0, 0, W, H);
    // 회전 광채 (배경)
    const t = state.t * 0.5;
    for (let i = 0; i < 24; i++) {
      const ang = (t * 0.01 + i * Math.PI / 12);
      const r = 200 + Math.sin(state.t * 0.05 + i) * 30;
      const px = CX + Math.cos(ang) * r;
      const py = CY + Math.sin(ang) * r;
      ctx.globalAlpha = 0.15;
      ctx.fillStyle = '#aaccff';
      ctx.fillRect(px - 1, py - 1, 2, 2);
    }
    ctx.globalAlpha = 1;
    // 🌟 v241 — 스택 모드 감지: 제안된 유물을 모두 이미 보유 중이면 스택 모드
    const ownedSet = new Set((state.activeRelics || []).map(r => r.id));
    const isStackMode = state.relicOffering.every(rid => ownedSet.has(rid));
    // 타이틀
    ctx.fillStyle = isStackMode ? '#aaccff' : '#ffd479';
    ctx.font = 'bold 24px Jua, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText(isStackMode ? '✨ 유물 강화 ✨' : '보스의 유물', CX, 48);
    ctx.fillStyle = '#9aa3b3';
    ctx.font = '12px Jua, sans-serif';
    ctx.fillText(isStackMode
      ? '강화할 유물을 선택 (스택 +1 · 데미지+3% · 골드+3%)'
      : '하나를 선택하세요 (영원히 이번 게임에 적용)', CX, 68);
    // 유물 제단 — 수직 3개
    const altarW = 360, altarH = 100, gap = 14;
    const totalH = altarH * state.relicOffering.length + gap * (state.relicOffering.length - 1);
    const startY = (H - totalH) / 2 + 10;
    const x = (W - altarW) / 2;
    for (let i = 0; i < state.relicOffering.length; i++) {
      const rid = state.relicOffering[i];
      const r = RELICS[rid];
      if (!r) continue;
      const y = startY + i * (altarH + gap);
      const rarInfo = RELIC_RARITY[r.rarity];
      // 글로우 (펄스)
      const pulse = 0.7 + 0.3 * Math.sin(state.t * 0.08 + i);
      ctx.fillStyle = rarInfo.glow;
      ctx.globalAlpha = 0.15 * pulse;
      ctx.fillRect(x - 12, y - 12, altarW + 24, altarH + 24);
      ctx.globalAlpha = 1;
      // 메인 박스 — 신비한 깊이감
      const grad = ctx.createLinearGradient(0, y, 0, y + altarH);
      grad.addColorStop(0, '#1a1f2b');
      grad.addColorStop(1, '#0a0d14');
      ctx.fillStyle = grad;
      ctx.fillRect(x, y, altarW, altarH);
      // 등급 색 테두리 (양옆 두꺼움)
      ctx.fillStyle = rarInfo.color;
      ctx.fillRect(x, y, 4, altarH);
      ctx.fillRect(x + altarW - 4, y, 4, altarH);
      // 상단/하단 가는 테두리
      ctx.fillRect(x, y, altarW, 1);
      ctx.fillRect(x, y + altarH - 1, altarW, 1);
      // 등급 라벨
      ctx.fillStyle = rarInfo.color;
      ctx.font = 'bold 11px Jua, sans-serif';
      ctx.textAlign = 'left';
      ctx.fillText(`✦ ${rarInfo.label.toUpperCase()} ✦`, x + 16, y + 18);
      // 🖼 v247 — 아이콘 (이미지 우선, 없으면 emoji 폴백)
      // 좌측 큰 박스 영역 (~80x80) 안에 그리기
      const iconBoxSize = 78;
      const iconBoxX = x + 10;
      const iconBoxY = y + (altarH - iconBoxSize) / 2;
      ctx.globalAlpha = 0.95;
      const usedImage = drawRelicIcon(ctx, rid, iconBoxX, iconBoxY, iconBoxSize, { color: rarInfo.color, emojiFontSize: 56 });
      ctx.globalAlpha = 1;
      // 이름
      ctx.fillStyle = '#fff';
      ctx.font = 'bold 18px Jua, sans-serif';
      ctx.textAlign = 'left';
      ctx.fillText(r.name, x + 100, y + 40);
      // 🌟 v241 — 스택 모드: 현재 누적 스택 표시 + 강화 후 표시
      const existing = (state.activeRelics || []).find(rr => rr.id === rid);
      if (isStackMode && existing) {
        const curStack = existing.stacks || 0;
        const nameW = ctx.measureText(r.name).width;
        // 뱃지 배경
        ctx.fillStyle = '#aa88ff';
        const badgeX = x + 100 + nameW + 8;
        const badgeY = y + 26;
        const badgeText = `+${curStack} → +${curStack + 1}`;
        ctx.font = 'bold 12px Jua, sans-serif';
        const badgeW = ctx.measureText(badgeText).width + 10;
        ctx.fillRect(badgeX, badgeY, badgeW, 18);
        ctx.fillStyle = '#fff';
        ctx.fillText(badgeText, badgeX + 5, y + 40);
      }
      // 설명
      ctx.fillStyle = '#c8cdd8';
      ctx.font = '13px Jua, sans-serif';
      // 줄바꿈 처리
      const words = r.desc.split(' ');
      let line = '';
      let lineY = y + 62;
      const maxW = altarW - 110;
      for (const w of words) {
        const testLine = line ? line + ' ' + w : w;
        if (ctx.measureText(testLine).width > maxW) {
          ctx.fillText(line, x + 100, lineY);
          line = w;
          lineY += 18;
        } else { line = testLine; }
      }
      if (line) ctx.fillText(line, x + 100, lineY);
      // 클릭 영역 저장 (전역으로 — 입력 핸들러가 사용)
      if (!state._relicHitboxes) state._relicHitboxes = [];
      state._relicHitboxes[i] = { x, y, w: altarW, h: altarH, rid };
    }
    // 스킵 안내
    ctx.fillStyle = '#5a5f6a';
    ctx.font = '11px Jua, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText('(클릭으로 선택 — 스킵 불가)', CX, H - 28);
    ctx.textAlign = 'start';
  }

  // ♾ R100 클리어 시 엔드리스 모드 선택 모달
  function drawEndlessOffer() {
    if (!state.endlessOfferPending) {
      state._endlessYesBtn = null;
      state._endlessNoBtn = null;
      return;
    }
    // 배경 어둡게
    ctx.fillStyle = 'rgba(0, 0, 0, 0.78)';
    ctx.fillRect(0, 0, W, H);
    // 타이틀
    ctx.textAlign = 'center';
    ctx.fillStyle = '#ffd479';
    ctx.font = 'bold 38px Jua, sans-serif';
    ctx.fillText('🏆 VICTORY', CX, CY - 110);
    ctx.fillStyle = '#fff';
    ctx.font = '20px Jua, sans-serif';
    ctx.fillText('R100 클리어!', CX, CY - 76);
    // 안내
    ctx.fillStyle = '#88e0ff';
    ctx.font = 'bold 22px Jua, sans-serif';
    ctx.fillText('♾ 엔드리스 모드로 계속하시겠습니까?', CX, CY - 28);
    ctx.fillStyle = '#cfd6e3';
    ctx.font = '13px Jua, sans-serif';
    ctx.fillText('매 라운드마다 적 HP가 ×1.5 배수로 증가합니다.', CX, CY + 2);
    ctx.fillStyle = '#9aa3b3';
    ctx.font = '11px Jua, sans-serif';
    ctx.fillText('현재 기록은 이미 R100 클리어로 저장되었습니다.', CX, CY + 22);
    // 버튼
    const btnW = 160, btnH = 48, btnGap = 16;
    const totalW = btnW * 2 + btnGap;
    const btnY = CY + 56;
    const btnX1 = CX - totalW / 2;
    const btnX2 = btnX1 + btnW + btnGap;
    // YES (♾)
    ctx.fillStyle = '#1a2a14';
    ctx.fillRect(btnX1, btnY, btnW, btnH);
    ctx.strokeStyle = '#88ff88';
    ctx.lineWidth = 2;
    ctx.strokeRect(btnX1, btnY, btnW, btnH);
    ctx.fillStyle = '#88ff88';
    ctx.font = 'bold 16px Jua, sans-serif';
    ctx.fillText('♾ 계속한다', btnX1 + btnW / 2, btnY + 30);
    // NO (종료)
    ctx.fillStyle = '#2a1414';
    ctx.fillRect(btnX2, btnY, btnW, btnH);
    ctx.strokeStyle = '#ff8888';
    ctx.lineWidth = 2;
    ctx.strokeRect(btnX2, btnY, btnW, btnH);
    ctx.fillStyle = '#ff8888';
    ctx.font = 'bold 16px Jua, sans-serif';
    ctx.fillText('🏁 종료', btnX2 + btnW / 2, btnY + 30);
    state._endlessYesBtn = { x: btnX1, y: btnY, w: btnW, h: btnH };
    state._endlessNoBtn  = { x: btnX2, y: btnY, w: btnW, h: btnH };
    ctx.textAlign = 'start';
  }

  // ♾ 엔드리스 모드 시작 — pending 해제, 라운드 진행 재개
  function startEndlessMode() {
    if (!state.endlessOfferPending) return;
    state.endless = true;
    state.endlessOfferPending = false;
    paused = false;
    // 보유 유물 효과 일부 리셋 (영원의 빛 등은 유지)
    planRound();
    toast('♾ 엔드리스 모드 시작! 적 HP 매 라운드 ×1.5');
    shake(20, 30);
    state.comboFlash = 60;
    state.comboFlashColor = '#88ff88';
  }
  // 엔드리스 거부 → 게임 종료
  function declineEndless() {
    if (!state.endlessOfferPending) return;
    state.endlessOfferPending = false;
    endGame('🏆 100라운드 클리어!', true);
  }

  function drawDamageNumbers() {
    ctx.textAlign = 'center';
    for (const d of state.damageNumbers) {
      const a = Math.min(1, d.life / 30);
      ctx.globalAlpha = a;
      ctx.font = `bold ${d.size}px Jua, sans-serif`;
      ctx.fillStyle = '#000';
      ctx.fillText(d.text, d.x + 1, d.y + 1);
      ctx.fillStyle = d.color;
      ctx.fillText(d.text, d.x, d.y);
    }
    ctx.globalAlpha = 1;
    ctx.textAlign = 'start';
  }
  function drawWaveClear() {
    const w = state.waveClearText;
    if (!w) return;
    const total = 70;
    const t = (total - w.life) / total;
    let scale = 1, alpha = 1;
    if (t < 0.2) { scale = t / 0.2; alpha = scale; }
    else if (t > 0.7) { alpha = 1 - (t - 0.7) / 0.3; }
    ctx.save();
    ctx.translate(CX, CY - 80);
    ctx.scale(scale, scale);
    ctx.globalAlpha = alpha;
    ctx.fillStyle = '#ffe070';
    ctx.font = 'bold 30px Jua, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText(`R${w.round} CLEAR!`, 0, 0);
    ctx.fillStyle = '#fff';
    ctx.font = '14px Jua, sans-serif';
    ctx.fillText(`+${w.bonus.toLocaleString()} (${w.timeSaved.toFixed(1)}s 단축)`, 0, 22);
    ctx.restore();
    ctx.globalAlpha = 1;
    ctx.textAlign = 'start';
  }
  function drawComboReveal() {
    const cr = state.comboReveal;
    if (!cr) return;
    const def = ABILITY_DEFS[cr.id];
    if (!def) return;
    const total = 60;
    const t = (total - cr.life) / total;
    let scale, alpha;
    if (t < 0.25) {           // pop in
      scale = t / 0.25;
      alpha = scale;
    } else if (t < 0.75) {    // hold
      scale = 1 + Math.sin((t - 0.25) * 6) * 0.04;
      alpha = 1;
    } else {                  // fade out
      scale = 1;
      alpha = 1 - (t - 0.75) / 0.25;
    }
    ctx.save();
    ctx.translate(CX, CY);
    ctx.scale(scale, scale);
    ctx.globalAlpha = alpha;
    // 카드
    const cw = 260, ch = 100;
    ctx.fillStyle = '#0b0d12';
    ctx.fillRect(-cw/2, -ch/2, cw, ch);
    ctx.strokeStyle = def.color;
    ctx.lineWidth = 3;
    ctx.strokeRect(-cw/2, -ch/2, cw, ch);
    // 위 라벨
    ctx.fillStyle = '#ffd479';
    ctx.font = 'bold 12px Jua, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText('조합 완성', 0, -ch/2 + 18);
    // 이름
    ctx.fillStyle = def.color;
    ctx.font = 'bold 24px Jua, sans-serif';
    ctx.fillText(def.name, 0, 8);
    // 설명
    ctx.fillStyle = '#c8cdd8';
    ctx.font = '11px Jua, sans-serif';
    ctx.fillText(def.desc(cr.level || 1), 0, ch/2 - 14);
    ctx.restore();
    ctx.globalAlpha = 1;
    ctx.textAlign = 'start';
  }
  // 카드 4티어 색상 팔레트 (능력별 색 X — 티어별 통합)
  const CARD_TIERS = {
    new: {
      bg1: '#1c1e26', bg2: '#0a0c14',
      border: '#e6e6ec', name: '#ffffff',
      accent: '#c0c4cc', glow: null,
      label: '⭐ NEW',
    },
    upgrade: {
      bg1: '#1a3050', bg2: '#0a1424',
      border: '#88c8ff', name: '#cce8ff',
      accent: '#88c8ff', glow: 'rgba(136, 200, 255, 0.20)',
      label: '▲ UPGRADE',
    },
    combo: {
      bg1: '#3a1e58', bg2: '#180824',
      border: '#c084ff', name: '#e0c0ff',
      accent: '#c084ff', glow: 'rgba(192, 132, 255, 0.30)',
      label: '✦ 조합!',
    },
    triple: {
      // 세련된 와인 레드 (딥 크림슨)
      bg1: '#48121c', bg2: '#1d0608',
      border: '#e8364a', name: '#ff7a8c',
      accent: '#e8364a', glow: 'rgba(232, 54, 74, 0.42)',
      label: '🔥 히든 조합!',
    },
    bonusScore: {
      // 점수 보너스 — 잎새 같은 차분한 청록
      bg1: '#103024', bg2: '#06150f',
      border: '#88dda8', name: '#bcf0d2',
      accent: '#88dda8', glow: 'rgba(136, 221, 168, 0.25)',
      label: '🎁 점수',
    },
    bonusStardust: {
      // 스타더스트 — 부드러운 골드
      bg1: '#2e2410', bg2: '#181104',
      border: '#ffd479', name: '#ffe890',
      accent: '#ffd479', glow: 'rgba(255, 212, 121, 0.30)',
      label: '⭐ 스타더스트',
    },
    ascendant: {
      // 🌟 v241 — 어센던트 (엔드리스 +% 카드) 화려한 보라/시안 그라데이션
      bg1: '#1f1840', bg2: '#0c0820',
      border: '#aa88ff', name: '#d0c0ff',
      accent: '#aaccff', glow: 'rgba(170, 136, 255, 0.55)',
      label: '✨ ASCENDANT',
    },
    lucky: {
      // LUCKY +2 — 행운의 녹색/금색
      bg1: '#1e3018', bg2: '#0f1808',
      border: '#88ff88', name: '#ccffcc',
      accent: '#aaff88', glow: 'rgba(136, 255, 136, 0.45)',
      label: '🍀 LUCKY +2',
    },
    superLucky: {
      // SUPER LUCKY +3 — 무지개 핫핑크/금색 화려함
      bg1: '#3a1840', bg2: '#1a0820',
      border: '#ff80ff', name: '#ffe0ff',
      accent: '#ffd0ff', glow: 'rgba(255, 128, 255, 0.55)',
      label: '💫 SUPER LUCKY +3',
    },
  };
  function getCardTier(c) {
    if (c.action === 'level') {
      if (c.lucky === 2) return 'superLucky';
      if (c.lucky === 1) return 'lucky';
      return 'upgrade';
    }
    if (c.action === 'combo') return c.tier === 3 ? 'triple' : 'combo';
    if (c.action === 'bonusScore') return 'bonusScore';
    if (c.action === 'bonusStardust') return 'bonusStardust';
    if (c.action === 'ascendant') return 'ascendant';
    return 'new';
  }

  function drawLevelUpModal() {
    if (!state.levelUpChoices) {
      state._cardModalStartMs = null;
      return;
    }
    // 🎬 v255 — 카드 모달 페이드 인 (실시간 ms 기준 — paused 상태에서도 동작)
    //   ⚠ state.t 는 paused 시 정지하므로 사용 X → performance.now() 로 측정
    if (state._cardModalStartMs == null) state._cardModalStartMs = performance.now();
    const elapsedMs = performance.now() - state._cardModalStartMs;
    const fadeMs = 300;
    const fadeAlpha = Math.min(1, elapsedMs / fadeMs);
    const eased = 1 - Math.pow(1 - fadeAlpha, 2);  // ease-out
    ctx.save();
    ctx.globalAlpha = eased;
    ctx.fillStyle = 'rgba(0,0,0,0.80)';
    ctx.fillRect(0, 0, W, H);
    // 제목 (모바일 가독성 위해 폰트 ↑)
    const isRandom = state.cardCost > 0;
    const isFreeRoll = !!state.isFreeRollCard;
    if (isFreeRoll) {
      // 시작 무료 카드 — 강화소 보너스
      const totalFreeRolls = (state.metaMods && state.metaMods.freeRolls) || 0;
      const currentIdx = totalFreeRolls - state.pendingFreeRolls + 1;
      ctx.fillStyle = '#88ff88';
      ctx.font = 'bold 26px Jua, sans-serif';
      ctx.textAlign = 'center';
      ctx.fillText(`🎁 시작 무료 카드 (${currentIdx}/${totalFreeRolls})`, CX, 70);
      ctx.fillStyle = '#9aa3b3';
      ctx.font = '13px Jua, sans-serif';
      ctx.fillText('강화소 보너스 · 골드 차감 없음', CX, 92);
    } else {
      ctx.fillStyle = isRandom ? '#ffd479' : '#ffe070';
      ctx.font = 'bold 26px Jua, sans-serif';
      ctx.textAlign = 'center';
      ctx.fillText(isRandom ? '🎲 카드 선택' : `LEVEL ${state.playerLevel} UP!`, CX, 70);
      ctx.fillStyle = '#9aa3b3';
      ctx.font = '13px Jua, sans-serif';
      ctx.fillText(isRandom ? `선택 시 ${state.cardCost}G 차감` : '3장 중 하나를 선택하세요', CX, 92);
    }

    const cardW = 175, cardH = 290, gap = 12;   // 아이콘 공간 위해 cardH ↑
    const totalW = cardW * 3 + gap * 2;
    const startX = (W - totalW) / 2;
    const cardY = (H - cardH) / 2 - 10;
    const ownedIds = new Set(state.tower.abilities.map(a => a.id));
    const ICON_SIZE = 72;   // 카드 위 큰 아이콘 크기

    for (let i = 0; i < state.levelUpChoices.length; i++) {
      const c = state.levelUpChoices[i];
      const def = ABILITY_DEFS[c.id];  // 보너스 카드는 def 없음
      const tier = getCardTier(c);
      const p = CARD_TIERS[tier];
      const x = startX + i * (cardW + gap);
      const y = cardY;
      const isAscendant = c.action === 'ascendant';
      const isBonus = c.action === 'bonusScore' || c.action === 'bonusStardust' || isAscendant;
      const ascDef = isAscendant ? ASCENDANT_BY_ID[c.id] : null;
      const ascStack = isAscendant && state.ascendantStacks ? (state.ascendantStacks[c.id] || 0) : 0;

      // 🎯 v227 — 카드 눌림 효과 (pointerdown 시 살짝 작게 + 글로우 강조)
      const isPressed = state.cardPressIdx === i;
      ctx.save();
      if (isPressed) {
        const cx = x + cardW / 2;
        const cy = y + cardH / 2;
        ctx.translate(cx, cy);
        ctx.scale(0.95, 0.95);
        ctx.translate(-cx, -cy);
      }

      // 🎬 등장 — 아래서 살짝 떠오르며 (페이드 인 동안)
      if (eased < 1) ctx.translate(0, (1 - eased) * 24);
      // 다이아 스파클 헬퍼
      const sparkle = (sx, sy, sr, col) => { ctx.fillStyle = col; ctx.beginPath(); ctx.moveTo(sx, sy-sr); ctx.lineTo(sx+sr*0.55, sy); ctx.lineTo(sx, sy+sr); ctx.lineTo(sx-sr*0.55, sy); ctx.closePath(); ctx.fill(); };
      // 외곽 글로우 (소프트 — 눌릴 때 강조)
      if (p.glow) {
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        ctx.fillStyle = isPressed ? 'rgba(255,255,255,0.18)' : p.glow;
        ctx.fillRect(x - 8, y - 8, cardW + 16, cardH + 16);
        ctx.restore();
      }
      // 살짝 펄스하는 트리플
      if (tier === 'triple') {
        const pulse = 0.5 + 0.5 * Math.sin(state.t * 0.12);
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        ctx.fillStyle = `rgba(255, 208, 96, ${0.12 + pulse * 0.12})`;
        ctx.fillRect(x - 12, y - 12, cardW + 24, cardH + 24); ctx.restore();
      }
      // 🍀 LUCKY — 녹색 펄스 + 다이아 스파클
      if (tier === 'lucky') {
        const pulse = 0.5 + 0.5 * Math.sin(state.t * 0.18);
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        ctx.fillStyle = `rgba(136, 255, 136, ${0.16 + pulse * 0.16})`;
        ctx.fillRect(x - 14, y - 14, cardW + 28, cardH + 28);
        for (let k = 0; k < 6; k++) {
          const sa = state.t * 0.08 + k * (Math.PI * 2 / 6);
          const sr = 4 + Math.sin(state.t * 0.15 + k) * 2;
          const sx = x + cardW/2 + Math.cos(sa) * (cardW/2 + 16);
          const sy = y + cardH/2 + Math.sin(sa) * (cardH/2 + 16);
          sparkle(sx, sy, sr, `rgba(180, 255, 150, ${0.5 + Math.sin(state.t * 0.2 + k) * 0.3})`);
        }
        ctx.restore();
      }
      // 💫 SUPER LUCKY — 무지개 펄스 + 다이아 스파클
      if (tier === 'superLucky') {
        const pulse = 0.5 + 0.5 * Math.sin(state.t * 0.22);
        const hueOffset = (state.t * 3) % 360;
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        for (let g = 0; g < 3; g++) {
          const hue = (hueOffset + g * 120) % 360;
          ctx.fillStyle = `hsla(${hue}, 90%, 65%, ${(0.09 + pulse * 0.10) * (1 - g * 0.22)})`;
          ctx.fillRect(x - 16 - g*4, y - 16 - g*4, cardW + 32 + g*8, cardH + 32 + g*8);
        }
        for (let k = 0; k < 10; k++) {
          const sa = state.t * 0.12 + k * (Math.PI * 2 / 10);
          const sr = 3.5 + Math.sin(state.t * 0.18 + k) * 2;
          const rad = cardW/2 + 22 + Math.sin(state.t * 0.1 + k * 0.7) * 6;
          const sx = x + cardW/2 + Math.cos(sa) * rad;
          const sy = y + cardH/2 + Math.sin(sa) * rad;
          const hue = (hueOffset + k * 36) % 360;
          sparkle(sx, sy, sr, `hsla(${hue}, 100%, 78%, 0.9)`);
        }
        ctx.restore();
      }
      // 카드 배경 (살짝만 둥근 + 그라데이션) — 여백 보존
      const grad = ctx.createLinearGradient(x, y, x, y + cardH);
      grad.addColorStop(0, p.bg1);
      grad.addColorStop(1, p.bg2);
      ctx.fillStyle = grad;
      rr(x, y, cardW, cardH, 7); ctx.fill();
      // 본체 테두리
      ctx.strokeStyle = p.border; ctx.lineWidth = 3;
      rr(x, y, cardW, cardH, 7); ctx.stroke();
      // 상단 액센트 바 (둥근 모서리 안에 클립)
      ctx.save(); rr(x, y, cardW, cardH, 7); ctx.clip();
      ctx.fillStyle = p.border; ctx.fillRect(x, y, cardW, 3);
      ctx.restore();

      // 티어 라벨 (보너스는 위, 능력은 아이콘 아래 — 충분한 간격으로 안 겹침)
      ctx.fillStyle = p.accent;
      ctx.font = 'bold 13px Jua, sans-serif';
      ctx.textAlign = 'center';
      const tierY = isBonus ? y + 24 : y + 100;
      // LUCKY/SUPER LUCKY 는 폰트도 큼지막하게 + 그림자 효과
      if (tier === 'lucky') {
        ctx.font = 'bold 16px Jua, sans-serif';
        ctx.shadowColor = '#88ff88';
        ctx.shadowBlur = 12;
      } else if (tier === 'superLucky') {
        ctx.font = 'bold 18px Jua, sans-serif';
        ctx.shadowColor = '#ff80ff';
        ctx.shadowBlur = 18;
        // 무지개 색상 사이클
        const hue = (state.t * 4) % 360;
        ctx.fillStyle = `hsl(${hue}, 100%, 75%)`;
      }
      ctx.fillText(p.label, x + cardW/2, tierY);
      ctx.shadowBlur = 0;

      // ⭐ 큰 아이콘 — 카드 위쪽 (보너스 카드는 X)
      if (!isBonus && c.id) {
        const iconX = x + (cardW - ICON_SIZE) / 2;
        const iconY = y + 12;
        drawAbilityIcon(c.id, iconX, iconY, ICON_SIZE);
      }

      // 능력 종류 태그 (아이콘 아래)
      const kindY = isBonus ? y + 42 : y + 116;   // 102 → 116
      // 🌟 v242 — 어센던트는 '어센던트'로 표시 (이전엔 '보너스' 잘못 표시)
      if (isAscendant) {
        ctx.fillStyle = '#aaccff';
        ctx.font = 'bold 11px Jua, sans-serif';
        ctx.fillText('어센던트', x + cardW/2, kindY);
      } else if (isBonus) {
        ctx.fillStyle = '#7a8090';
        ctx.font = '11px Jua, sans-serif';
        ctx.fillText('보너스', x + cardW/2, kindY);
      } else if (def) {
        ctx.fillStyle = '#7a8090';
        ctx.font = '11px Jua, sans-serif';
        const kindTag = def.isPassive ? '⚙ 패시브' : (def.isCombo ? '✨ 조합' : '⚡ 액티브');
        ctx.fillText(kindTag, x + cardW/2, kindY);
      }

      // 능력 태그 (광역/슬로우/관통 등) — 보너스 카드 X, 능력 카드만
      if (!isBonus && c.id) {
        const tags = getAbilityTags(c.id);
        if (tags.length > 0) {
          ctx.font = 'bold 10px Jua, sans-serif';
          // 전체 너비 측정 + 가운데 정렬
          const segs = [];
          for (let ti = 0; ti < tags.length; ti++) {
            segs.push({ text: tags[ti], color: TAG_COLORS[tags[ti]] || '#888' });
            if (ti < tags.length - 1) segs.push({ text: ' · ', color: '#555' });
          }
          let totalW = 0;
          for (const s of segs) totalW += ctx.measureText(s.text).width;
          // 너비 초과 시 폰트 축소
          if (totalW > cardW - 16) {
            ctx.font = 'bold 9px Jua, sans-serif';
            totalW = 0;
            for (const s of segs) totalW += ctx.measureText(s.text).width;
          }
          ctx.textAlign = 'left';
          let curX = x + cardW/2 - totalW/2;
          for (const s of segs) {
            ctx.fillStyle = s.color;
            ctx.fillText(s.text, curX, y + 132);   // 118 → 132 (tier/kind 아래로 밀림)
            curX += ctx.measureText(s.text).width;
          }
          ctx.textAlign = 'center';
        }
      }

      // 이름 (티어 색) — 보너스는 카드 윗부분 그대로, 능력은 아이콘 아래
      ctx.fillStyle = p.name;
      ctx.font = 'bold 20px Jua, sans-serif';
      if (isAscendant && ascDef) {
        // 🌟 v241 — 어센던트 카드 렌더: 아이콘 + 이름 + 효과 + 누적 스택
        ctx.fillStyle = ascDef.color;
        ctx.font = 'bold 44px sans-serif';
        ctx.fillText(ascDef.icon, x + cardW/2, y + 78);
        ctx.fillStyle = p.name;
        ctx.font = 'bold 17px Jua, sans-serif';
        ctx.fillText(ascDef.name, x + cardW/2, y + 110);
        ctx.fillStyle = ascDef.color;
        ctx.font = 'bold 14px Jua, sans-serif';
        ctx.fillText(ascDef.desc, x + cardW/2, y + 138);
        if (ascStack > 0) {
          ctx.fillStyle = '#aaccff';
          ctx.font = 'bold 12px Jua, sans-serif';
          ctx.fillText(`현재 누적 +${ascStack}`, x + cardW/2, y + 164);
        }
        ctx.fillStyle = '#9aa3b3';
        ctx.font = '11px Jua, sans-serif';
        ctx.fillText('영구 글로벌 강화', x + cardW/2, y + cardH - 60);
      } else if (isBonus) {
        const isScore = c.action === 'bonusScore';
        const amountText = isScore
          ? `+${c.amount.toLocaleString()}`
          : `+${c.amount} ★`;
        ctx.fillStyle = p.name;
        ctx.font = 'bold 26px Jua, sans-serif';
        ctx.fillText(amountText, x + cardW/2, y + 82);
        ctx.fillStyle = p.accent;
        ctx.font = '13px Jua, sans-serif';
        ctx.fillText(isScore ? '점수' : '스타더스트', x + cardW/2, y + 104);
        ctx.fillStyle = '#9aa3b3';
        ctx.font = '11px Jua, sans-serif';
        const helpTxt = isScore
          ? '현재 게임 점수 즉시 추가'
          : '영구 통화 (메뉴 강화소)';
        ctx.fillText(helpTxt, x + cardW/2, y + cardH - 60);
      } else {
        ctx.fillText(def.name, x + cardW/2, y + 152);   // 138 → 152
      }

      // 레벨 표시 / 조합 재료 — 텍스트들 +14 더 시프트 (NEW 라벨과 안 겹침)
      let nextLineY = y + 176;
      if (isBonus) {
        nextLineY = y + cardH;
      } else if (c.action === 'level') {
        // 럭키 카드는 큰 폰트로 강조
        const isLucky = c.lucky && c.lucky > 0;
        ctx.fillStyle = p.accent;
        ctx.font = isLucky ? 'bold 15px Jua, sans-serif' : '13px Jua, sans-serif';
        ctx.fillText(`Lv${c.level} → Lv${c.newLevel}`, x + cardW/2, y + 170);
        nextLineY = y + 190;
      } else if (c.action === 'combo' && c.parts) {
        const p1 = ABILITY_DEFS[c.parts[0]];
        const p2 = ABILITY_DEFS[c.parts[1]];
        if (p1 && p2) {
          ctx.fillStyle = p.accent;
          ctx.font = '12px Jua, sans-serif';
          ctx.fillText('재료 ↓', x + cardW/2, y + 170);
          ctx.fillStyle = '#c8cdd8';
          ctx.font = 'bold 12px Jua, sans-serif';
          ctx.fillText(`${p1.name} + ${p2.name}`, x + cardW/2, y + 186);
          ctx.fillStyle = p.accent;
          ctx.font = '11px Jua, sans-serif';
          ctx.fillText('(MAX 재료 소진)', x + cardW/2, y + 200);
          nextLineY = y + 218;
        }
      }

      // 설명 — 폰트 확대
      let lineY = nextLineY;
      if (!isBonus && def) {
        ctx.fillStyle = '#c8cdd8';
        ctx.font = '12px Jua, sans-serif';
        const desc = def.desc(c.newLevel || c.level || 1);
        const words = desc.split(' ');
        let line = '';
        for (const w of words) {
          const testLine = line ? line + ' ' + w : w;
          if (ctx.measureText(testLine).width > cardW - 18) {
            ctx.fillText(line, x + cardW/2, lineY);
            line = w;
            lineY += 15;
          } else line = testLine;
        }
        if (line) { ctx.fillText(line, x + cardW/2, lineY); lineY += 15; }
      }

      // 조합 힌트 — 보너스 카드는 표시 안 함
      // 보유 파트너 우선 정렬 → 후보 잘림으로 인한 비대칭 표시 방지
      const rawPartners = (!isBonus && c.id) ? (COMBO_PARTNERS[c.id] || []) : [];
      const partners = [...rawPartners].sort((p1, p2) => {
        const o1 = ownedIds.has(p1.partner) ? 1 : 0;
        const o2 = ownedIds.has(p2.partner) ? 1 : 0;
        if (o2 !== o1) return o2 - o1;
        return (p2.tier || 2) - (p1.tier || 2);
      });
      if (partners.length > 0) {
        // 구분선
        ctx.strokeStyle = `rgba(255,255,255,0.08)`;
        ctx.lineWidth = 1;
        ctx.beginPath();
        ctx.moveTo(x + 14, lineY + 4);
        ctx.lineTo(x + cardW - 14, lineY + 4);
        ctx.stroke();
        lineY += 16;
        let shown = 0;
        for (const pp of partners) {
          if (shown >= 3) break;
          const pdef = ABILITY_DEFS[pp.partner];
          const cdef = ABILITY_DEFS[pp.combo];
          if (!pdef || !cdef) continue;
          const has = ownedIds.has(pp.partner);
          const isTrip = pp.tier === 3;
          // 보유 시 강조 색
          ctx.fillStyle = has
            ? (isTrip ? '#ffd060' : '#c084ff')
            : '#5a6068';
          ctx.font = (has ? 'bold ' : '') + '11px Jua, sans-serif';
          const tag = isTrip ? '🔥' : (cdef.isCombo && pdef.isPassive ? '⚙' : '+');
          const hint = `${tag} ${pdef.name} → ${cdef.name}`;
          let txt = hint;
          while (ctx.measureText(txt).width > cardW - 14 && txt.length > 8) txt = txt.slice(0, -1);
          if (txt !== hint) txt = txt.slice(0, -1) + '…';
          ctx.fillText(txt, x + cardW/2, lineY);
          lineY += 14;
          shown++;
        }
      }

      // 하단 번호 키 (폰트 확대)
      ctx.fillStyle = p.accent;
      ctx.font = 'bold 15px Jua, sans-serif';
      ctx.fillText(`[${i + 1}]`, x + cardW/2, y + cardH - 12);
      ctx.restore();   // 🎯 v227 — 카드 눌림 변형 종료
    }

    // 하단 버튼 — 리롤 / 취소 (있을 때만)
    const showReroll = state.rerollAvailable;
    const showCancel = state.cardCancelable;
    const btnY = cardY + cardH + 18;
    const bh = 38;
    state._rerollBtn = null;
    state._cancelBtn = null;
    if (showReroll && showCancel) {
      // 두 버튼 나란히
      const bw = 130;
      const gap2 = 14;
      const totalBW = bw * 2 + gap2;
      const bx1 = CX - totalBW / 2;
      const bx2 = bx1 + bw + gap2;
      drawModalBtn(bx1, btnY, bw, bh, '🎲 리롤', '#1f2a35', '#7ad7ff');
      drawModalBtn(bx2, btnY, bw, bh, '취소 [ESC]', '#1a1f2b', '#3a4256');
      state._rerollBtn = { x: bx1, y: btnY, w: bw, h: bh };
      state._cancelBtn = { x: bx2, y: btnY, w: bw, h: bh };
    } else if (showReroll) {
      const bw = 150;
      const bx = CX - bw / 2;
      drawModalBtn(bx, btnY, bw, bh, '🎲 리롤 (남은 1회)', '#1f2a35', '#7ad7ff');
      state._rerollBtn = { x: bx, y: btnY, w: bw, h: bh };
    } else if (showCancel) {
      const bw = 120;
      const bx = CX - bw / 2;
      drawModalBtn(bx, btnY, bw, bh, '취소 [ESC]', '#1a1f2b', '#3a4256');
      state._cancelBtn = { x: bx, y: btnY, w: bw, h: bh };
    }

    // 자동 카드 선택 카운트다운 (모든 카드 보너스일 때만) — 실시간 deadline 기반
    if (state.autoCardTimer > 0) {
      const remainMs = Math.max(0, state.autoCardTimer - performance.now());
      const sec = Math.ceil(remainMs / 1000);
      const countY = btnY + bh + 22;
      ctx.font = '12px Jua, sans-serif';
      ctx.textAlign = 'center';
      ctx.fillStyle = '#9aa3b3';
      ctx.fillText('스타더스트 자동 선택', CX, countY);
      // 카운트다운 숫자 — 작게 강조
      ctx.font = 'bold 18px Jua, sans-serif';
      ctx.fillStyle = sec <= 1 ? '#ff8898' : (sec <= 2 ? '#ffd479' : '#88dda8');
      ctx.fillText(`${sec}S`, CX, countY + 22);
    }

    ctx.textAlign = 'start';
    // 🎬 v253 — 페이드 인 ctx.save 해제
    ctx.restore();
  }

  // 모달 버튼 한 개를 그리는 헬퍼
  function drawModalBtn(x, y, w, h, label, bg, border) {
    ctx.fillStyle = bg;
    ctx.fillRect(x, y, w, h);
    ctx.strokeStyle = border;
    ctx.lineWidth = 1.5;
    ctx.strokeRect(x, y, w, h);
    ctx.fillStyle = '#e8eaf0';
    ctx.font = '13px Jua, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText(label, x + w / 2, y + 24);
  }

  // ===== 패널 UI =====
  const $ = id => document.getElementById(id);
  const elRandom = $('randomBtn');
  const elAb     = $('abilities');
  const elToast  = $('toast');

  elRandom.onclick = actRandomAcquire;
  // 🏰 TD 타워 뽑기 버튼 클릭 — 카드 없으면 뽑기, 카드 들고있으면 버리기
  const _tdDrawBtn = document.getElementById('tdDrawBtn');
  if (_tdDrawBtn) {
    _tdDrawBtn.onclick = () => {
      if (state && state.tdHeldCard) {
        discardHeldCard();
      } else {
        openTowerDrawModal();
      }
    };
  }
  // 💎 유물 보기 버튼 — 보유 시 상세 / 빈 상태면 안내
  const _relicViewBtn = document.getElementById('relicViewBtn');
  if (_relicViewBtn) _relicViewBtn.onclick = () => {
    if ((state.activeRelics || []).length === 0) {
      toast('💎 보스 처치 시 40% 확률로 유물이 등장합니다');
      return;
    }
    openRelicDetail();
  };

  // 🚀 DOM diff helpers — 변경된 값만 실제 쓰기. 같은 값 재할당은 무시.
  //    가벼운 비교이지만 60fps × 12개 필드를 대부분 skip 가능 → reflow / 비교 비용 절감.
  function _setText(el, val) {
    if (el && el._lastText !== val) { el.textContent = val; el._lastText = val; }
  }
  function _setStyle(el, prop, val) {
    if (!el) return;
    const key = '_style_' + prop;
    if (el[key] !== val) { el.style[prop] = val; el[key] = val; }
  }
  function _setDisabled(el, val) {
    if (el && el._lastDisabled !== val) { el.disabled = val; el._lastDisabled = val; }
  }
  function _toggleClass(el, cls, on) {
    if (!el) return;
    const key = '_cls_' + cls;
    if (el[key] !== on) { el.classList.toggle(cls, on); el[key] = on; }
  }
  function renderStats() {
    // 라운드 + 승천 뱃지 + 엔드리스 표시
    const ascSuffix = (state.ascension && state.ascension > 0) ? ` ⚡${state.ascension}` : '';
    const endlessPrefix = state.endless ? '♾ ' : '';
    _setText($('s-round'), endlessPrefix + state.round + ascSuffix);
    const cfg = roundConfig(state.round);
    const remain = Math.max(0, cfg.duration - state.roundFrame) / FPS;
    _setText($('s-time'), remain.toFixed(1) + 's');
    // 🚀 정수 %로 양자화 — 매 틱 고유 문자열로 _setStyle 게이트가 뚫려 상시 레이아웃 유발하던 것 제거 (.15s transition이 1% 스텝을 부드럽게 메움)
    _setStyle($('s-timebar'), 'width', Math.round(100 * (cfg.duration - state.roundFrame) / cfg.duration) + '%');
    _setText($('s-gold'), String(state.gold));
    _setText($('s-score'), state.score.toLocaleString());
    const _maxA = getMaxAlive();
    _setText($('s-enemies'), `${state.enemies.length} / ${_maxA}`);
    // ✨ 누적 강화 표시 — 이벤트/상점/유물/승천 효과를 상시 확인
    const _re = state.relicEffects || {}, _mm = state.metaMods || {};
    const _dmgP = Math.round(((_mm.dmgMul || 1) - 1) * 100);          // 모든 데미지 (dmgMul)
    const _aoeP = Math.round(((_re.aoeDmgMul || 1) - 1) * 100);       // 광역 데미지만 (aoeDmgMul)
    const _bossP = Math.round(((_mm.bossDmgMul || 1) - 1) * 100);
    const _goldP = Math.round(((_mm.goldMul || 1) - 1) * 100);
    const _kg = _re.killGoldBonus || 0;
    const _bp = [];
    if (_dmgP) _bp.push(`데미지 ${_dmgP > 0 ? '+' : ''}${_dmgP}%`);
    if (_aoeP) _bp.push(`광역 데미지 ${_aoeP > 0 ? '+' : ''}${_aoeP}%`);
    if (_bossP) _bp.push(`보스 데미지 ${_bossP > 0 ? '+' : ''}${_bossP}%`);
    if (_goldP) _bp.push(`획득 골드 ${_goldP > 0 ? '+' : ''}${_goldP}%`);
    if (_kg) _bp.push(`처치당 골드 +${_kg}`);
    const _bel = $('s-buffs');
    if (_bel) { if (_bp.length) { _bel.style.display = ''; _setText($('s-buffs-val'), _bp.join(' · ')); } else { _bel.style.display = 'none'; } }
    const pl = $('s-plevel');
    if (pl) _setText(pl, `Lv${state.playerLevel} (${state.kills}/${state.killsToNextLevel} kills)`);
    const tk = $('s-totalkills');
    if (tk) _setText(tk, (state.totalKills || 0).toLocaleString());
    // 🏰 디펜스 모드 (TD): 본진 HP만
    const defBlock = $('s-defense-block');
    if (state.mode === 'defense') {
      if (defBlock) _setStyle(defBlock, 'display', '');
      const hpEl = $('s-towerhp');
      if (hpEl) _setText(hpEl, `${state.towerHP} / ${state.towerMaxHP}`);
      const hpBar = $('s-towerhp-bar');
      const hpPct = Math.max(0, state.towerHP / Math.max(1, state.towerMaxHP)) * 100;
      if (hpBar) {
        _setStyle(hpBar, 'width', hpPct + '%');
        _setStyle(hpBar, 'background', hpPct <= 20 ? '#ff3344' : (hpPct <= 50 ? '#ff8855' : '#ff5b6e'));
      }
    } else {
      if (defBlock) _setStyle(defBlock, 'display', 'none');
    }
    const pct = state.enemies.length / _maxA;
    const bar = $('s-enemybar');
    _setStyle(bar, 'width', (pct*100) + '%');
    _toggleClass(bar.parentElement, 'danger', pct > 0.75);
    _toggleClass(bar.parentElement, 'warn',   pct > 0.5 && pct <= 0.75);
    // 🛡 v214 — 랜덤 버튼 상태 — _setDisabled 캐시가 refreshAbilityAffordability 의 직접 .disabled=true 설정과
    //   충돌해서 모달 닫혀도 캐시가 stale인 채로 남는 버그 발생. 직접 set 으로 변경.
    const acqCost = randomAcquireCost();
    const modalOpenForRandom = !!state.levelUpChoices;
    elRandom.disabled = state.gold < acqCost || modalOpenForRandom;
    // 슬롯 가득이면 보너스 카드 모드임을 명시
    const aFull = activeCount() >= maxActiveSlots();
    const pFull = passiveCount() >= maxPassiveSlots();
    const hasCombo = findAvailableCombos().length > 0;
    const hasUpgradable = state.tower.abilities.some(a => !isAtMax(a));
    const bonusOnly = aFull && pFull && !hasCombo && !hasUpgradable;
    const costLabel = acqCost === 0 ? '무료' : `${acqCost}G`;
    const newText = bonusOnly
      ? `✨ 어센던트 카드 (${costLabel})`
      : `🎲 랜덤 능력 획득 (${costLabel})`;
    // 텍스트만 캐시 (성능) — 안전한 비교
    if (elRandom._lastText !== newText) { elRandom.textContent = newText; elRandom._lastText = newText; }
    // 능력 강화 버튼 어포더블 상태 매 프레임 갱신
    refreshAbilityAffordability();
  }

  // 강화 버튼 활성/비활성 + 색상을 현재 골드 기준으로 즉시 갱신 (DOM 재생성 없이)
  // 카드 모달 떠있을 때는 모든 강화/삭제 버튼 비활성 (꼼수 방지)
  //   ⚠ v205 — 캐싱/diff 제거. 매 프레임 querySelectorAll + 직접 set.
  //   🚀 v384 — DOM 캐시 대신 "입력 시그니처 게이트": 결과를 바꾸는 입력(골드/모달/패널세대)이
  //   동일하면 통째로 스킵. DOM 참조는 캐시하지 않으므로 v205의 stale 캐시 버그 부류는 불가능.
  let _affSig = '', _affGen = 0;
  function _invalidateAbBtnCache() { _affGen++; } // 패널 재구성/강화 시 시그니처 무효화 (renderPanel이 호출)
  function refreshAbilityAffordability() {
    if (!elAb) return;
    const modalOpen = !!state.levelUpChoices;
    const _sig = state.gold + '|' + modalOpen + '|' + _affGen + '|' + state.tower.abilities.length;
    if (_sig === _affSig) return;
    _affSig = _sig;
    // 강화 버튼 — 직접 처리 (캐시 없음)
    const upBtns = elAb.querySelectorAll('button[data-act="up"]');
    for (let i = 0; i < upBtns.length; i++) {
      const btn = upBtns[i];
      const idx = +btn.dataset.i;
      const a = state.tower.abilities[idx];
      if (!a) continue;
      if (isAtMax(a)) continue;
      const cost = enhanceCost(a);
      const canAfford = state.gold >= cost;
      const enabled = canAfford && !modalOpen;
      btn.disabled = !enabled;
      btn.style.opacity = enabled ? '' : '0.55';
      const row = btn.closest('.ability-row');
      if (row) row.classList.toggle('affordable', enabled);
      const costSpan = btn.querySelector('span');
      if (costSpan) costSpan.style.color = enabled ? '#ffd479' : '#5a5f6a';
    }
    // 삭제 버튼도 모달 중엔 비활성
    const rmBtns = elAb.querySelectorAll('button[data-act="rm"]');
    for (let i = 0; i < rmBtns.length; i++) {
      const btn = rmBtns[i];
      btn.disabled = modalOpen;
      btn.style.opacity = modalOpen ? '0.4' : '';
    }
    // 랜덤 버튼 처리는 renderStats 에서 이미 함 (modal + gold 조건 둘 다 반영) — 여기선 중복 X
  }

  // 🎬 v243 — 범용 행 접힘 헬퍼 (능력 삭제, 리스트 항목 제거 등 모든 UI 재사용 가능)
  // 사용법: collapseElementThen(rowEl, () => { 실제 데이터 삭제 + 재렌더 })
  // 행 자체를 max-height 0 로 접고 → 아래 행들은 자연스러운 flow로 위로 올라옴
  function collapseElementThen(el, done, durationMs) {
    if (!el || !el.isConnected) { if (done) done(); return; }
    const ms = durationMs || 220;
    const h = el.offsetHeight;
    el.style.maxHeight = h + 'px';
    el.classList.add('row-collapsing');
    // 강제 reflow — max-height 적용 후 다음 프레임에 collapsed 클래스 추가
    void el.offsetHeight;
    requestAnimationFrame(() => {
      el.classList.add('collapsed');
    });
    setTimeout(() => {
      if (done) done();
    }, ms + 30); // 약간 버퍼
  }
  // 🎬 v243 — 모달 열기/닫기 페이드 (display=flex/none 띡 끊김 방지)
  function openModalAnimated(el, display) {
    if (!el) return;
    const d = display || 'flex';
    el.classList.remove('modal-anim-out');
    el.style.display = d;
    void el.offsetHeight;
    el.classList.add('modal-anim-in');
  }
  function closeModalAnimated(el) {
    if (!el || el.style.display === 'none') return;
    el.classList.remove('modal-anim-in');
    el.classList.add('modal-anim-out');
    // 같은 setTimeout 묶음 안에서 또 닫기 호출이 들어와도 안전하게 한 번만 정리
    if (el._closeAnimTimer) clearTimeout(el._closeAnimTimer);
    el._closeAnimTimer = setTimeout(() => {
      el.style.display = 'none';
      el.classList.remove('modal-anim-out');
      el._closeAnimTimer = null;
    }, 170);
  }

  let currentAbTab = 'active';
  // 탭 클릭 핸들러
  document.querySelectorAll('.ab-tab').forEach(btn => {
    btn.onclick = () => {
      currentAbTab = btn.dataset.abtab;
      document.querySelectorAll('.ab-tab').forEach(b => b.classList.toggle('active', b === btn));
      renderPanel();
      SFX.click();
    };
  });

  function renderPanel() {
    // 🚀 패널 재구성 직전에 캐시된 버튼 셀렉터 무효화
    _invalidateAbBtnCache();
    renderStats();
    // 🎴 TD 타워 뽑기 버튼 — 모드/골드/홀딩 상태 반영
    refreshTDDrawBtn();
    // 클래식 모드면 뽑기 버튼 숨김, TD 모드면 노출
    const tdBtn = document.getElementById('tdDrawBtn');
    if (tdBtn) tdBtn.style.display = (state.mode === 'defense') ? '' : 'none';
    // 클래식 랜덤 능력 버튼은 TD 모드에서 숨김 (능력은 패시브 카드로만 획득)
    const rndBtn = document.getElementById('randomBtn');
    if (rndBtn) rndBtn.style.display = (state.mode === 'defense') ? 'none' : '';
    // 💎 유물 버튼 — 항상 표시, 빈 상태(empty) ↔ 활성 클래스 전환
    const relicBtn = document.getElementById('relicViewBtn');
    const relicCnt = document.getElementById('relic-view-count');
    if (relicBtn) {
      const n = (state.activeRelics || []).length;
      if (relicCnt) relicCnt.textContent = n > 0 ? `${n}개 보기` : '0개 (보스 처치 시 등장)';
      relicBtn.classList.toggle('empty', n === 0);
    }
    elAb.innerHTML = '';
    // 카테고리에 맞는 능력만 필터링
    const isPassiveTab = currentAbTab === 'passive';
    const filtered = state.tower.abilities.filter(a =>
      isPassiveTab ? ABILITY_DEFS[a.id].isPassive : !ABILITY_DEFS[a.id].isPassive
    );
    // 슬롯 카운트 갱신
    const aMax = maxActiveSlots(), pMax = maxPassiveSlots();
    const aCnt = activeCount(), pCnt = passiveCount();
    const aEl = document.getElementById('ab-active-count');
    const pEl = document.getElementById('ab-passive-count');
    if (aEl) aEl.textContent = `${aCnt}/${aMax}`;
    if (pEl) pEl.textContent = `${pCnt}/${pMax}`;

    const slotMax = isPassiveTab ? pMax : aMax;
    // 원본 인덱스 매핑 (삭제/강화 시 정확한 인덱스 필요)
    const origIdx = state.tower.abilities.map((a, i) => i)
      .filter(i => {
        const d = ABILITY_DEFS[state.tower.abilities[i].id];
        return isPassiveTab ? d.isPassive : !d.isPassive;
      });

    for (let i = 0; i < slotMax; i++) {
      const a = filtered[i];
      const row = document.createElement('div');
      if (!a) {
        row.className = 'ability-row empty';
        row.textContent = '(빈 슬롯)';
        elAb.appendChild(row);
        continue;
      }
      // 🎬 v243 — 신규 능력 fade-in 플래그 (className 재설정 이후 적용)
      const isNewRow = a._isNew;
      if (isNewRow) delete a._isNew;
      const def = ABILITY_DEFS[a.id];
      // 조합 힌트 (다중 파트너 지원)
      let comboHint = '';
      let nameColor = def.color;
      if (def.isCombo) {
        // 조합 능력은 그냥 자기 색
      } else if (COMBO_PARTNERS[a.id]) {
        const ownedSet = new Set(state.tower.abilities.map(x => x.id));
        // 보유 중인 파트너 먼저, 그 다음 미보유. 가챠 고유는 캐릭터 매칭 안 되면 숨김.
        const allP = COMBO_PARTNERS[a.id] || [];
        const sorted = [...allP].sort((p1, p2) => {
          const o1 = ownedSet.has(p1.partner) ? 1 : 0;
          const o2 = ownedSet.has(p2.partner) ? 1 : 0;
          if (o2 !== o1) return o2 - o1;            // 보유 우선
          return (p2.tier || 2) - (p1.tier || 2);   // 트리플 우선
        });
        // 최대 4개 (보유 가능한 모든 조합 + 힌트 일부)
        const limited = sorted.slice(0, 4);
        const hints = limited.map(p => {
          const pdef = ABILITY_DEFS[p.partner];
          const cdef = ABILITY_DEFS[p.combo];
          if (!pdef || !cdef) return '';
          const has = ownedSet.has(p.partner);
          const c = has ? '#52e07a' : '#6b7283';
          const trip = p.tier === 3 ? '🔥' : '+';
          return `<small style="color:${c}">${trip} ${pdef.name} → ${cdef.name}</small>`;
        }).filter(Boolean);
        comboHint = hints.join('');
      }
      const max = isAtMax(a);
      const cost = max ? 0 : enhanceCost(a);
      const canAfford = !max && state.gold >= cost;
      const lvLabel = max
        ? `<span style="color:#52e07a">MAX</span>`
        : `<span style="color:#9bb3ff">Lv${a.level}/${maxLvFor(a.id)}</span>`;
      const costColor = canAfford ? '#ffd479' : '#5a5f6a';
      const upBtn = max
        ? `<button disabled style="opacity:0.4; color:#52e07a; border-color:#2a4a30">MAX</button>`
        : `<button data-act="up" data-i="${origIdx[i]}"${canAfford ? '' : ' disabled style="opacity:0.55"'}>강화<br/><span style="color:${costColor}">${cost}G</span></button>`;
      row.className = 'ability-row';
      if (max) row.classList.add('maxed');
      else if (canAfford) row.classList.add('affordable');
      if (isNewRow) row.classList.add('row-fade-in');
      const tags = getAbilityTags(a.id);
      const tagsHtml = tags.length > 0
        ? `<div class="ability-tag-row">${tags.map(tagChipHtml).join('')}</div>`
        : '';
      const iconSize = wrapEl && wrapEl.classList.contains('portrait') ? 36 : 28;
      row.innerHTML = `
        <div class="ability-name">
          <div class="row-header">
            ${iconHtml(a.id, iconSize)}
            <b style="color:${nameColor}">${def.name} ${lvLabel}</b>
          </div>
          ${tagsHtml}
          <small>${def.desc(a.level)}</small>
          ${comboHint}
        </div>
        ${upBtn}
        ${(a._deleteArmedUntil && performance.now() < a._deleteArmedUntil)
          ? `<button data-act="rm" data-i="${origIdx[i]}" class="rm-armed" title="다시 누르면 삭제">❗</button>`
          : `<button data-act="rm" data-i="${origIdx[i]}" title="삭제">✕</button>`}
      `;
      elAb.appendChild(row);
    }
    elAb.querySelectorAll('button').forEach(btn => {
      btn.onclick = () => {
        const i = +btn.dataset.i;
        if (btn.dataset.act === 'up') actEnhance(i);
        else actDelete(i, btn);   // 🗑 v260 — 버튼 참조 전달 (2단계 삭제 무장 표시용)
      };
    });
  }

  let toastTimer = 0;
  function toast(msg) {
    elToast.textContent = msg;
    elToast.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => elToast.classList.remove('show'), 1200);
  }

  // ===== 🛒 특별 상점 — 라운드마다 낮은 확률로 등장 (index 능력 모델에 맞춤) =====
  const SHOP_NPC_NAME = '떠돌이 상인 · 핀';
  // 능력 획득 — 미보유면 새 능력(슬롯 여유 시), 보유면 +1 강화, 슬롯 꽉 차면 보유 능력 강화로 대체
  function _shopGainAbility(id) {
    if (!ABILITY_DEFS[id]) return;
    const existing = state.tower.abilities.find(a => a.id === id);
    if (existing) {
      if (!isAtMax(existing)) { existing.level = Math.min(existing.level + 1, maxLvFor(id)); if (existing.level >= maxLvFor(id)) checkAncientAwakening(id); }
      return;
    }
    const def = ABILITY_DEFS[id];
    const slotFree = def.isPassive ? (passiveCount() < maxPassiveSlots()) : (activeCount() < maxActiveSlots());
    if (!slotFree) { _shopUpgradeRandom(1); return; }
    const ab = { id, level: 1, acquiredRound: state.round || 1, _isNew: true };
    def.init(ab);
    state.tower.abilities.push(ab);
    unlockAbility(id);
  }
  // 무작위 비-max 능력 +n 강화 → 능력 이름 반환
  let _lastUpgraded = null;   // ⬆ 직전 강화된 능력 기록 (상점 결과 팝업 / 이벤트 아이콘용)
  function _shopUpgradeRandom(n) {
    n = n || 1;
    const pool = state.tower.abilities.filter(a => !isAtMax(a));
    if (!pool.length) { _lastUpgraded = null; return null; }
    const a = pool[Math.floor(Math.random() * pool.length)];
    const _before = a.level;
    a.level = Math.min(a.level + n, maxLvFor(a.id));
    if (a.level >= maxLvFor(a.id)) checkAncientAwakening(a.id);
    _lastUpgraded = { id: a.id, level: a.level, delta: a.level - _before };
    return ABILITY_DEFS[a.id].name;
  }
  // 영구 버프 (어센던트) 적용
  function _shopBuff(aid) {
    const t = ASCENDANT_BY_ID[aid]; if (!t) return;
    try { t.apply(state); } catch (e) {}
    if (!state.ascendantStacks) state.ascendantStacks = {};
    state.ascendantStacks[aid] = (state.ascendantStacks[aid] || 0) + 1;
  }
  function buildShopStock() {
    const round = state.round || 1;
    const roundMul = 1 + round * 0.12;
    const ownedIds = [...new Set(state.tower.abilities.map(a => a.id))];
    const allowed = (typeof getUnlockedAbilityIds === 'function') ? getUnlockedAbilityIds() : new Set(RANDOM_POOL_IDS);
    const unowned = RANDOM_POOL_IDS.filter(id => allowed.has(id) && !ownedIds.includes(id));
    const hasUpgradable = state.tower.abilities.some(a => !isAtMax(a));
    const cands = [];
    // 🟣 유물 — 등급 가중 무작위 3 (미보유·해금조건 없음·weight>0 → 고대 제외)
    const ownedR = (state.activeRelics || []).map(r => r.id);
    const relicPool = RELIC_IDS.filter(rid => { const r = RELICS[rid]; const rr = r && RELIC_RARITY[r.rarity]; return rr && rr.weight > 0 && !r.unlockBy && ownedR.indexOf(rid) < 0; });
    const usedRelic = new Set();
    for (let n = 0; n < 3 && relicPool.length; n++) {
      let total = relicPool.reduce((s, rid) => s + (RELIC_RARITY[RELICS[rid].rarity].weight || 1), 0);
      let roll = Math.random() * total, rid = relicPool[0];
      for (const id of relicPool) { roll -= RELIC_RARITY[RELICS[id].rarity].weight || 1; if (roll <= 0) { rid = id; break; } }
      if (usedRelic.has(rid)) continue; usedRelic.add(rid);
      const r = RELICS[rid];
      cands.push({ relicId: rid, name: r.name, desc: (r.desc || '').replace(/\.$/, '').slice(0, 38), rarity: r.rarity, baseCost: 55, weight: RELIC_RARITY[r.rarity].weight, apply: () => acquireRelic(rid) });
    }
    // 🎴 새 능력 — 미보유 2 (슬롯 여유 있으면 새로, 없으면 강화로 대체됨)
    const uShuf = unowned.slice().sort(() => Math.random() - 0.5).slice(0, 2);
    for (const id of uShuf) {
      const d = ABILITY_DEFS[id]; if (!d) continue;
      const rarity = d.isTriple ? 'epic' : (d.isCombo ? 'rare' : 'common');
      cands.push({ abIcon: id, name: d.name, desc: d.isPassive ? '새 패시브 능력 획득' : '새 능력 획득', rarity, baseCost: 45, weight: 75, apply: () => _shopGainAbility(id) });
    }
    // ⬆ 강화 +1 / ✨ 럭키 강화 +3
    if (hasUpgradable) {
      cands.push({ icon: '⬆', name: '능력 강화', desc: '무작위 능력 +1 레벨', rarity: 'common', baseCost: 30, weight: 70, apply: () => _shopUpgradeRandom(1) });
      cands.push({ icon: '✨', name: '럭키 강화', desc: '무작위 능력 +3 레벨', rarity: 'epic', baseCost: 65, weight: 26, apply: () => _shopUpgradeRandom(3) });
    }
    // ⚔ 영구 버프 (어센던트)
    cands.push({ icon: '⚔', name: '신성한 일격', desc: '모든 데미지 영구 +5%', rarity: 'rare', baseCost: 55, weight: 38, apply: () => _shopBuff('asc_damage') });
    cands.push({ icon: '👹', name: '거대 사냥꾼', desc: '보스 데미지 영구 +8%', rarity: 'epic', baseCost: 60, weight: 24, apply: () => _shopBuff('asc_bossDmg') });
    cands.push({ icon: '💰', name: '황금의 손길', desc: '획득 골드 영구 +5%', rarity: 'rare', baseCost: 45, weight: 36, apply: () => _shopBuff('asc_gold') });
    // 가중 무작위 6개 (중복 없이) — 등급 높을수록 비쌈
    const RAR_COST = { common: 1, rare: 1.5, epic: 2.3, legendary: 3.6, ancient: 5 };
    const stock = []; let guard = 0;
    while (stock.length < 8 && cands.length && guard++ < 60) {
      let total = cands.reduce((s, c) => s + (c.weight || 1), 0);
      let roll = Math.random() * total, idx = 0;
      for (let i = 0; i < cands.length; i++) { roll -= (cands[i].weight || 1); if (roll <= 0) { idx = i; break; } }
      const pick = cands.splice(idx, 1)[0];
      const cost = Math.ceil(pick.baseCost * roundMul * (RAR_COST[pick.rarity] || 1));
      stock.push({ icon: pick.icon, abIcon: pick.abIcon, relicId: pick.relicId, name: pick.name, desc: pick.desc, rarity: pick.rarity, cost, bought: false, apply: pick.apply });
    }
    return stock;
  }
  function buildShopUI() {
    const ge = document.getElementById('shopGold'); if (ge) ge.textContent = String(Math.floor(state.gold));
    const grid = document.getElementById('shopGrid'); if (!grid) return;
    grid.innerHTML = '';
    (state._shopStock || []).forEach((it, i) => {
      const rar = RELIC_RARITY[it.rarity] || RELIC_RARITY.common;
      const can = state.gold >= it.cost && !it.bought;
      let iconInner;
      if (it.abIcon) iconInner = iconHtml(it.abIcon, 26);
      else if (it.relicId) iconInner = getRelicImageHtml(it.relicId, 26);
      else iconInner = it.icon || '❓';
      const el = document.createElement('div');
      el.className = 'shop-item rar-' + it.rarity + (it.bought ? ' soldout' : (state.gold < it.cost ? ' cant' : ''));
      if (!it.bought) {
        const glowR = it.rarity === 'legendary' ? 18 : it.rarity === 'epic' ? 13 : it.rarity === 'rare' ? 9 : 5;
        el.style.borderColor = rar.color;
        el.style.boxShadow = `0 0 ${glowR}px ${rar.glow}, inset 0 1px 0 rgba(255,255,255,0.05)`;
        el.style.background = `linear-gradient(180deg, ${rar.color}22, #131825)`;
      }
      el.innerHTML = `<div class="si-top"><div class="si-icon">${iconInner}</div>
          <div style="min-width:0;">
            <div class="si-name" style="color:${it.bought ? '#7a8090' : rar.color}">${it.name}</div>
            <div class="si-rar" style="color:${rar.color}">${rar.label}</div>
          </div></div>
        <div class="si-desc">${it.desc}</div>
        <div class="si-price">${it.bought ? '✓ 구매함' : it.cost + ' G'}</div>`;
      if (can) el.onclick = () => _shopConfirm(i);
      grid.appendChild(el);
    });
  }
  function buyShopItem(i) {
    const it = (state._shopStock || [])[i];
    if (!it || it.bought || state.gold < it.cost) return;
    state.gold -= it.cost;
    _lastUpgraded = null;
    try { it.apply(); } catch (e) {}
    it.bought = true;
    if (SFX && SFX.click) SFX.click();
    for (let k = 0; k < 10; k++) spawnParticles(CX, CY, '#ffd479', 1);
    if (_lastUpgraded) _showShopUpgradeResult(_lastUpgraded);   // ⬆ 어떤 능력이 강화됐는지 결과 팝업
    else toast(`🛒 ${it.name} 구매!`);
    buildShopUI();
    renderPanel();
  }
  // ⬆ 능력 강화 결과 팝업 — 어떤 능력이 +몇 레벨 됐는지 아이콘과 함께
  function _showShopUpgradeResult(up) {
    const def = ABILITY_DEFS[up.id];
    const sc = document.getElementById('shopScene');
    if (!def || !sc) { toast(def ? `⬆ ${def.name} Lv${up.level}!` : '⬆ 강화 완료!'); return; }
    const old = document.getElementById('shopUpResult'); if (old) old.remove();
    const dlg = document.createElement('div'); dlg.id = 'shopUpResult'; dlg.className = 'shop-confirm';
    dlg.innerHTML = '<div class="sc-box">'
      + '<div class="sc-q">⬆ 강화 완료!</div>'
      + '<div class="sc-up-row">' + iconHtml(up.id, 48)
      + '<div class="sc-up-info"><div class="sc-up-name" style="color:' + (def.color || '#ffd479') + ';">' + def.name + '</div>'
      + '<div class="sc-up-lv">Lv ' + up.level + (up.delta > 0 ? ' <span style="color:#88ff9a;">(+' + up.delta + ')</span>' : '') + '</div></div></div>'
      + '<div class="sc-btns"><button class="npc-btn" id="shopUpOk">확인</button></div>'
      + '</div>';
    sc.appendChild(dlg);
    const close = () => { const d = document.getElementById('shopUpResult'); if (d) d.remove(); };
    dlg.onclick = (e) => { if (e.target === dlg) close(); };
    const ok = document.getElementById('shopUpOk'); if (ok) ok.onclick = close;
  }
  // 🛒 구매 확인 팝업 — 클릭 즉시 구매 방지 (오구매 방지)
  function _shopConfirm(i) {
    const it = (state._shopStock || [])[i];
    if (!it || it.bought || state.gold < it.cost) return;
    const sc = document.getElementById('shopScene');
    if (!sc) { buyShopItem(i); return; }
    const old = document.getElementById('shopConfirm'); if (old) old.remove();
    const rr = (typeof RELIC_RARITY !== 'undefined' && RELIC_RARITY[it.rarity]) || {};
    const dlg = document.createElement('div'); dlg.id = 'shopConfirm'; dlg.className = 'shop-confirm';
    dlg.innerHTML =
      '<div class="sc-box">'
      + '<div class="sc-q">「<b style="color:' + (rr.color || '#ffd479') + '">' + it.name + '</b>」 구매할까요?</div>'
      + '<div class="sc-cost">💰 ' + it.cost + ' G</div>'
      + '<div class="sc-btns"><button class="npc-btn sc-no" id="shopConfNo">취소</button><button class="npc-btn" id="shopConfYes">구매 ▶</button></div>'
      + '</div>';
    sc.appendChild(dlg);
    const close = () => { const d = document.getElementById('shopConfirm'); if (d) d.remove(); };
    dlg.onclick = (e) => { if (e.target === dlg) close(); };   // 바깥 탭 → 취소
    const noB = document.getElementById('shopConfNo'); if (noB) noB.onclick = () => { if (SFX && SFX.click) try { SFX.click(); } catch (e) {} close(); };
    const yesB = document.getElementById('shopConfYes'); if (yesB) yesB.onclick = () => { close(); buyShopItem(i); };
  }
  function openShop() {
    if (state.mode === 'defense' || !state.tower || state.gameOver) return;
    paused = true;
    const portrait = document.getElementById('shopNpcPortrait');
    if (portrait) {
      portrait.innerHTML = '';
      const img = document.createElement('img');
      img.alt = '';
      img.onerror = () => { const ex = portrait.querySelector('img'); if (ex) ex.remove(); if (!portrait.querySelector('.npc-fallback')) { const fb = document.createElement('div'); fb.className = 'npc-fallback'; fb.textContent = '🛒'; portrait.prepend(fb); } };
      img.src = './icons/npc/merchant.png';
      portrait.appendChild(img);
      const nm = document.createElement('div'); nm.className = 'npc-name'; nm.textContent = SHOP_NPC_NAME; portrait.appendChild(nm);
    }
    state._shopStock = buildShopStock();
    buildShopUI();
    const sc = document.getElementById('shopScene'); if (sc) sc.classList.add('show');
  }
  function closeShop() {
    const _cf = document.getElementById('shopConfirm'); if (_cf) _cf.remove();
    const sc = document.getElementById('shopScene'); if (sc) sc.classList.remove('show');
    paused = false;
    const pb = document.getElementById('pauseBtn'); if (pb) pb.textContent = '⏸ 일시정지';
  }
  // 🏮 상점 등장 연출 — 암전 → 등불이 켜지며 상인이 어둠 속에서 드러난 뒤 상점 패널 오픈
  let _shopCutinTimer = null;
  function openShopCutin() {
    if (state.mode === 'defense' || !state.tower || state.gameOver) return;
    const sc = document.getElementById('shopCutin');
    if (!sc) { openShop(); return; }   // 연출 불가 시 바로 상점
    paused = true;
    sc.classList.remove('out');
    sc.innerHTML =
      '<div class="sc-glow"></div>'
      + '<img class="sc-merchant" alt="" src="./icons/npc/merchant.png" onerror="this.style.display=\'none\'">'
      + '<div class="sc-lantern">🏮</div>'
      + '<div class="sc-name">' + SHOP_NPC_NAME + '</div>'
      + '<div class="sc-line">"쉿— 좋은 물건 있는데. 구경만 해도 괜찮아."</div>';
    sc.classList.add('show');
    if (_shopCutinTimer) clearTimeout(_shopCutinTimer);
    _shopCutinTimer = setTimeout(() => {
      sc.classList.add('out');
      _shopCutinTimer = setTimeout(() => {
        sc.classList.remove('show'); sc.classList.remove('out'); sc.innerHTML = '';
        openShop();
      }, 300);
    }, 1400);
  }

  // ===== 🎭 특수보스 처치 이벤트 — NPC 서사 + 선택 (저주는 낮은 확률로 강제) =====
  // 🃏 13 타로 NPC — 각 NPC = 카드 1장, NPC당 이벤트 3개. (curse는 카드 아님, 강제 디버프 전용)
  const EVENT_NPCS = {
    wheel: { name: '운명의 수레바퀴 · 카이', fb: '🎲', art: 'wheel', color: '#ffd479', events: [
      () => { const stake = Math.floor(state.gold * 0.4); return {
        title: '🎲 동전 던지기', text: '"앞면이면 두 배, 뒷면이면 절반. …쫄려?"',
        choices: [
          { label: `건다 (${stake}G)`, desc: `50%: +${stake}G · 50%: -${stake}G`, disabled: stake < 5,
            resolve() { if (Math.random() < 0.5) { state.gold += stake; return `✦ 앞면! +${stake}G!`; } state.gold -= stake; _evClampGold(); return `✧ 뒷면… -${stake}G.`; } },
          { label: '거절한다', desc: '그냥 지나간다', resolve() { return '카이가 휘파람을 분다.'; } },
        ] }; },
      () => ({ title: '🎰 운명의 룰렛', text: '"한 판은 서비스야. 뭐가 걸릴진 나도 몰라."',
        choices: [
          { label: '돌린다 (무료)', desc: '무작위 결과', resolve() {
              const r = Math.random();
              if (r < 0.35) { const g = _evUnit() * 4; state.gold += g; return `🪙 잭팟! +${g}G!`; }
              if (r < 0.60) { _evBuff('asc_damage'); return '⚔ 데미지 +5% 영구!'; }
              if (r < 0.80) { return '🎴 ' + _evGainAbility(1); }
              if (r < 0.95) { return '··· 꽝!'; }
              const p = _evDmg(-5); return `💀 불운! 데미지 ${p}%.`; } },
          { label: '사양한다', desc: '위험은 싫다', resolve() { return '룰렛이 멈춘다.'; } },
        ] }),
      () => { const g = state.gold; return {
