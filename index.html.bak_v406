  }
  function initBackground() {
    BG.stars.length = 0;
    BG.planets.length = 0;
    BG.nebulae.length = 0;
    BG.meteors.length = 0;
    // 별: 3개 레이어 패럴랙스
    for (let i = 0; i < 80; i++) BG.stars.push({       // 멀리 (옅고 작음)
      x: Math.random()*W, y: Math.random()*H, size: 1,
      brightness: 0.25 + Math.random()*0.3,
      tw: Math.random()*Math.PI*2, twSpeed: 0.01 + Math.random()*0.02,
      vx: -0.03 - Math.random()*0.02,
    });
    for (let i = 0; i < 40; i++) BG.stars.push({       // 중간
      x: Math.random()*W, y: Math.random()*H, size: Math.random() < 0.5 ? 1 : 2,
      brightness: 0.5 + Math.random()*0.3,
      tw: Math.random()*Math.PI*2, twSpeed: 0.02 + Math.random()*0.03,
      vx: -0.07 - Math.random()*0.04,
    });
    for (let i = 0; i < 15; i++) BG.stars.push({       // 가까이 (밝고 빠름)
      x: Math.random()*W, y: Math.random()*H, size: 2,
      brightness: 0.75 + Math.random()*0.25,
      tw: Math.random()*Math.PI*2, twSpeed: 0.03 + Math.random()*0.04,
      vx: -0.12 - Math.random()*0.06,
    });
    // 🌌 단계별 팔레트 적용 (asc 고정 → 1회 세팅)
    const _tier = bgTierIndex(state && state.ascension);
    const T = BG_TIERS[_tier];
    BG.tier = _tier; BG.starTint = T.star; BG.glowTint = T.glow;
    BG.meteorRate = T.meteorRate; BG.meteorCol = T.meteorCol;
    BG.accent = T.accent; BG.sky = T.sky;   // 아레나 링 액센트 + 하늘 요소(오로라/은하)
    // 행성 (위치/크기 고정, 색은 단계별)
    const _pp = [[95, 110, 52], [525, 95, 26], [545, 560, 36]];
    const _ringC = _tier === 2 ? '#c87080' : (_tier === 1 ? '#a888d8' : '#6a8aa8');
    for (let i = 0; i < 3; i++) { const pc = T.planets[i]; BG.planets.push({ x: _pp[i][0], y: _pp[i][1], r: _pp[i][2], c1: pc[0], c2: pc[1], ring: pc[2], ringC: _ringC }); }
    // 성운 (단계별 색)
    const _np = [[180, 480, 240], [480, 210, 200], [320, 320, 320]];
    for (let i = 0; i < 3; i++) BG.nebulae.push({ x: _np[i][0], y: _np[i][1], r: _np[i][2], c: T.nebula[i] });
    // 초월 — 멀리 떠 있는 거대 은하 실루엣 (어둡게)
    BG.core = _tier === 2 ? { x: W * 0.80, y: H * 0.17, r: 95 } : null;
    // 🌌 아레나 바닥 텍스처 베이크 (액센트 확정 후 1회)
    bakeArenaTexture();
    // 🚀 정적 하늘/행성 베이크 무효화 + 재생성 (티어/팔레트 확정 후)
    BG.skyTex = null; BG.planetTex = null;
