    justice: { name: '정의 · 테미스', fb: '⚖', art: 'justice', color: '#88aaff', events: [
      () => { const cost = _evUnit() * 2; return { title: '⚖ 공정한 교환', text: '"등가 교환이오. 값을 치르면, 그만한 힘을 주지."',
        choices: [
          { label: `교환한다 (${cost}G)`, desc: `보스 데미지 +${_evP(18)}% 영구`, disabled: state.gold < cost, resolve() { state.gold -= cost; const p = _evBoss(18); return `⚖ 보스 데미지 +${p}% 영구!`; } },
          { label: '사양한다', desc: '필요 없다', resolve() { return '저울을 거둔다.'; } },
        ] }; },
      () => ({ title: '⚖ 심판', text: '"여기까지 온 그대의 공적을 셈하겠소."',
        choices: [ { label: '평가받는다', desc: '도달 라운드 비례 골드', resolve() { const g = Math.min(_evUnit() * 6, Math.round((state.round || 1) * 8)); state.gold += g; return `⚖ 공적 보상! +${g}G!`; } } ] }),
      () => ({ title: '⚖ 정지의 심판', text: '"전부 멈춰라. 질서를 되돌릴 시간이다."',
