        choices: [
          { label: '⚔ 힘', desc: `데미지 +${_evP(18)}% 영구`, resolve() { const p = _evDmg(18); return `⚔ 데미지 +${p}% 영구!`; } },
          { label: '👹 사냥', desc: `보스 데미지 +${_evP(24)}% 영구`, resolve() { const p = _evBoss(24); return `👹 보스 데미지 +${p}% 영구!`; } },
          { label: '🔮 유물', desc: '유물 확정', resolve() { const nm = _evGiveRelic(); return nm ? `🔮 ${nm}!` : '유물이 동났다…'; } },
        ] }),
