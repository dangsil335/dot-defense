        ] }),
      () => ({ title: '🌹 풍년', text: '"올해는 풍년이야. 거둘 때마다 곳간이 차오르지."',
        choices: [ { label: '받는다', desc: `획득 골드 +${_evP(15)}% 영구`, resolve() { const p = _evGold(15); return `🌾 획득 골드 +${p}% 영구!`; } } ] }),
      () => ({ title: '🌹 황금빛 밀밭', text: '"씨를 뿌려두렴. 벨 때마다 황금이 열릴 거야."',
        choices: [ { label: '심는다', desc: '처치당 골드 +1 (영구 누적)', resolve() { _evBuff('asc_killGold'); return '🌾 처치당 +1 골드 (영구)!'; } } ] }),
