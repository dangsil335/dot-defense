    for (let k = 0; k < 8; k++) { const a = k * Math.PI / 4 + _t * 0.004; ctx.save(); ctx.rotate(a); ctx.beginPath(); ctx.moveTo(-s * 0.1, -s * 1.08); ctx.lineTo(s * 0.1, -s * 1.08); ctx.lineTo(0, -s * 1.4); ctx.closePath(); ctx.fill(); ctx.restore(); }
    // 눈알 (구체 음영)
    const bg = ctx.createRadialGradient(-s * 0.35, -s * 0.35, s * 0.1, 0, 0, s * 1.05);
    bg.addColorStop(0, lightenHex(fill, 0.35)); bg.addColorStop(0.55, fill); bg.addColorStop(1, dark);
    ctx.fillStyle = bg; ctx.beginPath(); ctx.arc(0, 0, s * 1.0, 0, Math.PI * 2); ctx.fill();
