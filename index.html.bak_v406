  };
  // 칭호 id → 엠블럼 키
  const TITLE_ICON_KEY = {
    beginner:'seedling', veteran:'sword', elite:'shield', legend:'star', conqueror:'crown',
    builder:'flask', triangler:'gem', hiddenMast:'sparkle', fullset:'cards', grinder:'chart',
    scorer:'bullseye', scoreKing:'bullseye', killer:'sword', slaughter:'skull', bossSlayer:'dragon',
    codex50:'book', codexMast:'book', allHeroes:'masks', speedrun:'bolt', oneTrick:'bullseye',
    asc1Title:'sparkle', asc5Title:'star', asc10Title:'starburst', asc15Title:'crown',
    trans1Title:'galaxy', trans3Title:'galaxy', trans5Title:'starburst', trans10Title:'crown', trans15Title:'starburst',
    starGazer:'star', marineMaster:'wave', solarMaster:'sun', gravitasMaster:'vortex',
    sakuraMaster:'blossom', lunaMaster:'moon', ariaMaster:'star', misakiMaster:'butterfly',
    // 🔱 트리플 컬렉션
    tcUltra:'barrage', tcFrost:'bolt', tcElem:'sparkle', tcFusion:'cannon', tcGalaxy:'galaxy', tcTitan:'missile',
    tcPlasma:'bolt', tcVoidNova:'starburst', tcSiege:'beam', tcDeepSea:'wave', tcStellar:'sun', tcVoidStop:'vortex',
    tripleSageTitle:'fusion',
  };
  // 고등급 = 플레이트 배너 (SR/SSR 캐릭 · 고난이도 · 시즌은 별도 처리)
  const PLATE_TITLES = new Set([
    'conqueror', 'asc10Title', 'asc15Title',
    'trans1Title', 'trans3Title', 'trans5Title', 'trans10Title', 'trans15Title',
    'sakuraMaster', 'lunaMaster', 'ariaMaster', 'misakiMaster',
    'tripleSageTitle',   // 그랜드 — 한 게임 트리플 5개
  ]);
  function titleEmblemHtml(key, emojiFallback) {
    const svg = TITLE_ICON_SVG[key];
    if (svg) return `<span class="title-emblem">${svg}</span>`;
    return emojiFallback || '';
  }
  function getOwnedTitles() {
    const have = getUnlockedAchievements();
    const owned = [];
    for (const tid in TITLES) {
      if (have.has(TITLES[tid].achId)) owned.push(tid);
    }
    // 🏁 시즌 칭호 — 서버에서 fetch한 본인 시즌 우승 목록
    for (const tid of _ownedSeasonTitles) owned.push(tid);
    return owned;
  }
  // 시즌 칭호 — 본인이 획득한 시즌 우승 ID 목록 (서버 동기화)
  let _ownedSeasonTitles = [];
  function getSelectedTitle() { return META.selectedTitle || null; }
  function setSelectedTitle(tid) {
    if (!tid) {
      META.selectedTitle = null;
      saveMeta();
      return;
    }
    // 미리보기 템플릿은 저장 거부 (실제 보유 X)
    if (String(tid).startsWith('season_preview_')) return;
    // 일반 칭호: TITLES에 있어야 함 / 시즌 칭호: parseSeasonTitle 통과해야 함
    const isStandard = !!TITLES[tid];
    const seasonInfo = parseSeasonTitle(tid);
    const isSeason = !!(seasonInfo && !seasonInfo.isPreview);
    if (!isStandard && !isSeason) return; // 알 수 없는 ID 거부
    if (!getOwnedTitles().includes(tid)) return; // 미보유 거부
    META.selectedTitle = tid;
    saveMeta();
  }
  // 🏁 시즌 칭호 파싱
  // ID 형식: 'season_N_R' (실제 보유) 또는 'season_preview_R' (미리보기 템플릿)
  function parseSeasonTitle(tid) {
    if (!tid) return null;
    // 실제 보유 칭호
    let m = String(tid).match(/^season_(\d+)_(\d+)$/);
    if (m) {
      const num = parseInt(m[1], 10);
      const rank = parseInt(m[2], 10);
      if (rank === 1) return { name: `시즌 ${num} 챔피언`, icon: '🥇', style: 'rainbow' };
      if (rank === 2) return { name: `시즌 ${num} 준우승`, icon: '🥈', style: 'glow', color: '#c8d4e6' };
      if (rank === 3) return { name: `시즌 ${num} 3위`, icon: '🥉', style: 'bold', color: '#cd8856' };
      return null;
    }
    // 미리보기 템플릿 (어떤 시즌 칭호가 있는지 보여주기용)
    m = String(tid).match(/^season_preview_(\d+)$/);
    if (m) {
      const rank = parseInt(m[1], 10);
      if (rank === 1) return { name: '시즌 N 챔피언', icon: '🥇', style: 'rainbow', isPreview: true };
      if (rank === 2) return { name: '시즌 N 준우승', icon: '🥈', style: 'glow', color: '#c8d4e6', isPreview: true };
      if (rank === 3) return { name: '시즌 N 3위', icon: '🥉', style: 'bold', color: '#cd8856', isPreview: true };
    }
    return null;
  }

  // HTML 렌더 — 칭호 + 닉네임 조합 출력
  function titleHTML(tid) {
    if (!tid) return '';
    // 시즌 칭호 — 동적 ID로 파싱 (항상 플레이트 배너 + 메달 엠블럼)
    const season = parseSeasonTitle(tid);
    if (season) {
      const styleVar = season.color ? `--c:${season.color};` : '';
      const emblem = titleEmblemHtml('medal', season.icon);
      const pr = season.style === 'rainbow' ? ' tp-rainbow' : '';
      return `<span class="title-plate tp-season${pr}" style="${styleVar}">${emblem}<span class="tp-text title-${season.style}">${season.name}</span></span>`;
    }
    // 일반 (하드코딩) 칭호
    if (!TITLES[tid]) return '';
    const t = TITLES[tid];
    const styleVar = t.color ? `--c:${t.color};` : '';
    const emblem = titleEmblemHtml(TITLE_ICON_KEY[tid], t.icon);
    // 고등급 = 플레이트 배너 / 그 외 = 엠블럼 + 텍스트
    if (PLATE_TITLES.has(tid)) {
      const pr = t.style === 'rainbow' ? ' tp-rainbow' : '';
      const variant = (tid === 'sakuraMaster' || tid === 'lunaMaster' || tid === 'ariaMaster' || tid === 'misakiMaster') ? 'tp-char'
                    : (tid === 'tripleSageTitle') ? 'tp-grand'
                    : /^trans\d/.test(tid) ? 'tp-trans'   // 🌌 초월 = 프리미엄 우주 플레이트
                    : 'tp-rank';                           // 완전정복/승천 = 각진 계급장
      return `<span class="title-plate ${variant}${pr}" style="${styleVar}">${emblem}<span class="tp-text title-${t.style}">${t.name}</span></span>`;
    }
    return `<span class="rank-title title-${t.style}" style="${styleVar}">[${emblem} ${t.name}]</span>`;
  }
  function renderRankNameWithTitle(nickname, tid) {
    return `${titleHTML(tid)} ${escapeHtml(nickname)}`;
  }

  function validateNickname(n) {
    if (!n || typeof n !== 'string') return '닉네임을 입력하세요';
    const trimmed = n.trim();
    if (trimmed.length < 1) return '닉네임을 입력하세요';
    if (trimmed.length > 12) return '12자 이하';
    // 한글/영문/숫자만 허용 (공백 X, 특수문자 X)
    if (!/^[가-힣a-zA-Z0-9_]+$/.test(trimmed)) return '한/영/숫자만 가능 (특수문자 X)';
    return null;
  }
  function setNickname(n) {
    const err = validateNickname(n);
    if (err) return err;
    META.nickname = n.trim();
    saveMeta();
    refreshMenuNickname();
    return null;
  }
  function refreshMenuNickname() {
    const el = document.getElementById('nickname-text');
    if (!el) return;
    const nick = getNickname();
    if (!nick) { el.textContent = '-'; return; }
    const tid = getSelectedTitle();
    el.innerHTML = `${titleHTML(tid)}<span style="color:#7ad7ff;">${escapeHtml(nick)}</span>`;
  }

  // ===== 🔐 계정 인증 시스템 =====
  // 같은 기기 = META.userId + META.accountPassword 저장 → 자동 로그인 유지
  // 다른 기기 = 로그인 모달에서 닉/비번 입력 → 데이터 다운로드

  function isAccountLoggedIn() {
    return !!(META.accountCreated && META.userId && META.accountPassword);
  }
  // 🛡 다중접속 차단 — 다른 기기 로그인 시 이 기기는 강퇴
  //   META.sessionId가 서버 토큰과 일치해야 sync 통과.
  //   불일치 시 이 함수 호출 → 로컬 데이터는 보존, 인증 정보만 제거
  let _sessionInvalidated = false;
  function handleSessionInvalidation() {
    if (_sessionInvalidated) return;
    _sessionInvalidated = true;
    // 인증 정보만 제거 (게임 데이터는 그대로 보존 — 사용자가 재로그인하면 동기화)
    META.accountPassword = null;
    META.sessionId = null;
    META.accountCreated = false;
    saveMeta();
    // 진행 중인 sync 큐 취소
    if (_syncTimer)    { clearTimeout(_syncTimer);    _syncTimer = null; }
    if (_syncMaxTimer) { clearTimeout(_syncMaxTimer); _syncMaxTimer = null; }
    // 사용자에게 알림 (toast → 모달)
    try { toast('⚠ 다른 기기에서 로그인됨 — 자동 로그아웃'); } catch {}
    setTimeout(() => {
      try {
        alert('⚠ 다른 기기에서 같은 계정으로 로그인했습니다.\n\n이 기기는 자동으로 로그아웃됩니다.\n(이 기기의 게임 데이터는 보존됩니다 — 다시 로그인하면 동기화됨)');
        // 인증 모달 열기 — 재로그인 유도
        if (typeof openAuthModal === 'function') openAuthModal({ tab: 'login', closable: false });
      } catch {}
    }, 100);
  }
  // 데이터 sync up (변경사항 서버에 저장) — debounced + max-delay 보장
  let _syncTimer = null;
  let _syncMaxTimer = null;  // 변경 후 최대 N초 안에는 무조건 동기화
  function queueServerSync(immediate = false) {
    if (!isAccountLoggedIn()) return;
    if (!isSupabaseEnabled()) return;
    if (_syncTimer) clearTimeout(_syncTimer);
    if (immediate) {
      // 즉시 동기화 — 강화소 구매 등 중요 변경
      if (_syncMaxTimer) { clearTimeout(_syncMaxTimer); _syncMaxTimer = null; }
      syncMetaToServer();
      return;
    }
    // 일반: 3초 디바운스 (이전 5초에서 단축)
    _syncTimer = setTimeout(() => {
      _syncTimer = null;
      if (_syncMaxTimer) { clearTimeout(_syncMaxTimer); _syncMaxTimer = null; }
      syncMetaToServer();
    }, 3000);
    // 첫 변경 후 최대 15초 안에는 반드시 동기화 (계속 변경되어도 적어도 15초마다 1회)
    if (!_syncMaxTimer) {
      _syncMaxTimer = setTimeout(() => {
        _syncMaxTimer = null;
        if (_syncTimer) { clearTimeout(_syncTimer); _syncTimer = null; }
        syncMetaToServer();
      }, 15000);
    }
  }
  // 페이지 닫힘/숨김 시 미동기화 변경사항 즉시 플러시
  function flushPendingSync() {
    if (!_syncTimer && !_syncMaxTimer) return;  // 대기 중인 sync 없음
    if (!isAccountLoggedIn() || !isSupabaseEnabled()) return;
    if (_syncTimer) { clearTimeout(_syncTimer); _syncTimer = null; }
    if (_syncMaxTimer) { clearTimeout(_syncMaxTimer); _syncMaxTimer = null; }
    // sendBeacon은 비동기 안전 — 페이지 unload 시에도 동작
    try {
      const sb = getSupabase();
      if (!sb) return;
      const dataToSync = { ...META };
      delete dataToSync.accountPassword;
      delete dataToSync.sessionId;
      // navigator.sendBeacon 사용을 위해 RPC 직접 호출 (fetch + keepalive)
      const url = `${SUPABASE_URL}/rest/v1/rpc/sync_account_data`;
      const body = JSON.stringify({
        p_user_id: META.userId,
        p_password: META.accountPassword,
        p_data: dataToSync,
        p_session_id: META.sessionId || null,    // 🛡 세션 토큰
      });
      fetch(url, {
        method: 'POST',
        headers: {
          'apikey': SUPABASE_ANON_KEY,
          'Authorization': `Bearer ${SUPABASE_ANON_KEY}`,
          'Content-Type': 'application/json',
        },
        body,
        keepalive: true,  // unload 중에도 요청 완료 보장
      }).catch(() => {});
    } catch (e) {}
  }
  // 페이지 unload + 가시성 변화 → 동기화 보장
  window.addEventListener('beforeunload', flushPendingSync);
  window.addEventListener('pagehide', flushPendingSync);
  document.addEventListener('visibilitychange', () => {
    if (document.hidden) flushPendingSync();
  });
  // 🛡 syncMetaToServer — 성공/실패 boolean 반환 (v206)
  //   v212: 성공 시각 추적 + 진단 로그 + 콘솔에서 _lastSyncSuccessAt 확인 가능
  let _lastSyncSuccessAt = 0;       // 마지막 성공 시각 (ms)
  let _lastSyncAttemptAt = 0;       // 마지막 시도 시각 (ms)
  let _lastSyncErrorMsg = '';       // 마지막 에러 메시지 (디버깅용)
  // 🛡 v216 — 매 호출마다 4-param 먼저 시도 (캐시된 false 상태 제거).
  //   v213의 _serverSupportsSession=false 가 한 번 설정되면 페이지 새로고침 전까지
  //   영원히 4-param 시도 안 하던 버그 수정. PostgREST 캐시가 늦게 갱신돼도
  //   다음 호출에서 자동 회복.
  async function syncMetaToServer() {
    _lastSyncAttemptAt = Date.now();
    if (!isAccountLoggedIn()) { _lastSyncErrorMsg = 'not-logged-in'; return false; }
    if (_sessionInvalidated) { _lastSyncErrorMsg = 'session-invalidated'; return false; }
    const sb = getSupabase();
    if (!sb) { _lastSyncErrorMsg = 'no-supabase'; return false; }
    const dataToSync = { ...META };
    delete dataToSync.accountPassword;
    delete dataToSync.sessionId;

    // ① 항상 4-param 먼저 시도 (캐시 없음 — 매번 시도)
    try {
      const { data, error } = await sb.rpc('sync_account_data', {
        p_user_id: META.userId,
        p_password: META.accountPassword,
        p_data: dataToSync,
        p_session_id: META.sessionId || null,
      });
      if (!error) {
        if (data === 'invalid_session') {
          _lastSyncErrorMsg = 'invalid_session';
          handleSessionInvalidation();
          return false;
        }
        if (data === 'auth_failed' || data === false) {
          _lastSyncErrorMsg = 'auth_failed';
          console.warn('[sync] 인증 실패');
          return false;
        }
        if (data === 'ok' || data === true) {
          _lastSyncSuccessAt = Date.now();
          _lastSyncErrorMsg = '';
          return true;
        }
        _lastSyncErrorMsg = `unknown-response: ${JSON.stringify(data)}`;
        return false;
      }
      // 에러 발생 — "함수 없음" 만 폴백, 다른 에러는 즉시 실패
      const msg = (error.message || '').toLowerCase();
      const isFunctionMissing = msg.includes('does not exist') || msg.includes('no function') || msg.includes('could not find');
      if (!isFunctionMissing) {
        _lastSyncErrorMsg = `rpc-error: ${error.message}`;
        console.warn('[sync] RPC 에러:', error.message);
        return false;
      }
      // 4-param 함수 없음 — 3-param 시도
      console.warn('[sync] 신버전 함수 없음 → 구버전 fallback (NOTIFY pgrst, reload schema 가 필요할 수 있음)');
    } catch (e) {
      _lastSyncErrorMsg = `exception: ${(e && e.message) || e}`;
      console.warn('[sync] 통신 예외:', e);
      return false;
    }

    // ② 3-param 폴백 — 4-param 함수가 정말 없을 때만 (서버 SQL 미적용 상태)
    try {
      const { data, error } = await sb.rpc('sync_account_data', {
        p_user_id: META.userId,
        p_password: META.accountPassword,
        p_data: dataToSync,
      });
      if (error) {
        _lastSyncErrorMsg = `rpc-error (3-param fallback도 실패): ${error.message}`;
        console.warn('[sync] 구버전 fallback도 실패. NOTIFY pgrst, reload schema; 실행 필요.');
        return false;
      }
      if (data === false) {
        _lastSyncErrorMsg = 'auth_failed';
        return false;
      }
      _lastSyncSuccessAt = Date.now();
      _lastSyncErrorMsg = '';
      return true;
    } catch (e) {
      _lastSyncErrorMsg = `exception (3-param fallback): ${(e && e.message) || e}`;
      console.warn('[sync] 구버전 fallback 예외:', e);
      return false;
    }
  }
  // 콘솔에서 동기화 상태 확인용 — F12 → window.__syncStatus()
  window.__syncStatus = () => ({
    lastSuccess: _lastSyncSuccessAt ? new Date(_lastSyncSuccessAt).toLocaleTimeString() : '없음',
    lastAttempt: _lastSyncAttemptAt ? new Date(_lastSyncAttemptAt).toLocaleTimeString() : '없음',
    lastError: _lastSyncErrorMsg || '없음',
    metaUpdatedAt: META.metaUpdatedAt ? new Date(META.metaUpdatedAt).toLocaleTimeString() : '없음',
    syncedAfterLastChange: _lastSyncSuccessAt >= (META.metaUpdatedAt || 0),
    isLoggedIn: isAccountLoggedIn(),
    hasNetwork: navigator.onLine,
    serverConfigured: isSupabaseEnabled(),
  });
  // 🔧 강제 sync — 콘솔에서 직접 호출 가능. 즉시 결과 보여줌.
  window.__forceSync = async () => {
    console.log('[__forceSync] 시작...');
    const ok = await syncMetaToServer();
    console.log('[__forceSync] 결과:', ok ? '✅ 성공' : '❌ 실패');
    console.log('[__forceSync] 상세:', window.__syncStatus());
    return ok;
  };
  // 🔍 서버 데이터 확인 — 진짜로 서버에 뭐가 저장돼 있는지 직접 fetch
  window.__checkServerData = async () => {
    if (!isAccountLoggedIn()) { console.warn('로그인 필요'); return; }
    const sb = getSupabase();
    if (!sb) { console.warn('Supabase 미설정'); return; }
    try {
      const { data, error } = await sb.rpc('login_account', {
        p_nickname: META.nickname,
        p_password: META.accountPassword,
      });
      if (error) { console.warn('서버 조회 실패:', error.message); return; }
      if (!data || data.length === 0) { console.warn('계정 없음 또는 비밀번호 불일치'); return; }
      const sd = data[0].data || {};
      console.log('🌐 서버 데이터:', {
        stardust: sd.stardust,
        stardustEarned: sd.stardustEarned,
        crystals: sd.crystals,
        maxAscension: sd.maxAscension,
        upgrades: Object.keys(sd.upgrades || {}).length + '개 강화',
        achievements: (sd.achievements || []).length + '개 업적',
        charStars: Object.keys(sd.charStars || {}).length + '개 캐릭터 별',
        gachaUnlocked: Object.keys(sd.gachaUnlocked || {}).length + '개 가챠 해금',
        records: (sd.records || []).length + '개 기록',
      });
      console.log('💾 로컬 데이터:', {
        stardust: META.stardust,
        stardustEarned: META.stardustEarned,
        crystals: META.crystals,
        maxAscension: META.maxAscension,
        upgrades: Object.keys(META.upgrades || {}).length + '개',
        achievements: (META.achievements || []).length + '개',
        charStars: Object.keys(META.charStars || {}).length + '개',
        gachaUnlocked: Object.keys(META.gachaUnlocked || {}).length + '개',
        records: (META.records || []).length + '개',
      });
      return { server: sd, local: META };
    } catch (e) {
      console.warn('서버 조회 예외:', e);
    }
  };

  // 🔄 앱 시작 시 서버에서 최신 데이터 가져오기 (로컬과 병합)
  // 다기기 동기화 지원 — 어제 다른 기기에서 한 강화가 오늘 반영됨
  // 🔄 다기기 동기화 — 마지막 pull 시점 + 안전 재-pull 헬퍼
  let _lastMetaPullAt = 0;
  const META_PULL_INTERVAL = 20 * 1000;   // 20s 쿨다운 (스팸 방지)
  let _metaPullInFlight = null;
  // 메뉴 진입 등에서 호출 — 쿨다운 내면 스킵, 아니면 push→pull 순차 실행
  async function refreshMetaFromServerIfStale(force = false) {
    if (!isAccountLoggedIn()) return false;
    if (!force && Date.now() - _lastMetaPullAt < META_PULL_INTERVAL) return false;
    if (_metaPullInFlight) return _metaPullInFlight;   // 진행 중이면 그것 대기
    _metaPullInFlight = (async () => {
      try {
        // 🐛 BUG FIX (v190): 기존엔 push → pull 이었으나,
        //   다기기 시나리오에서 PC의 오래된 META가 서버(휴대폰 최신본)를 덮어쓰는 문제 발생.
        //   pullMetaFromServer 내부에서 병합(Math.max) 후 자동으로 queueServerSync(true) 호출하므로
        //   pull 우선 → 병합 → 자동 push 순서로 변경하면 양쪽 진행도가 모두 보존됨.
        const ok = await pullMetaFromServer();
        _lastMetaPullAt = Date.now();
        if (ok) {
          // UI 갱신
          if (typeof refreshMenuNickname === 'function') refreshMenuNickname();
          if (typeof refreshMenuButtons === 'function') refreshMenuButtons();
          if (typeof refreshGachaCircleBtn === 'function') refreshGachaCircleBtn();
          if (typeof renderPanel === 'function') renderPanel();
        }
        return ok;
      } finally {
        _metaPullInFlight = null;
      }
    })();
    return _metaPullInFlight;
  }
  // 🔄 서버 데이터를 그대로 로드 (병합 X) — 수동 동기화 버튼 전용
  // "다른 기기에서 한 것 그대로 가져오기" 직관적 동작
  async function forceLoadFromServer() {
    if (!isAccountLoggedIn()) return false;
    if (!isSupabaseEnabled()) return false;
    const sb = getSupabase();
    if (!sb) return false;
    try {
      const { data, error } = await sb.rpc('login_account', {
        p_nickname: META.nickname,
        p_password: META.accountPassword,
      });
      if (error || !data || data.length === 0) return false;
      const server = data[0].data || {};
      // 인증 정보 + 비밀번호는 로컬 유지, 나머지는 서버를 그대로 신뢰
      const fresh = { ...server };
      fresh.userId          = data[0].user_id || META.userId;
      fresh.nickname        = data[0].nickname || META.nickname;
      fresh.accountCreated  = true;
      fresh.accountPassword = META.accountPassword;   // 비밀번호는 서버 저장 안 함
      fresh.sessionId       = data[0].session_id || null;    // 🛡 새 세션 토큰
      _sessionInvalidated = false;
      META = fresh;
      saveMeta();
      return true;
    } catch (e) {
      console.warn('서버 강제 로드 실패:', e);
      return false;
    }
  }

  async function pullMetaFromServer() {
    if (!isAccountLoggedIn()) return false;
    if (!isSupabaseEnabled()) return false;
    const sb = getSupabase();
    if (!sb) return false;
    try {
      const { data, error } = await sb.rpc('login_account', {
        p_nickname: META.nickname,
        p_password: META.accountPassword,
      });
      if (error || !data || data.length === 0) return false;
      const server = data[0].data || {};
      // 🤝 완전 병합 — 모든 META 필드를 명시적으로 처리하여 어떤 진행도도 손실되지 않게
      //   기준:
      //     • 시작점은 {...server, ...META} — 서버 신규 필드 보존 + 로컬 우선
      //     • progress (강화/별/누적): max 또는 union
      //     • spendable (스타더스트/결정): earned-spent 누적 차분
      //     • preferences (selected*): 최근 변경된 쪽 (metaUpdatedAt 비교)
      //     • boolean flags: OR (true 우선)
      const merged = { ...server, ...META };

      // ━━━ 1) 스타더스트 — earned/spent 누적 ━━━
      const localStarEarned = (META.stardustEarned !== undefined) ? META.stardustEarned : (META.stardust || 0);
      const localStarSpent  = META.stardustSpent || 0;
      const serverStarEarned = (server.stardustEarned !== undefined) ? server.stardustEarned : (server.stardust || 0);
      const serverStarSpent  = server.stardustSpent || 0;
      merged.stardustEarned = Math.max(localStarEarned, serverStarEarned);
      merged.stardustSpent  = Math.max(localStarSpent,  serverStarSpent);
      merged.stardust = Math.max(0, merged.stardustEarned - merged.stardustSpent);

      // ━━━ 2) 결정 — earned/spent 누적 ━━━
      const localCryEarned = (META.crystalsEarned !== undefined) ? META.crystalsEarned : (META.crystals || 0);
      const localCrySpent  = META.crystalsSpent || 0;
      const serverCryEarned = (server.crystalsEarned !== undefined) ? server.crystalsEarned : (server.crystals || 0);
      const serverCrySpent  = server.crystalsSpent || 0;
      merged.crystalsEarned = Math.max(localCryEarned, serverCryEarned);
      merged.crystalsSpent  = Math.max(localCrySpent,  serverCrySpent);
      merged.crystals = Math.max(0, merged.crystalsEarned - merged.crystalsSpent);

      // ━━━ 3) 진행도 객체들 — 키별 max ━━━
      const mergeMaxObject = (localObj, serverObj) => {
        const out = { ...(serverObj || {}) };
        const loc = localObj || {};
        for (const k of new Set([...Object.keys(out), ...Object.keys(loc)])) {
          out[k] = Math.max(out[k] || 0, loc[k] || 0);
        }
        return out;
      };
      merged.upgrades       = mergeMaxObject(META.upgrades,       server.upgrades);        // 강화소
      merged.abilityPerma   = mergeMaxObject(META.abilityPerma,   server.abilityPerma);    // 능력 영구
      merged.charStars      = mergeMaxObject(META.charStars,      server.charStars);       // 캐릭터 별
      merged.gachaUnlocked  = mergeMaxObject(META.gachaUnlocked,  server.gachaUnlocked);   // 가챠 누적
      // 🌌 v245 — 고대 유물 별 동기화 (중첩 객체 구조 { rid: { stars: N } })
      merged.ancientRelics = (() => {
        const out = { ...(server.ancientRelics || {}) };
        const loc = META.ancientRelics || {};
        for (const k of new Set([...Object.keys(out), ...Object.keys(loc)])) {
          const oS = (out[k] && out[k].stars) || 0;
          const lS = (loc[k] && loc[k].stars) || 0;
          out[k] = { stars: Math.max(oS, lS) };
        }
        return out;
      })();
      merged.charUsage      = mergeMaxObject(META.charUsage,      server.charUsage);       // 캐릭터 사용 기록 (구)
      merged.charactersUsed = mergeMaxObject(META.charactersUsed, server.charactersUsed);  // 캐릭터 사용 기록 (신)
      merged.repeatCounts   = mergeMaxObject(META.repeatCounts,   server.repeatCounts);    // 반복 업적 카운트

      // ━━━ 4) 단일 수치 — max ━━━
      merged.maxAscension = Math.max(META.maxAscension || 0, server.maxAscension || 0);

      // ━━━ 5) 객체/배열 합집합 ━━━
      merged.unlockedChars = { ...(server.unlockedChars || {}), ...(META.unlockedChars || {}) };
      const localAch  = Array.isArray(META.achievements)   ? META.achievements   : [];
      const serverAch = Array.isArray(server.achievements) ? server.achievements : [];
      merged.achievements = [...new Set([...serverAch, ...localAch])];
      const localTitles  = Array.isArray(META.seasonTitles)   ? META.seasonTitles   : [];
      const serverTitles = Array.isArray(server.seasonTitles) ? server.seasonTitles : [];
      merged.seasonTitles = [...new Set([...serverTitles, ...localTitles])];
      // 🏆 기록 병합 — 양쪽 합집합 (date+score+character로 중복 제거) → 점수 내림차순 → 상위 10개
      //   다기기에서 각자 기록한 게임을 모두 보존. 어느 쪽도 잃지 않음.
      const localRecs  = Array.isArray(META.records)   ? META.records   : [];
      const serverRecs = Array.isArray(server.records) ? server.records : [];
      const recKey = r => `${r.date}|${r.score}|${r.character || ''}|${r.ascension || 0}`;
      const recMap = new Map();
      for (const r of [...serverRecs, ...localRecs]) {
        if (r && typeof r.score === 'number') recMap.set(recKey(r), r);
      }
      const mergedRecs = [...recMap.values()].filter(r => (r.score || 0) <= SCORE_SANE_CAP);  // 🛡 비정상 기록 제거
      mergedRecs.sort((a, b) => b.score - a.score);
      merged.records = mergedRecs.slice(0, 10);

      // ━━━ 6) 사용자 선호 (preferences) — 더 최근에 변경된 쪽 채택 ━━━
      // 양쪽에 metaUpdatedAt 있으면 비교, 없으면 정의된 쪽 우선
      const localTs  = META.metaUpdatedAt  || 0;
      const serverTs = server.metaUpdatedAt || 0;
      const serverNewer = serverTs > localTs;
      const pickPref = (key) => {
        const lv = META[key];
        const sv = server[key];
        if (lv === undefined || lv === null) return sv;
        if (sv === undefined || sv === null) return lv;
        return serverNewer ? sv : lv;
      };
      merged.selectedTitle     = pickPref('selectedTitle');
      merged.selectedAscension = pickPref('selectedAscension');
      merged.selectedCharacter = pickPref('selectedCharacter');
      merged.lastSelectedMode  = pickPref('lastSelectedMode');
      merged.metaUpdatedAt = Math.max(localTs, serverTs);

      // ━━━ 7) Boolean flags — OR (true가 한 번이라도 있으면 true) ━━━
      merged.skippedSignupPrompt = !!(META.skippedSignupPrompt || server.skippedSignupPrompt);

      // ━━━ 8) 인증 정보 (서버 응답 신뢰, 비밀번호는 로컬 유지) ━━━
      merged.userId          = data[0].user_id || META.userId;
      merged.nickname        = data[0].nickname || META.nickname;
      merged.accountCreated  = true;
      merged.accountPassword = META.accountPassword;  // 비밀번호는 서버에 저장 X
      // 🛡 세션 토큰 — login_account 호출이 새 토큰 발급한 셈이므로 갱신
      //   이 기기가 활성 세션이 되고, 다른 기기는 다음 sync 때 강퇴됨
      merged.sessionId = data[0].session_id || META.sessionId || null;
      _sessionInvalidated = false;

      META = merged;
      saveMeta();
      // 병합한 결과를 서버에도 동기화 (서버가 로컬보다 뒤처져 있었을 수 있음)
      queueServerSync(true);
      return true;
    } catch (e) {
      console.warn('서버 데이터 pull 실패:', e);
      return false;
    }
  }

  async function signupAccount(nickname, password) {
    if (!isSupabaseEnabled()) throw new Error('서버 미설정');
    const sb = getSupabase();
    if (!sb) throw new Error('Supabase 연결 실패');
    // 현재 META를 그대로 업로드 (기존 진행 사항 보존)
    const userId = META.userId || crypto.randomUUID();
    const dataToUpload = { ...META, nickname, accountCreated: true };
    delete dataToUpload.accountPassword;
    const { data, error } = await sb.rpc('signup_account', {
      p_nickname: nickname,
      p_password: password,
      p_user_id: userId,
      p_data: dataToUpload,
    });
    if (error) {
      if (/nickname_taken/.test(error.message || '')) {
        throw new Error('이미 사용 중인 닉네임입니다');
      }
      throw new Error(error.message || '회원가입 실패');
    }
    // 로컬 저장 (자동 로그인용) — 세션 토큰은 다음 login에서 받음
    META = { ...dataToUpload, userId, accountPassword: password };
    saveMeta();
    // 🛡 회원가입 직후 login_account 호출 → 세션 토큰 발급
    //   이걸 안 하면 sessionId가 비어서 다중접속 차단이 첫 sync 후에야 적용됨.
    try {
      const { data: loginData } = await sb.rpc('login_account', {
        p_nickname: nickname,
        p_password: password,
      });
      if (loginData && loginData[0] && loginData[0].session_id) {
        META.sessionId = loginData[0].session_id;
        _sessionInvalidated = false;
        saveMeta();
      }
    } catch {}
    return userId;
  }

  async function loginAccount(nickname, password) {
    if (!isSupabaseEnabled()) throw new Error('서버 미설정');
    const sb = getSupabase();
    if (!sb) throw new Error('Supabase 연결 실패');
    const { data, error } = await sb.rpc('login_account', {
      p_nickname: nickname,
      p_password: password,
    });
    if (error) throw new Error(error.message || '로그인 실패');
    if (!data || data.length === 0) {
      throw new Error('닉네임 또는 비밀번호가 일치하지 않습니다');
    }
    const row = data[0];
    // 서버 데이터로 로컬 덮어쓰기 + 로그인 정보 저장
    const serverData = row.data || {};
    META = {
      ...serverData,
      userId: row.user_id,
      nickname: row.nickname,
      accountCreated: true,
      accountPassword: password,
      sessionId: row.session_id || null,    // 🛡 세션 토큰 저장 — 다중접속 차단용
    };
    _sessionInvalidated = false;    // 새 로그인 → 무효화 플래그 리셋
    saveMeta();
    return row;
  }

  async function logoutAccount() {
    if (!confirm('로그아웃하면 이 기기의 데이터는 초기화됩니다. (서버 데이터는 안전)\n\n계속하시겠어요?')) return;
    // 🛡 v212 — 효율적 로그아웃:
    //   1) 최근 (60초 이내) 성공 sync 가 있고 그 뒤로 META 변경 없음 → 즉시 로그아웃 (sync 스킵)
    //   2) 미푸시 변경 있음 → push 시도, 실패 시 자세한 에러 안내
    if (typeof _syncTimer !== 'undefined' && _syncTimer) { clearTimeout(_syncTimer); _syncTimer = null; }
    if (typeof _syncMaxTimer !== 'undefined' && _syncMaxTimer) { clearTimeout(_syncMaxTimer); _syncMaxTimer = null; }

    let syncOk = true;
    if (isAccountLoggedIn()) {
      // 🚀 빠른 경로 — 최근 sync 성공 시각이 META 변경 시각보다 더 최신이면 스킵
      const lastChange = META.metaUpdatedAt || 0;
      const needsSync = _lastSyncSuccessAt < lastChange;
      if (!needsSync && _lastSyncSuccessAt > 0) {
        console.log('[logout] 최근 sync 성공 + 변경 없음 → 즉시 로그아웃');
        syncOk = true;
      } else {
        // 변경사항 있음 → push 시도 (20초 타임아웃 — 큰 페이로드 대비)
        console.log('[logout] 미푸시 변경 감지 → 강제 sync 시작');
        try {
          syncOk = await Promise.race([
            syncMetaToServer(),
            new Promise(resolve => setTimeout(() => resolve('timeout'), 20000)),
          ]);
          if (syncOk === 'timeout') {
            _lastSyncErrorMsg = 'logout-timeout-20s';
            syncOk = false;
          }
        } catch (e) {
          console.warn('[logout] sync 예외:', e);
          syncOk = false;
        }
      }
    }

    if (!syncOk) {
      // 💥 sync 실패 — 구체적 사유 포함
      const errorReason = _lastSyncErrorMsg || '알 수 없는 오류';
      const forceLogout = confirm(
        '⚠ 서버 동기화 실패!\n\n' +
        `사유: ${errorReason}\n\n` +
        '이 기기의 진행도가 서버에 저장되지 않았습니다.\n' +
        '지금 로그아웃하면 마지막 동기화 이후의 진행도가 사라집니다.\n\n' +
        '[확인] = 어쨌든 로그아웃 (데이터 손실 감수)\n' +
        '[취소] = 로그아웃 취소 (인터넷 확인 후 다시 시도)\n\n' +
        '🔍 더 자세히 보려면: F12 → 콘솔에서 __syncStatus() 입력'
      );
      if (!forceLogout) return;
    }

    META = {};
    try {
      localStorage.removeItem(META_KEY);
      localStorage.removeItem(META_KEY_OLD);
    } catch {}
    location.reload();
  }

  // 인증 모달 컨트롤
  function openAuthModal(opts = {}) {
    const { tab = 'signup', closable = false } = opts;
    const modal = document.getElementById('authModal');
    openModalAnimated(modal);
    switchAuthTab(tab);
    const closeBtn = document.getElementById('authCloseBtn');
    closeBtn.style.display = closable ? '' : 'none';
    document.getElementById('signupError').textContent = '';
    document.getElementById('loginError').textContent = '';
  }
  function closeAuthModal() {
    closeModalAnimated(document.getElementById('authModal'));
  }
  function switchAuthTab(tab) {
    document.querySelectorAll('.auth-tab').forEach(t => t.classList.remove('active'));
    document.querySelector(`.auth-tab[data-tab="${tab}"]`).classList.add('active');
    document.getElementById('authSignupForm').style.display = tab === 'signup' ? '' : 'none';
    document.getElementById('authLoginForm').style.display = tab === 'login' ? '' : 'none';
  }

  document.querySelectorAll('.auth-tab').forEach(t => {
    t.onclick = () => switchAuthTab(t.dataset.tab);
  });
  document.getElementById('authCloseBtn').onclick = closeAuthModal;
  document.getElementById('authSkipBtn').onclick = () => {
    // 게스트 모드 — 로컬만, 서버 백업 X
    // 닉네임이 없으면 무조건 닉네임 모달 열어서 랭킹 등록 가능하게 함
    closeAuthModal();
    if (!getNickname()) {
      openNicknameModal(true); // 닫기 불가 — 반드시 입력
    } else {
      toast('게스트로 계속 진행 — 닉네임은 메뉴 하단에서 변경 가능');
    }
  };

  // 회원가입 제출
  document.getElementById('signupSubmitBtn').onclick = async () => {
    const btn = document.getElementById('signupSubmitBtn');
    const errEl = document.getElementById('signupError');
    const nick = document.getElementById('signupNicknameInput').value.trim();
    const pw = document.getElementById('signupPasswordInput').value;
    const pwc = document.getElementById('signupPasswordConfirm').value;
    errEl.textContent = '';
    // 검증
    const formatErr = validateNickname(nick);
    if (formatErr) { errEl.textContent = formatErr; return; }
    if (pw.length < 4) { errEl.textContent = '비밀번호는 4자 이상'; return; }
    if (pw !== pwc) { errEl.textContent = '비밀번호 확인이 일치하지 않습니다'; return; }
    btn.disabled = true;
    btn.textContent = '계정 생성 중...';
    try {
      await signupAccount(nick, pw);
      refreshMenuNickname();
      closeAuthModal();
      toast('✅ 계정 생성 완료!');
    } catch (e) {
      errEl.textContent = '⚠ ' + (e.message || '실패');
    } finally {
      btn.disabled = false;
      btn.textContent = '계정 만들기';
    }
  };
  // 로그인 제출
  document.getElementById('loginSubmitBtn').onclick = async () => {
    const btn = document.getElementById('loginSubmitBtn');
    const errEl = document.getElementById('loginError');
    const nick = document.getElementById('loginNicknameInput').value.trim();
    const pw = document.getElementById('loginPasswordInput').value;
    errEl.textContent = '';
    if (!nick || !pw) { errEl.textContent = '닉네임/비밀번호 입력'; return; }
    btn.disabled = true;
    btn.textContent = '불러오는 중...';
    try {
      await loginAccount(nick, pw);
      refreshMenuNickname();
      closeAuthModal();
      toast('✅ 로그인 완료! 데이터 동기화됨');
      // 페이지 새로고침 — META가 완전히 바뀌므로 UI 일관성 위해
      setTimeout(() => location.reload(), 800);
    } catch (e) {
      errEl.textContent = '⚠ ' + (e.message || '실패');
    } finally {
      btn.disabled = false;
      btn.textContent = '로그인 + 데이터 불러오기';
    }
  };

  // 첫 실행 / 자동 로그인 분기
  function checkFirstLaunch() {
    if (isAccountLoggedIn()) {
      // ✅ 로그인된 상태 — 그냥 진행 (자동 로그인 유지)
      refreshMenuNickname();
      return;
    }
    if (getNickname() && !META.accountCreated) {
      // 기존 게스트 플레이어 — 계정 가입 권장 prompt (닫기 가능)
      refreshMenuNickname();
      // 한 번만 권장 (sessionStorage로 관리하면 새로고침마다 또 뜨니까 META로 추적)
      if (!META.skippedSignupPrompt) {
        setTimeout(() => {
          openAuthModal({ tab: 'signup', closable: true });
          // 닫으면 다음 세션에선 또 뜸 — 의도된 약한 nag
        }, 500);
      }
      return;
    }
    // 진짜 첫 실행 — 인증 모달
    openAuthModal({ tab: 'signup', closable: false });
  }
  // 모달 내 임시 선택 (확인 누르기 전엔 META에 저장 X)
  let _modalPreviewTitle = null;

  function openNicknameModal(forceRequired) {
    const modal = document.getElementById('nicknameModal');
    openModalAnimated(modal);
    // 🔴 칭호 NEW 해제 (닉네임/칭호 화면 = 칭호 확인 경로)
    if (META.unseen && META.unseen.titles) {
      META.unseen.titles = 0; saveMeta();
      const _nd = document.getElementById('nickname-display');
      const _dot = _nd && _nd.querySelector('.menu-new-dot');
      if (_dot) _dot.remove();
    }
    const input = document.getElementById('nicknameInput');
    input.value = META.nickname || '';
    document.getElementById('nicknameError').textContent = '';
    modal._forceRequired = forceRequired;
    // 닫기 X — 첫 실행(필수 입력)엔 숨김
    const _xb = document.getElementById('nicknameCloseBtn');
    if (_xb) _xb.style.display = forceRequired ? 'none' : 'flex';
    // 미리보기 — 현재 저장된 칭호로 초기화
    _modalPreviewTitle = getSelectedTitle();
    buildTitlePicker();
    updateTitlePreview();
    updateUnlockHint();
    updateNicknameSubmitState();
    // 계정 상태별 버튼 동적 생성
    buildAccountActions();
    // input에 keydown listener는 한 번만
    if (!input._previewBound) {
      input.addEventListener('input', updateTitlePreview);
      input._previewBound = true;
    }
    setTimeout(() => input.focus(), 50);
  }
  function buildAccountActions() {
    const box = document.getElementById('nicknameAccountActions');
    if (!box) return;
    box.innerHTML = '';
    if (isAccountLoggedIn()) {
      // 로그인 상태
      const status = document.createElement('div');
      status.style.cssText = 'width:100%; font-size:11px; color:#88ff88; text-align:center; padding:4px 0;';
      status.innerHTML = `🔐 로그인됨: <b>${escapeHtml(META.nickname)}</b>`;
      box.appendChild(status);
      const logout = document.createElement('button');
      logout.style.cssText = 'flex:1; background:#2a1f1a; color:#ffaa88; border:1px solid #5a3020; padding:6px 10px; border-radius:5px; font-size:11px; cursor:pointer;';
      logout.textContent = '🚪 로그아웃 (이 기기 초기화)';
      logout.onclick = logoutAccount;
      box.appendChild(logout);
      const switchBtn = document.createElement('button');
      switchBtn.style.cssText = 'flex:1; background:#1a1f2a; color:#aaccff; border:1px solid #3a4256; padding:6px 10px; border-radius:5px; font-size:11px; cursor:pointer;';
      switchBtn.textContent = '🔄 다른 계정 불러오기';
      switchBtn.onclick = () => {
        closeNicknameModal();
        openAuthModal({ tab: 'login', closable: true });
      };
      box.appendChild(switchBtn);
    } else {
      // 게스트 — 백업 권장
      const warn = document.createElement('div');
      warn.style.cssText = 'width:100%; font-size:11px; color:#ffaa66; text-align:center; padding:4px 0; line-height:1.4;';
      warn.innerHTML = '⚠ 게스트 모드 — 기기 변경 시 데이터 손실';
      box.appendChild(warn);
      const signup = document.createElement('button');
      signup.style.cssText = 'width:100%; background:#1a2a40; color:#7ad7ff; border:1px solid #2a4878; padding:8px 10px; border-radius:5px; font-size:12px; font-weight:bold; cursor:pointer;';
      signup.textContent = '🔐 계정 만들어 백업하기';
      signup.onclick = () => {
        closeNicknameModal();
        openAuthModal({ tab: 'signup', closable: true });
      };
      box.appendChild(signup);
      const login = document.createElement('button');
      login.style.cssText = 'width:100%; background:none; color:#9aa3b3; border:1px solid #3a4256; padding:6px 10px; border-radius:5px; font-size:11px; cursor:pointer; margin-top:2px;';
      login.textContent = '↩️ 기존 계정 불러오기';
      login.onclick = () => {
        closeNicknameModal();
        openAuthModal({ tab: 'login', closable: true });
      };
      box.appendChild(login);
    }
  }
  // 칭호 그리드 빌드 — 미보유도 클릭 가능
  function buildTitlePicker() {
    const grid = document.getElementById('title-picker');
    grid.innerHTML = '';
    const owned = new Set(getOwnedTitles());

    // 🏁 시즌 우승 칭호 섹션 (헤더 + 보유 + 미리보기 템플릿)
    const seasonHeader = document.createElement('div');
    seasonHeader.style.cssText = 'grid-column:1/-1; font-size:11px; color:#ffd479; padding:4px 6px; margin-top:2px; border-bottom:1px solid #2a2f3a;';
    seasonHeader.textContent = '🏁 시즌 우승 칭호 (글로벌 랭킹 1~3위 시즌 종료 시 부여)';
    grid.appendChild(seasonHeader);

    // 보유한 시즌 칭호 (실제 보유, 선택 가능)
    for (const tid of _ownedSeasonTitles) {
      const isSel = tid === _modalPreviewTitle;
      const item = document.createElement('div');
      item.className = 'title-pick-item' + (isSel ? ' selected' : '');
      item.innerHTML = titleHTML(tid);
      item.onclick = () => { _modalPreviewTitle = tid; refreshTitlePicker(); };
      item.title = '🏁 시즌 우승 칭호';
      grid.appendChild(item);
    }
    // 미리보기 템플릿 (3개 등급 — 어떤 시즌 칭호가 있는지 보여주기)
    // 클릭하면 미리보기 가능, 확인 누르면 거부 (locked 상태)
    for (const rank of [1, 2, 3]) {
      const tid = `season_preview_${rank}`;
      const isSel = tid === _modalPreviewTitle;
      const item = document.createElement('div');
      item.className = 'title-pick-item locked' + (isSel ? ' selected' : '');
      item.innerHTML = titleHTML(tid);
      item.onclick = () => { _modalPreviewTitle = tid; refreshTitlePicker(); };
      const rankName = rank === 1 ? '1위' : rank === 2 ? '2위' : '3위';
      item.title = `🔒 글로벌 랭킹 ${rankName} 시즌 종료 시 부여`;
      grid.appendChild(item);
    }

    // 구분선
    const divider = document.createElement('div');
    divider.style.cssText = 'grid-column:1/-1; font-size:11px; color:#9aa3b3; padding:8px 6px 4px; border-bottom:1px solid #2a2f3a; margin-top:6px;';
    divider.textContent = '🏆 업적 칭호';
    grid.appendChild(divider);

    // 선택 안 함 옵션 — 업적 칭호 섹션 시작
    const none = document.createElement('div');
    none.className = 'title-pick-item' + (_modalPreviewTitle === null ? ' selected' : '');
    none.textContent = '없음';
    none.onclick = () => { _modalPreviewTitle = null; refreshTitlePicker(); };
    grid.appendChild(none);

    // 모든 칭호 (보유 = 정상 / 미보유 = 잠금 표시지만 클릭 가능)
    for (const tid in TITLES) {
      const t = TITLES[tid];
      const isOwned = owned.has(tid);
      const isSel = tid === _modalPreviewTitle;
      const item = document.createElement('div');
      item.className = 'title-pick-item' + (isSel ? ' selected' : '') + (!isOwned ? ' locked' : '');
      item.innerHTML = titleHTML(tid);
      // 미보유도 클릭 → 미리보기 + 안내 표시
      item.onclick = () => { _modalPreviewTitle = tid; refreshTitlePicker(); };
      item.title = isOwned ? `업적: ${t.achId}` : `🔒 미보유 — 클릭으로 미리보기`;
      grid.appendChild(item);
    }
  }
  function refreshTitlePicker() {
    buildTitlePicker();
    updateTitlePreview();
    updateUnlockHint();
    updateNicknameSubmitState();
  }
  function updateTitlePreview() {
    const preview = document.getElementById('title-preview');
    const nick = document.getElementById('nicknameInput').value.trim() || '닉네임';
    const tid = _modalPreviewTitle;
    preview.innerHTML = `${titleHTML(tid)} <span style="color:#fff;font-weight:bold;">${escapeHtml(nick)}</span>`;
  }
  // 미보유 칭호 선택 시 해금 방법 안내
  function updateUnlockHint() {
    const hint = document.getElementById('title-unlock-hint');
    if (!hint) return;
    const tid = _modalPreviewTitle;
    if (!tid) { hint.style.display = 'none'; return; }
    const owned = new Set(getOwnedTitles());
    if (owned.has(tid)) { hint.style.display = 'none'; return; }
    // 시즌 칭호 미보유 / 미리보기 템플릿
    const season = parseSeasonTitle(tid);
    if (season) {
      if (season.isPreview) {
        // 템플릿 — 등급별 안내
        const rank = tid.match(/^season_preview_(\d+)$/)[1];
        const rankName = rank === '1' ? '🥇 1위' : rank === '2' ? '🥈 2위' : '🥉 3위';
        hint.innerHTML = `🏁 <b>예시 미리보기</b> — 글로벌 랭킹 ${rankName} 로 시즌 종료 시 부여됩니다.<br/>실제 칭호엔 시즌 번호가 들어가요 (예: "시즌 3 챔피언").`;
      } else {
        hint.innerHTML = `🏁 <b>해금 조건:</b> 시즌 종료 시 글로벌 랭킹 1~3위 안에 들기`;
      }
      hint.style.display = '';
      return;
    }
    // 일반 미보유 — 업적 정보
    const t = TITLES[tid];
    if (!t) { hint.style.display = 'none'; return; }
    const ach = ACHIEVEMENTS.find(a => a.id === t.achId);
    if (ach) {
      hint.innerHTML = `🔒 <b>해금 조건:</b> [${escapeHtml(ach.name)}] ${escapeHtml(ach.desc)}`;
    } else {
      hint.innerHTML = `🔒 해금 조건: 업적 [${escapeHtml(t.achId)}] 달성`;
    }
    hint.style.display = '';
  }
  // 확인 버튼 활성/비활성 — 미보유 칭호 선택 시 비활성
  function updateNicknameSubmitState() {
    const submit = document.getElementById('nicknameSubmit');
    if (!submit) return;
    const tid = _modalPreviewTitle;
    const owned = new Set(getOwnedTitles());
    const isLocked = !!(tid && !owned.has(tid));
    submit.disabled = isLocked;
    submit.style.opacity = isLocked ? '0.45' : '1';
    submit.style.cursor = isLocked ? 'not-allowed' : 'pointer';
    submit.textContent = isLocked ? '🔒 미보유 칭호 — 선택 불가' : '확인';
  }
  function closeNicknameModal() {
    const modal = document.getElementById('nicknameModal');
    if (modal._forceRequired) return; // 첫 실행 시 닫기 금지
    closeModalAnimated(modal);
  }
  async function submitNickname() {
    const input = document.getElementById('nicknameInput');
    const errEl = document.getElementById('nicknameError');
    const submitBtn = document.getElementById('nicknameSubmit');
    const newNick = input.value.trim();

    // 1. 형식 검증 (1~12자, 한/영/숫자)
    const formatErr = validateNickname(newNick);
    if (formatErr) {
      errEl.textContent = formatErr;
      return;
    }

    // 2. 미보유 칭호 거부
    const owned = new Set(getOwnedTitles());
    if (_modalPreviewTitle && String(_modalPreviewTitle).startsWith('season_preview_')) {
      errEl.textContent = '🏁 미리보기 — 시즌 우승 후 실제 칭호로 부여됩니다';
      return;
    }
    if (_modalPreviewTitle && !owned.has(_modalPreviewTitle)) {
      errEl.textContent = '🔒 미보유 칭호는 선택할 수 없습니다';
      return;
    }

    // 3. 서버 닉네임 중복 체크 (본인 닉네임 그대로면 스킵)
    if (newNick !== getNickname()) {
      submitBtn.disabled = true;
      submitBtn.style.opacity = '0.6';
      submitBtn.textContent = '확인 중...';
      errEl.textContent = '';
      let taken = false;
      try {
        taken = await isNicknameTaken(newNick);
      } catch (e) { /* 안전 통과 */ }
      submitBtn.disabled = false;
      submitBtn.style.opacity = '1';
      if (taken) {
        errEl.textContent = `⚠ "${newNick}" 는 이미 사용 중인 닉네임입니다`;
        updateNicknameSubmitState(); // 버튼 라벨 복구
        return;
      }
    }

    // 4. 저장 — ⚠ 순서 중요: 칭호 먼저 저장 → 그 다음 메뉴 새로고침 (안 그러면 1회 lag)
    META.nickname = newNick;
    setSelectedTitle(_modalPreviewTitle);  // META.selectedTitle 갱신 + 저장
    refreshMenuNickname();                  // 이제 새 칭호 반영된 상태로 메뉴 갱신
    ensureUserId();
    const modal = document.getElementById('nicknameModal');
    modal._forceRequired = false;
    closeModalAnimated(modal);
    // 🌐 서버 측 프로필 즉시 갱신 (기존 랭킹 기록 있을 경우)
    updateProfileInRankings();
  }

  // ===== 점수 제출 (게임 종료 시) — title 컬럼 미생성 대응 =====
  let _lastSubmitError = null;
  let _submitPromise = null;       // 진행 중인 제출 Promise (조회 시 await 용도)
  function submitGlobalScore(override) {
    // override 있으면 그 기록(점수/라운드/난이도/캐릭/모드)을 제출, 없으면 현재 게임 state
    _submitPromise = _submitGlobalScoreImpl(override);
    return _submitPromise;
  }
  async function _submitGlobalScoreImpl(override) {
    _lastSubmitError = null;
    if (!isSupabaseEnabled()) { _lastSubmitError = 'Supabase 미설정'; console.warn('[점수제출] Supabase 미설정'); return; }
    const sb = getSupabase();
    if (!sb) { _lastSubmitError = 'Supabase 클라이언트 생성 실패'; console.warn('[점수제출] 클라이언트 생성 실패'); return; }
    const nickname = getNickname();
    if (!nickname) { _lastSubmitError = '닉네임 없음'; console.warn('[점수제출] 닉네임 미설정'); return; }
    const userId = ensureUserId();
    // ⚠ 모든 값을 await 이전에 캡처 (state.score race 방어). override 있으면 그 기록 사용.
    const gameMode  = override ? (override.mode || 'standard')   : (state.mode || 'standard');
    const newScore  = override ? (override.score || 0)           : (state.score || 0);
    const gameRound = override ? (override.round || 1)           : (state.gameWin ? MAX_ROUND : Math.max(1, state.round || 1));
    const gameAsc   = override ? (override.ascension || 0)       : (state.ascension || 0);
    const gameChar  = override ? (override.character || 'standard') : (state.character || 'standard');
    const titleVal = getSelectedTitle() || null;
    if (newScore <= 0) { _lastSubmitError = '점수 0'; console.warn('[점수제출] 점수가 0 — 제출 생략'); return; }
    console.log(`[점수제출] 시작: ${newScore}점 (mode=${gameMode}, round=${gameRound}, asc=${gameAsc})`);

    // 🛡 기존 점수 조회 — 실패해도 제출은 계속 (Supabase upsert 가 conflict 처리)
    //    조회 성공 + 기존 점수가 더 높으면 그때만 스킵
    let existing = null;
    let queryFailed = false;
    try {
      const tryQuery = await sb.from('rankings').select('score').eq('user_id', userId).eq('mode', gameMode).maybeSingle();
      if (tryQuery.error) {
        // mode 컬럼 없으면 user_id 만으로 재조회
        if (/mode/i.test(tryQuery.error.message || '')) {
          const fb = await sb.from('rankings').select('score').eq('user_id', userId).maybeSingle();
          if (!fb.error) existing = fb.data;
          else queryFailed = true;
        } else {
          console.warn('[점수제출] 조회 실패 — 제출은 그대로 진행:', tryQuery.error.message);
          queryFailed = true;
        }
      } else {
        existing = tryQuery.data;
      }
    } catch (e) {
      console.warn('[점수제출] 조회 예외 — 제출은 그대로 진행:', e);
      queryFailed = true;
    }
    // 조회 성공 + 기존 점수가 더 높으면 스킵 (조회 실패 시엔 강제 진행)
    if (!queryFailed && existing && existing.score >= newScore) {
      console.log(`[점수제출] 기존 점수 ${existing.score} ≥ 새 점수 ${newScore} — 스킵`);
      return;
    }

    // 🚀 업서트 — 4단계 폴백으로 어떻게든 저장 시도
    const baseRow = {
      user_id: userId,
      nickname: nickname,
      score: newScore,
      round: gameRound,
      ascension: gameAsc,
      character: gameChar,
      updated_at: new Date().toISOString(),
    };
    // 단계별 시도 함수 — 각 단계마다 어떤 컬럼/제약을 시도하는지 명확히
    const attempts = [
      // 1단계: mode + title 포함, (user_id, mode) 복합 PK
      () => sb.from('rankings').upsert({ ...baseRow, title: titleVal, mode: gameMode }, { onConflict: 'user_id,mode' }),
      // 2단계: mode 포함, (user_id, mode) 복합 PK, title 제외
      () => sb.from('rankings').upsert({ ...baseRow, mode: gameMode }, { onConflict: 'user_id,mode' }),
      // 3단계: title 포함, user_id PK (구버전)
      () => sb.from('rankings').upsert({ ...baseRow, title: titleVal }, { onConflict: 'user_id' }),
      // 4단계: 기본 필드만, user_id PK
      () => sb.from('rankings').upsert(baseRow, { onConflict: 'user_id' }),
    ];
    let res = null, lastError = null;
    for (let i = 0; i < attempts.length; i++) {
      try {
        res = await attempts[i]();
        if (!res.error) {
          console.log(`[점수제출] ✅ 성공 (시도 ${i+1}/${attempts.length}): ${newScore.toLocaleString()}점 (mode=${gameMode})`);
          invalidateRankingCache();
          _lastSubmitError = null;
          return;
        }
        lastError = res.error;
        console.warn(`[점수제출] 시도 ${i+1} 실패: ${res.error.message}`);
      } catch (e) {
        lastError = e;
        console.warn(`[점수제출] 시도 ${i+1} 예외:`, e);
      }
      // 약간의 backoff (네트워크 일시 오류 대비)
      if (i < attempts.length - 1) await new Promise(r => setTimeout(r, 200));
    }
    _lastSubmitError = (lastError && lastError.message) || '알 수 없는 오류';
    console.warn('[점수제출] ❌ 모든 시도 실패:', _lastSubmitError, lastError);
  }

  // 🔁 수동 재제출 — 마지막 게임 결과를 다시 서버에 시도
  //    state.gameOver 와 state.score 가 유효하면 submitGlobalScore() 재호출
  function manualResubmitScore() {
    // 🏁 이번 시즌(직전 리셋 이후) 기록 중 모드별 최고점을 서버에 재제출
    const seasonStart = getSeasonStartTime();
    const recs = (loadRecords() || []).filter(r =>
      r && typeof r.score === 'number' && r.score > 0 && r.score <= SCORE_SANE_CAP && (r.date || 0) >= seasonStart);
    if (recs.length === 0) {
      toast('⚠ 이번 시즌 기록이 없습니다');
      return null;
    }
    // 모드별 최고 기록 선별
    const bestByMode = {};
    for (const r of recs) {
      const m = r.mode || 'standard';
      if (!bestByMode[m] || r.score > bestByMode[m].score) bestByMode[m] = r;
    }
    const list = Object.values(bestByMode);
    toast(`🔁 이번 시즌 최고 기록 재제출 중... (${list.length}개 모드)`);
    const p = Promise.all(list.map(r => submitGlobalScore({
      score: r.score, round: r.round || 1, ascension: r.ascension || 0,
      character: r.character || 'standard', mode: r.mode || 'standard',
    })));
    p.then(() => {
      if (_lastSubmitError) toast(`❌ 재제출 실패: ${_lastSubmitError}`);
      else { toast('✅ 이번 시즌 최고 기록 재제출 완료'); invalidateRankingCache(); loadGlobalRankings(); }
    });
    return p;
  }

  // ===== 랭킹 조회 + 렌더 (A: 병렬 + D: 캐시) =====
  // 🏰 모드별 랭킹 — 캐시는 모드별 분리
  let _rankingCache = { standard: null, defense: null };
  let _selectedRankMode = 'standard';  // 현재 선택된 랭킹 모드 탭
  const RANKING_CACHE_TTL = 60000;
  function invalidateRankingCache() { _rankingCache = { standard: null, defense: null }; }

  async function fetchRankingsData(mode) {
    mode = mode || _selectedRankMode || 'standard';
    const sb = getSupabase();
    if (!sb) throw new Error('Supabase 연결 실패');
    const userId = ensureUserId();
    const fullCols = 'user_id, nickname, title, score, round, ascension, character, updated_at, mode';
    const safeColsNoMode = 'user_id, nickname, title, score, round, ascension, character, updated_at';
    const safeCols = 'user_id, nickname, score, round, ascension, character, updated_at';

    // 1단계: top10 + 내 기록 병렬 조회 (모드 필터)
    let [top10Res, myRowRes] = await Promise.all([
      sb.from('rankings').select(fullCols).eq('mode', mode).order('score', { ascending: false }).limit(10),
      sb.from('rankings').select(fullCols).eq('user_id', userId).eq('mode', mode).maybeSingle(),
    ]);
    // mode 컬럼 없으면 fallback — 전체 조회 (standard로 간주)
    if ((top10Res.error && /mode/i.test(top10Res.error.message || '')) ||
        (myRowRes.error && /mode/i.test(myRowRes.error.message || ''))) {
      console.warn('⚠️ mode 컬럼 없음 — 전체 랭킹 조회로 fallback (Supabase SQL: alter table rankings add column mode text default \'standard\';)');
      if (mode !== 'standard') {
        // defense 모드인데 컬럼 없으면 빈 결과
        return { top10: [], myRow: null, myRank: null, userId, mode };
      }
      [top10Res, myRowRes] = await Promise.all([
        sb.from('rankings').select(safeColsNoMode).order('score', { ascending: false }).limit(10),
        sb.from('rankings').select(safeColsNoMode).eq('user_id', userId).maybeSingle(),
      ]);
    }
    // title 컬럼 미생성 fallback
    if ((top10Res.error && /title/i.test(top10Res.error.message || '')) ||
        (myRowRes.error && /title/i.test(myRowRes.error.message || ''))) {
      console.warn('⚠️ title 컬럼 없음 — fallback');
      [top10Res, myRowRes] = await Promise.all([
        sb.from('rankings').select(safeCols).order('score', { ascending: false }).limit(10),
        sb.from('rankings').select(safeCols).eq('user_id', userId).maybeSingle(),
      ]);
    }
    if (top10Res.error) throw top10Res.error;
    const top10 = top10Res.data || [];
    const myRow = myRowRes.data || null;

    // 2단계: 내 순위 카운트 — myRow 있을 때만 (의존성, 모드 필터)
    let myRank = null;
    if (myRow) {
      const rankQuery = await sb
        .from('rankings')
        .select('*', { count: 'exact', head: true })
        .eq('mode', mode)
        .gt('score', myRow.score);
      if (rankQuery.error && /mode/i.test(rankQuery.error.message || '')) {
        // fallback without mode
        const fb = await sb.from('rankings').select('*', { count: 'exact', head: true }).gt('score', myRow.score);
        myRank = (fb.count || 0) + 1;
      } else {
        myRank = (rankQuery.count || 0) + 1;
      }
    }
    return { top10, myRow, myRank, userId, mode };
  }

  // 순수 렌더
  function renderRankings(data, isStale) {
    const statusEl = document.getElementById('globalRank-status');
    const top10El = document.getElementById('globalRank-top10');
    const dividerEl = document.getElementById('globalRank-divider');
    const meEl = document.getElementById('globalRank-me');
    top10El.innerHTML = '';
    meEl.innerHTML = '';
    dividerEl.style.display = 'none';

    if (!data.top10 || data.top10.length === 0) {
      statusEl.style.display = '';
      if (_lastSubmitError) {
        statusEl.innerHTML = `
          <div style="color:#ff8888; font-weight:bold;">⚠ 점수 제출 실패</div>
          <div style="font-size:11px; margin-top:6px; color:#9aa3b3; line-height:1.5;">
            마지막 제출 에러:<br>
            <code style="color:#ffaa66; word-break:break-all;">${escapeHtml(_lastSubmitError)}</code>
          </div>`;
      } else {
        statusEl.textContent = '아직 기록이 없습니다. 첫 도전자가 되어보세요!';
      }
      return;
    }
    statusEl.style.display = 'none';
    // stale 표시 — 캐시된 데이터 보여주는 중인 경우 작은 배너
    if (isStale) {
      const stale = document.createElement('div');
      stale.id = 'stale-banner';
      stale.style.cssText = 'text-align:center; color:#7a8090; font-size:11px; padding:6px; background:rgba(122,215,255,0.05); border-bottom:1px solid #1a1f2b; margin-bottom:6px;';
      stale.textContent = '🔄 백그라운드에서 최신 기록 확인 중...';
      top10El.appendChild(stale);
    }
    for (let i = 0; i < data.top10.length; i++) {
      const r = data.top10[i];
      const isMe = data.myRow && r.user_id === data.userId;
      top10El.appendChild(renderRankRow(i + 1, r, isMe));
    }
    if (data.myRow && data.myRank > 10) {
      dividerEl.style.display = '';
      meEl.appendChild(renderRankRow(data.myRank, data.myRow, true));
    }
  }

  // ===== 닉네임 중복 체크 (case-insensitive, 자기 자신 제외) =====
  async function isNicknameTaken(nickname) {
    if (!isSupabaseEnabled()) return false;
    const sb = getSupabase();
    if (!sb) return false;
    const userId = ensureUserId();
    try {
      const { data, error } = await sb
        .from('rankings')
        .select('user_id')
        .ilike('nickname', nickname)   // case-insensitive (PostgreSQL)
        .neq('user_id', userId)         // 자기 자신 제외 (재선택 시 OK)
        .limit(1);
      if (error) {
        console.warn('닉네임 중복 체크 실패:', error.message);
        return false; // 안전 fallback — 통과시킴
      }
      return !!(data && data.length > 0);
    } catch (e) {
      console.warn('닉네임 중복 체크 통신 실패:', e);
      return false;
    }
  }

  // ===== 🏁 시즌 우승 기록 fetch — 본인이 가진 시즌 칭호 동기화 =====
  async function fetchMySeasonTitles() {
    if (!isSupabaseEnabled()) return;
    const sb = getSupabase();
    if (!sb) return;
    const userId = ensureUserId();
    try {
      const { data, error } = await sb
        .from('season_winners')
        .select('season_num, rank')
        .eq('user_id', userId)
        .order('season_num', { ascending: false });
      if (error) {
        if (/relation .* does not exist/i.test(error.message || '')) {
          // 테이블 미생성 — 조용히 무시 (SQL 미실행 시)
          return;
        }
        console.warn('시즌 우승 조회 실패:', error.message);
        return;
      }
      _ownedSeasonTitles = (data || []).map(r => `season_${r.season_num}_${r.rank}`);
      console.log(`🏁 보유 시즌 칭호: ${_ownedSeasonTitles.length}개`);
    } catch (e) {
      console.warn('시즌 우승 통신 실패:', e);
    }
  }

  // ===== 프로필 갱신 (닉네임/칭호 변경 시) — 기존 rankings 행 업데이트 =====
  // 점수는 안 건드리고 nickname, title만 갱신. user_id 매칭 안 되면 (아직 게임 안 함) 그냥 무시.
  let _updateProfilePromise = null;
  function updateProfileInRankings() {
    _updateProfilePromise = _updateProfileImpl();
    return _updateProfilePromise;
  }
  async function _updateProfileImpl() {
    if (!isSupabaseEnabled()) return;
    const sb = getSupabase();
    if (!sb) return;
    const nickname = getNickname();
    if (!nickname) return;
    const userId = ensureUserId();
    try {
      // title 포함해서 업데이트 시도
      const fullPatch = {
        nickname: nickname,
        title: getSelectedTitle() || null,
        updated_at: new Date().toISOString(),
      };
      let res = await sb.from('rankings').update(fullPatch).eq('user_id', userId);
      // title 컬럼 없으면 빼고 재시도
      if (res.error && /title/i.test(res.error.message || '')) {
        console.warn('⚠️ title 컬럼 없음 — nickname만 갱신');
        const fallback = { nickname: nickname, updated_at: new Date().toISOString() };
        res = await sb.from('rankings').update(fallback).eq('user_id', userId);
      }
      if (res.error) {
        console.warn('프로필 갱신 실패:', res.error.message);
      } else {
        console.log(`✅ 프로필 갱신: ${nickname} / 칭호 ${getSelectedTitle() || '없음'}`);
        invalidateRankingCache(); // 다음 랭킹 조회 시 새 프로필 반영
      }
    } catch (e) {
      console.warn('프로필 갱신 통신 실패:', e);
    }
  }

  // ===== 🏁 시즌 리셋 카운트다운 =====
  // Supabase pg_cron 스케줄과 동기화 — 매주 월요일 00:00 KST (= 일요일 15:00 UTC)
  // pg_cron 스케줄 변경 시 이 함수도 같이 수정해야 함
  function getNextResetTime() {
    const now = new Date();
    const target = new Date(now);
    const dow = target.getUTCDay(); // 0=Sun, 1=Mon, ..., 6=Sat
    // 다음 일요일 15:00 UTC 까지 며칠?
    let daysToAdd = (7 - dow) % 7;
    if (daysToAdd === 0) {
      // 이미 일요일 — 시간 체크
      if (target.getUTCHours() >= 15) {
        daysToAdd = 7; // 다음 주
      }
    }
    target.setUTCDate(target.getUTCDate() + daysToAdd);
    target.setUTCHours(15, 0, 0, 0);
    return target;
  }
  // 🏁 이번 시즌 시작 시각(ms) = 직전 리셋 = 다음 리셋 - 7일. 이 이후 기록만 "이번 시즌".
  function getSeasonStartTime() { return getNextResetTime().getTime() - 7 * 86400000; }

  let _countdownInterval = null;
  function startRankCountdown() {
    stopRankCountdown();
    const update = () => {
      const el = document.getElementById('rank-countdown');
      if (!el) return;
      const now = new Date();
      const next = getNextResetTime();
      let diff = Math.max(0, next - now);
      const days = Math.floor(diff / 86400000);
      diff %= 86400000;
      const hours = Math.floor(diff / 3600000);
      diff %= 3600000;
      const minutes = Math.floor(diff / 60000);
      diff %= 60000;
      const seconds = Math.floor(diff / 1000);
      let txt;
      if (days > 0) txt = `다음 리셋: ${days}일 ${hours}시간 ${String(minutes).padStart(2,'0')}분`;
      else if (hours > 0) txt = `다음 리셋: ${hours}:${String(minutes).padStart(2,'0')}:${String(seconds).padStart(2,'0')}`;
      else txt = `⚠ 리셋까지 ${minutes}:${String(seconds).padStart(2,'0')} 남음!`;
      el.textContent = txt;
      // 1분 이하 남으면 빨간색 강조
      el.style.color = (days === 0 && hours === 0 && minutes < 1) ? '#ff8888' :
                       (days === 0 && hours < 1) ? '#ffaa66' : '#88ccff';
    };
    update();
    _countdownInterval = setInterval(update, 1000);
  }
  function stopRankCountdown() {
    if (_countdownInterval) {
      clearInterval(_countdownInterval);
      _countdownInterval = null;
    }
  }

  // 메인 진입점 — 캐시 + 병렬 fetch + 백그라운드 갱신
  async function loadGlobalRankings() {
    const statusEl = document.getElementById('globalRank-status');
    const top10El = document.getElementById('globalRank-top10');

    if (!isSupabaseEnabled()) {
      top10El.innerHTML = '';
      statusEl.style.display = '';
      statusEl.innerHTML = `
        <div style="color:#ffaa66;">⚠ 글로벌 랭킹 미설정</div>
        <div style="margin-top:8px; font-size:12px; color:#7a8090;">
          개발자가 Supabase 키를 설정해야 작동합니다.<br>
          (코드 내 SUPABASE_URL / SUPABASE_ANON_KEY)
        </div>`;
      return;
    }

    // 진행 중인 점수 제출 대기 — 끝나면 캐시 무효화
    if (_submitPromise) {
      top10El.innerHTML = '';
      statusEl.style.display = '';
      statusEl.innerHTML = `
        <div style="color:#7ad7ff;">⬆ 점수 제출 중...</div>
        <div style="margin-top:6px; font-size:11px; color:#7a8090;">방금 게임 결과를 서버에 전송하고 있어요</div>`;
      try { await _submitPromise; } catch (e) {}
      _submitPromise = null;
      invalidateRankingCache(); // 새 점수 제출됐으니 캐시 폐기
    }
    // 진행 중인 프로필 갱신 대기 (닉네임/칭호 변경 직후 진입한 경우)
    if (_updateProfilePromise) {
      try { await _updateProfilePromise; } catch (e) {}
      _updateProfilePromise = null;
    }

    // === 캐시 활용 (D: Stale-while-revalidate) — 모드별 분리 ===
    const mode = _selectedRankMode || 'standard';
    const cached = _rankingCache[mode];
    const isFresh = cached && (Date.now() - cached.timestamp < RANKING_CACHE_TTL);
    if (isFresh) {
      renderRankings(cached.data, true);
      fetchRankingsData(mode).then(data => {
        _rankingCache[mode] = { timestamp: Date.now(), data };
        renderRankings(data, false);
      }).catch(e => {
        console.warn('백그라운드 갱신 실패:', e);
        const banner = document.getElementById('stale-banner');
        if (banner) banner.textContent = '⚠ 갱신 실패 — 캐시된 결과';
      });
      return;
    }

    // === 캐시 없음 — 첫 로드 ===
    top10El.innerHTML = '';
    statusEl.style.display = '';
    statusEl.textContent = '불러오는 중...';
    try {
      const data = await fetchRankingsData(mode);
      _rankingCache[mode] = { timestamp: Date.now(), data };
      renderRankings(data, false);
    } catch (e) {
      console.warn(e);
      statusEl.style.display = '';
      statusEl.innerHTML = `<div style="color:#ff8888;">⚠ 불러오기 실패</div><div style="font-size:11px; margin-top:6px; color:#7a8090;">${escapeHtml((e.message || e).toString().substring(0, 100))}</div>`;
    }
  }
  function renderRankRow(rankNum, r, isMe) {
    const row = document.createElement('div');
    row.className = `rank-row ${isMe ? 'me' : ''} rank-${rankNum <= 3 ? rankNum : 'n'}`;
    const ch = CHARACTERS[r.character];
    const charName = ch ? ch.name : (r.character || '?');
    // 🛡 v258 — ascensionLabel 사용 (초월 영역도 정상 표시)
    const ascText = r.ascension > 0 ? ascensionLabel(r.ascension) : '기본';
    // 📏 닉네임 길이 기반 폰트 자동 축소 (한국어/이모지 고려해 codePoint 단위 카운트)
    const nick = r.nickname || '';
    const nickLen = [...nick].length;
    let lenClass = '';
    if      (nickLen >= 16) lenClass = ' len-xl';
    else if (nickLen >= 12) lenClass = ' len-lg';
    else if (nickLen >=  8) lenClass = ' len-md';
    row.innerHTML = `
      <div class="rank-num">${rankNum <= 3 ? ['🥇','🥈','🥉'][rankNum-1] : `#${rankNum}`}</div>
      <div class="rank-info">
        <div class="rank-nick${lenClass}">${isMe ? '👤 ' : ''}${titleHTML(r.title)}<span>${escapeHtml(r.nickname)}</span></div>
        <div class="rank-meta">R${r.round} · ${ascText} · ${charName}</div>
      </div>
      <div class="rank-score">${(r.score || 0).toLocaleString()}</div>
    `;
    return row;
  }
  function escapeHtml(s) {
    if (!s) return '';
    return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
  }

  // ===== 승천(Ascension) 난이도 시스템 =====
  // 0 = 기본, 1~15 = 승천 1~15
  const MAX_ASCENSION = 15;
  const MAX_HELL = 15;
  const MAX_DIFFICULTY = MAX_ASCENSION + MAX_HELL;   // 30 — asc(0~15) + hell(1~15 = asc 16~30)
  function getMaxAscension() { return META.maxAscension || 0; }
  function isHellMode(asc) { return asc > MAX_ASCENSION; }
  function hellLevel(asc) { return Math.max(0, asc - MAX_ASCENSION); }
  function getSelectedAscension() {
    const a = META.selectedAscension || 0;
    return Math.max(0, Math.min(getMaxAscension(), a));
  }
  function setSelectedAscension(a) {
    META.selectedAscension = Math.max(0, Math.min(getMaxAscension(), a));
    saveMeta();
  }
  // 승천 / 초월 N 의 적용 효과
  // 승천 (0~15): 선형 + 2차 — 점진적 상승
  // 초월 (16~30 = trans 1~15): 승천 15 위에 두 번째 가파른 곡선 — 거의 불가능 수준
  function getAscensionMods(asc) {
    // === 1) 승천 영역 (0~15) — 기존 곡선 + v259 베테랑 보정 ===
    if (asc <= MAX_ASCENSION) {
      // 🛡 v259 — ANCIENT/어센던트/유물 스택 등 베테랑 파워 대응 (이전 v251 보정 강화)
      // 승천 10+ 에 추가 HP 보정 (10:+20%, 15:+120% / 보스 +15~90%)
      //   풀빌드 베테랑 데미지 ×20~30 에 맞춰 asc 15 가 "거의 풀강으로도 빠듯" 수준
      const veteranBoost  = asc >= 10 ? (1 + (asc - 9) * 0.20) : 1;
      const veteranBossB  = asc >= 10 ? (1 + (asc - 9) * 0.15) : 1;
      return {
        enemyHpMul:    (1 + 0.30 * asc + 0.025 * asc * asc) * veteranBoost,
        bossHpMul:     (1 + 0.40 * asc + 0.030 * asc * asc) * veteranBossB,
        maxAliveAdd:  -3 * asc,
        scoreReward:   1 + 0.12 * asc,
        stardustMul:   1 + 0.08 * asc,
        enemySpeedMul: 1 + 0.05 * asc,
        extraBossCount: asc >= 13 ? 3 : (asc >= 10 ? 2 : (asc >= 4 ? 1 : 0)),
        eliteEscorts:  asc >= 14 ? 6 : (asc >= 11 ? 4 : (asc >= 8 ? 2 : 0)),
        extraBossRounds: asc >= 10,
        bossDmgMul:    1 + Math.max(0, asc - 2) * 0.20,
        enemyCountAdd: 0,
        roundTimeMul:  1,
        enhanceMul:    1,
        startGoldMul:  1,
        startScoreMul: 1,
      };
    }
    // === 2) 초월 영역 (asc 16~30, h = 1~15) — SSR/완벽 빌드 필수 ===
    const h = asc - MAX_ASCENSION;   // 1~15
    const base = getAscensionMods(MAX_ASCENSION);   // 승천 15 베이스
    // 초월 가파른 추가 스케일링
    //   적 HP: 승천15 × (1.8 + h*0.55 + h²*0.07)
    //          → h1: ×2.42, h5: ×6.3, h10: ×14.3, h15: ×25.8 (승천15 위 multiplicative)
    const hpHellMul   = 1.8 + h * 0.55 + h * h * 0.07;
    const bossHellMul = 2.2 + h * 0.70 + h * h * 0.08;
    return {
      enemyHpMul:    base.enemyHpMul * hpHellMul,
      bossHpMul:     base.bossHpMul  * bossHellMul,
      maxAliveAdd:   base.maxAliveAdd - h * 2,             // 적 수용 한계 더 깎임
      // 보상도 미친 듯이 상승 (보너스가 아니면 시도할 가치 X)
      scoreReward:   base.scoreReward + h * 0.5,           // Hell15 = +780% 점수
      stardustMul:   base.stardustMul + h * 0.6,           // Hell15 = +1020% 스타더스트
      enemySpeedMul: base.enemySpeedMul * (1 + h * 0.04),  // 더 빠른 적
      extraBossCount: base.extraBossCount + Math.floor(h / 2),   // 보스 더 많이
      eliteEscorts:  base.eliteEscorts + h,                // 정예 호위 +1/h
      extraBossRounds: true,
      bossDmgMul:    base.bossDmgMul + h * 0.10,
      enemyCountAdd: h * 4,                                 // 한 라운드 적 +4/h
      roundTimeMul:  Math.max(0.5, 1 - h * 0.025),         // 시간 단축 (h15: -37.5%)
      enhanceMul:    1 + h * 0.08,                          // 강화 비용 ↑ (h15: +120%)
      startGoldMul:  Math.max(0.3, 1 - h * 0.04),          // 시작 골드 ↓
      startScoreMul: 1,
    };
  }
  // ===== 🎰 가챠 시스템 =====
  // 가챠 캐릭터 풀 (등급별)
  const GACHA_POOL = {
    R:   [],   // 🆕 R 등급 폐지 — 마린/솔라/그래비타스는 SR로 승격
    SR:  ['sakura', 'luna', 'marine', 'solar', 'gravitas'],
    SSR: ['aria', 'misaki'],
  };
  const GACHA_RATES = { SR: 0.05, SSR: 0.01 };   // (구) 단일 배너 호환용 — 나머지(0.94)는 스타더스트
  const GACHA_REFUND = { R: 150, SR: 400, SSR: 800 };  // 중복 시 스타더스트 환불
  // 🆕 스타더스트 뽑기 (구 R 슬롯, ~94%) — 대부분 소량, 낮은 확률로 대박
  const GACHA_STARDUST_SMALL = [20, 60];     // 일반 (랜덤 범위)
  const GACHA_STARDUST_BIG   = [300, 600];   // ✨ 대박 (랜덤 범위)
  const GACHA_STARDUST_JACKPOT = 0.05;       // 스타더스트 결과 중 대박 확률 (5%)
  const GACHA_COST = 1;       // 1뽑기 = 결정 1개
  const GACHA_COST_10 = 9;    // 10뽑기 = 결정 9개 (1개 할인)

  // 🎴 배너별 가챠 정의 — 픽업 캐릭터, 풀, 확률
  // 각 배너는 자기 SSR만 픽업 (다른 SSR 제외), SR/R 풀은 동일
  const GACHA_BANNERS = [
    {
      id: 'aria',
      name: '🌟 아리아 픽업',
      desc: '천공의 노래를 듣는 자',
      bannerImg: './icons/gacha-aria.png',
      pool: {
        SSR: ['aria'],                              // 픽업 단독
        SR:  ['sakura', 'luna', 'marine', 'solar', 'gravitas'],
        R:   [],
      },
      rates: { SR: 0.05, SSR: 0.01 },   // 나머지(0.94) = 스타더스트 (구 R 슬롯)     // SSR 픽업 1.0%
      featured: 'aria',                            // 픽업 캐릭터 ID
      ancientRelic: 'ariaHarp',                    // 🌌 v245 — 별도 뽑기 결과 (캐릭터 대신 출현)
      ancientRelicRate: 0.005,                     // 0.5% — 이 확률 적중 시 캐릭터 풀 진입 X, 유물만 등장
    },
    {
      id: 'misaki',
      name: '🦋 미사키 픽업',
      desc: '시간을 거니는 자',
      bannerImg: './icons/gacha-misaki.png',
      pool: {
        SSR: ['misaki'],
        SR:  ['sakura', 'luna', 'marine', 'solar', 'gravitas'],
        R:   [],
      },
      rates: { SR: 0.05, SSR: 0.01 },   // 나머지(0.94) = 스타더스트 (구 R 슬롯)
      featured: 'misaki',
      ancientRelic: 'misakiHourglass',             // 🌌 v245 — 별도 뽑기 결과 (캐릭터 대신 출현)
      ancientRelicRate: 0.005,                     // 0.5% — 이 확률 적중 시 캐릭터 풀 진입 X, 유물만 등장
    },
  ];
  // 현재 선택된 배너 인덱스 (META 에 저장)
  function getCurrentBannerIdx() {
    const id = META.selectedBanner || GACHA_BANNERS[0].id;
    const idx = GACHA_BANNERS.findIndex(b => b.id === id);
    return idx < 0 ? 0 : idx;
  }
  function getCurrentBanner() { return GACHA_BANNERS[getCurrentBannerIdx()]; }
  function setBannerIdx(idx) {
    const i = ((idx % GACHA_BANNERS.length) + GACHA_BANNERS.length) % GACHA_BANNERS.length;
    META.selectedBanner = GACHA_BANNERS[i].id;
    saveMeta();
  }
  // 🚀 모든 배너 이미지 사전 로드 — 전환 시 이전 이미지가 남아있지 않게
  const _gachaBannerImgCache = {};
  (function preloadGachaBanners() {
    for (const b of GACHA_BANNERS) {
      if (!b.bannerImg) continue;
      const img = new Image();
      img.src = b.bannerImg;
      _gachaBannerImgCache[b.id] = img;
    }
  })();

  function getCrystals() { return META.crystals || 0; }
  function spendCrystals(n) {
    if ((META.crystals || 0) < n) return false;
    META.crystals = (META.crystals || 0) - n;
    META.crystalsSpent = (META.crystalsSpent || 0) + n;   // 🛡 누적 소비 카운터
    saveMeta();
    // 🎯 v226 — 결정 감소 펄스 (가챠 화면에서)
    setTimeout(() => _pulseEl(document.getElementById('crystal-count'), true), 0);
    return true;
  }
  // 🎯 v226 — 숫자 변경 펄스 헬퍼 (애니메이션 재시작 위해 클래스 재설정)
  function _pulseEl(el, down) {
    if (!el) return;
    const cls = down ? '_num-pulse-down' : '_num-pulse';
    el.classList.remove(cls);
    void el.offsetWidth;   // force reflow → 애니메이션 재시작
    el.classList.add(cls);
    setTimeout(() => el && el.classList && el.classList.remove(cls), 600);
  }
  function addCrystals(n) {
    META.crystals = (META.crystals || 0) + n;
    // 🛡 crystalsEarned catch-up — sync 시 데이터 손실 방지
    META.crystalsEarned = Math.max(META.crystalsEarned || 0, (META.crystals - n) || 0) + n;
    saveMeta();
  }
  // 게임 종료 시 결정 보상 계산 (단일 게임 마일스톤 기반)
  function earnCrystals() {
    let crystals = 0;
    const reasons = [];
    if (state.score >= 500000) { crystals += 1; reasons.push('점수 50만점 +1 💎'); }
    if (state.score >= 1000000) { crystals += 1; reasons.push('점수 100만점 +1 💎'); }
    if (state.round >= 50) { crystals += 1; reasons.push('R50 도달 +1 💎'); }
    if (state.gameWin) { crystals += 2; reasons.push('R100 클리어 +2 💎'); }
    const tripleCount = state.tower.abilities.filter(a => ABILITY_DEFS[a.id] && ABILITY_DEFS[a.id].isTriple).length;
    if (tripleCount >= 3) { crystals += 1; reasons.push('트리플 3개 형성 +1 💎'); }
    if ((state.totalKills || 0) >= 2000) { crystals += 1; reasons.push('2000 처치 +1 💎'); }
    if (state.gameWin && (state.ascension || 0) > 0) {
      const ascBonus = Math.ceil((state.ascension || 0) / 3);
      crystals += ascBonus;
      reasons.push(`승천 ${state.ascension} 클리어 +${ascBonus} 💎`);
    }
    if (crystals > 0) addCrystals(crystals);
    state.crystalsEarned = crystals;
    state.crystalReasons = reasons;
  }
  // ⭐ 캐릭터 별 시스템 — 중복 시 +1★ (max 8★), 8★ 초과 시 스타더스트 환급
  const CHAR_MAX_STARS = 8;
  function getCharStars(charId) {
    return (META.charStars && META.charStars[charId]) || 0;
  }
  function isAt4Star(charId) { return getCharStars(charId) >= 4; }
  function isAt8Star(charId) { return getCharStars(charId) >= CHAR_MAX_STARS; }
  // 별 등급별 데미지 보너스 (해당 캐릭터의 startAbilities 에 적용)
  // ★1: +10%, ★2: +20%, ★3: +35%, ★4: +50%, ★5: +70%, ★6: +95%, ★7: +130%, ★8: +200%
  const CHAR_STAR_DMG_BONUS = [0, 0.10, 0.20, 0.35, 0.50, 0.70, 0.95, 1.30, 2.00];
  function getCharStarDmgBonus(charId) {
    return CHAR_STAR_DMG_BONUS[Math.min(getCharStars(charId), CHAR_MAX_STARS)] || 0;
  }
  // 능력 ID → 해당 캐릭터의 별 보너스 (해당 캐릭터의 고유 능력일 때만)
  function getCharStarBonusForAbility(abilityId) {
    const charId = findCharByAbility(abilityId);
    return charId ? getCharStarDmgBonus(charId) : 0;
  }
  // ⭐ 능력별 별 등급 퍼크 (★2, 3, 5, 6, 7 — 데미지 외 특별 효과)
  // 사용처: 각 능력의 tick에서 perks(ability_id).cooldownMul / extraCount / rangeMul 등 조회
  // 🚀 퍼크 객체 메모 — 키에 별 수를 포함해 별 상승 시 자동 무효화 (능력 tick에서 매 프레임 객체 할당 제거)
  const _charPerksCache = Object.create(null);
  function getCharStarPerks(abilityId) {
    const charId = findCharByAbility(abilityId);
    if (!charId) return null;
    const s = getCharStars(charId);
    if (s <= 0) return null;
    const _pk = abilityId + '|' + s;
    if (_charPerksCache[_pk]) return _charPerksCache[_pk];
    // 모든 가챠 캐릭터에 공통 — 능력별 보편 퍼크 (★2,3,5,6,7)
    return _charPerksCache[_pk] = {
      stars:        s,
      // ★2: 발사 쿨다운 -10% (발사 속도 ↑)
      cooldownMul:  s >= 2 ? 0.90 : 1,
      // ★3: 발사 개수 +1 (count 기반 능력)
      extraCount:   s >= 3 ? 1 : 0,
      // ★4: 사거리/범위 +15%
      rangeMul:     s >= 4 ? 1.15 : 1,
      // ★5: 효과 강도 +25% (슬로우 지속, 폭발 반경 등)
      effectMul:    s >= 5 ? 1.25 : 1,
      // ★6: 발사 개수 +2 (총 +3 with ★3)
      bonusCount:   s >= 6 ? 2 : 0,
      // ★7: 폭발/광역 반경 +25%
      aoeMul:       s >= 7 ? 1.25 : 1,
    };
  }
  // 헬퍼: 능력의 효과 모디파이어 모음 — 별 퍼크 적용 (없으면 1/0 반환)
  function permaCount(abilityId)    { const p = getCharStarPerks(abilityId); return p ? (p.extraCount + p.bonusCount) : 0; }
  function permaCdMul(abilityId)    { const p = getCharStarPerks(abilityId); return p ? p.cooldownMul : 1; }
  function permaRangeMul(abilityId) { const p = getCharStarPerks(abilityId); return p ? p.rangeMul : 1; }
  function permaEffMul(abilityId)   { const p = getCharStarPerks(abilityId); return p ? p.effectMul : 1; }
  function permaAoeMul(abilityId)   { const p = getCharStarPerks(abilityId); return p ? p.aoeMul : 1; }
  // 🌌 v245 — 고대 유물 가챠 처리 (캐릭터 별 시스템과 동일 패턴)
  // 새로 획득 시 ★1 해금, 중복 시 ★+1 (최대 ★8), 만렙 후 중복은 스타더스트 환산
  const ANCIENT_RELIC_REFUND = 50000; // 만렙 후 중복 시 스타더스트
  function pullAncientRelic(rid) {
    META.ancientRelics = META.ancientRelics || {};
    META.ancientRelics[rid] = META.ancientRelics[rid] || { stars: 0 };
    const oldStars = META.ancientRelics[rid].stars || 0;
    const isNew = oldStars === 0;
    let refund = 0;
    let starUp = false;
    if (isNew) {
      META.ancientRelics[rid].stars = 1;
    } else if (oldStars < ANCIENT_MAX_STARS) {
      META.ancientRelics[rid].stars = oldStars + 1;
      starUp = true;
    } else {
      // 만렙 후 중복 → 스타더스트 환산
      refund = ANCIENT_RELIC_REFUND;
      META.stardust = (META.stardust || 0) + refund;
      META.stardustEarned = Math.max(META.stardustEarned || 0, (META.stardust - refund) || 0) + refund;
    }
    saveMeta();
    return {
      rarity: 'ancient',
      isAncient: true,
      ancientId: rid,
      relicName: RELICS[rid].name,
      relicIcon: RELICS[rid].icon,
      isNew, starUp, refund,
      newStars: META.ancientRelics[rid].stars,
    };
  }
  // 한 번 뽑기 — 현재 선택된 배너의 풀/확률 사용
  function gachaPullOne() {
    const banner = getCurrentBanner();
    // 🌌 v245 — 고대 유물 별도 결과 (캐릭터와 동시 X)
    // 0.5% 적중 → 유물만 반환하고 종료 (캐릭터 풀 진입 X)
    // 빗나가면 → 캐릭터 풀로 진입 (R/SR/SSR 추첨)
    if (banner.ancientRelic && Math.random() < (banner.ancientRelicRate || 0)) {
      return pullAncientRelic(banner.ancientRelic);
    }
    const rates = banner.rates;
    const r = Math.random();
    let rarity;
    if (r < rates.SSR) rarity = 'SSR';
    else if (r < rates.SSR + rates.SR) rarity = 'SR';
    else {
      // 🆕 스타더스트 (구 R 슬롯, ~94%) — 대부분 소량, 낮은 확률로 대박
      const jackpot = Math.random() < GACHA_STARDUST_JACKPOT;
      const rng = jackpot ? GACHA_STARDUST_BIG : GACHA_STARDUST_SMALL;
      const amt = rng[0] + Math.floor(Math.random() * (rng[1] - rng[0] + 1));
      META.stardust = (META.stardust || 0) + amt;
      META.stardustEarned = (META.stardustEarned || 0) + amt;
      saveMeta();
      return { isStardust: true, stardust: amt, isJackpot: jackpot };
    }
    // 풀이 비어있으면 다른 등급으로 대체 (안전망)
    let pool = banner.pool[rarity];
    if (!pool || pool.length === 0) { rarity = 'SR'; pool = banner.pool.SR; }
    if (!pool || pool.length === 0) { rarity = 'SSR'; pool = banner.pool.SSR; }
    const charId = pool[Math.floor(Math.random() * pool.length)];
    META.gachaUnlocked = META.gachaUnlocked || {};
    META.charStars = META.charStars || {};
    const isNew = !META.gachaUnlocked[charId];
    META.gachaUnlocked[charId] = (META.gachaUnlocked[charId] || 0) + 1;
    let refund = 0;
    let starUp = false;
    let oldStars = getCharStars(charId);
    if (!isNew) {
      if (oldStars < CHAR_MAX_STARS) {
        // 별 +1
        META.charStars[charId] = oldStars + 1;
        starUp = true;
      } else {
        // 별 만렙 → 스타더스트 환급
        refund = GACHA_REFUND[rarity] || 0;
        META.stardust = (META.stardust || 0) + refund;
        // 🛡 stardustEarned catch-up
        META.stardustEarned = Math.max(META.stardustEarned || 0, (META.stardust - refund) || 0) + refund;
      }
    }
    saveMeta();
    return { rarity, charId, isNew, refund, starUp, newStars: getCharStars(charId) };
  }

  function ascensionLabel(asc) {
    if (asc === 0) return '기본';
    if (asc <= MAX_ASCENSION) return `승천 ${asc}`;
    return `🌌 초월 ${asc - MAX_ASCENSION}`;
  }
  function ascensionDescriptions() {
    const descs = ['기본 — 표준 난이도'];
    for (let a = 1; a <= MAX_DIFFICULTY; a++) {
      const m = getAscensionMods(a);
      const hp = Math.round((m.enemyHpMul - 1) * 100);
      const bossHp = Math.round((m.bossHpMul - 1) * 100);
      const maxAlive = 80 + m.maxAliveAdd;
      const score = Math.round((m.scoreReward - 1) * 100);
      const dust = Math.round((m.stardustMul - 1) * 100);
      const spd = Math.round((m.enemySpeedMul - 1) * 100);
      const isHell = a > MAX_ASCENSION;
      const h = a - MAX_ASCENSION;
      const labelPrefix = isHell ? `🌌 초월 ${h}` : `승천 ${a}`;
      // 단계별 특수 메커니즘 라벨
      const extras = [];
      if (a >= 1) extras.push(`적속도 +${spd}%`);
      if (a >= 3) extras.push(`보스DMG +${Math.round((m.bossDmgMul - 1) * 100)}%`);
      if (m.extraBossCount > 0) {
        const dragons = '🐲'.repeat(1 + m.extraBossCount);
        extras.push(`${dragons} 보스 ${1 + m.extraBossCount}마리`);
      }
      if (m.eliteEscorts > 0) extras.push(`⭐ 정예 ${m.eliteEscorts}`);
      if (m.extraBossRounds) extras.push(`☠️ R10/30/50/70/90 추가보스`);
      if (isHell) {
        if (m.enemyCountAdd > 0) extras.push(`👹 적 수 +${m.enemyCountAdd}`);
        if (m.roundTimeMul < 1) extras.push(`⏱ 시간 -${Math.round((1-m.roundTimeMul)*100)}%`);
        if (m.enhanceMul > 1)   extras.push(`💸 강화비 +${Math.round((m.enhanceMul-1)*100)}%`);
        if (m.startGoldMul < 1) extras.push(`💰 시작골드 -${Math.round((1-m.startGoldMul)*100)}%`);
      }
      const extraStr = extras.length > 0 ? ` · ${extras.join(' · ')}` : '';
      descs.push(`${labelPrefix}: HP +${hp}% / 보스HP +${bossHp}% / 한계 ${maxAlive}마리${extraStr} · 보상 +${score}%점 +${dust}%★`);
    }
    return descs;
  }
  function metaLv(id) { return (META.upgrades && META.upgrades[id]) || 0; }
  function metaDust() { return META.stardust || 0; }
  // 🌟 능력별 영구 강화 (스타더스트로 구매) — 모든 능력 (passive 포함)
  // META.abilityPerma[id] = lv (0~20), 각 lv 마다 데미지 +0.5%
  const ABILITY_PERMA_MAX = 20;
  const ABILITY_PERMA_DMG_PER_LV = 0.005;   // 0.5%
  function getAbilityPermaLv(id) {
    return (META.abilityPerma && META.abilityPerma[id]) || 0;
  }
  function getAbilityPermaBonus(id) {
    if (!id) return 0;
    return getAbilityPermaLv(id) * ABILITY_PERMA_DMG_PER_LV;
  }
  // 🌟 v235 — 능력 영구 강화 비용: 등급 + 조합 위계별 배수
  //   기본 공식: 80 + lv·50 + lv²·8 (이전 50 + lv·30 + lv²·5 보다 ~60% ↑)
  //   배수: 능력 등급/카테고리에 따라 1.0x ~ 5.0x
  function abilityPermaCostMul(id) {
    const def = ABILITY_DEFS[id];
    if (!def) return 1.0;
    // 별 해금 능력 (4★/8★ 캐릭터 능력 - 매우 희귀)
    if (def.isStarUnlock) return 3.0;
    // 가챠 고유 능력 (등급별 차등)
    if (def.isGachaUnique) {
      // 등급별 — 능력 자체에 rarity 없으므로 캐릭터에서 역추적 또는 색상 기반 추정
      // 단순화: 능력 ID 가 SR/SSR 캐릭터의 starting/조합/트리플인지 체크
      // SSR 능력 풀
      const ssrAbilities = new Set([
        'starSong', 'timeButterfly',                        // SSR start
        'cosmicChorus', 'timePrison',                       // SSR combo
        'celestialSymphony', 'eternalMoment',               // SSR triple
        'celestialEcho', 'sirensSong',                      // aria 4/8★
        'temporalLoop', 'paradoxFreeze',                    // misaki 4/8★
      ]);
      const srAbilities = new Set([
        'sakuraSlash', 'moonShot',                          // SR start
        'sakuraStorm', 'moonFrostArrow',                    // SR combo
        'sakuraInferno', 'moonBombardment',                 // SR triple
        'petalStorm', 'cherrySingularity',                  // sakura 4/8★
        'lunarRain', 'eclipsePiercer',                      // luna 4/8★
      ]);
      if (ssrAbilities.has(id)) {
        if (def.isTriple) return 5.0;
        if (def.isCombo) return 5.0;
        return 4.0;
      }
      if (srAbilities.has(id)) {
        if (def.isTriple) return 3.5;
        if (def.isCombo) return 3.5;
        return 2.5;
      }
      // R 가챠
      if (def.isTriple) return 2.0;
      if (def.isCombo) return 2.0;
      return 1.5;
    }
    // 기본 능력
    if (def.isTriple) return 2.0;
    if (def.isCombo) return 1.4;
    return 1.0;
  }
  function abilityPermaCost(id) {
    const lv = getAbilityPermaLv(id);
    if (lv >= ABILITY_PERMA_MAX) return Infinity;
    // 🌟 v236 — 세제곱 추가로 후반 레벨 가속 (lv 15+ 가 비용의 70%)
    //   lv0:50, lv5:525, lv10:2,850, lv15:8,400, lv19:16,143
    //   누적: 기본 ~91k, SSR 트리플 ×5 = ~456k
    const base = 50 + lv * 30 + lv * lv * 5 + lv * lv * lv * 2;
    const mul = abilityPermaCostMul(id);
    return Math.ceil(base * mul);
  }
  // 🌟 능력별 영구 강화 효과 라벨 (능력 성격에 맞는 설명)
  function getAbilityPermaEffectLabel(id) {
    const d = ABILITY_DEFS[id];
    if (!d) return 'DMG';
    // 유틸리티 패시브 — 능력별 고유 효과
    if (id === 'vampiric')    return '골드';
    if (id === 'fortune')     return '점수 확률';
    if (id === 'scholar')     return '강화 할인';
    if (id === 'haste')       return '쿨다운 감소';
    if (id === 'reaper')      return '즉사 임계 + 골드';
    // 그 외 모든 능력 (액티브/콤보/트리플/가챠/별해금 + 데미지 패시브) → DMG
    return 'DMG';
  }
  function buyAbilityPerma(id) {
    const lv = getAbilityPermaLv(id);
    if (lv >= ABILITY_PERMA_MAX) return false;
    const cost = abilityPermaCost(id);
    if ((META.stardust || 0) < cost) return false;
    META.stardust -= cost;
    META.stardustSpent = (META.stardustSpent || 0) + cost;   // 🛡 누적 소비 카운터
    META.abilityPerma = META.abilityPerma || {};
    META.abilityPerma[id] = lv + 1;
    saveMeta();
    if (typeof queueServerSync === 'function') queueServerSync(true);
    // 🎯 v226 — 스타더스트 감소 펄스
    setTimeout(() => _pulseEl(document.getElementById('perma-stardust-count'), true), 0);
    return true;
  }

  // 강화소 항목 정의 (확장: 11종, 더 높은 max 레벨)
  // 카테고리 정의 (UI 그룹화용)
  const SHOP_CATEGORIES = [
    { id: 'resource', label: '💰 자원',     color: '#ffd479' },
    { id: 'combat',   label: '⚔️ 전투력',    color: '#ff8a98' },
    { id: 'attacktype', label: '🎯 공격 유형 특화', color: '#ff9966' },
    { id: 'build',    label: '🎴 빌드 / 카드', color: '#b890ff' },
    { id: 'survival', label: '🛡️ 생존 / 슬롯',  color: '#7ad7ff' },
    { id: 'defense',  label: '🏰 디펜스 모드', color: '#ddc080' },
  ];
