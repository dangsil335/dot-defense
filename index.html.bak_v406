    { id: 'tc_deepSeaBarrage', name: '🌊 심해의 포술사',  desc: '심해폭격(트리플) 형성',     reward: 150, check: s => s.tower.abilities.some(a => a.id === 'deepSeaBarrage') },
    { id: 'tc_stellarCollapse',name: '☄️ 별을 부수는 자', desc: '항성붕괴(트리플) 형성',     reward: 150, check: s => s.tower.abilities.some(a => a.id === 'stellarCollapse') },
    { id: 'tc_voidStop',       name: '🌀 시공 봉인자',    desc: '공허정지(트리플) 형성',     reward: 150, check: s => s.tower.abilities.some(a => a.id === 'voidStop') },
    // 🌟 그랜드 — 한 게임에 트리플 5개 (조합 늘어도 안 깨지는 고정 임계값)
    { id: 'tripleSage',        name: '✨ 조합의 현자',    desc: '한 게임에 트리플 5개 형성', reward: 2500, check: s => s.tower.abilities.filter(a => ABILITY_DEFS[a.id].isTriple).length >= 5 },
  ];

  // ===== 반복 업적 — 게임 종료마다 조건 충족 시 매번 보상 =====
  const REPEAT_ACHIEVEMENTS = [
    { id: 'rGame',     name: '꾸준한 도전',     desc: '게임 종료 시 +5★ 누적',           reward: 5,   check: () => true },
    { id: 'rR10',      name: '베테랑 (반복)',   desc: 'R10 도달마다 +15★',              reward: 15,  check: s => s.round >= 10 },
    { id: 'rR25',      name: '엘리트 (반복)',   desc: 'R25 도달마다 +40★',              reward: 40,  check: s => s.round >= 25 },
    { id: 'rR50',      name: '레전드 (반복)',   desc: 'R50 도달마다 +100★',             reward: 100, check: s => s.round >= 50 },
    { id: 'rWin',      name: '승리 (반복)',     desc: 'R100 클리어마다 +300★',          reward: 300, check: s => !!s.gameWin },
    { id: 'rKills500', name: '학살 (반복)',     desc: '한 게임 500처치마다 +20★',        reward: 20,  check: s => (s.totalKills || 0) >= 500 },
    { id: 'rKills2k',  name: '대학살 (반복)',   desc: '한 게임 2000처치마다 +80★',       reward: 80,  check: s => (s.totalKills || 0) >= 2000 },
    { id: 'rTriple',   name: '히든 사냥 (반복)', desc: '게임에 트리플 조합 형성마다 +50★', reward: 50,  check: s => s.tower.abilities.some(a => ABILITY_DEFS[a.id].isTriple) },
    { id: 'rBoss5',    name: '보스 사냥 (반복)', desc: '보스 5마리 처치마다 +40★',        reward: 40,  check: s => (s.bossKills || 0) >= 5 },
    { id: 'rAscClear', name: '승천 도전 (반복)', desc: '승천 클리어마다 +(승천 단계 × 50)★', reward: 50,
      check: s => !!s.gameWin && (s.ascension || 0) > 0 && (s.ascension || 0) <= MAX_ASCENSION,
      // 보상은 ascension 단계에 따라 동적 계산 (checkAchievements에서 처리)
      dynamic: s => (s.ascension || 0) * 50 },
    { id: 'rTransClear', name: '🌌 초월 도전 (반복)', desc: '초월 클리어마다 +(초월 단계 × 200)★', reward: 200,
      check: s => !!s.gameWin && (s.ascension || 0) > MAX_ASCENSION,
      dynamic: s => ((s.ascension || 0) - MAX_ASCENSION) * 200 },
  ];
  function getUnlockedAchievements() {
    // 🛠 데이터 복구: 이전 버그로 achievements가 객체로 손상된 경우 배열로 복원
    if (META.achievements && !Array.isArray(META.achievements) && typeof META.achievements === 'object') {
      // 객체의 값들이 업적 ID 문자열 (예: {0: 'first', 1: 'round10'})
      const values = Object.values(META.achievements).filter(v => typeof v === 'string');
      // 객체의 키들도 업적 ID일 수 있음 (구버전 호환)
      const keys = Object.keys(META.achievements).filter(k => isNaN(Number(k)));
      META.achievements = [...new Set([...values, ...keys])];
      try { saveMeta(); } catch {}
    }
    return new Set(META.achievements || []);
  }
  function checkAchievements() {
    const have = getUnlockedAchievements();
    let earned = 0, newOnes = [];
    // 단발 업적 — 한 번만 획득
    for (const ach of ACHIEVEMENTS) {
      if (have.has(ach.id)) continue;
      if (ach.check(state)) {
        have.add(ach.id);
        earned += ach.reward;
        newOnes.push(ach);
      }
    }
    // 반복 업적 — 매 게임마다 조건 충족 시 보상
    let repeatEarned = 0;
    const repeatHits = [];
    META.repeatCounts = META.repeatCounts || {};
    for (const ach of REPEAT_ACHIEVEMENTS) {
      if (ach.check(state)) {
        META.repeatCounts[ach.id] = (META.repeatCounts[ach.id] || 0) + 1;
        // dynamic 보상이 있으면 그 값 사용 (예: 승천 단계 × 50)
        const reward = ach.dynamic ? ach.dynamic(state) : ach.reward;
        repeatEarned += reward;
        repeatHits.push(ach);
      }
    }
    if (newOnes.length > 0 || repeatEarned > 0) {
      META.achievements = [...have];
      const totalGain = earned + repeatEarned;
      META.stardust = (META.stardust || 0) + totalGain;
      // 🛡 stardustEarned catch-up
      META.stardustEarned = Math.max(META.stardustEarned || 0, (META.stardust - totalGain) || 0) + totalGain;
      saveMeta();
      state.achievementsEarned = newOnes;
      state.achievementStardust = earned;
      state.repeatStardust = repeatEarned;
      state.repeatHits = repeatHits;
    }
  }

  // ===== 🎁 게임 결과 — 획득 보상 집계 + 패널 (v322) =====
  //   업적이 푼 캐릭터/칭호/능력을 한 곳에 모아 결과 화면 패널로 명확히 표시.
  //   + 안 본 해금은 META.unseen 카운트로 누적 → 메뉴 NEW 뱃지.
  function computeRewardData() {
    const newAchs = state.achievementsEarned || [];
    const newAchIds = new Set(newAchs.map(a => a.id));
    const chars = [], abilities = [];
    for (const a of newAchs) {
      if (a.unlocks) {
        if (a.unlocks.char && CHARACTERS[a.unlocks.char]) chars.push(a.unlocks.char);
        if (a.unlocks.ability && ABILITY_DEFS[a.unlocks.ability]) abilities.push(a.unlocks.ability);
      }
    }
    const titles = [];
    for (const tid in TITLES) {
      if (newAchIds.has(TITLES[tid].achId)) titles.push(tid);
    }
    // 🟣 업적이 해금한 유물 (RELICS 역추적)
    const relics = [];
    for (const a of newAchs) {
      const needle = 'achievement:' + a.id;
      for (const rid in RELICS) { if (RELICS[rid].unlockBy === needle) relics.push(rid); }
    }
    const uniqChars = [...new Set(chars)];
    const uniqAbil = [...new Set(abilities)];
    const uniqRelics = [...new Set(relics)];
    state.rewardData = {
      achievements: newAchs,
      chars: uniqChars,
      abilities: uniqAbil,
      titles: titles,
      relics: uniqRelics,
      totalStardust: state.stardustEarned || 0,
      crystals: state.crystalsEarned || 0,
      ascension: state.newAscensionUnlocked || 0,
    };
    // 🔴 안 본 해금 누적 (메뉴 NEW 뱃지용) — 유물은 도감에서 보므로 능력(도감) 뱃지에 합산
    if (uniqChars.length || newAchs.length || uniqAbil.length || titles.length || uniqRelics.length) {
      META.unseen = META.unseen || { chars: 0, achs: 0, abilities: 0, titles: 0 };
      META.unseen.chars = (META.unseen.chars || 0) + uniqChars.length;
      META.unseen.achs = (META.unseen.achs || 0) + newAchs.length;
      META.unseen.abilities = (META.unseen.abilities || 0) + uniqAbil.length + uniqRelics.length;
      META.unseen.titles = (META.unseen.titles || 0) + titles.length;
      saveMeta();
    }
  }
  function rewardHasUnlocks() {
    const d = state.rewardData;
    return !!(d && (d.chars.length || d.titles.length || d.abilities.length || (d.relics && d.relics.length) || d.achievements.length));
  }
  function showRewardSummary() {
    const d = state.rewardData;
    if (!d || !rewardHasUnlocks()) return;
    const body = document.getElementById('rewardBody');
    const sub = document.getElementById('rewardSub');
    const overlay = document.getElementById('rewardSummary');
    if (!body || !overlay) return;
    let html = '';
    // 새 캐릭터
    for (const cid of d.chars) {
      const c = CHARACTERS[cid]; if (!c) continue;
      const src = getCharacterImageSrc(cid);
      const ico = src ? `<img src="${src}" alt="">` : `<span style="color:${c.color || '#ffd479'};font-weight:bold;">${escapeHtml((c.name || '?').charAt(0))}</span>`;
      html += `<div class="reward-row hot">
        <div class="reward-ico">${ico}</div>
        <div class="reward-txt">
          <div class="reward-kind" style="color:#ffd479">새 캐릭터 해금</div>
          <div class="reward-name" style="color:${c.color || '#e8eaf0'}">${escapeHtml(c.name)}</div>
          <div class="reward-desc">${escapeHtml(c.desc || '')}</div>
        </div><span class="reward-new">NEW</span></div>`;
    }
    // 새 칭호 — 실제 칭호 플레이트 렌더
    for (const tid of d.titles) {
      const t = TITLES[tid]; if (!t) continue;
      html += `<div class="reward-row hot">
        <div class="reward-ico">🏆</div>
        <div class="reward-txt">
          <div class="reward-kind" style="color:#c084ff">새 칭호 해금</div>
          <div class="reward-name">${titleHTML(tid)}</div>
        </div><span class="reward-new">NEW</span></div>`;
    }
    // 새 능력 — 능력 아이콘 PNG (도감과 동일)
    for (const aid of d.abilities) {
      const ab = ABILITY_DEFS[aid]; if (!ab) continue;
      html += `<div class="reward-row">
        <div class="reward-ico">${iconHtml(aid, 40)}</div>
        <div class="reward-txt">
          <div class="reward-kind">새 능력 해금</div>
          <div class="reward-name" style="color:${ab.color || '#e8eaf0'}">${escapeHtml(ab.name)}</div>
          <div class="reward-desc">랜덤 · 레벨업 능력 풀에 추가됨</div>
        </div><span class="reward-new">NEW</span></div>`;
    }
    // 새 유물 — 유물 아이콘 PNG
    for (const rid of (d.relics || [])) {
      const r = RELICS[rid]; if (!r) continue;
      const rar = RELIC_RARITY[r.rarity] || { color: '#c084ff' };
      html += `<div class="reward-row hot" style="border-color:${rar.color}55">
        <div class="reward-ico">${getRelicImageHtml(rid, 40)}</div>
        <div class="reward-txt">
          <div class="reward-kind" style="color:${rar.color}">새 유물 해금</div>
          <div class="reward-name" style="color:${rar.color}">${escapeHtml(r.name)}</div>
          <div class="reward-desc">유물 컬렉션에 추가됨</div>
        </div><span class="reward-new">NEW</span></div>`;
    }
    // 달성 업적
    for (const ach of d.achievements) {
      html += `<div class="reward-row">
        <div class="reward-ico">🏅</div>
        <div class="reward-txt">
          <div class="reward-kind" style="color:#52e07a">업적 달성</div>
          <div class="reward-name">${escapeHtml(ach.name)}</div>
          <div class="reward-desc">${escapeHtml(ach.desc || '')} · +${ach.reward || 0}★</div>
        </div></div>`;
    }
    // 통화 요약
    let cur = '';
    if (d.totalStardust) cur += `<span>★ +${d.totalStardust.toLocaleString()} 스타더스트</span>`;
    if (d.crystals) cur += `<span style="color:#88ccff">💎 +${d.crystals} 결정</span>`;
    if (d.ascension) cur += `<span style="color:#ff80ff">✨ 승천 ${d.ascension} 해금</span>`;
    if (cur) html += `<div class="reward-currency">${cur}</div>`;
    body.innerHTML = html;
    // 서브 요약
    const parts = [];
    if (d.chars.length) parts.push(`캐릭터 ${d.chars.length}`);
    if (d.titles.length) parts.push(`칭호 ${d.titles.length}`);
    if (d.abilities.length) parts.push(`능력 ${d.abilities.length}`);
    if (d.relics && d.relics.length) parts.push(`유물 ${d.relics.length}`);
    if (d.achievements.length) parts.push(`업적 ${d.achievements.length}`);
    if (sub) sub.textContent = parts.length ? ('이번 게임에서 새로 — ' + parts.join(' · ')) : '';
    overlay.classList.add('show');
  }
  function scheduleRewardSummary() {
    if (!rewardHasUnlocks()) return;
    setTimeout(() => {
      if (state.gameOver && currentScreen === 'game') showRewardSummary();
    }, 1500);
  }
  function hideRewardSummary() {
    const el = document.getElementById('rewardSummary');
    if (el) el.classList.remove('show');
  }

  // 업적으로 해금된 능력 ID 집합 (랜덤 풀 + 레벨업 풀에 포함될지 결정)
  function getUnlockedAbilityIds() {
    const set = new Set();
    // 기본적으로 해금된 능력 (특수 능력 외)
    const lockedByAchievement = new Set();
    for (const ach of ACHIEVEMENTS) {
      if (ach.unlocks && ach.unlocks.ability) {
        lockedByAchievement.add(ach.unlocks.ability);
      }
    }
    const have = getUnlockedAchievements();
    for (const id of BASIC_ABILITY_IDS) {
      // 🎰 가챠 고유 능력은 랜덤/레벨업 풀에서 제외 (해당 캐릭터의 startAbilities 로만 획득)
      if (ABILITY_DEFS[id].isGachaUnique) continue;
      if (!lockedByAchievement.has(id)) { set.add(id); continue; }
      // 잠긴 능력은 그 업적 보유 시에만 해금
      for (const ach of ACHIEVEMENTS) {
        if (ach.unlocks && ach.unlocks.ability === id && have.has(ach.id)) {
          set.add(id); break;
        }
      }
    }
    return set;
  }
  // 캐릭터 사용 기록 (allChars 업적용)
  function recordCharUsage() {
    META.charactersUsed = META.charactersUsed || {};
    const id = state.character || 'standard';
    const round = state.round || 1;
    if ((META.charactersUsed[id] || 0) < round) {
      META.charactersUsed[id] = round;
      saveMeta();
    }
  }

  // ===== 점수 기록 (상위 10) — META 통합 (다기기 동기화) + localStorage 폴백 =====
  //   v200: 기록을 META.records 로 이동 → 서버 동기화 시 다른 기기 기록도 병합됨.
  //   기존 'dot-defense-records' localStorage 키는 1회 마이그레이션 후 그대로 두고 폴백으로만 사용.
  const RECORDS_KEY = 'dot-defense-records';   // legacy fallback
  // 기록 1회 마이그레이션 — localStorage → META.records
  (function migrateRecords() {
    if (Array.isArray(META.records) && META.records.length > 0) return;   // 이미 META에 있음
    try {
      const legacy = JSON.parse(localStorage.getItem(RECORDS_KEY) || '[]');
      if (Array.isArray(legacy) && legacy.length > 0) {
        META.records = legacy;
        try { localStorage.setItem(META_KEY, _packMeta(META)); } catch {}
      }
    } catch {}
  })();
  // 🛡 로드 시 비정상(상한 초과) 기록 자동 제거 — 익스플로잇 점수가 로컬에 남아 병합으로 되살아나는 것 차단
  (function sanitizeRecordsOnLoad() {
    try {
      if (!Array.isArray(META.records)) return;
      const before = META.records.length;
      META.records = META.records.filter(r => r && typeof r.score === 'number' && r.score <= SCORE_SANE_CAP);
      if (META.records.length !== before) {
        try { localStorage.setItem(META_KEY, _packMeta(META)); } catch {}
        try { localStorage.setItem(RECORDS_KEY, JSON.stringify(META.records)); } catch {}
        if (typeof saveMeta === 'function') { try { saveMeta(); } catch {} }   // 서버에도 정리본 동기화
      }
    } catch {}
  })();
  function loadRecords() {
    // META.records 우선. 없으면 localStorage 폴백
    if (Array.isArray(META.records)) return META.records;
    try { return JSON.parse(localStorage.getItem(RECORDS_KEY) || '[]'); }
    catch { return []; }
  }
  function saveRecord() {
    // 점수 0 + R1에서 즉시 끝낸 경우는 저장 안 함
    if (state.score === 0 && state.round <= 1) return;
    const records = loadRecords();
    records.push({
      score: state.score,
      round: state.gameWin ? MAX_ROUND : Math.max(1, state.round - (state.gameWin ? 0 : 1)),
      date: Date.now(),
      abilities: state.tower.abilities.map(a => ({ id: a.id, level: a.level })),
      win: !!state.gameWin,
      ascension: state.ascension || 0,            // 난이도 저장
      character: state.character || 'standard',   // 캐릭터 저장
      mode: state.mode || 'standard',             // 🏰 모드 저장 (재제출 시 모드별 랭킹 매칭용)
    });
    records.sort((a, b) => b.score - a.score);
    records.length = Math.min(records.length, 10);
    META.records = records;
    saveMeta();   // 서버 동기화 트리거 (queueServerSync 자동 호출)
    // legacy 키도 함께 유지 — 오프라인 폴백
    try { localStorage.setItem(RECORDS_KEY, JSON.stringify(records)); } catch {}
  }

  function planRound() {
    const cfg = roundConfig(state.round);
    state.roundFrame = 0;
    state.spawnPlan = [];
    state.bossesSpawnedThisRound = 0;
    // 🛡 v273 — 매 라운드 특수 보스 연출 상태 초기화 (이전 라운드 잔존값으로 오발동 방지)
    //   특수 보스 당첨 시에만 아래에서 다시 설정됨. 미당첨/일반 라운드는 연출 절대 안 뜸.
    state.bossIntro = null;
    state.pendingSpecialBoss = null;
    // 정예 적 인덱스 마킹 (앞쪽 N개 스폰을 정예로)
    state.eliteIndices = new Set();
    for (let i = 0; i < cfg.spawnCount; i++) {
      state.spawnPlan.push((i + 1) * cfg.spawnInterval);
      if (i < cfg.eliteCount) state.eliteIndices.add(i);
    }
    // 보스 스폰 큐. 일반: [], 보스 라운드: [60, +stagger, ...], 최종: [60, +50s, +100s]
    if (cfg.isFinal) {
      // ☠ 최종 보스 · 아바돈 — 전용 등장 연출(암전·강림) 후 단일 강림
      state.pendingSpecialBoss = 'abaddon';
      state.bossIntro = { special: 'abaddon', frame: 0, skip: false };
      state.bossSpawns = [60 + BOSS_INTRO_DUR];
    } else if (cfg.isBoss) {
      // 메인 보스 1마리 + 추가 보스 (3초 간격으로 등장)
      state.bossSpawns = [60];
      for (let k = 1; k <= cfg.extraBosses; k++) {
        state.bossSpawns.push(60 + 3 * FPS * k);
      }
      // 🌌 v272 — 특수 보스 (R15+ 보스 라운드, 35%, 최종보스 제외)
      //   연출은 라운드 시작과 함께 배경에서 9초간 진행 (게임 정지 X) → 그 후 보스 등장
      //   잡몹과 싸우는 동안 뒤에서 보스가 헤엄쳐 다가오다 자연스럽게 합류
      if (state.round >= 15 && !cfg.isFinal && Math.random() < 0.35) {
        const sid = SPECIAL_BOSS_IDS[Math.floor(Math.random() * SPECIAL_BOSS_IDS.length)];
        state.pendingSpecialBoss = sid;
        state.bossIntro = { special: sid, frame: 0, skip: false };
        // 보스 스폰을 연출 길이(9초)만큼 미룸 → 연출 끝나는 시점에 등장
        state.bossSpawns = state.bossSpawns.map(t => t + BOSS_INTRO_DUR);
      }
    } else {
      state.bossSpawns = [];
    }
    // 추가 보스 라운드 경고 — 13+ 승천 R10/30/50/70/90
    if (cfg.isExtraBoss) {
      toast(`⚠ 추가 보스 라운드 (R${state.round})`);
    }
  }

  // ===== 능력용 헬퍼 =====
  // 🎯 TD 사거리 캡 적용 — state.currentAbilityRange 가 설정돼있으면 그 값으로 캡
  //    Infinity 면 캡 없음, null/undefined 면 표준 모드(원래 동작)
  function tdCappedRange(range) {
    const cap = state.currentAbilityRange;
    if (cap === null || cap === undefined) return range;
    if (cap === Infinity) return range;
    return Math.min(range, cap);
  }
  function findNearestEnemy(range) {
    range = tdCappedRange(range);
    let target = null, best = Infinity;
    const r2 = range * range;
    for (const e of state.enemies) {
      if (e.hp <= 0) continue;
      const [x, y] = enemyXY(e);
      const d2 = (x-CX)*(x-CX) + (y-CY)*(y-CY);
      if (d2 < r2 && d2 < best) { best = d2; target = e; }
    }
    return target;
  }
  function findFarthestEnemy(range) {
    range = tdCappedRange(range);
    let target = null, best = -1;
    const r2 = range * range;
    for (const e of state.enemies) {
      if (e.hp <= 0) continue;
      const [x, y] = enemyXY(e);
      const d2 = (x-CX)*(x-CX) + (y-CY)*(y-CY);
      if (d2 < r2 && d2 > best) { best = d2; target = e; }
    }
    return target;
  }
  // 🏰 TD 모드 — 적이 경로를 따라 한 줄로 이동하므로 360° 분산은 효율 X
  //   현재 타워에서 가장 가까운 적 방향으로 펜을 좁혀 발사
  function tdIsDefense() { return state.mode === 'defense'; }
  // 🏰 TD 모드 효과 반경 캡 — 슬로우/광역 효과가 사거리를 벗어나지 않도록
  //   - 클래식: fallback 그대로
  //   - TD: state.currentAbilityRange 와 fallback 의 더 작은 값
  //   - Infinity/None 시: fallback 그대로
  function tdMaxEffectRadius(fallback) {
    if (!tdIsDefense()) return fallback;
    const cap = state.currentAbilityRange;
    if (cap === null || cap === undefined) return fallback;
    if (cap === Infinity) return fallback;
    return Math.min(fallback, cap);
  }
  // 적이 현재 능력 사거리 내에 있는지 (효과 적용 가드)
  function tdInRange(e) {
    if (!tdIsDefense()) return true;
    const cap = state.currentAbilityRange;
    if (cap === null || cap === undefined) return true;
    if (cap === Infinity) return true;
    const [ex, ey] = enemyXY(e);
    return (ex-CX)*(ex-CX) + (ey-CY)*(ey-CY) <= cap*cap;
  }
  // 🏰 TD: 하늘에서 떨어지는 능력 (운석/검비 등) — 적 위치를 타격하도록 위치 생성
  // 클래식: 아레나 내 무작위 위치
  // strikes: 떨어질 개수, returns: [{x, y}, ...]
  function tdDropPositions(strikes, options = {}) {
    const { bossWeight = 5, offset = 50 } = options;
    if (tdIsDefense()) {
      const pool = state.enemies.filter(e => e.hp > 0);
      if (pool.length > 0) {
        const weighted = [];
        for (const e of pool) {
          const w = e.isBoss ? bossWeight : 1;
          for (let k = 0; k < w; k++) weighted.push(e);
        }
        const result = [];
        for (let i = 0; i < strikes; i++) {
          const target = weighted[Math.floor(Math.random() * weighted.length)];
          const [ex, ey] = enemyXY(target);
          const ox = (Math.random() - 0.5) * offset;
          const oy = (Math.random() - 0.5) * offset;
          result.push({ x: ex + ox, y: ey + oy });
        }
        return result;
      }
    }
    // 표준 모드 (또는 TD 적 없을 때) — 아레나 내 무작위
    const result = [];
    for (let i = 0; i < strikes; i++) {
      const a = Math.random() * Math.PI * 2;
      const r = Math.random() * (ARENA_R - 30);
      result.push({ x: CX + Math.cos(a) * r, y: CY + Math.sin(a) * r });
    }
    return result;
  }
  // n발 발사 — TD 모드면 타워→가장 가까운 적 방향의 좁은 cone, 아니면 360° 균등
  // fireFn(angle, idx) 호출됨
  function tdDirectionalFan(n, narrowSpread, fireFn) {
    const target = tdIsDefense() ? findNearestEnemy(360) : null;   // 사거리 캡 적용
    if (target) {
      const [tx, ty] = enemyXY(target);
      const base = Math.atan2(ty - CY, tx - CX);
      for (let i = 0; i < n; i++) {
        const off = n === 1 ? 0 : (-narrowSpread/2 + narrowSpread * (i/(n-1)));
        fireFn(base + off, i);
      }
    } else {
      // 360° 균등 (클래식 + 적 없을 때 TD)
      const off0 = tdIsDefense() ? 0 : Math.random() * (Math.PI * 2 / n);
      for (let i = 0; i < n; i++) {
        fireFn((Math.PI * 2 / n) * i + off0, i);
      }
    }
  }
  // target: 유도 대상 (null이면 직진)
  // leader: 리더 탄환 (null이면 일반 탄환). 사이드 탄환은 리더 방향을 추종.
  // offsetAngle: 리더 진행 방향 대비 사이드 탄환의 고정 각도 오프셋
  function fireBullet(angle, dmg, color, target, leader, offsetAngle) {
    const tx = towerX(), ty = towerY();
    const b = {
      x: tx, y: ty,
      vx: Math.cos(angle)*7, vy: Math.sin(angle)*7,
      dmg, life: 100, color,
      target: target || null,
      leader: leader || null,
      offsetAngle: offsetAngle || 0,
      tier: state.currentAbilityTier || 'basic',
      sourceId: state.currentAbilityId || null,
    };
    state.bullets.push(b);
    return b;
  }
  function damageEnemy(e, dmg) {
    if (e.hp <= 0) return;
    // 👁 공허의 눈 — 점멸 무적 중 피해 무효
    if (e.blinkInvulnUntil && e.blinkInvulnUntil > state.t) return;
    // 💎 수정 군주 — 결정 보호막 활성 중 피해 대폭 감소
    if (e.shieldPhaseUntil && e.shieldPhaseUntil > state.t) dmg *= 0.18;
    // 모든 데미지 멀티 (캐릭터 + 모든 패시브 + 메타 효과)
    if (state.metaMods) {
      const mm = state.metaMods;
      // 🛡 v257 — 패시브 합산 cap (한 슬롯당 최대 +500% / 5x boost)
      //   합산 무한대 방지 + 슬롯간 곱연산이라 5^N 폭증도 자연 방지
      const cap = v => Math.min(5.0, v || 0);
      let mul = (mm.dmgMul || 1)
        * (1 + (mm.dmgBoost || 0))            // 메타: 데미지 부스트
        * (1 + cap(mm.furyBonus))             // 액티브 패시브: 분노
        * (1 + cap(mm.precisionBonus))        // 패시브: 정확
        * (1 + cap(mm.frenzyBonus))           // 패시브: 광폭
        * (1 + cap(mm.masteryBonus));         // 패시브: 숙련
      // ⭐ 캐릭터 별 보너스 — 가챠 캐릭터 고유 능력에만 적용 (해당 캐릭터 별 수만큼 데미지 ↑)
      const starBonus = getCharStarBonusForAbility(state.currentAbilityId);
      if (starBonus > 0) mul *= (1 + starBonus);
      // 🌟 능력별 영구 강화 (스타더스트 강화) — 모든 능력
      const permaBonus = getAbilityPermaBonus(state.currentAbilityId);
      if (permaBonus > 0) mul *= (1 + permaBonus);
      // ❄️ paradoxFreeze 동결 중 — 받는 데미지 증폭
      if (e._paradoxVuln) {
        // paradoxFreeze 의 발동 lv 가 필요 → 가장 높은 미사키 8★ 능력의 lv 추정 (기본 ×2.5)
        let vulnMul = 2.5;
        // state.tower.abilities 에서 paradoxFreeze 찾아서 lv 반영
        if (state.tower && state.tower.abilities) {
          const pf = state.tower.abilities.find(a => a.id === 'paradoxFreeze');
          if (pf) vulnMul = 2.5 + pf.level * 0.1;
        }
        // 디펜스 모드 — towers 에서 찾기
        if (state.towers) {
          for (const t of state.towers) {
            if (t.ab && t.ab.id === 'paradoxFreeze') {
              vulnMul = Math.max(vulnMul, 2.5 + t.ab.level * 0.1);
            }
          }
        }
        mul *= vulnMul;
      }
      if (e.isBoss) {
        // 🛡 v257 — ironwillBonus cap (한 슬롯당 +500%)
        mul *= (mm.bossDmgMul || 1) * (1 + cap(mm.ironwillBonus));
      }
      // 신규 패시브: 처형 (저체력 비-보스 적에게 추가 데미지)
      if (!e.isBoss && mm.executionerBonus && e.maxHp > 0 && e.hp / e.maxHp <= 0.5) {
        // 🛡 v257 — executionerBonus cap
        mul *= (1 + cap(mm.executionerBonus));
      }
      // 💎 유물 처형 (즉사) — 저체력 비-보스 적
      const exBelow = (state.relicEffects && state.relicEffects.executeBelow) || 0;
      if (!e.isBoss && exBelow > 0 && e.maxHp > 0 && e.hp / e.maxHp <= exBelow) {
        dmg = e.hp + 1; // 즉사
      }
      // 💎 유물 누적/조건 보너스 (mul에 곱)
      const re = state.relicEffects;
      if (re) {
        // 묘비의 화환 (라운드 클리어 누적)
        if (re.tombStackBonus > 0) mul *= (1 + re.tombStackBonus);
        // 차원 용 (보스 처치 누적)
        if (re.dragonStackBonus > 0) mul *= (1 + re.dragonStackBonus);
        // 사신의 손 (100킬당) — 게임당 ~2000킬 기준 최대 20스택
        if (re.killCountDmgRate > 0) {
          const stacks = Math.floor((state.totalKills || 0) / 100);
          mul *= (1 + stacks * re.killCountDmgRate);
        }
        // 망자의 부적 (500골드당) — 게임당 ~5~15k 골드 기준 10~30스택
        if (re.goldEarnedDmgRate > 0) {
          const stacks = Math.floor((re.goldEarnedTotal || 0) / 500);
          mul *= (1 + stacks * re.goldEarnedDmgRate);
        }
        // 어둠의 약속 / 운명의 저울 — 한계 적 비율
        if ((re.darkPactBonus > 0 || re.fateScaleBonus > 0)) {
          const ratio = state.enemies.length / Math.max(1, getMaxAlive());
          if (re.darkPactBonus > 0 && ratio < 0.5) mul *= (1 + re.darkPactBonus);
          if (re.fateScaleBonus > 0 && ratio >= 0.5) mul *= (1 + re.fateScaleBonus);
        }
        // 🎯 v282 — 공격 유형별 데미지 강화 (능력 태그 기반, 보유 유형마다 중첩)
        if (state.currentAbilityTier && state.currentAbilityId) {
          const tags = ABILITY_TAGS[state.currentAbilityId] || [];
          // 유물 aoeDmgMul — 기존대로 광역/영역
          if (re.aoeDmgMul !== 1 && (tags.includes('광역') || tags.includes('영역'))) mul *= re.aoeDmgMul;
          // 메타 공격 유형 특화 (태그별)
          const td = mm.tagDmg;
          if (td) {
            if (td.wide   && (tags.includes('광역') || tags.includes('영역'))) mul *= (1 + td.wide);
            if (td.explo  && tags.includes('폭발')) mul *= (1 + td.explo);
            if (td.pierce && (tags.includes('관통') || tags.includes('빔'))) mul *= (1 + td.pierce);
            if (td.multi  && tags.includes('다중공격')) mul *= (1 + td.multi);
            if (td.chain  && tags.includes('연쇄')) mul *= (1 + td.chain);
            if (td.spin   && tags.includes('회전')) mul *= (1 + td.spin);
            if (td.snipe  && (tags.includes('단발') || tags.includes('단일') || tags.includes('최강적'))) mul *= (1 + td.snipe);
          }
        }
      }
      // 신규 패시브: 불굴 (누적 처치에 비례한 영구 데미지 — 매 프레임 갱신됨)
      if (mm.resilienceBonus) {
        // 🛡 v257 — resilienceBonus cap
        mul *= (1 + cap(mm.resilienceBonus));
      }
      // 조합/트리플 위계 보너스 — 메타 강화 적용 (comboPower)
      // 사용자 요청: 기본 능력 2개 max 합친 거니까 조합 = 기본max × 2 이상,
      //              트리플 = 기본max × 3 이상의 위력이어야 함
      const cpb = mm.comboPowerBonus || 0;
      if (state.currentAbilityTier === 'combo') mul *= (3.00 + cpb);        // 1.40 → 3.00
      else if (state.currentAbilityTier === 'triple') mul *= (6.00 + cpb * 1.67); // 2.20 → 6.00
      dmg = dmg * mul;
    }
    // 보호막 적/보스: 처음 N회 데미지는 무효 (보호막 카운트만 줄임)
    if ((e.behavior === 'shielded' || (e.isBoss && e.shieldHp > 0)) && e.shieldHp > 0) {
      e.shieldHp--;
      const [ex, ey] = enemyXY(e);
      spawnParticles(ex, ey, '#88ccff', 2);
      state.damageNumbers.push({
        x: ex, y: ey - e.size - 4, vy: -0.6,
        text: 'BLOCK', color: '#88ccff', life: 25, size: 10,
      });
      return;
    }
    e.lastDamageAt = state.t;
    // 📊 능력별 데미지 통계 누적 (실제 적용된 데미지 = 적 hp 깎인 양 기준, 오버킬 제외)
    const dmgApplied = Math.min(dmg, e.hp); // hp 이상은 오버킬 — 통계에서 제외
    if (state.currentAbilityId && dmgApplied > 0) {
      state.abilityDamageStats[state.currentAbilityId] =
        (state.abilityDamageStats[state.currentAbilityId] || 0) + dmgApplied;
    }
    e.hp -= dmg;
    e.hitFlash = state.t + 3;   // ✨ 피격 흰 플래시 (3프레임) — 타격감
    const [ex, ey] = enemyXY(e);
    // 데미지 숫자 — 평소엔 흰색, 큰 데미지(크리티컬)만 골드로 강조
    const big = dmg >= 30;
    // 🛡 데미지 숫자 캡 (작은 데미지는 80개 넘으면 스킵 — 슬로우 + 광역 동시 피격 시 FPS 보호)
    if (big || state.damageNumbers.length < 80) {
      state.damageNumbers.push({
        x: ex + (Math.random() - 0.5) * 6,
        y: ey - e.size - 4,
        vy: -0.7,
        text: String(Math.round(dmg)),
        color: big ? '#ffd479' : '#dde2ec',
        life: 26,
        size: big ? 13 : 10,
      });
    }
    if (e.hp <= 0) {
      // 🏰 디펜스 모드: 타워에 도달해서 죽은 적은 보상 X (이미 페널티 줬음)
      if (e._reachedTower) return;
      const mm = state.metaMods || { goldMul: 1, scoreMul: 1 };
      // 골드 — 흡혈 패시브 + 보스 골드 보너스 (메타)
      // 보스 골드 배수 — 0 이하로는 떨어지지 않게 클램프 (deathPromise -0.5 + 기타 음수 합산 방어)
      const bossGold = e.isBoss ? Math.max(0, 1 + (mm.bossGoldMul || 0)) : 1;
      // 🛡 v257 — bonusGoldMul cap (최대 +300% / 4x 골드) — vampiric + 약탈폭격 합산 폭주 방지
      const goldBonus = Math.min(3.0, mm.bonusGoldMul || 0);
      // 💉 v276 — 흡혈 고정 골드 (처치당 +N, 적 골드 배수와 별개로 가산)
      const vampFlat = Math.floor(mm.vampiricFlat || 0);
      const goldDrop = Math.ceil(e.goldDrop * mm.goldMul * (1 + goldBonus) * bossGold) + vampFlat;
      state.gold += goldDrop;
      // 💎 망자의 부적용 누적 골드 추적
      if (state.relicEffects) state.relicEffects.goldEarnedTotal = (state.relicEffects.goldEarnedTotal || 0) + goldDrop;
      // 점수 + 행운 보너스 (확률)
      state.score += Math.ceil(10 * state.round * mm.scoreMul * ((state.asc && state.asc.scoreReward) || 1) * endlessScorePenalty());
      // 🛡 v257 — fortuneChance cap 0.95 (절대 100% 안 됨 — 약간의 랜덤성 보존)
      const fortuneP = Math.min(0.95, mm.fortuneChance || 0);
      if (fortuneP > 0 && Math.random() < fortuneP) {
        // 🛡 v265 — fortune 보너스도 엔드리스 패널티 적용 (점수 무한 누적 차단)
        const fortuneBonus = Math.ceil(40 * state.round * mm.scoreMul * endlessScorePenalty());
        state.score += fortuneBonus;
        const [ex2, ey2] = enemyXY(e);
        state.damageNumbers.push({
          x: ex2, y: ey2 - e.size - 12, vy: -1.2,
          text: '+' + fortuneBonus, color: '#ffcc66', life: 35, size: 12,
        });
      }
      // 광폭 트리거
      state.frenzyTrigger = true;
      // 🐲 보스 처치 시 경험치 보너스 (+5 추가 = 총 +6 kill 카운트)
      //    일반 처치 1, 보스 처치 6. 한 보스 = 잡몹 6마리분 경험치.
      const killValue = e.isBoss ? 6 : 1;
      state.kills += killValue;
      state.totalKills = (state.totalKills || 0) + 1;   // 누적은 1씩만 증가 (업적용)
      if (e.isBoss) {
        state.bossKills = (state.bossKills || 0) + 1;
        // 보스 처치 시 시각 피드백
        state.damageNumbers.push({
          x: ex, y: ey - e.size - 30, vy: -1.5,
          text: `+${killValue - 1} 보너스 EXP`, color: '#ffd479', life: 60, size: 13,
        });
      }
      // 🎆 처치 팝 — 일반 몬스터도 죽은 자리에서 약하게 톡 튀는 스파크 (보스는 위에서 큰 폭발 별도)
      burstFx(ex, ey, ['#ff8a6e', '#ffd479'], e.isBoss ? 8 : 4, 1.6);
      SFX.kill();
      // ⚡ 오딘의 창 — 처치 시 주변 3마리에 50% 연쇄 데미지
      if (state.relicEffects && state.relicEffects.chainLightning && !e._chainSource) {
        const chainR = 120;
        const chainDmg = Math.max(1, Math.ceil((e.maxHp || 1) * 0.5));
        let chained = 0;
        for (const e2 of state.enemies) {
          if (chained >= 3) break;
          if (e2 === e || e2.hp <= 0) continue;
          const [ex2, ey2] = enemyXY(e2);
          if ((ex-ex2)*(ex-ex2) + (ey-ey2)*(ey-ey2) < chainR*chainR) {
            e2._chainSource = true; // 무한 연쇄 방지
            damageEnemy(e2, chainDmg);
            e2._chainSource = false;
            state.thunderStrikes = state.thunderStrikes || [];
            state.thunderStrikes.push({ x: ex2, y: ey2, life: 10 });
            spawnParticles(ex2, ey2, '#ffe070', 4);
            chained++;
          }
        }
      }
      // 💎 처치 시 골드 보너스 (거머리/정전기)
      if (state.relicEffects.killGoldBonus > 0) {
        state.gold += state.relicEffects.killGoldBonus;
        state.relicEffects.goldEarnedTotal = (state.relicEffects.goldEarnedTotal || 0) + state.relicEffects.killGoldBonus;
      }
      if (state.relicEffects.killGoldCritChance > 0 && Math.random() < state.relicEffects.killGoldCritChance) {
        state.gold += 8;
        state.relicEffects.goldEarnedTotal = (state.relicEffects.goldEarnedTotal || 0) + 8;
        state.damageNumbers.push({
          x: ex, y: ey - e.size - 12, vy: -1.2,
          text: '⚡ +8', color: '#ffe070', life: 35, size: 11,
        });
      }
      // 💎 보석 사냥꾼 (Rare) — 8% 확률 +25골드
      if (state.relicEffects.gemHunterChance > 0 && Math.random() < state.relicEffects.gemHunterChance) {
        state.gold += 25;
        state.relicEffects.goldEarnedTotal = (state.relicEffects.goldEarnedTotal || 0) + 25;
        state.damageNumbers.push({
          x: ex, y: ey - e.size - 12, vy: -1.2,
          text: '💎 +25', color: '#88e0ff', life: 40, size: 12,
        });
      }
      if (e.isBoss) {
        shake(18, 12);
        SFX.explode();
        // 🎆 보스 폭발 — 죽은 자리에서 폭죽처럼 터지는 버스트 (특수보스는 더 화려). 화면 플래시 아님, 로컬.
        { const _fp = (typeof enemyXY === 'function') ? enemyXY(e) : [W / 2, H / 2];
          const _cols = e.special ? ['#ffffff', '#ffd479', '#ff8a4a', '#ff6bd6'] : ['#ffffff', '#ffd479', '#ff8a4a'];
          burstFx(_fp[0], _fp[1], _cols, e.isMiniBoss ? 8 : (e.special ? 22 : 15), e.isMiniBoss ? 2.0 : 2.9);
          for (let _k = 0; _k < 4; _k++) state.particles.push({ x: _fp[0], y: _fp[1], vx: (Math.random() - 0.5) * 0.7, vy: (Math.random() - 0.5) * 0.7, life: 8 + Math.random() * 4, color: '#ffffff' }); }
        // ☠ 아바돈 피날레 — 거대 폭발 + 잔여 잡몹 일소(웨이브 즉시 종료 → 승리 연출로)
        if (e.special === 'abaddon') {
          const _af = (typeof enemyXY === 'function') ? enemyXY(e) : [W / 2, H / 2];
          burstFx(_af[0], _af[1], ['#ffffff', '#ff2a5a', '#aa3aff', '#ffd479'], 40, 3.4);
          shake(28, 40);
          if (typeof _evClearField === 'function') _evClearField();
        }
        // 💎 유물 효과 — 보스 처치 시 발동
        if (state.relicEffects.bossKillResetCooldown) {
          for (const a of state.tower.abilities) { a.cooldown = 0; }
        }
        // 자비의 망토 — 보스 처치 시 적 정지 + 골드
        if (state.relicEffects.bossKillFreezeFrames > 0) {
          const fr = state.relicEffects.bossKillFreezeFrames;
          for (const en of state.enemies) {
            if (en.hp <= 0) continue;
            en.slowFrames = Math.max(en.slowFrames || 0, fr);
            if (!en.isBoss) en.timeStopped = state.t + fr;
          }
        }
        if (state.relicEffects.bossKillGoldPerRound > 0) {
          const bonus = (state.round || 1) * state.relicEffects.bossKillGoldPerRound;
          state.gold += bonus;
          toast(`😇 천사의 시간: +${bonus}골드`);
        }
        // 차원 용 누적
        if (state.relicEffects.dragonStackPerBoss > 0) {
          state.relicEffects.dragonStackBonus += state.relicEffects.dragonStackPerBoss;
        }
        state.relicEffects.bossesSlain = (state.relicEffects.bossesSlain || 0) + 1;
        // ✨ v275 — 특수 보스 처치 추가 보상 (미니 제외) — 소량 (일반 적 ~6마리분)
        if (e.special && !e.isMiniBoss) {
          const mm2 = state.metaMods || {};
          const bonusScore = Math.ceil(state.round * 60 * (mm2.scoreMul || 1) * ((state.asc && state.asc.scoreReward) || 1) * endlessScorePenalty());
          const bonusGold = state.round * 2;
          state.score += bonusScore;
          state.gold += bonusGold;
          const [bx2, by2] = enemyXY(e);
          state.damageNumbers.push({ x: bx2, y: by2 - e.size - 16, vy: -1.4,
            text: `✨ +${bonusScore.toLocaleString()}`, color: '#ff88ff', life: 55, size: 15 });
          toast(`✨ 특수 보스 처치! +${bonusScore.toLocaleString()}점 · +${bonusGold}G`);
        }
        // 🦈 v267 — 우주 레비아탄: 죽을 때 미니 레비아탄 2마리로 분열 (자식은 분열 X)
        if (e.special === 'leviathan' && !e.isMiniBoss) {
          for (let k = 0; k < 2; k++) {
            const mini = Object.assign({}, e, {
              hp: Math.max(1, Math.ceil(e.maxHp * 0.25)),
              maxHp: Math.max(1, Math.ceil(e.maxHp * 0.25)),
              size: Math.max(9, Math.floor(e.size * 0.6)),
              goldDrop: Math.max(1, Math.ceil(e.goldDrop * 0.3)),
              isMiniBoss: true, sealUsed: true, pattern: 'basic',
              angle: (e.angle || 0) + (k === 0 ? -0.3 : 0.3),
              spawnT: state.t,   // 🎬 v268 — 미니도 등장 애니메이션
            });
            state.enemies.push(mini);
          }
          toast('🦈 레비아탄 분열!');
          shake(8, 10);
        }
        // ☀ 초신성 코어 — 사멸 폭발: 처치 시 고속 잡몹 링 분출
        if (e.special === 'supernova' && !e.isMiniBoss) {
          const [bx2, by2] = enemyXY(e);
          const ringN = 8;
          for (let k = 0; k < ringN; k++) {
            const aa = (k / ringN) * Math.PI * 2;
            spawnEnemy({ angle: aa, radius: e.radius, behavior: null, size: 6 });
            const last = state.enemies[state.enemies.length - 1];
            if (last) { last.angle = aa; last.radius = e.radius; last.angularSpeed = (last.angularSpeed || 0) * 1.7; }
          }
          for (let p = 0; p < 26; p++) spawnParticles(bx2, by2, '#ffb04a', 3);
          shake(12, 16);
          toast('☀ 초신성 폭발!');
        }
        // 💎 종말의 시계 — 5마리당 다음 라운드 스킵 충전 (총 3회 사용)
        if (state.relicEffects.skipRoundCharges > 0) {
          state.relicEffects.skipRoundBossCount++;
          if (state.relicEffects.skipRoundBossCount >= 5) {
            state.relicEffects.skipRoundBossCount = 0;
            state.relicEffects.skipRoundCharges--;   // 충전 차감 — 진짜 3회 제한
            state.skipNextRound = true;
            toast(`⏳ 다음 라운드 자동 클리어! (남은 충전: ${state.relicEffects.skipRoundCharges})`);
          }
        }
        // 🎭 보스 처치 → 이벤트 (등급 분리): 특수보스=강화 이벤트, 일반 보스=유물 선택 이벤트. 미니보스 제외.
        //    🎆 보스 폭발 연출이 먼저 보이도록 ~0.42초 뒤에 이벤트 오픈 (보상 등장 전 한 박자).
        if (!state.relicOffering && !_activeEvent && !e.isMiniBoss && e.special !== 'abaddon') {
          const _bossSpecial = !!e.special;
          // 🎁 일반보스는 50%만 유물 이벤트 등장 (유물 과다 지급 완화). 특수보스 강화 이벤트는 항상.
          const _giveReward = _bossSpecial || (Math.random() < 0.5);
          if (_giveReward) {
            const _openBossReward = () => {
              if (!state || state.gameOver || _activeEvent || state.relicOffering) return;
              // 🃏 레벨업/무료 카드(게임화면 선택)가 떠 있으면 먼저 고르게 두고, 끝난 뒤 보스 카드 드래프트 → 화면 겹침 방지
              if (state.levelUpChoices) { setTimeout(_openBossReward, 300); return; }
              if (_bossSpecial) { if (typeof openBossEvent === 'function') openBossEvent(); }     // 특수보스 → 강화 이벤트
              else { if (typeof openBossRelicEvent === 'function') openBossRelicEvent(); }         // 일반보스 → 유물 이벤트
            };
            setTimeout(_openBossReward, 420);
          }
        }
      } else {
        shake(4, 4);
      }
      // 분열형: 죽을 때 작은 2마리로 갈라짐 (자식은 분열 X)
      if (e.behavior === 'splitter' && !e.isChild) {
        const cfg = roundConfig(state.round);
        for (let k = 0; k < 2; k++) {
          const newA = e.angle + (k === 0 ? -0.15 : 0.15);
          spawnEnemy({
            angle: newA, radius: e.radius,
            hp: Math.max(1, Math.ceil(e.maxHp * 0.4)),
            behavior: null, size: 5, type: e.type,
          });
          // 자식 표시
          const last = state.enemies[state.enemies.length - 1];
          if (last) { last.isChild = true; last.goldDrop = Math.max(1, Math.ceil(e.goldDrop * 0.5)); }
        }
      }
      // 레벨업 트리거 (모달 띄움)
      if (state.kills >= state.killsToNextLevel && !state.levelUpChoices) {
        triggerLevelUp();
      }
    }
  }
  // 화면 흔들림 트리거 — 🌊 정신없지 않게 강도 대폭 축소 + 상한
  function shake(strength, frames) {
    strength = Math.min(strength * 0.4, 5);   // 흔들림 약하게 (40%) + 최대 5px 캡
    if (state.shakeStrength < strength) state.shakeStrength = strength;
    if (state.shakeFrames < frames) state.shakeFrames = frames;
  }
  // 🎆 처치 버스트 — 죽은 자리에서 폭죽처럼 사방으로 튀는 스파크 (화면 플래시 아님, 로컬 이펙트)
  function burstFx(x, y, colors, count, power) {
    const cap = IS_MOBILE ? 110 : 300;
    const room = cap - state.particles.length;
    if (room <= 0) return;
    count = Math.min(count, room);
    for (let i = 0; i < count; i++) {
      const a = Math.random() * Math.PI * 2;
      const s = power * (0.45 + Math.random() * 1.05);
      state.particles.push({ x, y, vx: Math.cos(a) * s, vy: Math.sin(a) * s, life: 13 + Math.random() * 13, color: colors[(Math.random() * colors.length) | 0] });
    }
  }

  // ===== 능력 Max 레벨 시스템 =====
  // 뱀파이어 서바이버즈 스타일: 재료 둘 다 max 도달 시 다음 카드에서 조합 옵션 등장
  function maxLvFor(id) {
    const def = ABILITY_DEFS[id];
    if (!def) return 8;
    if (def.isTriple) return 4;
    if (def.isCombo) return 5;
    return 8;  // 기본 액티브/패시브
  }
  function isAtMax(a) { return a.level >= maxLvFor(a.id); }

  // 두 재료가 모두 max 도달한 조합 레시피들을 반환
  function findAvailableCombos() {
    const ownedAbs = state.tower.abilities;
    const ownedIds = new Set(ownedAbs.map(a => a.id));
    const available = [];
    for (const r of COMBO_RECIPES) {
      if (!ownedIds.has(r.parts[0]) || !ownedIds.has(r.parts[1])) continue;
      if (ownedIds.has(r.combo)) continue;  // 이미 보유 시 제외
      const a1 = ownedAbs.find(a => a.id === r.parts[0]);
      const a2 = ownedAbs.find(a => a.id === r.parts[1]);
      if (!isAtMax(a1) || !isAtMax(a2)) continue;
      available.push(r);
    }
    return available;
  }

  // ===== 레벨업 시스템 =====
  // 🌟 v240 — 보너스 점수 카드 공식 통일 (이전엔 800×r / 600×r 두 종류, 초반 과대 지급)
  //          다항식 스케일(150r + 4r²)로 초반은 부드럽게, 후반은 cap(80k)까지 비슷하게 유지.
  //          라운드 10: 1,900 (이전 8,000) / 라운드 30: 8,100 / 라운드 80+: cap 도달.
  //          scoreMul 적용 후 최종 cap → 풀스택(2.6x) 폭증도 차단.
  function bonusScoreAmount() {
    const round = Math.max(1, (state && state.round) || 1);
    const scoreMul = (state && state.metaMods && state.metaMods.scoreMul) || 1;
    const baseLine = 150 * round + 4 * round * round;
    const variance = 0.92 + Math.random() * 0.16;
    // 🛡 v265 — cap(80k) 후 엔드리스 난이도 패널티 적용 → 일반 엔드리스 무한 점수 파밍 차단
    const capped = Math.min(baseLine * scoreMul * variance, 80000);
    return Math.floor(capped * endlessScorePenalty());
  }
  // 🏰 TD 모드 레벨업 카드 — 패시브 + 보너스 (액티브 X)
  function generateTDLevelUpChoices() {
    const choices = [];
    const ownedIds = new Set(state.tower.abilities.map(a => a.id));
    const allowed = getUnlockedAbilityIds();
    // 미보유 패시브 후보
    const passivePool = [...allowed].filter(id => {
      const d = ABILITY_DEFS[id];
      return d && d.isPassive && !ownedIds.has(id);
    });
    // 강화 가능 패시브 (현재 보유 중 max 미만)
    const upgradablePassives = state.tower.abilities.filter(a => {
      const d = ABILITY_DEFS[a.id];
      return d && d.isPassive && !isAtMax(a);
    });
    // 🏰 초반(플레이어 레벨 ≤ 3)에는 보너스 카드(점수/스타더스트) 제외 — 초반 카드는 실질 강화로만
    const blockBonus = (state.playerLevel || 1) <= 3;
    // 🌟 v242 — 어센던트 조건 캐시 (루프 안에서 findAvailableCombos 반복 호출 방지)
    const ascMode = shouldOfferAscendant();
    // 카드 풀: 신규 패시브 60%, 강화 30%, 보너스 10% (초반은 보너스 차단 후 패시브로 대체)
    while (choices.length < 3) {
      const roll = Math.random();
      let added = false;
      // 1) 신규 패시브
      if (roll < 0.6 && passivePool.length > 0) {
        const candidates = passivePool.filter(id => !choices.some(c => c.action === 'new' && c.id === id));
        if (candidates.length > 0) {
          const id = candidates[Math.floor(Math.random() * candidates.length)];
          choices.push({ action: 'new', id, newLevel: 1 });
          added = true;
        }
      }
      // 2) 패시브 강화
      if (!added && roll < 0.9 && upgradablePassives.length > 0) {
        const candidates = upgradablePassives.filter(a => !choices.some(c => c.action === 'level' && c.id === a.id));
        if (candidates.length > 0) {
          const a = candidates[Math.floor(Math.random() * candidates.length)];
          // 럭키 확률 적용
          let lucky = 0;
          const mm = state.metaMods || {};
          if (Math.random() < ((mm.superLuckyChanceBonus || 0) + 0.03)) lucky = 2;
          else if (Math.random() < ((mm.luckyChanceBonus || 0) + 0.12)) lucky = 1;
          choices.push({ action: 'level', id: a.id, level: a.level, newLevel: a.level + 1 + lucky, lucky });
          added = true;
        }
      }
      // 보너스 비차단 구간: 풀 비었거나 강화 후보도 없으면 보너스 가능
      // 보너스 차단 구간(초반): 강화 후보가 비었으면 신규 한번 더 시도
      if (!added) {
        // 신규 또는 강화 어느 쪽이든 가능하면 한 번 더 시도 (보너스 회피)
        if (passivePool.length > 0) {
          const candidates = passivePool.filter(id => !choices.some(c => c.action === 'new' && c.id === id));
          if (candidates.length > 0) {
            const id = candidates[Math.floor(Math.random() * candidates.length)];
            choices.push({ action: 'new', id, newLevel: 1 });
            added = true;
          }
        }
        if (!added && upgradablePassives.length > 0) {
          const candidates = upgradablePassives.filter(a => !choices.some(c => c.action === 'level' && c.id === a.id));
          if (candidates.length > 0) {
            const a = candidates[Math.floor(Math.random() * candidates.length)];
            let lucky = 0;
            const mm = state.metaMods || {};
            if (Math.random() < ((mm.superLuckyChanceBonus || 0) + 0.03)) lucky = 2;
            else if (Math.random() < ((mm.luckyChanceBonus || 0) + 0.12)) lucky = 1;
            choices.push({ action: 'level', id: a.id, level: a.level, newLevel: a.level + 1 + lucky, lucky });
            added = true;
          }
        }
      }
      // 3) 보너스 (점수 / 스타더스트) — 초반(playerLevel ≤ 3)에는 차단
      // 🌟 v241 — 모든 능력 max 시 어센던트 카드 70% (엔드리스 정체 해소)
      if (!added && !blockBonus && ascMode && Math.random() < 0.7) {
        const t = ASCENDANT_TYPES[Math.floor(Math.random() * ASCENDANT_TYPES.length)];
        choices.push({ action: 'ascendant', id: t.id });
        added = true;
      }
      if (!added && !blockBonus) {
        const ratio = Math.random();
        if (ratio < 0.6) {
          choices.push({ action: 'bonusScore', amount: bonusScoreAmount() });
        } else {
          choices.push({ action: 'bonusStardust', amount: Math.max(1, Math.floor(state.round / 3)) });
        }
        added = true;
      }
      if (!added) break;
    }
    return choices;
  }

  function generateLevelUpChoices() {
    const choices = [];

    // 🏰 TD 모드: 패시브/유물/보너스만 — 액티브는 타워로 배치하므로 카드 풀에서 제외
    if (state.mode === 'defense') {
      return generateTDLevelUpChoices();
    }

    // 액티브 능력이 하나도 없으면 첫 카드는 무조건 액티브 3장 보장 (몬스터 처치 불가 방지)
    const forceActiveOnly = activeCount() === 0;

    // 1) 조합 카드 — 가능한 모든 조합을 카드로 표시 (트리플 우선, 최대 3장)
    //    예: A+B, A+C 둘 다 가능하면 둘 다 카드에 등장
    if (!forceActiveOnly) {
      const availableCombos = findAvailableCombos().slice();
      // 트리플(tier 3) 우선, 그 다음 일반(tier 2)
      availableCombos.sort((a, b) => (b.tier || 2) - (a.tier || 2));
      for (const r of availableCombos) {
        if (choices.length >= 3) break;
        choices.push({
          action: 'combo',
          id: r.combo,
          parts: r.parts,
          tier: r.tier || 2,
        });
      }
    }

    const owned = new Set(state.tower.abilities.map(a => a.id));
    const allowed = getUnlockedAbilityIds();
    // 조합 카드의 재료들 (소진될 예정) 추출
    // ⚠️ 조합 카드가 여러 장 있을 때 모두 합치면 너무 많은 능력을 미리 제외해서
    //   카드 풀이 비고 보너스 카드만 나오는 버그 발생. 플레이어는 1장만 선택하므로
    //   소진은 1장 분량만 예상. → 최우선 조합(트리플 우선) 1장의 재료만 마킹.
    const consumedByCombos = new Set();
    const comboCards = choices.filter(c => c.action === 'combo' && c.parts);
    if (comboCards.length === 1) {
      // 단독 조합 — 거의 확실히 선택됨 → 재료 미리 제외
      for (const part of comboCards[0].parts) consumedByCombos.add(part);
    }
    // 다중 조합일 때는 비워둠 (어떤 게 선택될지 모르므로 보수적으로 모두 살림)
    // 조합 카드가 있을 때, 그 카드의 재료(=소진될 능력)와만 조합되는 능력은 제외.
    // - 조합 파트너십이 전혀 없는 능력 (fury 등) → 통과 (조합과 무관한 일반 능력)
    // - 트리플 조합 재료가 한 개라도 있으면 → 통과 (user 명시 요구)
    // - 일반 조합 파트너 중 소진 안 될 파트너가 있으면 → 통과
    // - 위 모두 해당 안 되면 → 제외 (소진될 재료와만 조합 가능 = 무의미)
    function abilityHasFutureUse(id) {
      const partners = COMBO_PARTNERS[id] || [];
      if (partners.length === 0) return true;   // 조합 없는 능력은 일반 허용
      // 🛡 v277 — 이미 만든 조합(p.combo 보유)은 미래 가치 X → 그 경로 제외
      //   (예: 흡혈의 유일 조합 '약탈폭격'을 이미 보유 → 흡혈은 더 뜨지 않음)
      const usefulPartners = partners.filter(p => !owned.has(p.combo));
      if (usefulPartners.length === 0) return false;  // 모든 조합 이미 완성 → 재료로서 무의미
      for (const p of usefulPartners) {
        if (p.tier === 3) return true;          // 미완성 트리플 재료 — 무조건 통과
      }
      for (const p of usefulPartners) {
        if (!consumedByCombos.has(p.partner)) return true;  // 소진 안 될 파트너로 만들 미완성 조합
      }
      return false;   // 남은 일반 파트너가 전부 소진 예정 + 트리플 X
    }
    // RANDOM_POOL_IDS 사용 → 가챠 고유 능력 카드 풀에서 완전 차단 (belt-and-suspenders)
    const unownedActive  = RANDOM_POOL_IDS.filter(id => !owned.has(id) && allowed.has(id) && !ABILITY_DEFS[id].isPassive && abilityHasFutureUse(id));
    const unownedPassive = RANDOM_POOL_IDS.filter(id => !owned.has(id) && allowed.has(id) &&  ABILITY_DEFS[id].isPassive && abilityHasFutureUse(id));
    // ⭐ v209 — 현재 캐릭터의 별 해금 능력 추가 (4★/8★ 히든)
    //   getStarUnlockedAbilities() 는 모든 캐릭터의 별 해금을 반환하지만,
    //   레벨업 카드에는 현재 플레이 중인 캐릭터의 것만 등장해야 함.
    const myCharId = state.character;
    if (myCharId && CHAR_STAR_UNLOCKS[myCharId]) {
      const myStars = getCharStars(myCharId);
      const myStarAbilities = [];
      if (myStars >= 4 && CHAR_STAR_UNLOCKS[myCharId][4]) myStarAbilities.push(...CHAR_STAR_UNLOCKS[myCharId][4]);
      if (myStars >= 8 && CHAR_STAR_UNLOCKS[myCharId][8]) myStarAbilities.push(...CHAR_STAR_UNLOCKS[myCharId][8]);
      for (const id of myStarAbilities) {
        if (owned.has(id)) continue;
        const d = ABILITY_DEFS[id];
        if (!d) continue;
        if (d.isPassive) unownedPassive.push(id);
        else unownedActive.push(id);
      }
    }

    // 첫 카드 — 액티브만 3장 강제
    if (forceActiveOnly) {
      const activePool = unownedActive.slice();
      // 무작위로 3장 선택
      while (choices.length < 3 && activePool.length > 0) {
        const idx = Math.floor(Math.random() * activePool.length);
        const id = activePool.splice(idx, 1)[0];
        choices.push({ action: 'new', id, newLevel: 1 });
      }
      // 액티브 풀이 3개 미만이면 보너스 카드로 채움 (정말 극단적 케이스만)
      while (choices.length < 3) {
        choices.push({ action: 'bonusScore', amount: bonusScoreAmount() });
      }
      return choices;
    }
    // 강화 대상은 max 미달 능력만
    const ownedAbilities = state.tower.abilities.filter(a => !isAtMax(a));
    while (choices.length < 3) {
      const newActiveCount = choices.filter(c => c.action === 'new' && !ABILITY_DEFS[c.id].isPassive).length;
      const newPassiveCount = choices.filter(c => c.action === 'new' && ABILITY_DEFS[c.id].isPassive).length;
      const aSlotsFree = activeCount() + newActiveCount < maxActiveSlots();
      const pSlotsFree = passiveCount() + newPassiveCount < maxPassiveSlots();
      const newActivePool = unownedActive.filter(id => !choices.some(c => c.action === 'new' && c.id === id));
      const newPassivePool = unownedPassive.filter(id => !choices.some(c => c.action === 'new' && c.id === id));
      const lvPool = ownedAbilities.filter(a => !choices.some(c => c.action === 'level' && c.id === a.id));
      const canNewA = aSlotsFree && newActivePool.length > 0;
      const canNewP = pSlotsFree && newPassivePool.length > 0;
      const canLv = lvPool.length > 0;
      if (!canNewA && !canNewP && !canLv) break;
      // 초반엔 new 위주, 후반엔 level. 액티브 60% / 패시브 30% / 강화 사이.
      const roll = Math.random();
      const earlyGame = state.playerLevel < 4;
      let pick = null;
      if ((canNewA || canNewP) && (!canLv || roll < (earlyGame ? 0.75 : 0.45))) {
        // 신규 — 액티브가 더 자주 (적이 있는 경우만)
        const preferActive = canNewA && (!canNewP || Math.random() < 0.6);
        const pool = preferActive ? newActivePool : newPassivePool;
        const fallback = preferActive ? newPassivePool : newActivePool;
        const finalPool = pool.length > 0 ? pool : fallback;
        if (finalPool.length === 0) break;
        // 🧩 보유 능력의 조합 파트너 가중치 ×4 (조합 형성 기회 ↑)
        const ownedNow = new Set(state.tower.abilities.map(a => a.id));
        const weights = finalPool.map(id => {
          const partners = COMBO_PARTNERS[id] || [];
          const hasOwnedPartner = partners.some(p => ownedNow.has(p.partner));
          return hasOwnedPartner ? 4 : 1;
        });
        const totalW = weights.reduce((s, w) => s + w, 0);
        let rW = Math.random() * totalW;
        let id = finalPool[finalPool.length - 1];
        for (let i = 0; i < finalPool.length; i++) {
          rW -= weights[i];
          if (rW <= 0) { id = finalPool[i]; break; }
        }
        choices.push({ action: 'new', id, newLevel: 1 });
      } else if (canLv) {
        const p = lvPool[Math.floor(Math.random() * lvPool.length)];
        // 럭키 카드 확률 roll (강화 카드만) — 메타 강화 보너스 반영
        const maxLv = maxLvFor(p.id);
        const remainingLv = maxLv - p.level;
        const mm = state.metaMods || {};
        const luckyP = 0.12 + (mm.luckyChanceBonus || 0);            // 기본 12% + 강화
        const superLuckyP = 0.03 + (mm.superLuckyChanceBonus || 0);  // 기본 3% + 강화
        let lucky = 0;
        if (remainingLv >= 3 && Math.random() < superLuckyP) lucky = 2;
        else if (remainingLv >= 2 && Math.random() < luckyP) lucky = 1;
        const bonusLevels = lucky;
        choices.push({
          action: 'level',
          id: p.id,
          level: p.level,
          newLevel: p.level + 1 + bonusLevels,
          lucky,
        });
      } else break;
    }
    // ===== 보너스 폴백 직전 — 능력 카드 한 번 더 시도 =====
    // (메인 루프가 abilityHasFutureUse 필터로 막혀서 풀이 비어버린 경우 대비)
    // abilityHasFutureUse 무시하고 슬롯 + 미보유 + 해금된 것 전부 허용.
    // 🛡 v277 — 조합이 전부 완성된 "죽은 재료" 제외 (예: 약탈폭격 보유 시 흡혈) — 폴백에서도 막음
    const comboDead = id => {
      const ps = COMBO_PARTNERS[id];
      return ps && ps.length > 0 && ps.every(p => owned.has(p.combo));
    };
    while (choices.length < 3) {
      const newActiveCount = choices.filter(c => c.action === 'new' && !ABILITY_DEFS[c.id].isPassive).length;
      const newPassiveCount = choices.filter(c => c.action === 'new' && ABILITY_DEFS[c.id].isPassive).length;
      const aSlotsFree = activeCount() + newActiveCount < maxActiveSlots();
      const pSlotsFree = passiveCount() + newPassiveCount < maxPassiveSlots();
      const looseActive = RANDOM_POOL_IDS.filter(id =>
        !owned.has(id) && allowed.has(id) && !ABILITY_DEFS[id].isPassive && !comboDead(id) &&
        !choices.some(c => c.action === 'new' && c.id === id)
      );
      const looseUnPassive = RANDOM_POOL_IDS.filter(id =>
        !owned.has(id) && allowed.has(id) && ABILITY_DEFS[id].isPassive && !comboDead(id) &&
        !choices.some(c => c.action === 'new' && c.id === id)
      );
      const canA = aSlotsFree && looseActive.length > 0;
      const canP = pSlotsFree && looseUnPassive.length > 0;
      if (!canA && !canP) break;
      const useA = canA && (!canP || Math.random() < 0.6);
      const pool = useA ? looseActive : looseUnPassive;
      const id = pool[Math.floor(Math.random() * pool.length)];
      choices.push({ action: 'new', id, newLevel: 1 });
    }
    // ===== 그래도 부족하면 보너스 카드 (또는 v241 어센던트) =====
    // 🌟 v241 — 모든 능력 max + 슬롯 풀이면 어센던트 우선 (엔드리스 정체 해소)
    const ascMode = shouldOfferAscendant();
    while (choices.length < 3) {
      const r = Math.random();
      if (ascMode && r < 0.7) {
        // 어센던트 카드 (글로벌 +%)
        const t = ASCENDANT_TYPES[Math.floor(Math.random() * ASCENDANT_TYPES.length)];
        choices.push({ action: 'ascendant', id: t.id });
      } else if (r < 0.6) {
        // 점수 보너스 (라운드에 비례)
        choices.push({ action: 'bonusScore', amount: bonusScoreAmount() });
      } else {
        // 스타더스트 (영구 통화 소량)
        const amount = 3 + Math.floor(Math.random() * 8);
        choices.push({ action: 'bonusStardust', amount });
      }
    }
    return choices;
  }
  function triggerLevelUp() {
    state.playerLevel++;
    state.kills = 0;
    const mul = (state.metaMods && state.metaMods.levelUpMul) || 1;
    const fast = (state.metaMods && state.metaMods.levelUpFast) || 0;
    state.killsToNextLevel = Math.max(3, Math.floor((8 + state.playerLevel * 4) * mul - fast));
    const choices = generateLevelUpChoices();
    state.levelUpChoices = choices;
    state.rerollAvailable = metaLv('reroll') > 0;
    // 모든 카드가 보너스(점수/스타더스트)면 3초 자동 선택 타이머 시작
    // ⏱ 자동 선택 — 실시간 5초 (게임 속도 배율과 무관). 0 = 비활성, >0 = 절대 시각(ms)
    state.autoCardTimer = isAllBonusChoices(choices) ? (performance.now() + 5000) : 0;
    SFX.levelup();
  }
  function isAllBonusChoices(choices) {
    return choices.length > 0 && choices.every(c => c.action === 'bonusScore' || c.action === 'bonusStardust');
  }
  function rerollCards() {
    if (!state.levelUpChoices) return;
    if (!state.rerollAvailable) return;
    const choices = generateLevelUpChoices();
    if (choices.length === 0) return;
    state.levelUpChoices = choices;
    state.rerollAvailable = false;
    // 리롤 후에도 전부 보너스면 타이머 재시작 (사용자가 리롤로 일반 카드 시도했음 → 한 번 더 기다림)
    // ⏱ 자동 선택 — 실시간 5초 (게임 속도 배율과 무관). 0 = 비활성, >0 = 절대 시각(ms)
    state.autoCardTimer = isAllBonusChoices(choices) ? (performance.now() + 5000) : 0;
    SFX.click();
  }
  function applyLevelUpChoice(idx) {
    if (!state.levelUpChoices) return;
    if (idx === -1) {  // 취소 — 이미 차감된 골드 환불 (대신 다음 카드 비용은 올라감)
      if (state.cardCancelable) {
        const hadPaid = state.cardCostPaid > 0;
        if (hadPaid) state.gold += state.cardCostPaid;
        // 🚫 무한 리롤 방지: 취소도 획득 횟수 증가 → 다음 랜덤 비용 상승
        state.tower.acquireCount += 1;
        state.levelUpChoices = null;
        state.cardCost = 0;
        state.cardCostPaid = 0;
        state.cardCancelable = false;
        state.rerollAvailable = false;
        state.autoCardTimer = 0;
        SFX.click();
        toast(hadPaid ? '취소 · 골드 환불 (다음 카드 비용 ↑)' : '취소 (다음 카드 비용 ↑)');
      }
      return;
    }
    const c = state.levelUpChoices[idx];
    if (!c) return;
    // 카드가 랜덤 획득 모달에서 온 경우 — 골드는 이미 actRandomAcquire에서 차감됨
    // (acquireCount만 증가, 다음 번부터 비용이 늘어남: 0 → 25 → 60 → ...)
    if (state.cardCancelable) {
      state.tower.acquireCount += 1;
    }
    if (c.action === 'new') {
      // 🎴 v207 — 획득 시점 라운드 기록 → enhanceCost가 라운드별로 비싸짐
      // 🎬 v243 — _isNew 마크 → 다음 renderPanel 에서 fade-in
      const ab = { id: c.id, level: 1, acquiredRound: state.round || 1, _isNew: true };
      ABILITY_DEFS[c.id].init(ab);
      state.tower.abilities.push(ab);
      unlockAbility(c.id);
    } else if (c.action === 'level') {
      const a = state.tower.abilities.find(x => x.id === c.id);
      if (a) {
        const increment = 1 + (c.lucky || 0);
        a.level = Math.min(a.level + increment, maxLvFor(a.id));
        // 🌌 v245 — 능력 max 도달 시 고대 유물 각성 트리거 체크
        if (a.level >= maxLvFor(a.id)) checkAncientAwakening(a.id);
        // 럭키 효과 표시
        if (c.lucky > 0) state.luckyCount = (state.luckyCount || 0) + 1; // 업적 추적
        if (c.lucky === 1) {
          toast(`🍀 LUCKY! ${ABILITY_DEFS[a.id].name} +2 레벨!`);
          state.comboFlash = 24;
          state.comboFlashColor = '#88ff88';
        } else if (c.lucky === 2) {
          toast(`💫 SUPER LUCKY! ${ABILITY_DEFS[a.id].name} +3 레벨!`);
          state.comboFlash = 40;
          state.comboFlashColor = '#ffd0ff';
          shake(16, 14);
        }
      }
    } else if (c.action === 'bonusScore') {
      state.score += c.amount;
      state.damageNumbers.push({
        x: CX, y: CY - 80, vy: -1.5,
        text: `+${c.amount.toLocaleString()}`,
        color: '#bcf0d2', life: 50, size: 16,
      });
      toast(`🎁 점수 +${c.amount.toLocaleString()}`);
    } else if (c.action === 'ascendant') {
      // 🌟 v241 — 어센던트 카드: 글로벌 +% 영구 적용 (무한 스택)
      const t = ASCENDANT_BY_ID[c.id];
      if (t) {
        try { t.apply(state); } catch (e) { console.warn('어센던트 적용 실패:', e); }
        if (!state.ascendantStacks) state.ascendantStacks = {};
        state.ascendantStacks[c.id] = (state.ascendantStacks[c.id] || 0) + 1;
        state.comboFlash = 30;
        state.comboFlashColor = t.color;
        state.damageNumbers.push({
          x: CX, y: CY - 80, vy: -1.5,
          text: `${t.icon} ${t.name}`,
          color: t.color, life: 60, size: 16,
        });
        toast(`✨ ${t.icon} ${t.name} +${state.ascendantStacks[c.id]}`);
      }
    } else if (c.action === 'bonusStardust') {
      META.stardust = (META.stardust || 0) + c.amount;
      // 🛡 stardustEarned catch-up
      META.stardustEarned = Math.max(META.stardustEarned || 0, (META.stardust - c.amount) || 0) + c.amount;
      saveMeta();
      state.damageNumbers.push({
        x: CX, y: CY - 80, vy: -1.5,
        text: `+${c.amount}★`,
        color: '#ffe890', life: 50, size: 16,
      });
      toast(`⭐ 스타더스트 +${c.amount}`);
    } else if (c.action === 'combo') {
      // 조합 카드: 재료 2개 소진 → 새 조합 능력 생성
      const recipe = COMBO_RECIPES.find(r => r.combo === c.id);
      if (recipe) {
        const i1 = state.tower.abilities.findIndex(a => a.id === recipe.parts[0]);
        const i2 = state.tower.abilities.findIndex(a => a.id === recipe.parts[1]);
        if (i1 !== -1 && i2 !== -1) {
          state.tower.abilities.splice(Math.max(i1, i2), 1);
          state.tower.abilities.splice(Math.min(i1, i2), 1);
          // 🎴 v207 — 조합/트리플 생성 시점 라운드 기록
          // 🎬 v243 — _isNew 마크 → renderPanel 에서 fade-in
          const newAb = { id: c.id, level: 1, acquiredRound: state.round || 1, _isNew: true };
          ABILITY_DEFS[c.id].init(newAb);
          state.tower.abilities.push(newAb);
          // 화려한 형성 연출
          const isTriple = c.tier === 3;
          state.comboFlash = isTriple ? 50 : 30;
          state.comboFlashColor = ABILITY_DEFS[c.id].color || '#ffaa55';
          state.comboReveal = { id: c.id, level: 1, life: isTriple ? 90 : 60 };
          for (let k = 0; k < (isTriple ? 80 : 40); k++) spawnParticles(CX, CY, state.comboFlashColor, 1);
          shake(isTriple ? 20 : 12, isTriple ? 30 : 20);
          SFX.combo();
          toast(isTriple ? `🔥 트리플 조합! ${ABILITY_DEFS[c.id].name}` : `✨ ${ABILITY_DEFS[c.id].name} 조합 완성!`);
          unlockAbility(c.id);
          // 🆕 가챠 SR/SSR 캐릭터 시그니처 능력 조합 → 본인 캐릭터 좌측 컷인 (논블로킹)
          try {
            const _sc = _charBySigAbility[recipe.parts[0]] || _charBySigAbility[recipe.parts[1]] || _charBySigAbility[c.id];
            if (_sc && typeof showCharComboCutin === 'function') showCharComboCutin(_sc, c.id);
          } catch (e) {}
        }
      }
    }
    state.levelUpChoices = null;
    state.cardCost = 0;
    state.cardCostPaid = 0;
    state.cardCancelable = false;
    state.rerollAvailable = false;
    state.autoCardTimer = 0;
    const wasFreeRoll = state.isFreeRollCard;
    state.isFreeRollCard = false;
    SFX.click();
    renderPanel();
    // 무료 시작 카드였으면 다음 카드 띄우기
    if (wasFreeRoll && state.pendingFreeRolls > 0) {
      state.pendingFreeRolls--;
      if (state.pendingFreeRolls > 0) {
        // 살짝 딜레이 — 첫 카드 선택 연출 자연스럽게
        setTimeout(triggerFreeRollCard, 250);
      }
    }
  }
  function distPointSegmentSq(px, py, ax, ay, bx, by) {
    const dx = bx - ax, dy = by - ay;
    const len2 = dx*dx + dy*dy;
    if (len2 === 0) return (px-ax)*(px-ax) + (py-ay)*(py-ay);
    let t = ((px-ax)*dx + (py-ay)*dy) / len2;
    t = Math.max(0, Math.min(1, t));
    const cx = ax + t*dx, cy = ay + t*dy;
    return (px-cx)*(px-cx) + (py-cy)*(py-cy);
  }

  function enhanceCost(ability) {
    const def = ABILITY_DEFS[ability.id];
    const mm = state.metaMods || { enhanceMul: 1 };
    // 📚 scholar / scholarSnipe 패시브 실시간 계산
    let scholarMul = 1;
    if (state.tower && state.tower.abilities) {
      const sa = state.tower.abilities.find(a => a.id === 'scholar');
      if (sa) scholarMul = Math.min(scholarMul, 1 - sa.level * 0.04);
      const ss = state.tower.abilities.find(a => a.id === 'scholarSnipe');
      if (ss) scholarMul = Math.min(scholarMul, 1 - ss.level * 0.05);
    }
    // 🛡 누적 할인 최저 한도 — 최대 -55% 누적 할인
    const totalMul = Math.max(0.45, mm.enhanceMul * scholarMul);
    // 능력 레벨 스케일 — 후반 비싸지는 곡선
    const lvScale = (ability.level + 1) + ability.level * 0.10;
    // 🎴 v207 — 능력 획득 시점 라운드별 비용 가산
    //   R1 획득(기본 캐릭터 능력) = 1.0x, R10 = 1.45x, R25 = 2.2x, R50 = 3.45x, R100 = 5.95x
    //   후반에 새로 뽑은 능력 = 후반 골드 스케일에 맞춰 비싸짐
    const acqRound = ability.acquiredRound || 1;
    const roundMul = 1 + (acqRound - 1) * 0.05;
    return Math.ceil(def.baseCost * lvScale * roundMul * totalMul);
  }

  // 랜덤 능력 획득 비용: 0, 25, 60, 110, 180, 270, ...
  // 첫 획득은 0G, 누적 횟수에 따라 점점 비싸짐
  function randomAcquireCost() {
    const n = state.tower.acquireCount;
    if (n === 0) return 0;
    return 25 + (n - 1) * 25 + (n - 1) * (n - 1) * 10;
  }

  // ===== 액션 =====
  function actRandomAcquire() {
    if (state.gameOver) return;
    if (state.levelUpChoices) return;  // 이미 카드 모달 활성
    const cost = randomAcquireCost();
    if (state.gold < cost) return toast('골드 부족');
    const aSlotsFree = activeCount() < maxActiveSlots();
    const pSlotsFree = passiveCount() < maxPassiveSlots();
    const hasCombo = findAvailableCombos().length > 0;
    const hasUpgradable = state.tower.abilities.some(a => !isAtMax(a));
    // 슬롯/조합/강화 전부 불가 → 보너스 카드 (점수/스타더스트) 만 제공
    const bonusOnly = !aSlotsFree && !pSlotsFree && !hasCombo && !hasUpgradable;
    // 카드 생성 — bonusOnly 면 어센던트 3장 (엔드리스), 아니면 정상 풀
    let choices;
    if (bonusOnly) {
      // 🌟 v241 — 어센던트 3장 (정체 해소). 단 스타더스트 1장은 유지 (영구 통화 획득 경로 보존)
      choices = generateAscendantChoices();
      // 마지막 슬롯을 스타더스트로 교체 (1/3 확률로 골고루 분배)
      const dustAmount = Math.max(1, Math.floor(state.round / 3));
      choices[2] = { action: 'bonusStardust', amount: dustAmount };
    } else {
      choices = generateLevelUpChoices();
    }
    if (choices.length === 0) return toast('새 능력 없음');
    // 즉시 골드 차감 (카드 모달 떠있는 동안 강화로 골드 빠지는 버그 방지)
    state.gold -= cost;
    state.levelUpChoices = choices;
    state.cardCost = cost;            // 표시용 (모달 제목에 사용)
    state.cardCostPaid = cost;        // 취소 시 환불용
    state.cardCancelable = true;
    state.rerollAvailable = metaLv('reroll') > 0;
    SFX.click();
    renderPanel();
  }

  function actEnhance(idx) {
    if (state.gameOver) return;
    if (state.levelUpChoices) return toast('카드 선택 후 가능');  // 카드 모달 중 강화 차단 (꼼수 방지)
    const a = state.tower.abilities[idx];
    if (!a) return;
    if (isAtMax(a)) return toast('이미 MAX — 조합 카드 대기');
    const cost = enhanceCost(a);
    if (state.gold < cost) return toast('골드 부족');
    state.gold -= cost;
    a.level += 1;
    // 💎 복제기 (cloneEngine) — 강화 시 추가 +1 레벨 (충전 소진형, 총 5회)
    let cloneApplied = false;
    const re = state.relicEffects;
    if (re && re.doubleEnhance && (re.doubleEnhanceCharges || 0) > 0 && !isAtMax(a)) {
      a.level += 1;
      re.doubleEnhanceCharges--;
      cloneApplied = true;
    }
    const chargeTxt = cloneApplied ? ` (🧬+1 / 잔여 ${re.doubleEnhanceCharges})` : '';
    toast(`${ABILITY_DEFS[a.id].name} Lv${a.level}${chargeTxt}${isAtMax(a) ? ' MAX!' : ''}`);
    renderPanel();
  }

  // 🗑 v260 — 삭제 버튼 무장 (첫 클릭) — 2초 내 재클릭해야 실제 삭제
  function armDeleteButton(btnEl, a) {
    SFX.click();
    if (btnEl) {
      btnEl.textContent = '❗';
      btnEl.title = '다시 누르면 삭제';
      btnEl.classList.add('rm-armed');
    }
    if (a._deleteArmTimer) clearTimeout(a._deleteArmTimer);
    a._deleteArmTimer = setTimeout(() => {
      // 2초 경과 — 아직 삭제 안 됐으면 무장 해제
      if (a._deleteArmedUntil && performance.now() >= a._deleteArmedUntil) {
        a._deleteArmedUntil = 0;
        if (btnEl && btnEl.isConnected) {
          btnEl.textContent = '✕';
          btnEl.title = '삭제';
          btnEl.classList.remove('rm-armed');
        }
      }
    }, 2050);
  }
  function actDelete(idx, btnEl) {
    if (state.gameOver) return;
    if (state.levelUpChoices) return toast('카드 선택 후 가능');  // 카드 모달 중 삭제 차단
    const a = state.tower.abilities[idx];
    if (!a) return;
    // 🗑 v260 — 2단계 삭제: 첫 클릭은 "무장"만, 2초 내 재클릭해야 실제 삭제 (실수 방지)
    const now = performance.now();
    if (!a._deleteArmedUntil || now > a._deleteArmedUntil) {
      a._deleteArmedUntil = now + 2000;
      armDeleteButton(btnEl, a);
      return;
    }
    // 무장 상태 + 2초 이내 재클릭 → 실제 삭제 진행
    a._deleteArmedUntil = 0;
    if (a._deleteArmTimer) { clearTimeout(a._deleteArmTimer); a._deleteArmTimer = null; }
    // 🎬 v243 — 자연스러운 삭제 애니메이션
    // DOM 행을 찾아 접힘 → 완료 후 실제 데이터 삭제 + 재렌더
    // 현재 탭(액티브/패시브)에서의 visualIdx 계산 (filtered 배열 인덱스)
    const isPassive = ABILITY_DEFS[a.id].isPassive;
    const isPassiveTab = (typeof currentAbTab !== 'undefined' && currentAbTab === 'passive');
    let rowEl = null;
    if (isPassiveTab === isPassive) {
      const visualIdx = state.tower.abilities
        .slice(0, idx)
        .filter(x => ABILITY_DEFS[x.id].isPassive === isPassive).length;
      const rows = elAb ? elAb.querySelectorAll('.ability-row') : null;
      if (rows && rows[visualIdx]) rowEl = rows[visualIdx];
    }
    const commit = () => {
      // 🛡 v243 — 동시 삭제 시 인덱스 드리프트 방지: 참조로 현재 인덱스 재계산
      const curIdx = state.tower.abilities.indexOf(a);
      if (curIdx < 0) return; // 이미 삭제됨
      // 강화에 들인 골드의 40% 환불 (랜덤 획득 비용은 환불 없음)
      let refund = 0;
      for (let lv = 1; lv < a.level; lv++) {
        refund += Math.ceil(enhanceCost({id:a.id, level:lv}) * 0.4);
      }
      state.gold += refund;
      state.tower.abilities.splice(curIdx, 1);
      toast(refund > 0 ? `삭제 · ${refund}G 환불` : `삭제됨`);
      renderPanel();
    };
    if (rowEl) {
      collapseElementThen(rowEl, commit);
    } else {
      commit();
    }
  }

  // ===== 적 스폰 =====
  const ENEMY_MIN_R = CORE_R + 40;
  const ENEMY_MAX_R = ARENA_R - 20;
  // 적 타입은 라운드별로 순환 — 비주얼 변화 + 라운드 진척 체감
  // R1:소행성  R2:얼음  R3:드론  R4:플라즈마  R5:크리스탈+보스  R6~ 반복
  const ENEMY_TYPES = ['asteroid', 'ice', 'drone', 'plasma', 'crystal'];
  function getEnemyType(round) {
    return ENEMY_TYPES[(round - 1) % ENEMY_TYPES.length];
  }
  // seed 기반 결정적 난수 (개체별 디테일 변형용)
  function srand(s) { const x = Math.sin(s) * 10000; return x - Math.floor(x); }

  // 특수 행동: 라운드별로 일부 적이 특수 행동을 가짐
  // splitter (분열) / regen (재생) / shielded (보호막) / charger (돌격) — R3+ 부터 무작위로 섞임
  function pickEnemyBehavior(round) {
    if (round < 3) return null;
    const r = Math.random();
    const chance = Math.min(0.5, 0.10 + round * 0.015);  // R3:14%, R10:25%, R30:50%
    if (r > chance) return null;
    const pool = ['splitter', 'regen', 'shielded', 'charger'];
    return pool[Math.floor(Math.random() * pool.length)];
  }
  function spawnEnemy(opts = {}) {
    const cfg = roundConfig(state.round);
    // 🏰 디펜스 모드 (TD): 경로 따라 이동하는 적 스폰
    if (state.mode === 'defense') {
      const map = getActiveTDMap();
      const paths = getMapPaths(map);
      // 🔱 Phase 4: 다중경로 — 라운드로빈으로 path 할당 (or opts.pathId)
      const pathId = (opts.pathId !== undefined)
        ? opts.pathId
        : (state.tdNextPathId || 0) % paths.length;
      state.tdNextPathId = ((state.tdNextPathId || 0) + 1) % paths.length;
      const path = paths[pathId];
      const start = path[0];
      const center = cellCenter(start.col, start.row);
      const behavior = opts.behavior !== undefined ? opts.behavior : pickEnemyBehavior(state.round);
      let hp = opts.hp !== undefined ? opts.hp : cfg.enemyHp;
      let size = 7;
      if (behavior === 'shielded') hp = Math.ceil(hp * 1.6);
      if (behavior === 'charger') size = 6;
      if (opts.size) size = opts.size;
      const isElite = !!opts.isElite;
      if (isElite) { hp = Math.ceil(hp * 3.0); size = 9; }
      // 적 이동 속도 (셀당 frame 수 = 1 / 속도)
      const speedCellPerFrame = cfg.enemySpeed * 1.2 * (behavior === 'charger' ? 1.8 : 1) * (isElite ? 1.2 : 1);
      state.enemies.push({
        _cart: true,
        x: center.x, y: center.y,
        pathId,             // 🔱 어떤 경로를 따라갈지
        pathIdx: 0,         // 현재 path 인덱스 (목표는 path[pathIdx+1])
        pathT: 0,           // 현재 segment 진행도 (0~1)
        speed: speedCellPerFrame,
        angle: 0, radius: 0, targetRadius: 0, radiusChangeAt: 999999,
        angularSpeed: 0,
        hp, maxHp: hp, size,
        goldDrop: cfg.enemyGold * (isElite ? 4 : 1),
        slowFrames: 0,
        isBoss: false,
        isElite,
        type: opts.type || getEnemyType(state.round),
        seed: Math.random() * 1000,
        rotation: Math.random() * Math.PI * 2,
        rotSpeed: (Math.random() < 0.5 ? -1 : 1) * (0.005 + Math.random() * 0.01),
        behavior,
        shieldHp: behavior === 'shielded' ? 3 : 0,
        lastDamageAt: 0,
      });
      return;
    }
    // 이하 표준 모드 (라디얼)
    let a, r;
    if (opts.angle !== undefined) {
      a = opts.angle;
    } else {
      a = Math.random() * Math.PI * 2;
    }
    if (opts.radius !== undefined) {
      r = opts.radius;
    } else {
      r = ENEMY_MIN_R + Math.random() * (ENEMY_MAX_R - ENEMY_MIN_R);
    }
    const dir = Math.random() < 0.5 ? 1 : -1;
    const behavior = opts.behavior !== undefined ? opts.behavior : pickEnemyBehavior(state.round);
    let hp = opts.hp !== undefined ? opts.hp : cfg.enemyHp;
    let size = 7;
    if (behavior === 'shielded') hp = Math.ceil(hp * 1.6);  // 더 단단
    if (behavior === 'charger') size = 6;
    if (opts.size) size = opts.size;
    // === 정예 적 (Asc 10+ 보스 라운드 동반) — HP/속도/크기 강화 ===
    const isElite = !!opts.isElite;
    if (isElite) {
      hp = Math.ceil(hp * 3.0);   // HP 3배
      size = 9;                    // 더 큼
    }
    state.enemies.push({
      angle: a, radius: r,
      targetRadius: ENEMY_MIN_R + Math.random() * (ENEMY_MAX_R - ENEMY_MIN_R),
      radiusChangeAt: Math.floor(60 + Math.random()*120),
      angularSpeed: cfg.enemySpeed * dir * (behavior === 'charger' ? 2.0 : (0.5 + Math.random()*0.8)) * (isElite ? 1.35 : 1),
      hp, maxHp: hp, size,
      goldDrop: cfg.enemyGold * (isElite ? 4 : 1),
      slowFrames: 0,
      isBoss: false,
      isElite,
      type: opts.type || getEnemyType(state.round),
      seed: Math.random() * 1000,
      rotation: Math.random() * Math.PI * 2,
      rotSpeed: (Math.random() - 0.5) * 0.04,
      behavior,
      shieldHp: behavior === 'shielded' ? 5 : (isElite ? 3 : 0),  // 정예도 약한 보호막
      regenTimer: 0,
      lastDamageAt: 0,
    });
  }
  // 보스 패턴: 라운드별로 다른 능력 — 소환사/광폭화/실드 중 하나
  function pickBossPattern(round) {
    if (round < 10) return 'basic';      // R5: 평범
    if (round < 20) return 'summoner';   // R10-15: 잡몹 소환
    if (round < 30) return 'enrage';     // R20-25: HP낮으면 가속+공격력
    return ['summoner', 'enrage', 'shield'][Math.floor(Math.random() * 3)];  // R30+: 랜덤
  }
  function spawnBoss() {
    const cfg = roundConfig(state.round);
    // 🌌 v267 — 특수 보스 마킹 (첫 보스에만 적용, 1회 소비)
    const special = state.pendingSpecialBoss || null;
    const specialDef = special ? SPECIAL_BOSS_DEFS[special] : null;
    state.pendingSpecialBoss = null;
    const specialHpMul = specialDef ? (specialDef.hpMul || 1) : 1;
    // 🦁 다음 보스 균열 — "다음 보스 약점" 이벤트 효과: 이번 보스 HP 33% 감소(≈데미지 +50%), 1회 소비
    const crackMul = state._bossCrack ? 0.67 : 1;
    if (state._bossCrack) { state._bossCrack = false; }
    // 🏰 디펜스 모드 (TD): 보스도 path 시작점에서 스폰 (느리게)
    if (state.mode === 'defense') {
      const map = getActiveTDMap();
      const paths = getMapPaths(map);
      // 🔱 보스는 무작위 path 선택 (다중경로 맵에서도 한 경로만 사용)
      const pathId = Math.floor(Math.random() * paths.length);
      const path = paths[pathId];
      const start = path[0];
      const center = cellCenter(start.col, start.row);
      state.enemies.push({
        _cart: true,
        x: center.x, y: center.y,
        pathId,
        pathIdx: 0,
        pathT: 0,
        speed: cfg.enemySpeed * 0.7,  // 보스 천천히
        angle: 0, radius: 0, targetRadius: 0, radiusChangeAt: 999999,
        angularSpeed: 0,
        hp: Math.ceil(cfg.bossHp * specialHpMul * crackMul), maxHp: Math.ceil(cfg.bossHp * specialHpMul * crackMul),
        size: Math.round(18 * ((specialDef && specialDef.sizeMul) || 1)), goldDrop: Math.ceil(cfg.bossGold * (special ? 1.5 : 1)),
        slowFrames: 0, isBoss: true,
        type: 'boss', seed: Math.random() * 1000,
        rotation: 0, rotSpeed: special ? 0 : 0.012,   // 특수 보스는 회전 X (외형 인식)
        pattern: special === 'abaddon' ? 'finale' : pickBossPattern(state.round),
        patternCD: 180,
        enraged: false,
        shieldHp: 0,
        lastDamageAt: 0,
        special: special,          // 🌌 v267
        sealUsed: false,
        spawnT: state.t,           // 🎬 v268 — 등장 애니메이션 시작 시각
      });
      // 🎬 v268 — 등장 이펙트 (스르륵 커지며 + 빛 퍼짐)
      { const lb = state.enemies[state.enemies.length - 1]; const [bx, by] = enemyXY(lb);
        for (let p = 0; p < 16; p++) spawnParticles(bx, by, special ? SPECIAL_BOSS_DEFS[special].eye : '#ff8090', 2);
        shake(special ? 10 : 6, special ? 14 : 8); }
      const re = state.relicEffects;
      if (re && re.bossStartStop > 0) {
        for (const en of state.enemies) {
          en.slowFrames = Math.max(en.slowFrames || 0, re.bossStartStop);
        }
        toast(`🔮 시간이 멈춘다 — ${(re.bossStartStop/60).toFixed(1)}초`);
      }
      return;
    }
    // 이하 표준 모드 (라디얼)
    let a;
    a = Math.random() * Math.PI * 2;
    const r = ENEMY_MAX_R - 30;
    state.enemies.push({
      angle: a, radius: r,
      targetRadius: 100 + Math.random() * 150,
      radiusChangeAt: 240,
      angularSpeed: cfg.enemySpeed * (Math.random() < 0.5 ? 1 : -1) * 0.4,
      hp: Math.ceil(cfg.bossHp * specialHpMul * crackMul), maxHp: Math.ceil(cfg.bossHp * specialHpMul * crackMul),
      size: Math.round(18 * ((specialDef && specialDef.sizeMul) || 1)), goldDrop: Math.ceil(cfg.bossGold * (special ? 1.5 : 1)),
      slowFrames: 0, isBoss: true,
      type: 'boss', seed: Math.random() * 1000,
      rotation: 0, rotSpeed: special ? 0 : 0.012,
      pattern: special === 'abaddon' ? 'finale' : pickBossPattern(state.round),
      patternCD: 180,    // 보스 능력 쿨다운
      enraged: false,
      shieldHp: 0,
      lastDamageAt: 0,
      special: special,          // 🌌 v267
      sealUsed: false,
      spawnT: state.t,           // 🎬 v268 — 등장 애니메이션 시작 시각
    });
    // 🎬 v268 — 등장 이펙트
    { const lb = state.enemies[state.enemies.length - 1]; const [bx, by] = enemyXY(lb);
      for (let p = 0; p < 16; p++) spawnParticles(bx, by, special ? SPECIAL_BOSS_DEFS[special].eye : '#ff8090', 2);
      shake(special ? 10 : 6, special ? 14 : 8); }
    // 🔮 예언자의 수정구 — 보스 등장 시 모든 적 정지
    const re = state.relicEffects;
    if (re && re.bossStartStop > 0) {
      for (const en of state.enemies) {
        en.slowFrames = Math.max(en.slowFrames || 0, re.bossStartStop);
      }
      toast(`🔮 시간이 멈춘다 — ${(re.bossStartStop/60).toFixed(1)}초`);
    }
  }
  // 보스 능력 업데이트
  function updateBossPatterns() {
    for (const e of state.enemies) {
      if (!e.isBoss) continue;
      if (e.patternCD > 0) e.patternCD--;

      // 광폭화: HP 30% 이하면 가속 + 공격력 (영구)
      if (e.pattern === 'enrage' && !e.enraged && e.hp < e.maxHp * 0.3) {
        e.enraged = true;
        e.angularSpeed *= 2;
        e.rotSpeed *= 2;
        e.size = Math.ceil(e.size * 1.15);
        shake(15, 20);
        SFX.bossSpawn();
        toast('⚠️ 보스 광폭화!');
      }
      // 소환사: 주기적으로 잡몹 2-3마리 소환
      if (e.pattern === 'summoner' && e.patternCD <= 0) {
        const [bx, by] = enemyXY(e);
        const n = 2 + Math.floor(Math.random() * 2);
        for (let k = 0; k < n; k++) {
          const aa = Math.random() * Math.PI * 2;
          spawnEnemy({
            angle: aa, radius: e.radius,
            behavior: null, size: 6,
          });
          // 시각: 소환 위치 표시
          const last = state.enemies[state.enemies.length - 1];
          if (last) { last.angle = e.angle + (k - n/2) * 0.2; last.radius = e.radius - 20; }
        }
        spawnParticles(bx, by, '#cc66ff', 12);
        SFX.combo();
        e.patternCD = 360;  // 6초마다
      }
      // 실드: HP 50% 이하 시 일시 보호막
      if (e.pattern === 'shield' && !e.shieldUsed && e.hp < e.maxHp * 0.5) {
        e.shieldUsed = true;
        e.shieldHp = 20;
        const [bx, by] = enemyXY(e);
        spawnParticles(bx, by, '#88ccff', 16);
        toast('🛡 보스 실드 발동!');
        SFX.bossSpawn();
      }
      // ☠ 종말 · 아바돈 — 최종보스 3페이즈(HP 임계값) + 페이즈 비례 소환 + 보호막 + 회복 압박
      if (e.special === 'abaddon') {
        if (e.phase === undefined) { e.phase = 1; e.abadCD = 240; }
        const hpR = e.hp / e.maxHp;
        if (e.phase === 1 && hpR <= 0.66) {
          e.phase = 2; e.shieldHp = Math.max(e.shieldHp || 0, 30); e.angularSpeed *= 1.3;
          const [bx, by] = enemyXY(e); spawnParticles(bx, by, '#aa3aff', 22);
          shake(18, 24); SFX.bossSpawn(); state.comboFlash = 36; state.comboFlashColor = '#aa3aff'; toast('☠ 아바돈 — 각성 (2페이즈)');
        } else if (e.phase === 2 && hpR <= 0.33) {
          e.phase = 3; e.angularSpeed *= 1.35; e.rotSpeed *= 2; e.size = Math.ceil(e.size * 1.08);
          const [bx, by] = enemyXY(e); spawnParticles(bx, by, '#ff2a5a', 26);
          shake(24, 30); SFX.bossSpawn(); state.comboFlash = 44; state.comboFlashColor = '#ff2a5a'; toast('☠ 아바돈 — 발악 (최종 페이즈)');
        }
        if (--e.abadCD <= 0) {
          e.abadCD = e.phase === 3 ? 150 : (e.phase === 2 ? 240 : 330);
          const n = e.phase + 1; const [bx, by] = enemyXY(e);
          for (let k = 0; k < n; k++) { spawnEnemy({ angle: e.angle + (k - n / 2) * 0.25, radius: e.radius, behavior: null, size: 6 }); const last = state.enemies[state.enemies.length - 1]; if (last) last.radius = e.radius - 20; }
          spawnParticles(bx, by, '#aa3aff', 12); SFX.combo();
        }
        if (state.t % 60 === 0 && e.hp < e.maxHp) {   // 잡몹 살아있으면 초당 소량 회복(빨리 처치 유도, 상한 5)
          let adds = 0; for (const x of state.enemies) { if (!x.isBoss && x.hp > 0) adds++; }
          if (adds > 0) e.hp = Math.min(e.maxHp, e.hp + Math.ceil(e.maxHp * 0.003 * Math.min(adds, 5)));
        }
      }
      // 💀 v267 — 우주 사신: HP 50% 이하 시 1회, 2.5초간 능력 봉인 (공허 컨셉)
      if (e.special === 'reaper' && !e.sealUsed && e.hp < e.maxHp * 0.5) {
        e.sealUsed = true;
        state.abilitySealUntil = state.t + 150;   // 2.5초
        const [bx, by] = enemyXY(e);
        spawnParticles(bx, by, '#ff7ac0', 20);
        toast('💀 사신의 봉인 — 2.5초간 능력 정지!');
        state.comboFlash = 30; state.comboFlashColor = '#9a6ad0';
        SFX.bossSpawn();
      }
      // 🐙 우주 크라켄 — 포식: 주기적으로 주변 잡몹을 삼켜 회복
      if (e.special === 'kraken') {
        if (e.devourCD === undefined) e.devourCD = 240;
        if (--e.devourCD <= 0) {
          e.devourCD = 270;   // ~4.5초
          const [bx, by] = enemyXY(e);
          let eaten = 0;
          for (const t of state.enemies) {
            if (eaten >= 3) break;
            if (t === e || t.isBoss || t.hp <= 0) continue;
            const [tx, ty] = enemyXY(t);
            if (Math.hypot(tx - bx, ty - by) < e.size * 4.6) {
              t.hp = 0; eaten++;   // 삼킴 (보상 없이 제거 — _alivePredEnemy)
              for (let p = 0; p < 6; p++) spawnParticles(tx, ty, '#a0e0ff', 2);
            }
          }
          if (eaten > 0) {
            const heal = Math.ceil(e.maxHp * 0.05 * eaten);
            e.hp = Math.min(e.maxHp, e.hp + heal);
            state.damageNumbers.push({ x: bx, y: by - e.size - 14, vy: -1.2, text: `+${heal}`, color: '#7affc8', life: 45, size: 13 });
            spawnParticles(bx, by, '#a0e0ff', 12);
          }
        }
      }
      // 💎 수정 군주 — 결정 보호막: 주기적 3초간 피해 대폭 감소
      if (e.special === 'crystal') {
        if (e.shieldCD === undefined) e.shieldCD = 300;
        if (--e.shieldCD <= 0) {
          e.shieldCD = 420;                       // 7초 주기
          e.shieldPhaseUntil = state.t + 180;     // 3초 지속
          const [bx, by] = enemyXY(e);
          spawnParticles(bx, by, '#e6ffff', 18);
          toast('💎 수정 보호막 — 피해 감소!');
          SFX.bossSpawn();
        }
      }
      // 👁 공허의 눈 — 점멸: 주기적 순간이동 + 짧은 무적
      if (e.special === 'voidEye') {
        if (e.blinkCD === undefined) e.blinkCD = 240;
        if (--e.blinkCD <= 0) {
          e.blinkCD = 300;                        // 5초 주기
          const [ox, oy] = enemyXY(e);
          for (let p = 0; p < 14; p++) spawnParticles(ox, oy, '#ff5ad0', 2);
          if (state.mode !== 'defense') {
            e.angle = Math.random() * Math.PI * 2;
            e.radius = 90 + Math.random() * 150;
            e.targetRadius = e.radius; e._xyT = -1; // 🚀 위치 메모 무효화
          }
          e.blinkInvulnUntil = state.t + 26;      // ~0.43초 무적
          const [nx, ny] = enemyXY(e);
          for (let p = 0; p < 14; p++) spawnParticles(nx, ny, '#ff5ad0', 2);
        }
      }
    }
  }

  // ===== 업데이트 =====
  // 🚀 인플레이스 compaction — predicate가 true인 요소만 남김 (Array.filter 대체)
  //    매 프레임 호출되는 핫 패스에서 새 배열/클로저 할당을 제거하여 GC 압박 감소.
  //    동작은 filter와 100% 동일하지만 in-place로 처리하여 alloc 없음.
  function compactInPlace(arr, predicate) {
    let w = 0;
    const n = arr.length;
    for (let r = 0; r < n; r++) {
      const item = arr[r];
      if (predicate(item)) {
        if (w !== r) arr[w] = item;
        w++;
      }
    }
    arr.length = w;
  }
  // 자주 쓰는 predicate 캐싱 (클로저 재할당 방지)
  const _alivePredEnemy   = e => e.hp > 0;
  const _alivePredLife    = x => x.life > 0;
  // 🚀 능력 fx 배열용 공유 predicate — ABILITY_DEFS tick의 매 프레임 filter를 compactInPlace로 이관
  const _predNotDone      = o => !o.done;
  const _predNotExploded  = o => !o.exploded;
  const _predWaveArena    = w => w.r < ARENA_R + 30;
  const _predStunAlive    = s => s.e && s.e.hp > 0 && s.until > state.t;
  // 🛡 v254 — 패시브 공유 metaMods 슬롯 — 매 프레임 리셋 후 능력별 max/min 머지
  //          벡터: 같은 슬롯에 여러 능력이 쓰는 케이스 (vampiric + 약탈폭격 등)
  //          능력 제거 시 stale 값 잔존 방지 + 능력 간 충돌 방지
  function resetSharedPassiveSlots() {
    if (!state || !state.metaMods) return;
    const mm = state.metaMods;
    // 0 으로 리셋되는 슬롯들 (기본값 0, max 머지)
    mm.furyBonus       = 0;
    mm.precisionBonus  = 0;
    mm.frenzyBonus     = 0;
    mm.bonusGoldMul    = 0;
    mm.fortuneChance   = 0;
    mm.masteryBonus    = 0;
    mm.ironwillBonus   = 0;
    mm.executionerBonus= 0;
    mm.resilienceBonus = 0;
    mm.vampiricFlat    = 0;   // 💉 v276 — 흡혈 처치당 고정 골드 (%→+N 전환)
    // 1 로 리셋되는 슬롯들 (기본값 1, min 머지 — scholarMul 은 할인이라 작을수록 좋음)
    mm.scholarMul      = 1;
  }
  function update() {
    // 자동 카드 선택 타이머 — 실시간 deadline 방식 (게임 속도 배율 영향 X)
    if (state.levelUpChoices && !paused && state.autoCardTimer > 0) {
      if (performance.now() >= state.autoCardTimer) {
        // 스타더스트 카드 우선 자동 선택, 없으면 첫 보너스 카드
        const idx = state.levelUpChoices.findIndex(c => c.action === 'bonusStardust');
        applyLevelUpChoice(idx >= 0 ? idx : 0);
        return;
      }
    }
    if (paused || state.gameOver || state.levelUpChoices) return;
    state.t++;
    // 🌌 v272 — 특수 보스 연출은 배경에서 진행 (게임 정지 X). 플레이 계속하면서 보스가 다가옴
    if (state.bossIntro) updateBossIntro();

    // 라운드 진행
    const cfg = roundConfig(state.round);
    // 🏰 TD Prep Phase — Start 버튼 누르기 전까지 라운드 진행/스폰 정지
    if (state.tdPrepPhase) return;
    state.roundFrame++;
    while (state.spawnPlan.length && state.spawnPlan[0] <= state.roundFrame) {
      state.spawnPlan.shift();
      // 정예 적 마킹된 인덱스면 isElite=true로 스폰
      const totalIdx = (state.eliteIndices ? state.eliteIndices.size : 0) - (state.spawnPlan.length); // 잘못된 계산
      const spawnedCount = (cfg.spawnCount - 1) - state.spawnPlan.length;
      const isElite = state.eliteIndices && state.eliteIndices.has(spawnedCount);
      spawnEnemy({ isElite });
    }
    // 보스 스폰 (큐에 있는 시점 도달 시 차례로)
    while (state.bossSpawns && state.bossSpawns.length && state.roundFrame >= state.bossSpawns[0]) {
      state.bossSpawns.shift();
      // 첫 보스만 "이전 보스 미처치" 체크 (라운드 시작 보스). 추가 보스는 무조건 스폰
      if ((state.bossesSpawnedThisRound || 0) === 0) {
        if (state.enemies.some(e => e.isBoss)) {
          endGame('이전 보스를 처치하지 못함', false);
          break;
        }
      }
      spawnBoss();
      state.bossesSpawnedThisRound = (state.bossesSpawnedThisRound || 0) + 1;
      shake(15, 12);
      SFX.bossSpawn();
      // 🐲 v220 — 보스 등장 알림 (각 라운드 첫 보스만)
      if (state.bossesSpawnedThisRound === 1) {
        state.bossWarning = { life: 50 };
      }
    }
    if (state.gameOver) return;

    // 🐲 보스 생존 여부 — 조기 클리어 가드 (🚀 closure 없는 for 루프, 매 프레임 호출됨)
    let bossAlive = false;
    {
      const enemies = state.enemies;
      for (let i = 0; i < enemies.length; i++) {
        const e = enemies[i];
        if (e.isBoss && e.hp > 0) { bossAlive = true; break; }
      }
    }
    // 🏰 디펜스 모드: 살아남은 적은 어차피 아래로 내려와 죽음 → 조기 클리어 일찍 허용
    // 조기 클리어: 모든 적 처치 + 더 이상 스폰 없음 → 즉시 다음 라운드 + 시간 보너스
    if (state.enemies.length === 0
        && state.spawnPlan.length === 0
        && state.bossSpawns.length === 0
        && state.roundFrame > 60
        && !bossAlive) {
      const timeSaved = Math.max(0, (cfg.duration - state.roundFrame) / FPS);
      // 🛡 v265 — 시간 보너스도 엔드리스 패널티 적용
      const bonus = Math.max(0, Math.floor(timeSaved * 10 * state.round * endlessScorePenalty()));
      state.score += bonus;
      SFX.waveClear();
      state.waveClearText = {
        round: state.round, bonus, timeSaved, life: 70,
      };
      // 🌟 v220 — 라운드 클리어 시 부드러운 골드 sweep
      state.roundClearSweep = { life: 36 };
      toast(`R${state.round} 클리어! +${bonus} (${timeSaved.toFixed(1)}s 단축)`);
      advanceRound();
    }
    // 라운드 시간 만료 → 다음 라운드 (적이 남았어도 진행 — 원래 동작)
    else if (state.roundFrame >= cfg.duration) {
      advanceRound();
    }

    // 게임오버 체크 (적 누적)
    const maxAlive = getMaxAlive();
    // 🏰 디펜스 모드는 적 한계 게임오버 X (HP 0으로만 패배)
    if (state.mode !== 'defense' && state.enemies.length >= maxAlive) {
      // 🌅 영원의 빛 — 한 게임당 1회 자동 부활 (적 절반 학살 + 전체 정지 2초)
      const re = state.relicEffects;
      if (re && re.deathDefiance > 0) {
        re.deathDefiance--;
        // 비-보스 적 절반 즉사 (가장 가까운 것부터)
        const toKill = Math.ceil(state.enemies.length * 0.5);
        const sorted = state.enemies.filter(e => !e.isBoss).sort((a, b) => a.radius - b.radius);
        for (let i = 0; i < toKill && i < sorted.length; i++) {
          damageEnemy(sorted[i], sorted[i].hp * 2);
        }
        // 살아남은 모든 적 2초 완전 정지 (slowFrames + timeStopped)
        const stopDur = 120;
        for (const e of state.enemies) {
          if (e.hp <= 0) continue;
          e.slowFrames = Math.max(e.slowFrames || 0, stopDur);
          e.timeStopped = state.t + stopDur;
        }
        shake(20, 30);
        SFX.combo();
        state.comboFlash = 60;
        state.comboFlashColor = '#ffd479';
        toast('🌅 영원의 빛 — 부활!');
      } else {
        endGame(`적이 ${maxAlive}마리를 넘김`, false);
      }
    }

    // 적 이동 + 특수 행동 처리
    const isDefenseMode = state.mode === 'defense';
    const defenseSlowMul = isDefenseMode ? (1 - (state.metaMods.defenseSlowBonus || 0)) : 1;
    for (const e of state.enemies) {
      // 🛑 완전 정지 (timeStopped) — 8개 능력의 "정지" 효과 실제 적용
      const fullyStopped = e.timeStopped && e.timeStopped > state.t;
      const slowMul = fullyStopped ? 0 : (e.slowFrames > 0 ? 0.35 : 1);
      if (e.slowFrames > 0) e.slowFrames--;
      if (isDefenseMode) {
        // 🏰 디펜스 모드 (TD): 경로 따라 셀→셀 이동 (다중경로 지원)
        e.rotation = (e.rotation || 0) + (e.rotSpeed || 0) * slowMul;
        const map = getActiveTDMap();
        const paths = getMapPaths(map);
        const myPath = paths[e.pathId || 0] || paths[0];
        const totalSegments = myPath.length - 1;
        if (e.pathIdx >= totalSegments) {
          // 본진 도달
          const armor = state.metaMods.towerArmor || 0;
          const dmg = e.isBoss ? Math.max(5, Math.floor(e.maxHp / 8)) : 1;
          const finalDmg = Math.max(1, Math.ceil(dmg * (1 - armor)));
          state.towerHP -= finalDmg;
          const last = myPath[myPath.length - 1];
          const lc = cellCenter(last.col, last.row);
          shake(e.isBoss ? 18 : 6, e.isBoss ? 12 : 4);
          spawnParticles(lc.x, lc.y, '#ff5b6e', e.isBoss ? 20 : 6);
          state.damageNumbers.push({
            x: lc.x, y: lc.y - 22, vy: -1.2,
            text: `-${finalDmg} HP`, color: '#ff5b6e', life: 40, size: e.isBoss ? 16 : 12,
          });
          e.hp = -1;
          e._reachedTower = true;
        } else {
          // 다음 셀로 이동
          const from = myPath[e.pathIdx];
          const to = myPath[e.pathIdx + 1];
          const fc = cellCenter(from.col, from.row);
          const tc = cellCenter(to.col, to.row);
          const segLen = Math.hypot(tc.x - fc.x, tc.y - fc.y);
          const moveSpeed = e.speed * 60 * slowMul * defenseSlowMul;  // 셀/초 → 픽셀/프레임
          e.pathT += moveSpeed / Math.max(1, segLen);
          if (e.pathT >= 1) {
            e.pathT = 0;
            e.pathIdx++;
          }
          // 보간 위치
          const t = Math.min(1, Math.max(0, e.pathT));
          e.x = fc.x + (tc.x - fc.x) * t;
          e.y = fc.y + (tc.y - fc.y) * t;
        }
      } else {
        // 표준 모드: 원래 공전 동작 유지
        e.angle += e.angularSpeed * slowMul;
        const dr = e.targetRadius - e.radius;
        if (Math.abs(dr) > 0.2) e.radius += Math.sign(dr) * 0.4 * slowMul;
        e.radiusChangeAt--;
        if (e.radiusChangeAt <= 0) {
          e.targetRadius = ENEMY_MIN_R + Math.random() * (ENEMY_MAX_R - ENEMY_MIN_R);
          e.radiusChangeAt = 90 + Math.floor(Math.random()*150);
        }
      }
      // 재생형: 2초 동안 데미지 안 받으면 매 frame +0.5% maxHp 회복
      if (e.behavior === 'regen' && (state.t - e.lastDamageAt) > 120 && e.hp < e.maxHp) {
        e.hp = Math.min(e.maxHp, e.hp + e.maxHp * 0.005);
        if (Math.random() < 0.1) {
          const [ex, ey] = enemyXY(e);
          spawnParticles(ex, ey, '#88ff88', 1);
        }
      }
    }
    // 🏰 디펜스 모드: 타워 HP 0 → 게임 오버
    if (isDefenseMode && state.towerHP <= 0 && !state.gameOver) {
      // 🌅 부활 (강화소 메타 또는 영원의 빛 유물)
      const reviveAvailable = (state.metaMods.defenseRevive > 0 && !state.defenseReviveUsed) ||
                              (state.relicEffects && state.relicEffects.deathDefiance > 0);
      if (reviveAvailable) {
        if (state.metaMods.defenseRevive > 0 && !state.defenseReviveUsed) {
          state.defenseReviveUsed = true;
        } else if (state.relicEffects.deathDefiance > 0) {
          state.relicEffects.deathDefiance--;
        }
        state.towerHP = state.towerMaxHP;  // 풀회복
        // 모든 적 2초 정지
        for (const e of state.enemies) {
          if (e.hp <= 0) continue;
          e.slowFrames = Math.max(e.slowFrames || 0, 120);
          e.timeStopped = state.t + 120;
        }
        shake(25, 30);
        SFX.combo();
        state.comboFlash = 60;
        state.comboFlashColor = '#ffd479';
        toast('🌅 부활! 타워 HP 풀회복');
      } else {
        endGame('타워가 파괴됨', false);
      }
    }
    // 보스 능력 패턴 처리
    updateBossPatterns();

    // 🛡 v254 — 패시브 공유 슬롯 프레임 리셋 (능력 제거 시 stale 값 잔존 방지)
    //   여러 능력/조합이 같은 metaMods 슬롯에 쓸 때 안전한 max/min 머지 가능하게 함
    resetSharedPassiveSlots();
    // ⚡ v280 — 발사 속도 강화: 액티브 쿨다운 프레임당 추가 차감 (haste 메타판)
    const _fireRate = (state.metaMods && state.metaMods.fireRateBonus) || 0;
    if (_fireRate > 0) {
      if (state.mode === 'defense') {
        for (const t of (state.towers || [])) {
          if (t.ab && t.ab.cooldown > 0) t.ab.cooldown -= _fireRate;
        }
      } else {
        for (const a of state.tower.abilities) {
          if (!ABILITY_DEFS[a.id].isPassive && a.cooldown > 0) a.cooldown -= _fireRate;
        }
      }
    }
    // 💀 v267 — 사신 봉인 중이면 능력 tick 전체 스킵 (발사/패시브 정지)
    const _abilitySealed = state.abilitySealUntil > state.t;
    // 능력 tick — 모드별 분기
    if (!_abilitySealed && state.mode === 'defense') {
      // 🏰 TD: 각 배치 타워별로 CX/CY 스왑 후 ability tick
      // 적이 한 마리도 없으면 능력 발동 자체를 차단 (시각적으로도 깔끔 + 헛 발사 방지)
      const anyEnemyAlive = (state.enemies || []).some(e => e.hp > 0);
      for (const tower of (state.towers || [])) {
        const def = ABILITY_DEFS[tower.ab.id];
        if (!def) continue;
        // 적 없음 → 능력 tick 스킵 (탄환/이펙트 발사 X). 단, 쿨다운 진행은 허용해도 무방하지만
        // 발사 자체를 막으면 충분.
        if (!anyEnemyAlive) continue;
        state.currentAbilityTier = def.isTriple ? 'triple' : (def.isCombo ? 'combo' : 'basic');
        state.currentAbilityId = tower.ab.id;
        // 🎯 TD 모드: 능력별 사거리 캡 — findNearestEnemy/findFarthestEnemy 에서 자동 적용됨
        state.currentAbilityRange = getAbilityRange(tower.ab.id, tower.ab.level);
        const oldCX = CX, oldCY = CY;
        CX = tower.x; CY = tower.y;
        try { def.tick(tower.ab); }
        catch (e) { console.warn('tower tick error', tower.ab.id, e); }
        CX = oldCX; CY = oldCY;
        state.currentAbilityRange = null;
        // 💎 흡혈의 망토 — 능력 발동 시 골드
        const re = state.relicEffects;
        if (re && re.abilityUseGold > 0) {
          re.abilityUseCounter = (re.abilityUseCounter || 0) + 1;
          if (re.abilityUseCounter >= 120) {
            re.abilityUseCounter = 0;
            const gain = re.abilityUseGold * state.towers.length;
            state.gold += gain;
            re.goldEarnedTotal = (re.goldEarnedTotal || 0) + gain;
          }
        }
      }
      // 패시브 능력은 중앙 타워에 (state.tower.abilities) — 패시브만 슬롯 차지
      for (const ab of state.tower.abilities) {
        const def = ABILITY_DEFS[ab.id];
        if (!def || !def.isPassive) continue;
        state.currentAbilityId = ab.id;
        def.tick(ab);
      }
    } else if (!_abilitySealed) {
      // 표준 모드 — 기존 동작
      for (const ab of state.tower.abilities) {
        const def = ABILITY_DEFS[ab.id];
        state.currentAbilityTier = def.isTriple ? 'triple' : (def.isCombo ? 'combo' : 'basic');
        state.currentAbilityId = ab.id;
        def.tick(ab);
        const re = state.relicEffects;
        if (re && re.abilityUseGold > 0) {
          re.abilityUseCounter = (re.abilityUseCounter || 0) + 1;
          if (re.abilityUseCounter >= 120) {
            re.abilityUseCounter = 0;
            const gain = re.abilityUseGold * state.tower.abilities.length;
            state.gold += gain;
            re.goldEarnedTotal = (re.goldEarnedTotal || 0) + gain;
          }
        }
      }
    }
    state.currentAbilityId = null;
    // 💎 천둥의 신 (Epic) — 3초마다 가장 강한 적에게 번개
    if (state.relicEffects && state.relicEffects.thunderGod) {
      state.relicEffects.thunderTimer = (state.relicEffects.thunderTimer || 0) - 1;
      if (state.relicEffects.thunderTimer <= 0) {
        state.relicEffects.thunderTimer = 180; // 3초
        let target = null, bestHp = -1;
        for (const e of state.enemies) {
          if (e.hp <= 0) continue;
          const _s = e.isBoss ? e.hp + 1e9 : e.hp;
          if (_s > bestHp) { bestHp = _s; target = e; }
        }
        if (target) {
          const dmg = Math.ceil(target.maxHp * 0.12);
          damageEnemy(target, dmg);
          const [tx, ty] = enemyXY(target);
          for (let k = 0; k < 14; k++) spawnParticles(tx, ty, '#ffe070', 1);
          // 번개 줄기 그리기 위한 데이터 (잠시 후 사라짐)
          state.thunderStrikes = state.thunderStrikes || [];
          state.thunderStrikes.push({ x: tx, y: ty, life: 12 });
          shake(6, 5);
        }
      }
    }
    // 🌌 v245 — 종말의 모래 (Misaki 모래시계 ★8 각성 2단계) — 30초마다 모든 적 3초 정지
    if (state.relicEffects && state.relicEffects.ancientPeriodicStop) {
      state.relicEffects.ancientPeriodicStopTimer = (state.relicEffects.ancientPeriodicStopTimer || 0) - 1;
      if (state.relicEffects.ancientPeriodicStopTimer <= 0) {
        state.relicEffects.ancientPeriodicStopTimer = 1800; // 30초
        // 모든 적 3초 정지 (기존 자비의 망토 패턴 동일)
        const fr = 180;
        for (const en of state.enemies) {
          if (en.hp <= 0) continue;
          en.slowFrames = Math.max(en.slowFrames || 0, fr);
          if (!en.isBoss) en.timeStopped = state.t + fr;
        }
        toast('⌛✨ 종말의 모래');
        state.comboFlash = 30;
        state.comboFlashColor = '#ff88ff';
        shake(8, 12);
      }
    }
    // 번개 줄기 life 관리
    if (state.thunderStrikes) {
      for (const t of state.thunderStrikes) t.life--;
      compactInPlace(state.thunderStrikes, _alivePredLife);   // 🚀 GC 압박 감소
    }
    state.currentAbilityTier = null;

    // 탄환 이동 + (리더 추종 or 약한 유도) + 충돌
    for (const b of state.bullets) {
      // 리더 추종: 사이드 탄환은 리더 진행 방향 + 자기 오프셋 각도로 맞춤
      if (b.leader && b.leader.life > 0) {
        const leaderAng = Math.atan2(b.leader.vy, b.leader.vx);
        const myAng = leaderAng + b.offsetAngle;
        const sp = Math.hypot(b.vx, b.vy);
        b.vx = Math.cos(myAng) * sp;
        b.vy = Math.sin(myAng) * sp;
      }
      // 약한 유도: 타깃이 살아있으면 속도 방향을 살짝 보정
      else if (b.target && b.target.hp > 0) {
        const [tx, ty] = enemyXY(b.target);
        const curAng  = Math.atan2(b.vy, b.vx);
        const wantAng = Math.atan2(ty - b.y, tx - b.x);
        let diff = wantAng - curAng;
        while (diff >  Math.PI) diff -= Math.PI * 2;
        while (diff < -Math.PI) diff += Math.PI * 2;
        const turn = 0.06;
        const c = Math.max(-turn, Math.min(turn, diff));
        const a = curAng + c;
        const sp = Math.hypot(b.vx, b.vy);
        b.vx = Math.cos(a) * sp;
        b.vy = Math.sin(a) * sp;
      }
      const prevX = b.x, prevY = b.y;
      b.x += b.vx; b.y += b.vy; b.life--;
      // 🏰 디펜스 모드 (TD): 캔버스 밖 나가면 죽음
      if (state.mode === 'defense') {
        if (b.x < -20 || b.x > W + 20 || b.y < -20 || b.y > H + 20) b.life = 0;
      } else {
        const dx = b.x - CX_BASE, dy = b.y - CY_BASE;
        if (dx*dx + dy*dy > (ARENA_R+30)*(ARENA_R+30)) b.life = 0;
      }
      if (b.life <= 0) continue;
      for (const e of state.enemies) {
        if (e.hp <= 0) continue;
        const [ex, ey] = enemyXY(e);
        const r = e.size + 2;
        if ((b.x-ex)*(b.x-ex) + (b.y-ey)*(b.y-ey) < r*r) {
          // 탄환 위계 정보를 임시로 복원해서 데미지 적용 (콤보/트리플 보너스)
          const savedTier = state.currentAbilityTier;
          const savedId   = state.currentAbilityId;
          if (b.tier && b.tier !== 'basic') state.currentAbilityTier = b.tier;
          if (b.sourceId) state.currentAbilityId = b.sourceId;  // 📊 통계 귀속
          damageEnemy(e, b.dmg);
          spawnParticles(ex, ey, b.color || '#ffd479', 2);
          // 폭발탄: 추가 광역 데미지
          if (b.explodeRadius) {
            for (const e2 of state.enemies) {
              if (e2 === e || e2.hp <= 0) continue;
              const [ex2, ey2] = enemyXY(e2);
              if ((b.x-ex2)*(b.x-ex2) + (b.y-ey2)*(b.y-ey2) < b.explodeRadius * b.explodeRadius) {
                damageEnemy(e2, b.dmg);
                spawnParticles(ex2, ey2, b.color || '#ff8866', 2);
              }
            }
            if (b.explodeAb) b.explodeAb.explosions.push({ x: b.x, y: b.y, r: b.explodeRadius, life: 12 });
          }
          state.currentAbilityTier = savedTier;
          state.currentAbilityId   = savedId;
          // 슬로우 적용탄
          if (b.slow) e.slowFrames = Math.max(e.slowFrames || 0, b.slow);
          b.life = 0;
          break;
        }
      }
    }

    // 🚀 인플레이스 compaction — 4개 핫 배열에서 .filter 새 배열 할당 제거
    compactInPlace(state.bullets,  _alivePredLife);
    compactInPlace(state.enemies,  _alivePredEnemy);
    for (const p of state.particles) { p.x+=p.vx; p.y+=p.vy; p.vx*=0.92; p.vy*=0.92; p.life--; }
    compactInPlace(state.particles, _alivePredLife);
    // 데미지 숫자 부유
    for (const d of state.damageNumbers) { d.y += d.vy; d.vy *= 0.95; d.life--; }
    compactInPlace(state.damageNumbers, _alivePredLife);
    // 콤보 카드 라이프
    if (state.comboReveal) {
      state.comboReveal.life--;
      if (state.comboReveal.life <= 0) state.comboReveal = null;
    }
    // 웨이브 클리어 텍스트
    if (state.waveClearText) {
      state.waveClearText.life--;
      if (state.waveClearText.life <= 0) state.waveClearText = null;
    }
    // 🌟 v220 — 라운드 클리어 골드 sweep
    if (state.roundClearSweep) {
      state.roundClearSweep.life--;
      if (state.roundClearSweep.life <= 0) state.roundClearSweep = null;
    }
    // 🐲 v220 — 보스 등장 워닝
    if (state.bossWarning) {
      state.bossWarning.life--;
      if (state.bossWarning.life <= 0) state.bossWarning = null;
    }
    // 화면 흔들림 잔여 감소
    if (state.shakeFrames > 0) {
      state.shakeFrames--;
      state.shakeStrength *= 0.88;
    } else {
      state.shakeStrength = 0;
    }
    if (state.comboFlash > 0) state.comboFlash--;
    updateBackground();
    // 🚀 renderStats()는 rAF 루프에서 프레임당 1회만 호출 (배속 시 2-3중 호출 제거) — loop() 참고
  }

  // ===== 유틸 =====
  // 🚀 enemyXY — 결과를 재사용 버퍼에 써서 매 호출마다 새 배열 할당을 제거.
  //    호출처는 전부 `const [ex, ey] = enemyXY(e)` 형태로 즉시 destructure 하므로
  //    버퍼가 다음 호출 때 덮어써져도 로컬 변수에 이미 값이 복사돼 안전함.
  //    GC 압박이 가장 큰 핫스팟 (한 프레임에 수천 번 호출).
  const _enemyXYBuf = [0, 0];
  function enemyXY(e){
    // 🚀 틱(state.t) 단위 메모 — 같은 틱에 같은 적을 (탄환×적)·(능력×적) 쌍마다 재계산하던 cos/sin 제거.
    //    틱 중간에 위치를 바꾸는 코드(넉백/끌어당김/텔레포트)는 e._xyT = -1 로 무효화함.
    if (e._xyT === state.t) {
      _enemyXYBuf[0] = e._fx; _enemyXYBuf[1] = e._fy;
      return _enemyXYBuf;
    }
    let fx, fy;
    // 🏰 디펜스 모드: 직교좌표 직접 반환
    if (e._cart) { fx = e.x; fy = e.y; }
    else {
      fx = CX + Math.cos(e.angle)*e.radius;
      fy = CY + Math.sin(e.angle)*e.radius;
    }
    e._fx = fx; e._fy = fy; e._xyT = state.t;
    _enemyXYBuf[0] = fx; _enemyXYBuf[1] = fy;
    return _enemyXYBuf;
  }
  // 🏰 타워 발사 위치 — TD 모드는 "현재 ability 컨텍스트"의 타워 위치 (CX 자체가 swap됨)
  function towerX() { return CX; }
  function towerY() { return CY; }
  // 🎭 가챠 캐릭터 개성 모티프 — 능력 id별로 음표/꽃잎/나비/달/태양/물방울/소용돌이가 떠다님
  const MOTIF_THEME = {
    starSong:'note', cosmicChorus:'note', celestialSymphony:'note', celestialEcho:'note', sirensSong:'note',           // 아리아
    timeButterfly:'fly', timePrison:'fly', eternalMoment:'fly', voidStop:'fly', temporalLoop:'fly', paradoxFreeze:'fly', // 미사키
    sakuraSlash:'petal', sakuraStorm:'petal', sakuraInferno:'petal', petalStorm:'petal', cherrySingularity:'petal',     // 사쿠라
    moonShot:'moon', moonFrostArrow:'moon', moonBombardment:'moon', lunarRain:'moon', eclipsePiercer:'moon',           // 루나
    sunspot:'sun', solarStorm:'sun', stellarCollapse:'sun',                                                            // 솔라 (항성붕괴=솔라 트리플)
    torpedo:'drop', frozenTorpedo:'drop', deepSeaBarrage:'drop',                                                        // 마린
    pullField:'swirl', voidIceVortex:'swirl', voidNova:'swirl',                                                        // 그래비타스
  };
  const MOTIF_COL = { note:'#ffe070', fly:'#cc88ff', petal:'#ff9ecb', moon:'#bcd8ff', sun:'#ffb347', drop:'#66c2e0', swirl:'#b48cf0' };
  const _motifs = [];
  // 🌸 사쿠라 — 은은한 수채화 벚꽃 안개 (NORMAL 블렌드 = 부드럽게 번짐). 능력 id 셋.
  const SAKURA_IDS = { sakuraSlash:1, sakuraStorm:1, sakuraInferno:1, petalStorm:1, cherrySingularity:1 };
  const _sakuraHaze = [];
  // 🎤 아리아 — 엔젤릭버스터풍: 음표 + 골드 별 + 핑크 하트가 함께 반짝이며 떠오름
  const ARIA_IDS = { starSong:1, cosmicChorus:1, celestialSymphony:1, celestialEcho:1, sirensSong:1 };
  // 🦋 미사키 공유 — 섬세한 나비 (원점 기준, 호출자가 translate)
  function butterflyWings(wing, sc) {
    sc = sc || 1; ctx.save(); ctx.scale(wing * sc, sc);
    const wg = ctx.createLinearGradient(-6, -7, 6, 0); wg.addColorStop(0, '#b070ff'); wg.addColorStop(1, '#e8c2ff');
    ctx.fillStyle = wg;
    ctx.beginPath(); ctx.ellipse(-4, -2.5, 4.2, 5.2, 0.5, 0, Math.PI*2); ctx.fill();
    ctx.beginPath(); ctx.ellipse(4, -2.5, 4.2, 5.2, -0.5, 0, Math.PI*2); ctx.fill();
    ctx.fillStyle = '#c98cff';
    ctx.beginPath(); ctx.ellipse(-3, 3.2, 3, 3.6, 0.3, 0, Math.PI*2); ctx.fill();
    ctx.beginPath(); ctx.ellipse(3, 3.2, 3, 3.6, -0.3, 0, Math.PI*2); ctx.fill();
    ctx.fillStyle = '#fff0ff'; ctx.beginPath(); ctx.arc(-4, -3, 1, 0, 7); ctx.arc(4, -3, 1, 0, 7); ctx.fill();
    ctx.restore();
  }
  function drawTimeButterfly(b, glowCol, sc) {
    sc = sc || 1; const wing = Math.sin(b.phase * 4) * 0.45 + 0.85;
    for (let g = 2; g >= 1; g--) { ctx.save(); ctx.translate((b.x||0) - (b.vx||0)*g*1.6, (b.y||0) - (b.vy||0)*g*1.6); ctx.globalAlpha = 0.15 * g; butterflyWings(wing, sc); ctx.restore(); }
    ctx.save(); ctx.translate(b.x||0, b.y||0);
    ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.globalAlpha = 0.8; ctx.drawImage(getGlowSprite(glowCol || '#cc88ff'), -11*sc, -10*sc, 22*sc, 20*sc); ctx.restore();
    butterflyWings(wing, sc);
    ctx.strokeStyle = '#cdb0ff'; ctx.lineWidth = 0.7*sc;
    ctx.beginPath(); ctx.moveTo(-0.5*sc,-4*sc); ctx.quadraticCurveTo(-2*sc,-7*sc,-3*sc,-7.5*sc); ctx.moveTo(0.5*sc,-4*sc); ctx.quadraticCurveTo(2*sc,-7*sc,3*sc,-7.5*sc); ctx.stroke();
    ctx.fillStyle = '#3a2a5a'; ctx.beginPath(); ctx.ellipse(0, 0.5*sc, 1*sc, 5*sc, 0, 0, 7); ctx.fill();
    ctx.restore(); ctx.globalAlpha = 1;
  }
  // ⏰ 미사키 공유 — 회전하는 시계 룬 마법진 (원점 기준)
  function drawTimeCircle(cx, cy, R, spin, alpha, col) {
    col = col || '#c8a0ff';
    ctx.save(); ctx.translate(cx, cy); ctx.globalCompositeOperation = 'lighter'; ctx.globalAlpha = alpha;
    // 부드러운 글로우 링 (얇은 와이어프레임 느낌 제거 — 빛나는 마법진)
    ctx.save(); ctx.globalAlpha = alpha * 0.28; ctx.strokeStyle = col; ctx.lineWidth = 5;
    ctx.beginPath(); ctx.arc(0, 0, R, 0, Math.PI*2); ctx.stroke(); ctx.restore();
    ctx.strokeStyle = col; ctx.lineWidth = 1.6;
    ctx.beginPath(); ctx.arc(0, 0, R, 0, Math.PI*2); ctx.stroke();
    ctx.beginPath(); ctx.arc(0, 0, R*0.74, 0, Math.PI*2); ctx.stroke();
    // 시계 눈금
    ctx.save(); ctx.rotate(spin); ctx.lineWidth = 1.2;
    for (let k=0;k<12;k++){ const a=k*Math.PI/6, r1=R*0.74, r2=R*(k%3===0?0.9:0.84); ctx.beginPath(); ctx.moveTo(Math.cos(a)*r1,Math.sin(a)*r1); ctx.lineTo(Math.cos(a)*r2,Math.sin(a)*r2); ctx.stroke(); }
    ctx.restore();
    // 반대로 도는 룬 삼각형
    ctx.save(); ctx.rotate(-spin*1.4); ctx.globalAlpha = alpha*0.8;
    ctx.beginPath(); for (let k=0;k<3;k++){ const a=-Math.PI/2+k*2*Math.PI/3; const px=Math.cos(a)*R*0.66, py=Math.sin(a)*R*0.66; k?ctx.lineTo(px,py):ctx.moveTo(px,py);} ctx.closePath(); ctx.stroke();
    ctx.beginPath(); for (let k=0;k<3;k++){ const a=Math.PI/2+k*2*Math.PI/3; const px=Math.cos(a)*R*0.66, py=Math.sin(a)*R*0.66; k?ctx.lineTo(px,py):ctx.moveTo(px,py);} ctx.closePath(); ctx.stroke();
    ctx.restore();
    ctx.restore(); ctx.globalAlpha = 1;
  }
  // 🌀 중력/공허 에너지장 — "선이 빙빙" 나선 대신: 부드러운 글로우 + 수축 리플(회전X) + 빨려드는 글로우 점 + 펄스 코어 (세련, 탑다운)
  function drawVoidField(cx, cy, R, hex, opts) {
    opts = opts || {};
    const n = parseInt(hex.slice(1), 16), Rc = (n>>16)&255, Gc = (n>>8)&255, Bc = n&255, rgb = `${Rc},${Gc},${Bc}`;
    const core = opts.core || '#e6c8ff', coreR = opts.coreR || 22, pc = opts.particles == null ? 16 : opts.particles;
    ctx.save(); ctx.translate(cx, cy); ctx.globalCompositeOperation = 'lighter';
    // 인력 비네트 (부드럽게)
    const fg = ctx.createRadialGradient(0, 0, R*0.18, 0, 0, R);
    fg.addColorStop(0, `rgba(${rgb},0.15)`); fg.addColorStop(0.7, `rgba(${rgb},0.05)`); fg.addColorStop(1, `rgba(${rgb},0)`);
    ctx.fillStyle = fg; ctx.beginPath(); ctx.arc(0, 0, R, 0, Math.PI*2); ctx.fill();
    // 수축 중력 리플 (3겹, 안쪽으로 — 회전 아님)
    for (let i = 0; i < 3; i++) {
      const ph = (state.t * 1.1 + i * 52) % 156, rr2 = R * (0.95 - ph/156 * 0.78), fade = 1 - ph/156;
      if (rr2 < 2) continue;
      ctx.globalAlpha = fade * 0.30; ctx.strokeStyle = `rgb(${rgb})`; ctx.lineWidth = 1.8;
      ctx.beginPath(); ctx.arc(0, 0, rr2, 0, Math.PI*2); ctx.stroke();
    }
    // 빨려드는 글로우 점 (선 아님 — 안쪽으로 스트리밍)
    for (let k = 0; k < pc; k++) {
      const t = (state.t * 0.011 + k / pc) % 1, r = (R*0.82) * (1 - t) + coreR*0.5, a = k * (Math.PI*2/pc) + (1 - t) * 4.5;
      ctx.globalAlpha = 0.25 + t * 0.6; ctx.fillStyle = `rgb(${rgb})`;
      ctx.beginPath(); ctx.arc(Math.cos(a)*r, Math.sin(a)*r, 1.3 + t * 1.5, 0, Math.PI*2); ctx.fill();
    }
    ctx.globalAlpha = 1;
    // 코어 (밝은 펄스 글로우)
    const pulse = 1 + Math.sin(state.t * 0.08) * 0.12;
    const cg = ctx.createRadialGradient(0, 0, 1, 0, 0, coreR * pulse);
    cg.addColorStop(0, core); cg.addColorStop(0.5, `rgba(${rgb},0.55)`); cg.addColorStop(1, `rgba(${rgb},0)`);
    ctx.fillStyle = cg; ctx.beginPath(); ctx.arc(0, 0, coreR * pulse, 0, Math.PI*2); ctx.fill();
    if (opts.darkCore) { ctx.globalCompositeOperation = 'source-over'; ctx.fillStyle = opts.darkCore; ctx.beginPath(); ctx.arc(0, 0, coreR * 0.42, 0, Math.PI*2); ctx.fill(); }
    ctx.restore(); ctx.globalAlpha = 1;
  }
  // 💥 가산 글로우 폭발 — 부드러운 블룸 + 링 (밋밋한 평면 원 대체). hex 색상 1개.
  function glowBurst(x, y, r, a, hex) {
    if (r <= 0 || a <= 0) return;
    const n = parseInt(hex.slice(1), 16), R = (n>>16)&255, G = (n>>8)&255, B = n&255;
    ctx.save(); ctx.globalCompositeOperation = 'lighter';
    ctx.globalAlpha = a * 0.55;
    const g = ctx.createRadialGradient(x, y, 0, x, y, r);
    g.addColorStop(0, 'rgba(255,255,255,0.7)'); g.addColorStop(0.45, `rgba(${R},${G},${B},0.45)`); g.addColorStop(1, `rgba(${R},${G},${B},0)`);
    ctx.fillStyle = g; ctx.beginPath(); ctx.arc(x, y, r, 0, Math.PI*2); ctx.fill();
    ctx.globalAlpha = a * 0.9; ctx.strokeStyle = hex; ctx.lineWidth = 2.2; ctx.beginPath(); ctx.arc(x, y, r, 0, Math.PI*2); ctx.stroke();
    ctx.restore(); ctx.globalAlpha = 1;
  }
  // 🪃 회전 부메랑(십자 날) — 가산 글로우 + 모션 잔상 + 밝은 코어 (base boomerang 룩 통일)
  function drawSpinBoomerang(b, len, col, glowCol) {
    const w = Math.max(2, len * 0.26);
    ctx.save(); ctx.translate(b.x, b.y);
    ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.globalAlpha = 0.8; ctx.drawImage(getGlowSprite(glowCol || col), -len*1.5, -len*1.5, len*3, len*3); ctx.restore();
    ctx.rotate(b.rotation || 0);
    // 모션 잔상
    ctx.globalAlpha = 0.28; ctx.fillStyle = col; ctx.fillRect(-len*1.2, -w*0.7, len*2.4, w*1.4); ctx.fillRect(-w*0.7, -len*1.2, w*1.4, len*2.4);
    // 본체 + 밝은 코어
    ctx.globalAlpha = 1; ctx.fillStyle = col; ctx.fillRect(-len, -w, len*2, w*2); ctx.fillRect(-w, -len, w*2, len*2);
    const w2 = w*0.5; ctx.fillStyle = '#fff6dc'; ctx.fillRect(-len*0.78, -w2, len*1.56, w2*2); ctx.fillRect(-w2, -len*0.78, w2*2, len*1.56);
    ctx.fillStyle = '#ffffff'; ctx.fillRect(-w*0.8, -w*0.8, w*1.6, w*1.6);
    ctx.restore(); ctx.globalAlpha = 1;
  }
  // ▢ 둥근 사각형 경로 (roundRect 폴백 포함) — 호출 후 fill()/stroke()
  function rr(x, y, w, h, r) {
    if (ctx.roundRect) { ctx.beginPath(); ctx.roundRect(x, y, w, h, r); return; }
    r = Math.min(r, w/2, h/2);
    ctx.beginPath();
    ctx.moveTo(x+r, y); ctx.arcTo(x+w, y, x+w, y+h, r); ctx.arcTo(x+w, y+h, x, y+h, r);
    ctx.arcTo(x, y+h, x, y, r); ctx.arcTo(x, y, x+w, y, r); ctx.closePath();
  }
  // 🌑 발밑 타원 그림자 (접지감) — 납작한 라디얼
  // 🚀 스프라이트 1회 베이크 후 drawImage — 적마다 매 프레임 그라디언트 생성 제거 (최대 핫스팟)
  //    스톱(al, al*0.5, 0)이 al에 선형이라 알파 1.0으로 굽고 globalAlpha=al 곱하면 픽셀 동일.
  let _shadowSpriteCv = null;
  function _shadowSprite() {
    if (_shadowSpriteCv) return _shadowSpriteCv;
    const S = 128, c = document.createElement('canvas'); c.width = c.height = S;
    const g2 = c.getContext('2d');
    const g = g2.createRadialGradient(S/2, S/2, 0, S/2, S/2, S/2);
    g.addColorStop(0, 'rgba(0,0,0,1)'); g.addColorStop(0.65, 'rgba(0,0,0,0.5)'); g.addColorStop(1, 'rgba(0,0,0,0)');
    g2.fillStyle = g; g2.beginPath(); g2.arc(S/2, S/2, S/2, 0, Math.PI*2); g2.fill();
    _shadowSpriteCv = c; return c;
  }
  function castShadow(x, y, w, al) {
    al = al == null ? 0.3 : al;
    ctx.globalAlpha = al;
    ctx.drawImage(_shadowSprite(), x - w, y - w * 0.42, w * 2, w * 0.84);
    ctx.globalAlpha = 1;
  }
  function drawMotifShape(kind, s, col, ph) {
    ph = ph || 0;
    ctx.fillStyle = col; ctx.strokeStyle = '#ffffff'; ctx.lineWidth = 1; ctx.lineJoin = 'round'; ctx.lineCap = 'round';
    if (kind === 'note') {
      // 까딱이는 음표 — 머리 살짝 흔들림 + 작은 반짝임
      ctx.beginPath(); ctx.ellipse(-s*0.25, s*0.35, s*0.3, s*0.22, -0.4, 0, 7); ctx.fill();
      ctx.lineWidth = s*0.14; ctx.strokeStyle = col; ctx.beginPath(); ctx.moveTo(s*0.02, s*0.3); ctx.lineTo(s*0.02, -s*0.55); ctx.stroke();
      ctx.lineWidth = s*0.2; ctx.beginPath(); ctx.moveTo(s*0.02, -s*0.55); ctx.quadraticCurveTo(s*0.5, -s*0.45, s*0.36, -s*0.08); ctx.stroke();
      const tw = 0.4 + 0.6 * Math.abs(Math.sin(ph * 1.3));
      ctx.globalAlpha *= tw; ctx.fillStyle = '#fff'; ctx.beginPath(); ctx.arc(s*0.42, -s*0.6, s*0.1, 0, 7); ctx.fill(); ctx.globalAlpha /= tw;
    } else if (kind === 'fly') {
      // 🦋 날갯짓 — 날개가 펴졌다 접혔다 (가로 스케일 진동)
      const flap = 0.45 + 0.55 * Math.abs(Math.sin(ph * 1.6));
      ctx.save(); ctx.scale(flap, 1);
      ctx.beginPath(); ctx.ellipse(-s*0.3, -s*0.08, s*0.3, s*0.42, 0.5, 0, 7); ctx.ellipse(-s*0.24, s*0.3, s*0.22, s*0.28, 0.3, 0, 7); ctx.fill();
      ctx.beginPath(); ctx.ellipse(s*0.3, -s*0.08, s*0.3, s*0.42, -0.5, 0, 7); ctx.ellipse(s*0.24, s*0.3, s*0.22, s*0.28, -0.3, 0, 7); ctx.fill();
      ctx.restore();
      // 몸통
      ctx.fillStyle = col; ctx.beginPath(); ctx.ellipse(0, s*0.08, s*0.06, s*0.34, 0, 0, 7); ctx.fill();
    } else if (kind === 'petal') {
      ctx.beginPath(); ctx.moveTo(0, -s*0.5); ctx.quadraticCurveTo(s*0.45, 0, 0, s*0.5); ctx.quadraticCurveTo(-s*0.45, 0, 0, -s*0.5); ctx.fill();
      ctx.globalAlpha *= 0.5; ctx.fillStyle = '#fff'; ctx.beginPath(); ctx.moveTo(0, -s*0.28); ctx.quadraticCurveTo(s*0.18, 0, 0, s*0.28); ctx.quadraticCurveTo(-s*0.18, 0, 0, -s*0.28); ctx.fill(); ctx.globalAlpha *= 2;
    } else if (kind === 'moon') {
      ctx.beginPath(); ctx.arc(0, 0, s*0.5, 0.6, 5.0, false); ctx.arc(s*0.22, -s*0.08, s*0.45, 5.0, 0.6, true); ctx.closePath(); ctx.fill();
      // 반짝이는 별빛
      const tw = 0.3 + 0.7 * Math.abs(Math.sin(ph));
      ctx.globalAlpha *= tw; ctx.fillStyle = '#fff'; ctx.beginPath(); ctx.arc(-s*0.18, -s*0.28, s*0.08, 0, 7); ctx.fill(); ctx.globalAlpha /= tw;
    } else if (kind === 'sun') {
      ctx.beginPath(); ctx.arc(0, 0, s*0.3, 0, 7); ctx.fill();
      ctx.strokeStyle = col; ctx.lineWidth = s*0.13; const rr = s*0.62 + Math.sin(ph*1.5)*s*0.06; for (let i=0;i<8;i++){ const a=i/8*Math.PI*2; ctx.beginPath(); ctx.moveTo(Math.cos(a)*s*0.42, Math.sin(a)*s*0.42); ctx.lineTo(Math.cos(a)*rr, Math.sin(a)*rr); ctx.stroke(); }
    } else if (kind === 'drop') {
      ctx.beginPath(); ctx.moveTo(0, -s*0.55); ctx.quadraticCurveTo(s*0.42, s*0.15, 0, s*0.5); ctx.quadraticCurveTo(-s*0.42, s*0.15, 0, -s*0.55); ctx.fill();
    } else if (kind === 'star') {
      // ⭐ 5각 별 (아리아) — 살짝 맥동
      const sc = 1 + Math.sin(ph*1.4)*0.12; ctx.save(); ctx.scale(sc, sc);
      ctx.beginPath(); for (let i=0;i<10;i++){ const a=-Math.PI/2 + i*Math.PI/5, rr=(i%2?s*0.22:s*0.55); const px=Math.cos(a)*rr, py=Math.sin(a)*rr; i?ctx.lineTo(px,py):ctx.moveTo(px,py);} ctx.closePath(); ctx.fill();
      ctx.restore();
    } else if (kind === 'heart') {
      // 💗 하트 (아리아) — 살짝 두근
      const sc = 1 + Math.sin(ph*1.6)*0.14; ctx.save(); ctx.scale(sc, sc);
      ctx.beginPath(); ctx.moveTo(0, s*0.42); ctx.bezierCurveTo(s*0.55, -s*0.05, s*0.28, -s*0.5, 0, -s*0.16); ctx.bezierCurveTo(-s*0.28, -s*0.5, -s*0.55, -s*0.05, 0, s*0.42); ctx.fill();
      ctx.restore();
    } else { // swirl (gravity)
      ctx.strokeStyle = col; ctx.lineWidth = s*0.16; ctx.beginPath();
      for (let i=0;i<24;i++){ const t=i/24*Math.PI*2.6 + ph*0.3, r=s*0.08+t*s*0.12; const px=Math.cos(t)*r, py=Math.sin(t)*r; i?ctx.lineTo(px,py):ctx.moveTo(px,py);} ctx.stroke();
    }
  }
  function drawMotifFx() {
    // 🌸 수채화 벚꽃 안개 — 부드럽게 번지는 연분홍 구름 (꽃잎보다 먼저, NORMAL 블렌드)
    for (let i = _sakuraHaze.length - 1; i >= 0; i--) {
      const h = _sakuraHaze[i];
      h.r += h.gr; h.life--;
      if (h.life <= 0) { _sakuraHaze.splice(i, 1); continue; }
      const k = h.life / h.max;
      const g = ctx.createRadialGradient(h.x, h.y, 0, h.x, h.y, h.r);
      g.addColorStop(0, `rgba(255,190,220,${k * 0.16})`); g.addColorStop(0.6, `rgba(255,170,205,${k * 0.08})`); g.addColorStop(1, 'rgba(255,190,220,0)');
      ctx.fillStyle = g; ctx.beginPath(); ctx.arc(h.x, h.y, h.r, 0, Math.PI*2); ctx.fill();
    }
    for (let i = _motifs.length - 1; i >= 0; i--) {
      const m = _motifs[i];
      if (m.phase === undefined) { m.phase = Math.random()*6.28; m.pv = 0.12 + Math.random()*0.1; }
      m.phase += m.pv;
      // 🍃 종류별 자연스러운 움직임 (정적 X)
      if (m.kind === 'petal') {
        // 나풀나풀 — 좌우로 흔들리며 떨어지듯 회전 wobble
        m.x += Math.sin(m.phase) * 0.7; m.rot += m.vr + Math.sin(m.phase*1.3) * 0.05;
      } else if (m.kind === 'fly') {
        // 나비 — 위빙 비행 경로
        m.x += Math.sin(m.phase*1.5) * 1.0; m.y += Math.cos(m.phase*0.8) * 0.35; m.rot += m.vr*0.4;
      } else if (m.kind === 'note') {
        // 음표 — 까딱까딱 좌우 흔들림 + 살짝 기울기
        m.x += Math.sin(m.phase) * 0.55; m.rot = Math.sin(m.phase*0.7) * 0.3;
      } else if (m.kind === 'moon') {
        m.x += Math.sin(m.phase*0.6) * 0.35; m.rot += m.vr*0.5;
      } else if (m.kind === 'star' || m.kind === 'heart') {
        m.x += Math.sin(m.phase*0.9) * 0.5; m.rot += m.vr;
      } else { m.rot += m.vr; }
      m.x += m.vx; m.y += m.vy; m.vy += 0.006; m.life--;
      if (m.life <= 0) { _motifs.splice(i, 1); continue; }
      const k = m.life / m.max;
      ctx.globalAlpha = k < 0.3 ? k / 0.3 : 1;
      ctx.save(); ctx.translate(m.x, m.y); ctx.rotate(m.rot); drawMotifShape(m.kind, m.size, m.col || MOTIF_COL[m.kind] || '#fff', m.phase); ctx.restore();
    }
    ctx.globalAlpha = 1;
  }
  function spawnParticles(x, y, color, n=6){
    // 파티클 수 줄이고 수명 짧게 — 시각적 노이즈 감소
    n = Math.max(1, Math.floor(n * 0.6));
    // 🛡 글로벌 캡 — 많은 적 동시 피격 시 FPS 보호 (특히 슬로우/광역 동시 다발 시)
    // 📱 모바일은 더 낮게 (발열/렉 완화)
    const cap = IS_MOBILE ? 110 : 300;
    const room = cap - state.particles.length;
    if (room <= 0) return;
    if (n > room) n = room;
    for (let i=0; i<n; i++){
      const a = Math.random()*Math.PI*2;
      const s = 0.5 + Math.random()*1.3;
      state.particles.push({ x, y, vx: Math.cos(a)*s, vy: Math.sin(a)*s, life: 12 + Math.random()*8, color });
    }
    // 🎭 가챠 캐릭터 능력이면 개성 모티프 방출 (음표/꽃잎/나비…)
    try {
      const _id = state && state.currentAbilityId;
      const _k = MOTIF_THEME[_id];
      if (SAKURA_IDS[_id]) {
        // 🌸 은은한 수채화 벚꽃 안개 + 부드럽게 표류하는 꽃잎 (조합일수록 더 풍성)
        const combo = !!(ABILITY_DEFS[_id] && (ABILITY_DEFS[_id].isCombo || ABILITY_DEFS[_id].isTriple));
        if (_sakuraHaze.length < 48 && Math.random() < (combo ? 0.7 : 0.45)) {
          _sakuraHaze.push({ x: x+(Math.random()-0.5)*22, y: y+(Math.random()-0.5)*22, r: 7+Math.random()*9, gr: 0.45+Math.random()*0.6, life: 44+Math.random()*30, max: 74 });
        }
        const petalN = combo ? 2 : 1;
        if (_motifs.length < 96) for (let q=0; q<petalN; q++) _motifs.push({ x, y, vx:(Math.random()-0.5)*0.5, vy:-0.18-Math.random()*0.5, life:54+Math.random()*30, max:88, kind:'petal', rot:Math.random()*6.28, vr:(Math.random()-0.5)*0.07, size:7+Math.random()*5 });
      } else if (ARIA_IDS[_id] && _motifs.length < 80 && Math.random() < 0.55) {
        // 🎤 음표(70%) / 골드 별(20%) / 핑크 하트(10%) 믹스
        const r = Math.random(); const kind = r < 0.7 ? 'note' : (r < 0.9 ? 'star' : 'heart');
        const col = kind === 'note' ? '#ffe070' : (kind === 'star' ? '#ffe070' : '#ff9ccb');
        _motifs.push({ x, y, vx:(Math.random()-0.5)*0.7, vy:-0.35-Math.random()*0.6, life:46+Math.random()*26, max:74, kind, col, rot:(Math.random()-0.5)*0.6, vr:(Math.random()-0.5)*0.08, size:8+Math.random()*5 });
      } else if (_k && _motifs.length < 64 && Math.random() < 0.5) {
        _motifs.push({ x, y, vx:(Math.random()-0.5)*0.8, vy:-0.4-Math.random()*0.7, life:36+Math.random()*22, max:58, kind:_k, rot:Math.random()*6.28, vr:(Math.random()-0.5)*0.12, size:8+Math.random()*4 });
      }
    } catch(e){}
  }

  // ===== 우주 배경 =====
  const BG = { stars: [], planets: [], nebulae: [], meteors: [], meteorTimer: 200, tier: 0, starTint: '255,255,255', core: null };
  // 🌌 난이도(단계)별 우주 배경 — 기본(asc0) / 승천(asc1~15) / 초월(asc16~30)
  function bgTierIndex(asc) { asc = asc || 0; if (asc <= 0) return 0; if (asc <= 15) return 1; return 2; }
  // 🌌 전 단계 모두 어둡고 저채도 (중앙 깨끗·눈 편하게) → 단계는 "하늘 요소 + 미세 색조 + 아레나 액센트"로 구분
  const BG_TIERS = [
    { // 0 기본 — 고요한 청색 심우주
      core: [12, 18, 38], mid: '#070a16', edge: '#03040c', star: '255,255,255', glow: '170,205,255',
      accent: '#5ab4e0', sky: null,
      nebula: ['rgba(70,120,200,0.05)', 'rgba(60,150,200,0.04)', 'rgba(80,100,180,0.03)'],
      planets: [['#3a2860', '#160d28', false], ['#1e4866', '#0c1a2c', true], ['#5a2818', '#220d08', false]],
      meteorRate: [260, 520], meteorCol: '210,225,255',
    },
    { // 1 승천 — 차분한 보랏빛 + 오로라 (색칠 아님, 하늘 요소로 구분)
      core: [20, 16, 40], mid: '#090814', edge: '#04030a', star: '208,202,232', glow: '170,160,225',
      accent: '#9a7ad0', sky: 'aurora',
      nebula: ['rgba(120,80,190,0.05)', 'rgba(150,90,180,0.045)', 'rgba(100,80,180,0.03)'],
      planets: [['#4a2c78', '#1c0f34', false], ['#3a3080', '#120e2c', true], ['#6a3060', '#260f24', false]],
      meteorRate: [220, 460], meteorCol: '200,180,235',
    },
    { // 2 초월 — 어둡고 텅 빈 심연 + 멀리 거대한 은하 실루엣 (밝은 빨강 X)
      core: [16, 12, 26], mid: '#070510', edge: '#030208', star: '214,205,222', glow: '170,150,200',
      accent: '#b06aa0', sky: 'galaxy',
      nebula: ['rgba(110,60,140,0.05)', 'rgba(90,55,150,0.04)', 'rgba(70,40,110,0.035)'],
      planets: [['#5a2050', '#200a1c', false], ['#402060', '#160a24', true], ['#6a2840', '#260a18', false]],
      meteorRate: [220, 460], meteorCol: '210,175,205',
    },
  ];
  // 🌌 아레나 바닥 텍스처 베이크 (1회/게임) — 유기질 노이즈 + 그레인 (단계 액센트 틴트, 림 페이드)
  //   매 프레임 drawImage 1회로 "도트 텍스처" 질감 + 깊이감. 저채도/저알파 → 눈 편하게.
  function bakeArenaTexture() {
    try {
      const acc = BG.accent || '#5ab4e0';
      const n = parseInt(acc.slice(1), 16), AR = (n>>16)&255, AG = (n>>8)&255, AB = n&255;
      const R = ARENA_R, D = R * 2, cx = R, cy = R;
      const c = document.createElement('canvas'); c.width = D; c.height = D;
      const g = c.getContext('2d');
      g.save();
      g.beginPath(); g.arc(cx, cy, R, 0, Math.PI*2); g.clip();
      // 베이스 — 중앙이 약간 밝은 방사 (광원 로직)
      const base = g.createRadialGradient(cx, cy - R*0.12, R*0.1, cx, cy, R);
      base.addColorStop(0, `rgba(${AR},${AG},${AB},0.15)`);
      base.addColorStop(0.55, `rgba(${(AR*0.5)|0},${(AG*0.5)|0},${(AB*0.6)|0},0.09)`);
      base.addColorStop(1, 'rgba(0,0,0,0.02)');
      g.fillStyle = base; g.fillRect(0, 0, D, D);
      // 유기질 성운 얼룩 (절차적 텍스처)
      for (let i = 0; i < 70; i++) {
        const a = Math.random()*7, rr = Math.sqrt(Math.random())*R*0.96;
        const x = cx + Math.cos(a)*rr, y = cy + Math.sin(a)*rr;
        const rad = R*0.06 + Math.random()*R*0.22;
        const lighter = Math.random() < 0.55;
        g.globalCompositeOperation = lighter ? 'lighter' : 'source-over';
        g.globalAlpha = lighter ? (0.02 + Math.random()*0.05) : (0.03 + Math.random()*0.06);
