  };
  // 모든 캐릭터에 대해 이미지 사전 로드 시도 (chroma key 처리됨)
  // 파일 없으면 'missing'으로 마킹되어 fallback 동작
  preloadAllCharacterImages();

  function isCharUnlocked(id) {
    const c = CHARACTERS[id];
    if (!c.unlockBy) return true;
    // 가챠 캐릭터: META.gachaUnlocked 에 있어야 해금
    if (c.unlockBy.startsWith('gacha:')) {
      const gachaId = c.unlockBy.slice(6);
      return !!(META.gachaUnlocked && META.gachaUnlocked[gachaId] && META.gachaUnlocked[gachaId] > 0);
    }
    const have = getUnlockedAchievements();
    return have.has(c.unlockBy);
  }
  let selectedCharacter = META.selectedCharacter || 'standard';
  // 🔒 해금되지 않은 캐릭터가 선택돼 있으면(데이터 오염/조작 방지) standard로 강제 + 저장값도 정리
  try { if (!isCharUnlocked(selectedCharacter)) { selectedCharacter = 'standard'; META.selectedCharacter = 'standard'; } } catch (e) { selectedCharacter = 'standard'; }

  // ===== 업적 시스템 (15+) — 일부는 캐릭터/능력을 해금 =====
