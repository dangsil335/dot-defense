    ctx.fillStyle = bg; ctx.strokeStyle = edgeC; ctx.lineWidth = 2;
    ctx.beginPath(); for (let k = 0; k < 12; k++) { const a = k * Math.PI / 6 - Math.PI / 2; const rr = (k % 2 ? s * 0.7 : s * 1.04); const px = Math.cos(a) * rr, py = Math.sin(a) * rr; k ? ctx.lineTo(px, py) : ctx.moveTo(px, py); } ctx.closePath(); ctx.fill(); ctx.stroke();
    ctx.restore();
