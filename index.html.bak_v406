        choices: [
          { label: '맡긴다', desc: '가장 낮은 능력 2개 +1 강화', resolve() { const ns = _evAwakenLowest(2); return ns.length ? `🌱 ${ns.join(' · ')} +1!` : '키울 능력이 없었다.'; } },
