        choices: [
          { label: `전부 건다 (${g}G)`, desc: '42%: ×2.5 · 58%: 전부 잃음', disabled: g < 10,
            resolve() { if (Math.random() < 0.42) { const win = Math.floor(g * 2.5); state.gold = win; return `💰 대박! ${win}G!`; } state.gold = 0; return '💸 파산…'; } },
          { label: '거절한다', desc: '목숨이 중요하다', resolve() { return '"현명하군."'; } },
        ] }; },
    ]},
    devil: { name: '악마 · 마몬', fb: '😈', art: 'devil', color: '#aa88ff', events: [
