  <div class="codex-tabs" id="ach-tabs" style="overflow-x:auto; overflow-y:hidden; flex-wrap:nowrap; -webkit-overflow-scrolling:touch;">
    <button class="codex-tab active" data-achtab="progress" style="flex-shrink:0; white-space:nowrap;">📈 진행</button>
    <button class="codex-tab" data-achtab="build" style="flex-shrink:0; white-space:nowrap;">🎴 빌드</button>
    <button class="codex-tab" data-achtab="combat" style="flex-shrink:0; white-space:nowrap;">⚔️ 처치</button>
    <button class="codex-tab" data-achtab="ascension" style="flex-shrink:0; white-space:nowrap;">✨ 승천</button>
    <button class="codex-tab" data-achtab="trans" style="flex-shrink:0; white-space:nowrap;">🌌 초월</button>
    <button class="codex-tab" data-achtab="chars" style="flex-shrink:0; white-space:nowrap;">⭐ 캐릭터</button>
    <button class="codex-tab" data-achtab="special" style="flex-shrink:0; white-space:nowrap;">📖 특수</button>
    <button class="codex-tab" data-achtab="repeat" style="flex-shrink:0; white-space:nowrap;">🔁 반복</button>
  </div>
  <div id="achievements-list"></div>
</div>

<!-- ===== 모드 선택 화면 ===== -->
<div id="modeScreen" class="screen">
  <div class="codex-header">
    <h2>게임 모드 선택</h2>
    <button id="modeBack" class="codex-back">← 메뉴로</button>
  </div>
  <div style="display:flex; flex-direction:column; gap:14px; padding:20px; max-width:600px; margin:0 auto; width:100%; box-sizing:border-box;">
    <button class="mode-card" data-mode="standard">
      <div class="mode-icon">⚔️</div>
      <div class="mode-info">
        <div class="mode-name">표준 모드</div>
        <div class="mode-desc">적이 한계를 초과하면 패배. 끝없이 몰려오는 적을 학살하는 클래식 모드.</div>
        <div class="mode-tags">
          <span class="mode-tag">💥 화력 빌드</span>
          <span class="mode-tag">⚡ 빠른 처치</span>
          <span class="mode-tag">100라운드</span>
        </div>
      </div>
    </button>
    <button class="mode-card" data-mode="defense">
      <div class="mode-icon">🏰</div>
      <div class="mode-info">
        <div class="mode-name">디펜스 모드</div>
        <div class="mode-desc">적이 타워로 직진. 타워 HP가 0이 되면 패배. 사거리와 CC가 핵심.</div>
        <div class="mode-tags">
          <span class="mode-tag">🛡 방어 빌드</span>
          <span class="mode-tag">❄ 슬로우/정지</span>
          <span class="mode-tag">사거리 ↑</span>
        </div>
      </div>
    </button>
  </div>
</div>

<!-- ===== 캐릭터 화면 — 도감(메뉴 진입) / 선택(새 게임 진입) 둘 다 사용 ===== -->
<div id="characterScreen" class="screen">
  <div class="codex-header">
    <h2 id="character-screen-title">캐릭터 선택</h2>
    <button id="characterBack" class="codex-back">← 메뉴로</button>
  </div>
  <!-- 🎴 v221 — 현재 선택 캐릭터 큰 카드 (상단 hero) -->
  <div id="character-hero" class="char-hero">
    <!-- 동적으로 채워짐 — refreshCharacterHero() -->
  </div>
  <div class="codex-tabs" id="char-tabs">
    <button class="codex-tab active" data-chartab="all">📦 전체</button>
    <button class="codex-tab" data-chartab="basic">⚜️ 기본</button>
    <button class="codex-tab" data-chartab="gacha">🎰 가챠</button>
    <button class="codex-tab" data-chartab="owned">🌟 보유</button>
  </div>
  <div id="character-list"></div>
  <!-- 플로팅 시작 버튼 (화면 하단 고정) -->
  <div class="char-floating-bar">
    <div class="char-floating-selected" id="char-floating-selected">선택된 캐릭터: <span style="color:#7ad7ff;">표준</span></div>
    <button id="charStartGameBtn" class="char-start-btn">▶ 게임 시작</button>
  </div>
</div>

<!-- ===== 🎰 가챠 화면 ===== -->
<div id="gachaScreen" class="screen">
  <div class="gacha-top-bar">
    <button id="gachaBack" class="codex-back gacha-back-small">←</button>
    <div class="gacha-title">🎰 가챠</div>
    <div class="gacha-currencies">
      <span class="gacha-cur-chip"><span style="color:#88ccff">💎</span> <span id="crystal-count">0</span></span>
      <span class="gacha-cur-chip"><span style="color:#ffd479">⭐</span> <span id="gacha-stardust">0</span></span>
    </div>
  </div>

  <!-- 🎴 풀스크린 배너 (명조 스타일) — 큰 이미지 + 내부 오버레이 UI -->
  <div class="gacha-fullbanner">
    <!-- 배경 이미지 (배너별 동적 전환) — 비동기 디코딩으로 메인스레드 차단 X -->
    <img id="gacha-banner-img" class="gacha-fullbanner-img" src="./icons/gacha-aria.png"
         decoding="async" loading="eager" fetchpriority="low"
         onerror="this.src='./icons/gacha.png'; this.onerror=null;" />
    <div id="gacha-banner-fallback" class="gacha-fullbanner-fallback" style="display:none;">
      <div class="gacha-banner-sparkles">✨</div>
      <div class="gacha-banner-title">DOT DEFENSE</div>
      <div class="gacha-banner-sub">캐릭터 픽업 가챠</div>
    </div>

    <!-- 배너 좌/우 전환 화살표 -->
    <button id="gachaBannerPrev" class="gacha-banner-arrow gacha-arrow-left" title="이전 배너">◀</button>
    <button id="gachaBannerNext" class="gacha-banner-arrow gacha-arrow-right" title="다음 배너">▶</button>

    <!-- 상단 좌측: 배너 타이틀 + 픽업 표시 -->
    <div class="gacha-banner-top-overlay">
      <div id="gacha-banner-name" class="gacha-banner-name">🌟 아리아 픽업</div>
      <div id="gacha-banner-pickup-info" class="gacha-banner-pickup-info">SSR 1.0% · SR 5% · ⭐ 94%</div>
    </div>
    <!-- 🌌 v249 — 고대 유물 픽업 칩 (배너에 동봉된 ANCIENT 유물 표시) -->
    <div id="gacha-banner-ancient-chip" class="gacha-banner-ancient-chip" style="display:none;">
      <img id="gacha-banner-ancient-img" src="" alt="ancient" />
      <div class="ancient-chip-text">
        <div class="ancient-chip-label">🌌 ANCIENT</div>
        <div class="ancient-chip-name" id="gacha-banner-ancient-name">—</div>
        <div class="ancient-chip-rate" id="gacha-banner-ancient-rate">—</div>
      </div>
    </div>

    <!-- 하단 오버레이: 뽑기 버튼만 (일러스트 보존) -->
    <div class="gacha-banner-bottom-overlay">
      <!-- 픽업 캐릭터 — 숨김 (불필요한 가림 방지). 정보는 상단 칩 + 컬렉션에서 확인 -->
      <div id="gacha-pickup-icons" class="gacha-pickup-icons" style="display:none;"></div>

      <!-- 뽑기 버튼들 (반투명 + 블러로 일러스트 가리지 않음) -->
      <div class="gacha-pull-row">
        <button id="gachaPull1" class="gacha-pull-btn-overlay">
          <div class="gacha-pull-label">1회 뽑기</div>
          <div class="gacha-pull-cost"><span style="color:#88ccff">💎</span> 1</div>
        </button>
        <button id="gachaPull10" class="gacha-pull-btn-overlay primary">
          <div class="gacha-pull-label">10회 뽑기</div>
          <div class="gacha-pull-cost"><span style="color:#88ccff">💎</span> 9</div>
        </button>
      </div>
    </div>
  </div>

  <!-- 보조 액션 (배너 밖에 두기) -->
  <div class="gacha-secondary-actions">
    <button id="gachaConvertStardust" class="gacha-secondary-btn">
      ⭐ 4,000 → 💎 1
    </button>
  </div>
</div>

<!-- ===== 🎰 가챠 결과 화면 ===== -->
<div id="gachaResultScreen" class="screen">
  <div class="gacha-result-title">뽑기 결과</div>
  <div id="gacha-result-cards" class="gacha-result-cards"></div>
  <div id="gacha-result-summary" class="gacha-result-summary"></div>
  <div class="gacha-result-actions">
    <button id="gachaResultAgain" class="gacha-pull-btn primary">🎰 다시 뽑기</button>
    <button id="gachaResultClose" class="gacha-pull-btn">계속</button>
  </div>
</div>

<!-- ===== 난이도 선택 (승천) ===== -->
<div id="difficultyScreen" class="screen">
  <div class="codex-header">
    <h2>난이도 선택</h2>
    <button id="difficultyBack" class="codex-back">← 메뉴로</button>
  </div>
  <div class="stardust-bar" id="ascension-info">현재: <span id="ascension-current">기본</span></div>
  <div id="difficulty-list"></div>
</div>

<!-- ===== 강화소 화면 ===== -->
<div id="shop" class="screen">
  <div class="codex-header">
    <h2>강화소</h2>
    <button id="shopBack" class="codex-back">← 메뉴로</button>
  </div>
  <div class="stardust-bar">스타더스트: <span id="stardust-count">0</span> ★</div>
  <div class="codex-tabs" id="shop-tabs" style="overflow-x:auto; overflow-y:hidden; flex-wrap:nowrap; -webkit-overflow-scrolling:touch;">
    <button class="codex-tab active" data-shoptab="resource" style="flex-shrink:0; white-space:nowrap;">💰 자원</button>
    <button class="codex-tab" data-shoptab="combat" style="flex-shrink:0; white-space:nowrap;">⚔️ 전투력</button>
    <button class="codex-tab" data-shoptab="build" style="flex-shrink:0; white-space:nowrap;">🎴 빌드</button>
    <button class="codex-tab" data-shoptab="survival" style="flex-shrink:0; white-space:nowrap;">🛡️ 생존</button>
  </div>
  <div id="shop-list"></div>
</div>

<!-- ===== 🌟 능력 영구 강화 — 별도 화면 (강화소와 동일한 UI 구조로 통일) ===== -->
<div id="abilityPerma" class="screen">
  <div class="codex-header">
    <h2>능력 영구 강화</h2>
    <button id="abilityPermaBack" class="codex-back">← 메뉴로</button>
  </div>
  <div class="stardust-bar">스타더스트: <span id="perma-stardust-count">0</span> ★</div>
  <div class="codex-tabs" id="perma-tabs" style="display:flex; gap:4px; width:100%; max-width:600px; padding:0 8px; position:sticky; top:0; background:#0b0d12; padding-top:4px; padding-bottom:4px; z-index:5;">
    <button class="codex-tab active" data-permatab="active" style="flex:1 1 0; min-width:0; padding:8px 2px; font-size:12px; text-align:center; line-height:1.2;">⚡ 액티브</button>
    <button class="codex-tab" data-permatab="passive" style="flex:1 1 0; min-width:0; padding:8px 2px; font-size:12px; text-align:center; line-height:1.2;">⭐ 패시브</button>
    <button class="codex-tab" data-permatab="combo" style="flex:1 1 0; min-width:0; padding:8px 2px; font-size:12px; text-align:center; line-height:1.2;">🔥 조합</button>
    <button class="codex-tab" data-permatab="gacha" style="flex:1 1 0; min-width:0; padding:8px 2px; font-size:12px; text-align:center; line-height:1.2;">🎰 가챠</button>
  </div>
  <div id="perma-grid" style="width:100%; max-width:900px;"></div>
</div>

<!-- ===== 기록 화면 ===== -->
<div id="records" class="screen">
  <div class="codex-header">
    <h2>기록</h2>
    <button id="recordsBack" class="codex-back">← 메뉴로</button>
  </div>
  <div id="records-list"></div>
</div>

<!-- ===== 기록 상세 화면 ===== -->
<div id="recordDetail" class="screen">
  <div class="codex-header">
    <h2>기록 상세</h2>
    <button id="recordDetailBack" class="codex-back">← 기록 목록</button>
  </div>
  <div id="record-detail-content"></div>
</div>

<!-- ===== 도감 화면 ===== -->
<div id="codex" class="screen">
  <div class="codex-header">
    <h2>도감</h2>
    <button id="codexBack" class="codex-back">← 메뉴로</button>
  </div>
  <div class="codex-tabs">
    <button class="codex-tab active" data-tab="basic">액티브</button>
    <button class="codex-tab" data-tab="passive">패시브</button>
    <button class="codex-tab" data-tab="combo">조합</button>
    <button class="codex-tab" data-tab="triple">히든</button>
    <button class="codex-tab" data-tab="relic">유물</button>
  </div>
  <!-- 🎯 v224 — 필터 칩 (검색은 제거 — 모바일에서 자리만 차지) -->
  <div class="codex-filter-chips">
    <button class="codex-filter-chip active" data-codexfilter="all">전체</button>
    <button class="codex-filter-chip" data-codexfilter="owned">🔓 해금</button>
    <button class="codex-filter-chip" data-codexfilter="locked">🔒 잠김</button>
  </div>
  <div id="codex-list"></div>
</div>

<!-- 🎁 게임 결과 — 획득 보상 패널 (body 레벨 — 게임 컨테이너 transform/display 영향 차단) -->
<!-- 🛒 특별 상점 — 라운드마다 낮은 확률로 등장 (좌 NPC 일러스트 + 우 상품 그리드) -->
<style>
  .npc-scene { display: none; position: fixed; inset: 0; z-index: 9994; background: rgba(6,8,14,0.45); backdrop-filter: blur(2px); align-items: stretch; justify-content: center; padding: 14px; box-sizing: border-box; }
  .npc-scene.show { display: flex; }
  .npc-scene-inner { display: flex; width: 100%; max-width: 740px; max-height: 80vh; margin: auto; background: linear-gradient(180deg,#1a2030,#0e1119); border: 1px solid #3a4256; border-radius: 16px; overflow: hidden; box-shadow: 0 20px 60px rgba(0,0,0,0.6), 0 0 40px rgba(122,215,255,0.08); animation: rewardIn .3s cubic-bezier(.2,.9,.3,1.1); }
  .npc-portrait { position: relative; flex: 0 0 34%; min-width: 0; background: radial-gradient(ellipse at 50% 28%, #243049, #0c0e16); display: flex; align-items: flex-end; justify-content: center; overflow: hidden; }
  .npc-portrait img { width: 100%; height: 100%; object-fit: contain; object-position: center bottom; image-rendering: auto; }
  .npc-portrait .npc-fallback { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 60px; opacity: 0.85; }
  .npc-portrait .npc-name { position: absolute; left: 0; right: 0; bottom: 0; padding: 8px 10px; background: linear-gradient(0deg, rgba(8,10,16,0.94), transparent); color: #fff; font-weight: bold; font-size: 14px; text-align: center; text-shadow: 0 1px 3px #000; }
  .npc-panel { flex: 1; min-width: 0; display: flex; flex-direction: column; padding: 16px; box-sizing: border-box; }
  .npc-panel-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; gap: 8px; }
  .npc-panel-title { font-size: 18px; font-weight: bold; color: #ffd479; text-shadow: 0 0 14px rgba(255,212,121,0.35); }
  .npc-panel-gold { font-size: 13px; color: #ffd479; background:#0e1320; border:1px solid #2a3140; border-radius:999px; padding:5px 12px; white-space:nowrap; }
  .shop-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; overflow-y: auto; flex: 1; min-height: 0; padding: 2px; }
  .shop-item { display: flex; flex-direction: column; gap: 3px; padding: 10px; background: linear-gradient(180deg,#1c2333,#141a28); border:1px solid #2a3140; border-radius: 11px; cursor: pointer; transition: border-color .12s, transform .08s, box-shadow .12s; }
  .shop-item:hover:not(.soldout):not(.cant) { border-color:#ffd479; transform: translateY(-1px); box-shadow:0 4px 14px rgba(0,0,0,0.4); }
  .shop-item .si-top { display:flex; align-items:center; gap:8px; }
  .shop-item .si-icon { width:30px; height:30px; flex-shrink:0; display:flex; align-items:center; justify-content:center; font-size:18px; background:#0e1320; border-radius:8px; }
  .shop-item .si-icon img { width:100%; height:100%; object-fit:contain; border-radius:6px; }
  .shop-item .si-name { font-size:13px; font-weight:bold; color:#e8eaf0; }
  .shop-item .si-desc { font-size:11px; color:#9aa3b3; line-height:1.35; min-height:28px; }
  .shop-item .si-price { font-size:13px; font-weight:bold; color:#ffd479; }
  .shop-item .si-rar { font-size:9px; font-weight:800; letter-spacing:1px; margin-top:1px; }
  .shop-item.rar-legendary:not(.soldout) { animation: shopLeg 1.5s ease-in-out infinite; }
  .shop-item.rar-epic:not(.soldout) { animation: shopLeg 2.3s ease-in-out infinite; }
  @keyframes shopLeg { 0%,100% { filter: brightness(1); } 50% { filter: brightness(1.22); } }
  .shop-item.cant .si-price { color:#ff6b6b; }
  .shop-item.soldout { opacity:0.45; cursor:default; }
  .shop-item.soldout .si-price { color:#6b7283; }
  .npc-panel-foot { margin-top: 10px; flex-shrink: 0; }
  /* 🛒 모바일 상점 — 나가기 버튼이 스크롤 없이 항상 하단에 떠 있도록 (그리드는 그 위에서 스크롤) */
  #shopScene .npc-panel-foot { position: sticky; bottom: 0; background: linear-gradient(0deg, #0e1119 72%, rgba(14,17,25,0)); padding-top: 8px; z-index: 3; }
  /* 🛒 상점 구매 확인 팝업 */
  .shop-confirm { position: absolute; inset: 0; z-index: 6; display: flex; align-items: center; justify-content: center; background: rgba(4,6,12,0.55); padding: 16px; }
  .shop-confirm .sc-box { background: linear-gradient(180deg,#1c2434,#10141f); border: 1px solid #3a4660; border-radius: 14px; padding: 18px 20px; min-width: 220px; max-width: 86%; text-align: center; box-shadow: 0 14px 44px rgba(0,0,0,0.6); animation: rewardIn .2s ease; }
  .shop-confirm .sc-q { font-size: 15px; color: #e8eaf0; line-height: 1.5; }
  .shop-confirm .sc-cost { font-size: 21px; font-weight: bold; color: #ffd479; margin: 8px 0 14px; }
  .shop-confirm .sc-btns { display: flex; gap: 10px; }
  .shop-confirm .sc-btns .npc-btn { flex: 1; padding: 11px; }
  .shop-confirm .sc-no { background: linear-gradient(180deg,#3a3f4c,#262a36); border-color: #555c6e; box-shadow: none; }
  .npc-btn { width: 100%; padding: 12px; font-family: inherit; font-size: 15px; font-weight: bold; cursor: pointer; border-radius: 11px; background: linear-gradient(180deg,#44598a,#2a3550); color:#fff; border:1px solid #6a82b8; box-shadow: 0 0 14px rgba(122,215,255,0.18); transition: transform .08s, box-shadow .12s; touch-action: manipulation; }
  .npc-btn:hover { box-shadow: 0 0 20px rgba(122,215,255,0.3); }
  .npc-btn:active { transform: scale(.985); }
  /* 🎭 특수보스 처치 이벤트 패널 */
  .event-text { flex: 0 0 auto; font-size: 13.5px; line-height: 1.62; color: #cdd5e3; background: #0e1320; border: 1px solid #232a3a; border-radius: 10px; padding: 12px 13px; margin-bottom: 10px; max-height: 40%; overflow-y: auto; white-space: pre-wrap; }
  .event-choices { display: flex; flex-direction: column; gap: 8px; overflow-y: auto; flex: 1; min-height: 0; padding: 2px; }
  .event-choice { text-align: left; padding: 11px 13px; background: linear-gradient(180deg,#1c2333,#141a28); border: 1px solid #2a3140; border-radius: 11px; cursor: pointer; transition: border-color .12s, transform .08s, box-shadow .12s; color: #e8eaf0; font-family: inherit; }
  .event-choice:hover:not(:disabled) { border-color: #7ad7ff; transform: translateY(-1px); box-shadow: 0 4px 14px rgba(0,0,0,0.4); }
  .event-choice:disabled { opacity: 0.42; cursor: default; }
  .event-choice .ec-label { font-size: 14px; font-weight: bold; }
  .event-choice .ec-desc { font-size: 11.5px; color: #9aa3b3; line-height: 1.4; margin-top: 3px; }
  .event-outcome { font-size: 13.5px; line-height: 1.6; color: #ffe070; background: #161a10; border: 1px solid #3a3a20; border-radius: 10px; padding: 13px 14px; white-space: pre-wrap; animation: rewardIn .25s ease; }
  /* 🆕 이벤트 결과 능력 아이콘 (삭제/획득/강화) */
  .eo-icons { display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; margin-bottom: 10px; animation: rewardIn .25s ease; }
  .eo-icon { position: relative; display: flex; flex-direction: column; align-items: center; gap: 3px; padding: 6px 8px 5px; background: #11141c; border: 2px solid #888; border-radius: 10px; min-width: 56px; }
  .eo-icon img { width: 40px; height: 40px; image-rendering: auto; border-radius: 6px; }
  .eo-badge { position: absolute; top: -7px; right: -7px; width: 18px; height: 18px; border-radius: 50%; color: #0b0e14; font-weight: 900; font-size: 13px; line-height: 18px; text-align: center; box-shadow: 0 1px 4px rgba(0,0,0,.5); }
  .eo-name { font-size: 10px; color: #cfd6e3; font-weight: bold; max-width: 64px; text-align: center; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  /* ⬆ 상점 강화 결과 팝업 행 */
  .shop-confirm .sc-up-row { display: flex; align-items: center; justify-content: center; gap: 12px; margin: 10px 0 4px; }
  .shop-confirm .sc-up-row img { width: 48px; height: 48px; image-rendering: auto; border-radius: 8px; border: 2px solid #ffaa55; }
  .shop-confirm .sc-up-info { text-align: left; }
  .shop-confirm .sc-up-name { font-weight: bold; font-size: 15px; }
  .shop-confirm .sc-up-lv { font-size: 13px; color: #ffd479; margin-top: 2px; }
  /* 🔮 유물 획득 피드백 */
  .relic-reveal { display: flex; align-items: center; gap: 14px; padding: 15px 16px; border-radius: 14px; background: linear-gradient(180deg,#1a2132,#10141f); border: 2px solid var(--rc,#888); box-shadow: 0 0 24px var(--rg,rgba(255,255,255,.25)), inset 0 0 18px rgba(0,0,0,.4); animation: rewardIn .3s cubic-bezier(.2,1.4,.5,1); }
  .relic-reveal .rr-icon { flex: 0 0 64px; width: 64px; height: 64px; display: flex; align-items: center; justify-content: center; font-size: 44px; filter: drop-shadow(0 0 10px var(--rg,rgba(255,255,255,.3))); }
  .relic-reveal .rr-icon img { width: 60px; height: 60px; image-rendering: pixelated; object-fit: contain; }
  .relic-reveal .rr-info { min-width: 0; }
  .relic-reveal .rr-rar { font-size: 11px; font-weight: 800; letter-spacing: 1.5px; color: var(--rc,#cdd); text-transform: uppercase; }
  .relic-reveal .rr-name { font-size: 17px; font-weight: bold; color: #fff; margin: 2px 0 4px; }
  .relic-reveal .rr-desc { font-size: 12px; color: #9aa3b3; line-height: 1.45; }
  /* ⚡ 기습 이벤트 컷인 (A: 사이드 슬라이드) */
  .ambush-scene { display: none; position: fixed; inset: 0; z-index: 9995; overflow: hidden; align-items: center; justify-content: center; background: rgba(6,8,14,0); transition: background .25s ease; }
  .ambush-scene.show { display: flex; background: rgba(6,8,14,0.6); }
  .ambush-scene.out { background: rgba(6,8,14,0); }
  .ambush-bg { position: absolute; inset: -20%; opacity: 0; background: repeating-linear-gradient(112deg, transparent 0 16px, var(--ac,#7ad7ff) 16px 19px); mix-blend-mode: screen; animation: ambushBg .55s ease forwards; }
  @keyframes ambushBg { 0% { opacity: 0; transform: scale(1.5) } 35% { opacity: .16 } 100% { opacity: .07; transform: scale(1) } }
  .ambush-glow { position: absolute; width: 130vmin; height: 130vmin; border-radius: 50%; background: radial-gradient(circle, var(--ag,rgba(122,215,255,.45)) 0%, transparent 62%); opacity: 0; animation: ambushGlow .6s ease forwards; }
  @keyframes ambushGlow { 0% { opacity: 0; transform: scale(.55) } 50% { opacity: 1 } 100% { opacity: .5; transform: scale(1) } }
  .ambush-illus { position: relative; max-height: 80vh; max-width: 62vw; object-fit: contain; transform: translateX(62vw); opacity: 0; filter: drop-shadow(0 10px 32px rgba(0,0,0,.65)); image-rendering: auto; animation: ambushSlide .55s cubic-bezier(.18,1.45,.42,1) .06s forwards; }
  .ambush-scene.out .ambush-illus { animation: ambushExit .28s ease forwards; }
  @keyframes ambushSlide { 0% { transform: translateX(62vw); opacity: 0 } 55% { opacity: 1 } 100% { transform: translateX(0); opacity: 1 } }
  @keyframes ambushExit { to { transform: translateX(-12vw) scale(.94); opacity: 0 } }
  .ambush-name { position: absolute; left: 0; bottom: 24%; transform: skewY(-3deg) translateX(-115%); padding: 9px 30px 9px 18px; background: linear-gradient(90deg, var(--ac,#7ad7ff) 0%, var(--ac,#7ad7ff) 70%, transparent 100%); box-shadow: 0 4px 18px rgba(0,0,0,.5); opacity: 0; animation: ambushName .4s cubic-bezier(.2,.9,.3,1.1) .34s forwards; }
  .ambush-name .an-name { font-size: 22px; font-weight: 900; color: #0b0e14; text-shadow: 0 1px 0 rgba(255,255,255,.35); letter-spacing: .5px; }
  @keyframes ambushName { to { transform: skewY(-3deg) translateX(0); opacity: 1 } }
  .ambush-line { position: absolute; left: 7%; right: 7%; bottom: 12%; max-width: 80vw; margin: 0 auto; font-size: 16px; font-weight: 600; color: #fff; text-align: center; text-shadow: 0 2px 10px #000, 0 0 4px #000; opacity: 0; animation: ambushLine .35s ease .56s forwards; }
  @keyframes ambushLine { from { opacity: 0; transform: translateY(10px) } to { opacity: 1; transform: translateY(0) } }
  .ambush-flash { position: absolute; inset: 0; background: #fff; opacity: 0; pointer-events: none; animation: ambushFlash .4s ease forwards; }
  @keyframes ambushFlash { 0% { opacity: 0 } 7% { opacity: .55 } 100% { opacity: 0 } }
  /* 🆕 가챠 캐릭터 조합 컷인 — 좌측에 본인 캐릭터가 잠깐 등장 (논블로킹, 게임 정지 X) */
  .char-cutin { position: fixed; left: 0; bottom: 6%; z-index: 9990; pointer-events: none; display: flex; flex-direction: column; align-items: flex-start; }
  .char-cutin-illus { max-height: 48vh; max-width: 46vw; object-fit: contain; transform: translateX(-115%); opacity: 0; filter: drop-shadow(0 8px 26px rgba(0,0,0,.6)); image-rendering: auto; animation: charCutinIn .5s cubic-bezier(.18,1.4,.42,1) forwards; }
  .char-cutin.out .char-cutin-illus { animation: charCutinOut .35s ease forwards; }
  @keyframes charCutinIn { 0% { transform: translateX(-115%); opacity: 0 } 60% { opacity: 1 } 100% { transform: translateX(0); opacity: 1 } }
  @keyframes charCutinOut { to { transform: translateX(-115%); opacity: 0 } }
  .char-cutin-name { margin: 4px 0 0 10px; padding: 5px 16px 5px 12px; background: linear-gradient(90deg, var(--cc,#7ad7ff) 0%, var(--cc,#7ad7ff) 75%, transparent 100%); color: #0b0e14; font-weight: 900; font-size: 15px; border-radius: 0 4px 4px 0; box-shadow: 0 3px 12px rgba(0,0,0,.5); transform: translateX(-115%); opacity: 0; animation: charCutinName .4s cubic-bezier(.2,.9,.3,1.1) .18s forwards; }
  .char-cutin.out .char-cutin-name { opacity: 0; transition: opacity .2s; }
  @keyframes charCutinName { to { transform: translateX(0); opacity: 1 } }
  .char-cutin-line { margin: 6px 0 0 12px; max-width: 46vw; padding: 6px 14px; background: rgba(8,10,16,0.8); border-left: 3px solid var(--cc,#7ad7ff); color: #fff; font-size: 14px; font-weight: 600; text-shadow: 0 1px 4px #000; border-radius: 0 6px 6px 0; transform: translateX(-115%); opacity: 0; animation: charCutinName .4s cubic-bezier(.2,.9,.3,1.1) .3s forwards; }
  .char-cutin.out .char-cutin-line { opacity: 0; transition: opacity .2s; }
  /* 🏮 상점 등장 — 등불 점등 연출 (기습과 정반대: 암전 → 따뜻한 불빛) */
  .shop-cutin { display: none; position: fixed; inset: 0; z-index: 9995; overflow: hidden; align-items: center; justify-content: center; background: rgba(4,4,8,0); transition: background .3s ease; }
  .shop-cutin.show { display: flex; background: rgba(4,4,8,0.92); }
  .shop-cutin.out { background: rgba(4,4,8,0); }
  .sc-glow { position: absolute; left: 50%; top: 52%; width: 125vmin; height: 125vmin; transform: translate(-50%,-50%); border-radius: 50%; background: radial-gradient(circle, rgba(255,186,96,0.55) 0%, rgba(255,150,60,0.22) 32%, transparent 62%); opacity: 0; animation: lanternFlicker .95s ease forwards; }
  @keyframes lanternFlicker { 0% { opacity: 0 } 12% { opacity: .35 } 20% { opacity: .08 } 32% { opacity: .62 } 44% { opacity: .22 } 60% { opacity: .85 } 100% { opacity: .68 } }
  .sc-merchant { position: relative; max-height: 72vh; max-width: 60vw; object-fit: contain; filter: brightness(.05) drop-shadow(0 8px 30px rgba(0,0,0,.7)); opacity: .12; transform: translateY(8px); image-rendering: auto; animation: merchantLit .8s ease .18s forwards; }
  .shop-cutin.out .sc-merchant { animation: merchantDim .28s ease forwards; }
  @keyframes merchantLit { 0% { filter: brightness(.05); opacity: .12; transform: translateY(8px) } 32% { filter: brightness(.4); opacity: .5 } 100% { filter: brightness(1); opacity: 1; transform: translateY(0) } }
  @keyframes merchantDim { to { opacity: 0; transform: scale(.97) } }
  .sc-lantern { position: absolute; left: 50%; bottom: 13%; transform: translateX(-50%); font-size: 38px; opacity: 0; filter: drop-shadow(0 0 14px rgba(255,180,80,.95)); animation: lanternPop .5s cubic-bezier(.2,1.4,.5,1) .08s forwards; }
  @keyframes lanternPop { 0% { opacity: 0; transform: translateX(-50%) scale(.3) } 60% { opacity: 1 } 100% { opacity: 1; transform: translateX(-50%) scale(1) } }
  .sc-name { position: absolute; left: 0; right: 0; bottom: 27%; text-align: center; font-size: 22px; font-weight: 900; color: #ffcf8a; text-shadow: 0 0 18px rgba(255,160,60,.6), 0 2px 4px #000; opacity: 0; animation: scFade .42s ease .62s forwards; }
  .sc-line { position: absolute; left: 7%; right: 7%; bottom: 20%; text-align: center; font-size: 16px; font-weight: 600; color: #fff; text-shadow: 0 2px 10px #000; opacity: 0; animation: scFade .42s ease .76s forwards; }
  @keyframes scFade { from { opacity: 0; transform: translateY(8px) } to { opacity: 1; transform: translateY(0) } }
  /* 🎴 카드 드래프트 */
  .draft-inner { margin: auto; display: flex; flex-direction: column; align-items: center; gap: 18px; padding: 20px; }
  .draft-title { font-size: 21px; font-weight: bold; color: #ffd479; text-shadow: 0 0 16px rgba(255,212,121,0.4); }
  .draft-hint { font-size: 13px; color: #9aa3b3; min-height: 18px; }
  .draft-row { display: flex; gap: 12px; justify-content: center; width: min(92vw, 540px); perspective: 1000px; }
  .draft-card { flex: 1 1 0; min-width: 0; max-width: 170px; aspect-ratio: 2 / 3; border-radius: 12px; cursor: pointer; position: relative; transition: transform .15s, box-shadow .15s, opacity .2s; }
  .draft-card:hover:not(.revealed):not(.dim) { transform: translateY(-8px) scale(1.04); box-shadow: 0 10px 26px rgba(122,215,255,0.35); }
  .draft-card.dim { opacity: 0.3; transform: scale(0.9); }
  .draft-card.revealed { cursor: default; box-shadow: 0 0 30px rgba(255,212,121,0.55); }
  /* 🔄 카드 3D 플립 (뒷면 → 앞면) */
  .dc-inner { position: absolute; inset: 0; transform-style: preserve-3d; -webkit-transform-style: preserve-3d; transition: transform .6s cubic-bezier(.2,.75,.3,1.05); }
  .draft-card.revealed .dc-inner { transform: rotateY(180deg); }
  .dc-back, .dc-front { position: absolute; inset: 0; border-radius: 12px; overflow: hidden; border: 2px solid #3a4256; background: linear-gradient(160deg,#1a2440,#0c1020); backface-visibility: hidden; -webkit-backface-visibility: hidden; display: flex; align-items: center; justify-content: center; }
  .dc-front { transform: rotateY(180deg); border-color: #ffd479; }
  .dc-back img, .dc-front img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .dc-face { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; font-size: 46px; }
  .dc-name { position: absolute; left: 0; right: 0; bottom: 0; padding: 6px 4px; background: linear-gradient(0deg, rgba(8,10,16,0.95), transparent); color: #fff; font-size: 11px; font-weight: bold; text-align: center; }
  /* 🃏 카드 드래프트 등장 — 딜링(타이틀 → 카드 차례로 날아 들어옴) */
  #cardDraftScene.show { animation: dscrimIn .35s ease; }
  @keyframes dscrimIn { from { background-color: rgba(6,8,14,0); } to { background-color: rgba(6,8,14,0.45); } }
  .draft-title { animation: dtIn .4s ease .05s backwards; }
  @keyframes dtIn { from { opacity: 0; transform: translateY(-12px); } to { opacity: 1; transform: none; } }
  .draft-card { animation: dealIn .42s cubic-bezier(.2,.95,.3,1.25) backwards; }
  @keyframes dealIn { from { opacity: 0; transform: translateY(48px) scale(.82); } to { opacity: 1; transform: none; } }
  .draft-hint { display: none; }
  /* ✨ 대박 / 💀 저주 — 이벤트 패널 테두리 연출 */
  @keyframes jackpotGlow { 0%,100% { box-shadow: 0 0 26px rgba(255,210,74,.55), 0 20px 60px rgba(0,0,0,.6); } 50% { box-shadow: 0 0 52px rgba(255,210,74,1), 0 0 92px rgba(255,170,40,.55); } }
  #eventScene.jackpot .npc-scene-inner { border-color: #ffd24a; animation: jackpotGlow 1s ease-in-out infinite; }
  @keyframes curseGlow { 0%,100% { box-shadow: 0 0 18px rgba(180,40,60,.4), 0 20px 60px rgba(0,0,0,.78); } 50% { box-shadow: 0 0 42px rgba(220,30,50,.9); } }
  #eventScene.curse .npc-scene-inner { border-color: #b0203a; animation: curseGlow .7s ease-in-out infinite; }
  #eventScene.curse .npc-panel-title { color: #ff8a8a; text-shadow: 0 0 14px rgba(220,40,60,.6); }
  .draft-card.jackpot { box-shadow: 0 0 42px rgba(255,210,74,.95), 0 0 84px rgba(255,170,40,.55) !important; }
  .draft-card.jackpot .dc-front { border-color: #ffd24a; }
  /* 📱 모바일(세로): NPC 상단 / 내용 하단으로 세로 정렬 (shop·event 공통) */
  @media (max-width: 600px) {
    .npc-scene { padding: 10px; }
    .npc-scene-inner { flex-direction: column; max-height: 90vh; }
    .npc-portrait { flex: 0 0 38vh; width: 100%; min-height: 0; }
    .npc-panel { flex: 1 1 auto; min-height: 0; padding: 12px; }
    .shop-item { padding: 8px; }
    .event-text { max-height: 22vh; }
    .draft-row { gap: 8px; width: 96vw; }
    .draft-title { font-size: 18px; }
  }
</style>
<div id="shopScene" class="npc-scene">
  <div class="npc-scene-inner">
    <div class="npc-portrait" id="shopNpcPortrait"></div>
    <div class="npc-panel">
      <div class="npc-panel-head">
        <span class="npc-panel-title">🛒 떠돌이 상점</span>
        <span class="npc-panel-gold">💰 <span id="shopGold">0</span> G</span>
      </div>
      <div class="shop-grid" id="shopGrid"></div>
      <div class="npc-panel-foot">
        <button class="npc-btn" id="shopCloseBtn">다음 단계로 ▶</button>
      </div>
    </div>
  </div>
</div>

<!-- 🎭 특수보스 처치 이벤트 — 좌 NPC + 우 서사/선택 (.npc-scene 재사용) -->
<div id="eventScene" class="npc-scene">
  <div class="npc-scene-inner">
    <div class="npc-portrait" id="eventNpcPortrait"></div>
    <div class="npc-panel">
      <div class="npc-panel-head">
        <span class="npc-panel-title" id="eventTitle">✦ 사건</span>
        <span class="npc-panel-gold">💰 <span id="eventGold">0</span> G</span>
      </div>
      <div class="event-text" id="eventText"></div>
      <div class="event-choices" id="eventChoices"></div>
      <div class="npc-panel-foot" id="eventFoot" style="display:none;">
        <button class="npc-btn" id="eventCloseBtn">계속 ▶</button>
      </div>
    </div>
  </div>
</div>

<!-- 🎴 카드 드래프트 — 특수보스 처치 시 3장 뒷면 → 선택 → 공개 → 이벤트 -->
<div id="cardDraftScene" class="npc-scene">
  <div class="draft-inner">
    <div class="draft-title">🔮 운명의 카드</div>
    <div class="draft-row" id="draftRow"></div>
    <div class="draft-hint" id="draftHint">한 장을 선택하세요</div>
  </div>
</div>

<!-- ⚡ 기습 이벤트 컷인 — 라운드 중 NPC 난입 연출 (A: 사이드 슬라이드). 내용은 JS에서 주입 -->
<div id="ambushScene" class="ambush-scene"></div>

<!-- 🏮 상점 등장 컷인 — 등불 점등 연출. 내용은 JS에서 주입 -->
<div id="shopCutin" class="shop-cutin"></div>

<div id="rewardSummary" class="reward-overlay">
  <div class="reward-card">
    <div class="reward-head">
      <span class="reward-title">🎁 획득 보상</span>
      <span class="reward-sub" id="rewardSub"></span>
    </div>
    <div class="reward-body" id="rewardBody"></div>
    <button class="reward-ok" id="rewardOk">확인</button>
    <div class="reward-foot">메뉴 › 캐릭터 · 업적 · 도감 에서 다시 볼 수 있어요</div>
  </div>
</div>

<div id="wrap" style="position:relative; display:none;">
  <canvas id="game" width="640" height="640"></canvas>
  <div id="panel">
    <div id="stats">
      <!-- 🔝 핵심 스탯 — 라운드 + 골드 (큼, 강조) -->
      <div class="row primary round"><span class="label">라운드</span><span id="s-round">1</span></div>
      <div class="row secondary"><span class="label">시간</span><span id="s-time">20.0s</span></div>
      <div class="bar warn"><i id="s-timebar" style="width:100%"></i></div>
      <div class="row primary gold"><span class="label">골드</span><span id="s-gold">0</span></div>
      <!-- 🟡 보조 스탯 — 점수 + 적 -->
      <div class="row secondary"><span class="label">점수</span><span id="s-score">0</span></div>
      <div class="row secondary"><span class="label">적</span><span id="s-enemies">0 / 80</span></div>
      <div class="bar"><i id="s-enemybar" style="width:0%"></i></div>
      <!-- ✨ 누적 강화(버프) — 이벤트/상점/유물 효과 상시 표시 -->
      <div class="row secondary" id="s-buffs" style="display:none;"><span class="label">강화</span><span id="s-buffs-val" style="font-size:11px; text-align:right; line-height:1.3; white-space:normal;"></span></div>
      <!-- 🏰 디펜스 모드 (TD) 전용: 본진 HP -->
      <div id="s-defense-block" style="display:none;">
        <div class="row primary" style="border-left-color:#ff5b6e;">
          <span class="label">🏰 본진</span><span id="s-towerhp">30 / 30</span>
        </div>
        <div class="bar"><i id="s-towerhp-bar" style="width:100%; background:#ff5b6e;"></i></div>
      </div>
      <!-- ⚪ 보조 스탯 — 레벨 + 누적 처치 (작게) -->
      <div class="stats-tertiary-group">
        <div class="row tertiary"><span class="label">레벨</span><span id="s-plevel">Lv1 (0/8)</span></div>
        <div class="row tertiary"><span class="label">누적 처치</span><span id="s-totalkills">0</span></div>
      </div>
    </div>
    <hr/>
    <button id="randomBtn">🎲 랜덤 능력 획득 (50G)</button>
    <!-- 🏰 디펜스 모드: 슬롯 클릭 직접 사용 — 뽑기 버튼 제거됨 (v165) -->
    <button id="relicViewBtn" class="relic-view-btn empty">유물 <span id="relic-view-count">0개</span></button>
    <div class="ab-tabs">
      <button class="ab-tab active" data-abtab="active">액티브 <span id="ab-active-count">0/6</span></button>
      <button class="ab-tab" data-abtab="passive">패시브 <span id="ab-passive-count">0/6</span></button>
    </div>
    <div id="abilities"></div>
    <button id="abilityToggle" class="ability-toggle">▲ 능력 확인</button>
    <div class="footer">
      <div class="speed-row">
        <button id="pauseBtn" class="speed-btn" style="flex:1.4">⏸ 일시정지</button>
        <button id="resetBtn" class="speed-btn">⟳ 리셋</button>
        <button id="menuBtn" class="speed-btn">🏠 메뉴</button>
        <button id="speedCycle" class="speed-btn" title="배속 순환">⏩ ×1</button>
      </div>
      <div class="hotkey-hint">Space: 일시정지 · R: 리셋 · ⏩: 배속</div>
    </div>
  </div>
  <div id="toast" class="toast"></div>
</div>

<script>
(() => {
  // ===== 상수 =====
  const canvas = document.getElementById('game');
  const ctx = canvas.getContext('2d');
  // 📱 모바일 성능 — 발열/렉/강제종료 완화
  //   모바일 판별 (터치 포인터 또는 UA)
  const IS_MOBILE = (function(){
    try { return (window.matchMedia && window.matchMedia('(pointer: coarse)').matches)
      || /Android|iPhone|iPad|iPod|Mobile|Silk|Kindle/i.test(navigator.userAgent || ''); }
    catch(e){ return false; }
  })();
  // 📱 그림자 블러는 캔버스에서 가장 비싼 연산 → 모바일에선 전역 무력화 (프로토타입 단일 패치)
  if (IS_MOBILE) {
    try {
      const _proto = CanvasRenderingContext2D.prototype;
      const _d = Object.getOwnPropertyDescriptor(_proto, 'shadowBlur');
      if (_d && _d.set) Object.defineProperty(_proto, 'shadowBlur', {
        configurable: true, get: _d.get, set: function(){ _d.set.call(this, 0); },
      });
    } catch(e){}
  }
  // 논리적 크기 — 모드별로 가변 (표준 640×640, TD 540×800)
  // 내부 해상도는 DPR 만큼 키워 텍스트 선명도 확보.
  // 🎨 컬러 그레이딩 — 채도/대비 살짝 올려 화사하게 (GPU 처리라 가벼움)
  try { canvas.style.filter = 'saturate(1.08) contrast(1.03)'; } catch(e){}   // 🌙 밝기 가산 제거 — 채도만 살짝
  let W = 640, H = 640;
  // 📱 DPR 제한 — 모바일 1.5배(픽셀 ~75%↓), 데스크탑 2배. (기존 3배는 휴대폰에서 370만 픽셀/프레임 → 과열)
  const DPR = Math.max(1, Math.min(IS_MOBILE ? 1.5 : 2, window.devicePixelRatio || 1));
  // ⚠ CX, CY는 가변 — 타워별 컨텍스트 스왑 시 임시로 변경됨 (TD 모드)
  // 그래도 대부분의 시간엔 "캔버스 중앙"의 의미로 동작
  let CX = W/2, CY = H/2;
  let CX_BASE = CX, CY_BASE = CY;  // UI/그림 기준점 (가변 — 모드 전환 시 갱신)
  function applyCanvasSize(targetMode) {
    // 모든 모드 공통 — 640×640 정사각 (모바일 가로폭 통일, 오른쪽 여백 제거)
    // TD는 10×10 셀(셀폭 64) = 640×640 그리드로 캔버스를 가득 채움
    W = 640; H = 640;
    canvas.width = W * DPR;
    canvas.height = H * DPR;
    canvas.style.width = W + 'px';
    canvas.style.height = H + 'px';
    // canvas.width 변경 시 ctx transform 이 초기화되므로 DPR 스케일 재적용
    ctx.setTransform(1, 0, 0, 1, 0, 0);
    ctx.scale(DPR, DPR);
    // 🖼 스무딩 ON — 고해상도 캐릭터 PNG(533~870px)를 또렷하게 축소 + 글로우/블룸 매끈하게.
    //    적/능력은 벡터(arc/그라데이션)라 영향 없음. 계단현상(도트) 제거 → 세련된 룩.
    //    품질은 기본('low' bilinear) — 글로우 스프라이트 수천 개에도 가벼움. 캐릭터만 국소적으로 'high'.
    ctx.imageSmoothingEnabled = true;
    // 중앙 좌표 갱신
    CX = W/2; CY = H/2;
    CX_BASE = CX; CY_BASE = CY;
  }
  // 초기값 — 표준 모드 기준으로 캔버스 셋업
  applyCanvasSize('standard');

  const ARENA_R = 290;
  const CORE_R  = 22;
  // 🏰 디펜스 모드 — Tower Defense 클래식 (셀 그리드 미로)
  // 캔버스 640×640 (표준 모드와 동일). 셀 64×64 → 10×10 그리드 (정확히 캔버스 가득)
  const TD = {
    cellW: 64,
    cols: 10,
    rows: 10,
    canvasW: 640,
    canvasH: 640,
  };
  // 그리드 오프셋 — 캔버스 중앙에 9×12 그리드(540×720) 배치
  // W=540 → 가로 오프셋 0. H=800 → 세로 오프셋 (800-720)/2 = 40
  function tdGridOffsetX() { return Math.max(0, (W - TD.cols * TD.cellW) / 2); }
  function tdGridOffsetY() { return Math.max(0, (H - TD.rows * TD.cellW) / 2); }
  // 🚀 cellCenter — 셀 (col, row) → 픽셀 (x, y) 중심
  //    매 호출마다 객체 할당이 일어나던 핫 패스. W/H 변경 시에만 [col][row] 룩업 테이블 재계산.
  //    캐시된 객체는 read-only 가정 (현재 호출처는 모두 .x/.y만 읽음).
  function _ensureCellCenters() {
    if (TD._cachedW === W && TD._cachedH === H && TD._cellCenters) return;
    const offX = Math.max(0, (W - TD.cols * TD.cellW) / 2);
    const offY = Math.max(0, (H - TD.rows * TD.cellW) / 2);
    const halfCell = TD.cellW / 2;
    const tab = [];
    for (let c = 0; c < TD.cols; c++) {
      const colArr = [];
      for (let r = 0; r < TD.rows; r++) {
        colArr[r] = { x: offX + c * TD.cellW + halfCell, y: offY + r * TD.cellW + halfCell };
      }
      tab[c] = colArr;
    }
    TD._cellCenters = tab;
    TD._cachedW = W;
    TD._cachedH = H;
    TD._offX = offX;
    TD._offY = offY;
    TD._halfCell = halfCell;
  }
  function cellCenter(col, row) {
    _ensureCellCenters();
    const colArr = TD._cellCenters[col];
    if (colArr) {
      const cell = colArr[row];
      if (cell) return cell;
    }
    // 안전망 — 경계 밖 좌표는 새 객체 생성 (드물게 호출됨)
    return {
      x: TD._offX + col * TD.cellW + TD._halfCell,
      y: TD._offY + row * TD.cellW + TD._halfCell,
    };
  }
  // 셀 영역 (사각형)
  function cellRect(col, row) {
    return {
      x: tdGridOffsetX() + col * TD.cellW,
      y: tdGridOffsetY() + row * TD.cellW,
      w: TD.cellW, h: TD.cellW,
    };
  }
  // 두 셀 중심 간 거리 (path 진행용)
  function cellDist(a, b) {
    const ca = cellCenter(a.col, a.row), cb = cellCenter(b.col, b.row);
    return Math.hypot(cb.x - ca.x, cb.y - ca.y);
  }
  // 📜 MVP 맵 정의 — 기본 미로 (S자 경로)
  // path: 적이 이동하는 셀들 (시작→끝 순서, 인접해야 함)
  // slots: 타워 배치 가능 셀들
  // core: 적이 도달하면 타워가 데미지 받는 셀 (path의 마지막)
  // 단일 path → paths[0] 변환 헬퍼 (구버전 호환)
  function getMapPaths(map) {
    if (map.paths) return map.paths;
    return [map.path];
  }
  function getMapSpawns(map) {
    if (map.spawns) return map.spawns;
    const p = (map.paths || [map.path])[0];
    return [p[0]];
  }
  const TD_MAPS = {
    basic: {
      name: '기본 미로',
      // 10×10 grid, S자 경로 (3-단계 S + 마지막 코어 도착)
      path: [
        // 1단계: Row 0 (왼→오)
        {col:0, row:0}, {col:1, row:0}, {col:2, row:0}, {col:3, row:0}, {col:4, row:0},
        {col:5, row:0}, {col:6, row:0}, {col:7, row:0}, {col:8, row:0}, {col:9, row:0},
        // Row 1-2 (col 9 아래)
        {col:9, row:1}, {col:9, row:2},
        // 2단계: Row 3 (오→왼)
        {col:9, row:3}, {col:8, row:3}, {col:7, row:3}, {col:6, row:3}, {col:5, row:3},
        {col:4, row:3}, {col:3, row:3}, {col:2, row:3}, {col:1, row:3}, {col:0, row:3},
        // Row 4-5 (col 0 아래)
        {col:0, row:4}, {col:0, row:5},
        // 3단계: Row 6 (왼→오)
        {col:0, row:6}, {col:1, row:6}, {col:2, row:6}, {col:3, row:6}, {col:4, row:6},
        {col:5, row:6}, {col:6, row:6}, {col:7, row:6}, {col:8, row:6}, {col:9, row:6},
        // Row 7-8 (col 9 아래)
        {col:9, row:7}, {col:9, row:8},
