        choices: [
          { label: '계약한다', desc: `골드 -50% · 데미지 +${_evP(24)}% 영구`, disabled: state.gold < 10,
            resolve() { const lost = Math.floor(state.gold * 0.5); state.gold -= lost; _evClampGold(); const p = _evDmg(24); return `🩸 -${lost}G, 데미지 +${p}% 영구!`; } },
          { label: '거절한다', desc: '영혼은 안 판다', resolve() { return '악마가 사라진다.'; } },
