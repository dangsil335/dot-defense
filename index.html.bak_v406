      ctx.fillStyle = dark; ctx.beginPath(); ctx.moveTo(-s * 0.14, -s * 1.0); ctx.lineTo(s * 0.14, -s * 1.0); ctx.lineTo(0, -tip); ctx.closePath(); ctx.fill();
      ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.fillStyle = `rgba(${ergb},${0.5 * glowI})`; ctx.beginPath(); ctx.arc(0, -tip, s * 0.07, 0, Math.PI * 2); ctx.fill(); ctx.restore();
      ctx.restore();
