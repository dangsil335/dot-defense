        choices: [ { label: '받는다', desc: '골드 획득 (가끔 대박!)', resolve() { const big = Math.random() < 0.2; const g = _evUnit() * (big ? 6 : 3); state.gold += g; return big ? `☀✨ 대박! +${g}G!` : `☀ +${g}G!`; } } ] }),
