  let supabaseClient = null;
  function getSupabase() {
    if (supabaseClient) return supabaseClient;
    if (!SUPABASE_URL || !SUPABASE_ANON_KEY) return null;
    if (typeof window.supabase === 'undefined') return null; // CDN 미로드 시
    try {
      supabaseClient = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
      return supabaseClient;
    } catch (e) {
      console.warn('Supabase 초기화 실패:', e);
      return null;
    }
  }
  function isSupabaseEnabled() {
    return !!(SUPABASE_URL && SUPABASE_ANON_KEY && typeof window.supabase !== 'undefined');
  }

  // 닉네임 + 유저ID 관리
  function genUUID() {
    if (window.crypto && crypto.randomUUID) return crypto.randomUUID();
    return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, c => {
      const r = Math.random() * 16 | 0, v = c === 'x' ? r : (r & 0x3 | 0x8);
      return v.toString(16);
    });
  }
  function ensureUserId() {
    if (!META.userId) {
      META.userId = genUUID();
      saveMeta();
    }
    return META.userId;
  }
  function getNickname() { return META.nickname || null; }

