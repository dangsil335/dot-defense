        ] }),
    ]},
    fool: { name: '바보 · 단테', fb: '🃏', art: 'fool', color: '#9ad0ff', events: [
      () => ({ title: '🃏 수상한 상자', text: '길에 상자가 있네. …열어볼까?',
        choices: [
          { label: '열어본다', desc: '대박? 함정?', resolve() { const r = Math.random();
              if (r < 0.40) { const g = _evUnit() * 5; state.gold += g; return `🪙 +${g}G!`; }
              if (r < 0.65) { const nm = _evGiveRelic(); return nm ? `🔮 유물 ${nm}!` : '유물 발견!'; }
              if (r < 0.85) { return '🎴 ' + _evGainAbility(1); }
              const p = _evDmg(-7); return `💥 미믹! 데미지 ${p}%.`; } },
          { label: '두고 간다', desc: '수상하다', resolve() { return '상자를 지나친다.'; } },
        ] }),
      () => { const cost = _evUnit() * 3; return {
        title: '🃏 잠긴 보물상자', text: '자물쇠가 단단한데. 열쇠값은 좀 들겠어.',
        choices: [
          { label: `연다 (${cost}G)`, desc: '유물/큰 골드 확정', disabled: state.gold < cost, resolve() { state.gold -= cost; if (Math.random() < 0.5) { const nm = _evGiveRelic(); if (nm) return `🔮 유물 ${nm}!`; } const g = _evUnit() * 8; state.gold += g; return `💰 +${g}G!`; } },
          { label: '두고 간다', desc: '아깝다', resolve() { return '상자를 두고 떠난다.'; } },
        ] }; },
      () => { const lucky = Math.random() < 0.5; return {
        title: '🃏 믿음의 도약', text: '하나엔 보물, 하나엔 허탕. 감으로 골라.',
        choices: [
          { label: '◀ 왼쪽', desc: '두근두근…', resolve() { if (lucky) { const g = _evUnit() * 6; state.gold += g; return `🎉 정답! +${g}G!`; } return '텅… 비었다.'; } },
          { label: '오른쪽 ▶', desc: '두근두근…', resolve() { if (!lucky) { const g = _evUnit() * 6; state.gold += g; return `🎉 정답! +${g}G!`; } return '텅… 비었다.'; } },
        ] }; },
    ]},
    magician: { name: '마법사 · 메를린', fb: '🪄', art: 'magician', color: '#7ad7ff', events: [
      () => ({ title: '🪄 변성', text: '"마음에 안 드는 힘? 레벨은 그대로 둔 채, 다른 능력으로 빚어주지."',
        choices: [
