  // 🛒 v283 — 강화소 비용 전역 강화 (스타더스트 수급 증가 + 신규 항목 대응)
  //   v237: ×2 × (1+lv×0.1) → v283: ×2.8 × (1+lv×0.15)
  //   - 베이스 ×2.8: 전반 비용 40% ↑
  //   - 후반 가속 강화 (0.1→0.15): 만렙 막판이 가파르게 (수급 많은 후반 흡수)
  (function applyShopCostInflation() {
    for (const up of META_UPGRADES) {
      const origCost = up.cost;
      up.cost = (lv) => Math.ceil(origCost(lv) * 2.8 * (1 + lv * 0.15));
    }
  })();
  function getMetaMods() {
    const v = id => {
      const up = META_UPGRADES.find(u => u.id === id);
      return up && up.apply ? up.apply(metaLv(id)) : 0;
    };
    return {
      startGold:   v('startGold'),
      goldMul:     1 + v('goldGain'),
      freeRolls:   metaLv('freeRolls'),
      enhanceMul:  (1 - v('enhance')) * (1 - v('enhance2')),  // 두 강화 누적
      extraSlot:   metaLv('extraSlot'),
      bossDmgMul:  1 + v('bossDmg'),
      scoreMul:    1 + v('killScore'),
      startScore:  v('startScore'),
      levelUpFast: v('levelUpFast'),
      dmgBoost:    v('dmgBoost'),
      bossGoldMul: v('bossGold'),
      // 🆕 v280 — 신규 강화 항목
      fireRateBonus:    v('fireRate'),       // 액티브 쿨다운 감소 (프레임당 추가 차감)
      // 🎯 v282 — 공격 유형별 데미지 강화 (태그 기반)
      tagDmg: {
        wide:   v('dmgWide'),    explo: v('dmgExplo'), pierce: v('dmgPierce'),
        multi:  v('dmgMulti'),   chain: v('dmgChain'), spin:   v('dmgSpin'),
        snipe:  v('dmgSnipe'),
      },
      stardustGainMul:  1 + v('stardustGain'), // 게임 종료 스타더스트 배수
      passiveSlotBonus: metaLv('passiveSlot'), // 패시브 슬롯 추가
      luckyChanceBonus:      v('luckyChance'),         // 럭키 카드 추가 확률
      superLuckyChanceBonus: v('superLuckyChance'),    // 슈퍼럭키 추가 확률
      comboPowerBonus:       v('comboPower'),          // 조합/트리플 데미지 보너스
      maxAliveBonus:         v('maxAliveBonus'),       // 적 수용 한계 추가
      startReroll:           metaLv('startReroll'),    // 시작 시 추가 리롤
      roundTimeBonus:        v('roundTime'),           // 라운드 시간 추가 (초)
      relicRarityBoost:      v('relicRarity'),         // 유물 고급 등급 확률 (0~15)
      // 🏰 디펜스 모드 전용 (디펜스 모드일 때만 적용)
      towerHPBonus:          v('towerHP'),             // 타워 시작 HP 추가
      towerRegenLv:          v('towerRegen'),          // 라운드 클리어 시 타워 회복량
      towerArmor:            v('towerArmor'),          // 받는 데미지 감소율
      defenseSlowBonus:      v('defenseSlow'),         // 적 속도 감소
      defenseRevive:         metaLv('defenseRevive'),  // 부활 1회 (0 또는 1)
    };
  }
  function buyUpgrade(id) {
    const up = META_UPGRADES.find(u => u.id === id);
    if (!up) return false;
    const cur = metaLv(id);
    if (cur >= up.maxLv) return false;
    const cost = up.cost(cur);
    if ((META.stardust || 0) < cost) return false;
    META.stardust -= cost;
    META.stardustSpent = (META.stardustSpent || 0) + cost;   // 🛡 누적 소비 카운터 (refund 버그 방어)
    META.upgrades = META.upgrades || {};
    META.upgrades[id] = cur + 1;
    saveMeta();
    // 강화소 구매는 중요한 영구 진행 → 즉시 서버 동기화 (디바운스 X)
    if (typeof queueServerSync === 'function') queueServerSync(true);
    SFX.combo();
    // 🎯 v226 — 스타더스트 감소 펄스 (다음 프레임에 buildShop 호출 후 반영)
    setTimeout(() => _pulseEl(document.getElementById('stardust-count'), true), 0);
    return true;
  }
  function earnStardust() {
    const ascMul = (state.asc && state.asc.stardustMul) || 1;
    // 💎 v210 — 점수 기반 스타더스트 소프트캡 (고점수 폭주 차단)
    //   첫 100k 점수까지: 선형 (1/800) — 초/중반 보상 그대로
    //   100k 이상: sqrt 소프트캡 — 후반 1억점도 합리적 보상
    //   비교 (점수 → 점수분 스타더스트):
    //     100k    →  125  (그대로)
    //     1M      →  337  (이전 1,250)
    //     10M     →  829  (이전 12,500)
    //     100M    →  2,360 (이전 125,000)  ← ★ 53배 감소
    //     1B      →  7,200 (이전 1,250,000) ← 173배 감소
    const score = state.score || 0;
    let scoreDust;
    if (score <= 100000) {
      scoreDust = Math.floor(score / 800);
    } else {
      scoreDust = 125 + Math.floor(Math.sqrt((score - 100000) / 20));
    }
    // 🆕 v280 — 스타더스트 획득 강화 (메타) 적용
    const sdGainMul = (state.metaMods && state.metaMods.stardustGainMul) || 1;
    // 🛡 v266 — 한 게임 스타더스트 상한 20,000 (인플레/폭증 방지) — 강화 반영 후 cap
    const earned = Math.min(20000, Math.floor((scoreDust + state.round * 3 + (state.gameWin ? 300 : 0)) * ascMul * sdGainMul));
    META.stardust = (META.stardust || 0) + earned;
    // 🛡 stardustEarned가 stardust보다 작으면 (서버 직접 수정 등) catch-up 보장 → sync 시 데이터 손실 방지
    META.stardustEarned = Math.max(META.stardustEarned || 0, (META.stardust - earned) || 0) + earned;
    // 승천/초월 클리어 시 다음 단계 해금 — 초월 영역(16~30)까지 단계적 해금
    if (state.gameWin && state.ascension >= getMaxAscension() && state.ascension < MAX_DIFFICULTY) {
      META.maxAscension = (META.maxAscension || 0) + 1;
      state.newAscensionUnlocked = META.maxAscension;
    }
    saveMeta();
    state.stardustEarned = earned;
  }

