    _ascBadgeKey = ''; // 배지 캐시도 무효화 (액센트색 변경 반영)
  }
  function updateBackground() {
    for (const s of BG.stars) {
      s.x += s.vx;
      if (s.x < -3) s.x = W + 3;
      s.tw += s.twSpeed;
    }
    BG.meteorTimer--;
    if (BG.meteorTimer <= 0) {
      const mr = BG.meteorRate || [240, 500];
      BG.meteorTimer = mr[0] + Math.random()*mr[1];
      const fromTop = Math.random() < 0.5;
      BG.meteors.push({
        x: fromTop ? Math.random()*W : W + 50,
        y: fromTop ? -20 : Math.random()*H*0.5,
        vx: -4 - Math.random()*3,
        vy: 3 + Math.random()*2,
        life: 250,
      });
    }
    for (const m of BG.meteors) { m.x += m.vx; m.y += m.vy; m.life--; }
    // 🚀 인플레이스 compaction — 매 프레임 새 배열 할당 제거
    {
      let w = 0;
      const arr = BG.meteors;
      const n = arr.length;
      for (let r = 0; r < n; r++) {
        const m = arr[r];
        if (m.life > 0 && m.x > -60 && m.y < H + 60) {
          if (w !== r) arr[w] = m;
          w++;
        }
      }
      arr.length = w;
    }
  }
  // 🚀 정적 하늘 베이크 1 — 베이스 그라데이션 + 은하 실루엣 + 성운 (티어 변경 시에만 재생성)
  //    매 프레임 풀캔버스 라디얼 채우기 4회(베이스+성운3) → 불투명 drawImage 1회
  function bakeSkyTexture() {
    try {
      const BT = BG_TIERS[BG.tier || 0];
      const c = document.createElement('canvas'); c.width = W * DPR; c.height = H * DPR;
      const g2 = c.getContext('2d'); g2.scale(DPR, DPR);
      // 베이스 — 중앙 → 가장자리 칠흑
      const cx = W * 0.5, cy = H * 0.42;
      const bg = g2.createRadialGradient(cx, cy, 0, cx, cy, W * 0.82);
      bg.addColorStop(0, `rgb(${BT.core[0]}, ${BT.core[1]}, ${BT.core[2]})`);
      bg.addColorStop(0.55, BT.mid);
      bg.addColorStop(1, BT.edge);
      g2.fillStyle = bg; g2.fillRect(0, 0, W, H);
      // 초월 — 거대 은하 실루엣 (정적)
      if (BG.core) {
        const co = BG.core;
        g2.save(); g2.translate(co.x, co.y); g2.rotate(-0.5);
        const g = g2.createRadialGradient(0, 0, 0, 0, 0, co.r);
        g.addColorStop(0, 'rgba(120,98,150,0.15)'); g.addColorStop(0.4, 'rgba(82,66,112,0.09)'); g.addColorStop(1, 'rgba(50,40,80,0)');
        g2.fillStyle = g; g2.beginPath(); g2.ellipse(0, 0, co.r, co.r * 0.62, 0, 0, Math.PI*2); g2.fill();
        const cg = g2.createRadialGradient(0, 0, 0, 0, 0, co.r * 0.2);
        cg.addColorStop(0, 'rgba(186,166,206,0.18)'); cg.addColorStop(1, 'rgba(186,166,206,0)');
        g2.fillStyle = cg; g2.beginPath(); g2.arc(0, 0, co.r * 0.2, 0, Math.PI*2); g2.fill();
        g2.restore();
      }
      // 성운 (위치/색 고정)
      for (const n of BG.nebulae) {
        const ng = g2.createRadialGradient(n.x, n.y, 0, n.x, n.y, n.r);
        ng.addColorStop(0, n.c); ng.addColorStop(1, 'rgba(0,0,0,0)');
        g2.fillStyle = ng; g2.fillRect(0, 0, W, H);
      }
      BG.skyTex = c;
    } catch (e) { BG.skyTex = null; }
  }
  // 🚀 정적 하늘 베이크 2 — 행성 (본체+터미네이터+고리, 투명 배경) — 별이 행성 아래 깔리는 레이어 순서 유지용 분리
  function bakePlanetTexture() {
    try {
      const c = document.createElement('canvas'); c.width = W * DPR; c.height = H * DPR;
      const g2 = c.getContext('2d'); g2.scale(DPR, DPR);
      for (const p of BG.planets) {
        const pg = g2.createRadialGradient(p.x - p.r*0.35, p.y - p.r*0.35, 0, p.x, p.y, p.r);
        pg.addColorStop(0, p.c1); pg.addColorStop(1, p.c2);
        g2.fillStyle = pg; g2.beginPath(); g2.arc(p.x, p.y, p.r, 0, Math.PI*2); g2.fill();
        // 그림자 — 부드러운 터미네이터
        g2.save();
        g2.beginPath(); g2.arc(p.x, p.y, p.r, 0, Math.PI*2); g2.clip();
        const sg = g2.createRadialGradient(p.x - p.r*0.4, p.y - p.r*0.4, p.r*0.2, p.x + p.r*0.55, p.y + p.r*0.55, p.r*1.5);
        sg.addColorStop(0, 'rgba(0,0,0,0)'); sg.addColorStop(0.55, 'rgba(0,0,0,0.18)'); sg.addColorStop(1, 'rgba(0,0,0,0.62)');
        g2.fillStyle = sg; g2.fillRect(p.x - p.r, p.y - p.r, p.r*2, p.r*2);
        g2.restore();
        // 고리
        if (p.ring) {
          g2.save();
          g2.translate(p.x, p.y);
          g2.scale(1, 0.32);
          g2.strokeStyle = p.ringC; g2.lineWidth = 2;
          g2.beginPath(); g2.arc(0, 0, p.r * 1.9, 0, Math.PI*2); g2.stroke();
          g2.restore();
        }
      }
      BG.planetTex = c;
    } catch (e) { BG.planetTex = null; }
  }
  // 🚀 별 스프라이트 (단색 원) — 별마다 매 프레임 beginPath/arc/fill 패스 테셀레이션 제거
  const _starSpr = {};
  function _starSprite(col) {
    if (_starSpr[col]) return _starSpr[col];
    const S = 16, c = document.createElement('canvas'); c.width = c.height = S;
    const g2 = c.getContext('2d');
    g2.fillStyle = col; g2.beginPath(); g2.arc(S/2, S/2, S/2, 0, Math.PI*2); g2.fill();
    _starSpr[col] = c; return c;
  }
  let _ascBadgeCv = null, _ascBadgeKey = ''; // 🚀 승천 배지 캐시 (매 프레임 이모지 fillText+shadowBlur 제거)
  function drawBackground() {
    const asc = (state && state.ascension) || 0;
    const BT = BG_TIERS[BG.tier || 0];
    // 🌌 정적 하늘 (베이스+은하+성운) — 베이크 1장 blit
    if (!BG.skyTex) bakeSkyTexture();
    if (BG.skyTex) ctx.drawImage(BG.skyTex, 0, 0, W, H);
    else { ctx.fillStyle = BT.mid; ctx.fillRect(0, 0, W, H); }
    // 🌈 승천 — 상단 오로라 리본 (은은하게 흐름, 중앙 안 가림)
    if (BG.sky === 'aurora') {
      ctx.save(); ctx.globalCompositeOperation = 'lighter';
      const tt = state.t * 0.01;
      for (let band = 0; band < 2; band++) {
        const baseY = 66 + band * 46, col = band ? '150,118,222' : '120,162,220';
        ctx.beginPath();
        for (let x = -20; x <= W + 20; x += 16) {
          const y = baseY + Math.sin(x*0.012 + tt + band) * 16 + Math.sin(x*0.031 - tt*0.7) * 6;
          x <= -20 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
        }
        ctx.strokeStyle = `rgba(${col},${0.05 + 0.025*Math.sin(tt + band)})`; ctx.lineWidth = 22 - band*7; ctx.lineCap = 'round';
        ctx.stroke();
      }
      ctx.restore();
    }
    // 별 — 큰 별 글로우 (가산 1패스, 단계별 틴트) — 🚀 스프라이트 blit
    ctx.save(); ctx.globalCompositeOperation = 'lighter';
    const _gspr = _starSprite('rgb(' + (BG.glowTint || '191,224,255') + ')');
    for (const s of BG.stars) {
      if (s.size < 2) continue;
      const tw = (Math.sin(s.tw) + 1) / 2;
      ctx.globalAlpha = s.brightness * (0.5 + tw * 0.5) * 0.45;
      const gr = s.size * 1.6;
      ctx.drawImage(_gspr, s.x - gr, s.y - gr, gr * 2, gr * 2);
    }
    ctx.restore();
    // 별 코어 — 소프트 점 (단계별 틴트) — 🚀 스프라이트 blit
    const _cspr = _starSprite('rgb(' + (BG.starTint || '255,255,255') + ')');
    for (const s of BG.stars) {
      const tw = (Math.sin(s.tw) + 1) / 2;
      ctx.globalAlpha = s.brightness * (0.5 + tw * 0.5);
      const cr = s.size * 0.55 + 0.4;
      ctx.drawImage(_cspr, s.x - cr, s.y - cr, cr * 2, cr * 2);
    }
    ctx.globalAlpha = 1;
    // 행성 — 🚀 베이크 1장 blit (본체+터미네이터+고리, 별 위 레이어 순서 유지)
    if (!BG.planetTex) bakePlanetTexture();
    if (BG.planetTex) ctx.drawImage(BG.planetTex, 0, 0, W, H);
    // 배경 유성 (분위기용)
    for (const m of BG.meteors) {
      const alpha = Math.min(1, m.life / 50);
      const len = Math.hypot(m.vx, m.vy);
      const tx = m.x - (m.vx / len) * 28;
      const ty = m.y - (m.vy / len) * 28;
      const mc = BG.meteorCol || '255,224,128';
      const grad = ctx.createLinearGradient(m.x, m.y, tx, ty);
      grad.addColorStop(0, `rgba(${mc}, ${alpha * 0.85})`);
      grad.addColorStop(1, `rgba(${mc}, 0)`);
      ctx.strokeStyle = grad; ctx.lineWidth = 2;
      ctx.beginPath(); ctx.moveTo(m.x, m.y); ctx.lineTo(tx, ty); ctx.stroke();
      ctx.globalAlpha = alpha;
      ctx.fillStyle = '#ffffff'; ctx.fillRect(m.x - 1, m.y - 1, 3, 3);
    }
    ctx.globalAlpha = 1;
    // 단계 표시 = 우측 상단 배지만 — 🚀 캐시 canvas blit (매 프레임 이모지 fillText+shadowBlur 제거)
    if (asc > 0) {
      const tier = BG.tier || 1;
      const isTrans = tier >= 2;
      const bKey = (isTrans ? 'T' : 'A') + asc;
      if (_ascBadgeKey !== bKey || !_ascBadgeCv) {
        const c = document.createElement('canvas'); c.width = 170 * DPR; c.height = 30 * DPR;
        const g2 = c.getContext('2d'); g2.scale(DPR, DPR);
        g2.font = 'bold 14px Jua, sans-serif';
        g2.textAlign = 'right';
        g2.fillStyle = isTrans ? '#c89ad8' : '#c4b0e8';   // 차분한 액센트색
        g2.shadowColor = BG.accent || '#9a7ad0';
        g2.shadowBlur = 6;
        g2.fillText(isTrans ? `🌌 초월 ${asc - 15}` : `⚡ 승천 ${asc}`, 166, 22);
        _ascBadgeCv = c; _ascBadgeKey = bKey;
      }
      ctx.drawImage(_ascBadgeCv, W - 178, 0, 170, 30);
    }
  }

  // ===== 렌더 =====
  // 🚀 아레나 정적 리소스 캐시 (액센트는 게임당 고정 — hex 파싱/문자열/그라디언트 매 프레임 재생성 제거)
  let _arenaAcc = '', _arenaArgb = '', _arenaLrgb = '', _arenaFg = null, _arenaVg = null;
  let _arenaSpokeStyle = '', _arenaRingStyle = '', _arenaDashStyle = '', _arenaEdgeStyle = '';
  function drawArena() {
    // 🏰 디펜스 모드 — 완전히 다른 레이아웃 (3 레인 + 돌담 + 방벽)
    if (state.mode === 'defense') {
      drawDefenseArena();
      return;
    }
    // 표준 모드 — 홀로그래픽 라디얼 아레나 (단계 액센트색으로 틴트 = 색은 여기에만, 하늘은 깨끗)
    // 🚀 hex 파싱·문자열·그라디언트 전부 액센트 키로 캐시 (액센트는 게임당 고정)
    const acc = BG.accent || '#5ab4e0';
    if (_arenaAcc !== acc) {
      const _an = parseInt(acc.slice(1), 16), AR = (_an>>16)&255, AG = (_an>>8)&255, AB = _an&255;
      _arenaArgb = `${AR},${AG},${AB}`;
      _arenaLrgb = `${Math.min(255,AR+90)},${Math.min(255,AG+90)},${Math.min(255,AB+90)}`;
      _arenaFg = ctx.createRadialGradient(CX, CY - 24, 18, CX, CY, ARENA_R);
      _arenaFg.addColorStop(0, `rgba(${_arenaArgb},0.11)`); _arenaFg.addColorStop(0.62, `rgba(${_arenaArgb},0.05)`); _arenaFg.addColorStop(1, `rgba(${_arenaArgb},0)`);
      _arenaVg = ctx.createRadialGradient(CX, CY, ARENA_R*0.55, CX, CY, ARENA_R);
      _arenaVg.addColorStop(0, 'rgba(0,0,0,0)'); _arenaVg.addColorStop(1, 'rgba(0,0,0,0.26)');
      _arenaSpokeStyle = `rgba(${_arenaArgb},0.045)`;
      _arenaRingStyle = `rgba(${_arenaArgb},0.09)`;
      _arenaDashStyle = `rgba(${_arenaLrgb},0.16)`;
      _arenaEdgeStyle = `rgb(${_arenaLrgb})`;
      _arenaAcc = acc;
    }
    const argb = _arenaArgb, lrgb = _arenaLrgb;
    // 1) 바닥 에너지 디스크 (캐시 그라디언트)
    ctx.fillStyle = _arenaFg; ctx.beginPath(); ctx.arc(CX, CY, ARENA_R, 0, Math.PI*2); ctx.fill();
    // 1.5) 🌌 텍스처 바닥 (베이크) — 유기질 노이즈 + 그레인, 림 페이드 (도트 질감 + 깊이)
    if (BG.arenaTex) ctx.drawImage(BG.arenaTex, CX - ARENA_R, CY - ARENA_R);
    // 2) 회전 홀로 스포크 (가산, 아주 옅게) — 🚀 36개를 한 패스로 배칭 (1 stroke)
    ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.translate(CX, CY); ctx.rotate(state.t * 0.0022);
    ctx.strokeStyle = _arenaSpokeStyle; ctx.lineWidth = 1;
    ctx.beginPath();
    for (let k = 0; k < 36; k++) { const a = k * Math.PI / 18; ctx.moveTo(Math.cos(a)*44, Math.sin(a)*44); ctx.lineTo(Math.cos(a)*ARENA_R, Math.sin(a)*ARENA_R); }
    ctx.stroke();
    ctx.restore();
    // 3) 동심 그리드 링 — 🚀 한 패스로 배칭 (1 stroke)
    ctx.strokeStyle = _arenaRingStyle; ctx.lineWidth = 1;
    ctx.beginPath();
    for (let r = 60; r <= ARENA_R; r += 40) { ctx.moveTo(CX + r, CY); ctx.arc(CX, CY, r, 0, Math.PI*2); }
    ctx.stroke();
    // 4) 회전 점선 테크 링
    ctx.save(); ctx.strokeStyle = _arenaDashStyle; ctx.lineWidth = 1.5;
    ctx.setLineDash([6, 14]); ctx.lineDashOffset = -(state.t * 0.4) % 20;
    ctx.beginPath(); ctx.arc(CX, CY, ARENA_R * 0.72, 0, Math.PI*2); ctx.stroke();
    ctx.setLineDash([]); ctx.restore();
    // 4.5) 🌑 내부 엣지 섀도우 — 캐시 그라디언트 + 클립 제거 (채우기 패스가 동일 원이라 클립 불필요)
    ctx.fillStyle = _arenaVg; ctx.beginPath(); ctx.arc(CX, CY, ARENA_R, 0, Math.PI*2); ctx.fill();
    // 5) 엣지 글로우 링 (가산 펄스) + 선명한 테두리
    const aPulse = 0.5 + 0.5 * Math.sin(state.t * 0.03);
    ctx.save(); ctx.globalCompositeOperation = 'lighter';
    ctx.globalAlpha = 0.10 + aPulse * 0.06; ctx.strokeStyle = acc; ctx.lineWidth = 8;
    ctx.beginPath(); ctx.arc(CX, CY, ARENA_R, 0, Math.PI*2); ctx.stroke();
    ctx.globalAlpha = 0.5; ctx.strokeStyle = _arenaEdgeStyle; ctx.lineWidth = 2;
    ctx.beginPath(); ctx.arc(CX, CY, ARENA_R, 0, Math.PI*2); ctx.stroke();
    ctx.restore(); ctx.globalAlpha = 1;
  }
  // 🏰 디펜스 모드 아레나 (TD): 우주 배경 + 미니멀 그리드
  function drawDefenseArena() {
    const map = getActiveTDMap();
    const paths = getMapPaths(map);
    // 경로별 색상 — 다중경로일 때 시각적 구분
    const PATH_COLORS = [
      { bg: 'rgba(255, 100, 120, 0.18)', hi: 'rgba(255, 150, 170, 0.25)', flow: 'rgba(255, 200, 200, 0.4)' },  // 빨강
      { bg: 'rgba(120, 180, 255, 0.18)', hi: 'rgba(160, 200, 255, 0.25)', flow: 'rgba(200, 220, 255, 0.4)' },  // 파랑
      { bg: 'rgba(180, 255, 140, 0.18)', hi: 'rgba(200, 255, 170, 0.25)', flow: 'rgba(220, 255, 200, 0.4)' },  // 초록
    ];
    // 1) 각 경로를 색상별로 그림
    ctx.lineCap = 'round';
    ctx.lineJoin = 'round';
    for (let pi = 0; pi < paths.length; pi++) {
      const path = paths[pi];
      const colors = PATH_COLORS[pi % PATH_COLORS.length];
      // 베이스
      ctx.strokeStyle = colors.bg;
      ctx.lineWidth = TD.cellW * 0.55;
      ctx.beginPath();
      for (let i = 0; i < path.length; i++) {
        const c = cellCenter(path[i].col, path[i].row);
        if (i === 0) ctx.moveTo(c.x, c.y); else ctx.lineTo(c.x, c.y);
      }
      ctx.stroke();
      // 강조 라인
      ctx.strokeStyle = colors.hi;
      ctx.lineWidth = 2;
      ctx.beginPath();
      for (let i = 0; i < path.length; i++) {
        const c = cellCenter(path[i].col, path[i].row);
        if (i === 0) ctx.moveTo(c.x, c.y); else ctx.lineTo(c.x, c.y);
      }
      ctx.stroke();
    }
    ctx.lineCap = 'butt';
    ctx.lineJoin = 'miter';
    // 2) 진행 방향 점선 흐름 (애니메이션) — 모든 경로에 표시
    for (let pi = 0; pi < paths.length; pi++) {
      const path = paths[pi];
      const colors = PATH_COLORS[pi % PATH_COLORS.length];
      ctx.strokeStyle = colors.flow;
      ctx.lineWidth = 1.5;
      ctx.setLineDash([5, 12]);
      ctx.lineDashOffset = -(state.t * 0.5) % 17;
      ctx.beginPath();
      for (let i = 0; i < path.length; i++) {
        const c = cellCenter(path[i].col, path[i].row);
        if (i === 0) ctx.moveTo(c.x, c.y); else ctx.lineTo(c.x, c.y);
      }
      ctx.stroke();
    }
    ctx.setLineDash([]);
    // 3) 각 경로의 시작 셀 (ENEMY 라벨)
    for (let pi = 0; pi < paths.length; pi++) {
      const path = paths[pi];
      const startC = cellCenter(path[0].col, path[0].row);
      ctx.fillStyle = pi === 0 ? 'rgba(255, 100, 120, 0.85)' : (pi === 1 ? 'rgba(120, 180, 255, 0.85)' : 'rgba(180, 255, 140, 0.85)');
      ctx.font = 'bold 10px Jua, sans-serif';
      ctx.textAlign = 'center';
      ctx.fillText(paths.length > 1 ? `▼ ENEMY ${pi + 1}` : '▼ ENEMY', startC.x, startC.y - 22);
    }
    // 4) 타워 슬롯 — 골드 충분할 때만 표시 (부족하면 숨김)
    const towers = state.towers || [];
    const placeCost = tdDrawCost();
    const canAffordPlace = (state.gold || 0) >= placeCost;
    if (canAffordPlace) {
      for (const slot of map.slots) {
        const occupied = towers.some(t => t.col === slot.col && t.row === slot.row);
        if (occupied) continue;
        const c = cellCenter(slot.col, slot.row);
        // 외곽 펄스 원
        const pulse = 0.4 + 0.25 * Math.sin(state.t * 0.06 + (slot.col + slot.row));
        ctx.strokeStyle = `rgba(122, 215, 255, ${pulse})`;
        ctx.lineWidth = 1.5;
        ctx.setLineDash([3, 3]);
        ctx.beginPath();
        ctx.arc(c.x, c.y, TD.cellW * 0.32, 0, Math.PI * 2);
        ctx.stroke();
        ctx.setLineDash([]);
        // 가운데 + (희미하게)
        ctx.fillStyle = `rgba(122, 215, 255, ${pulse * 0.7})`;
        ctx.font = 'bold 18px Jua, sans-serif';
        ctx.fillText('+', c.x, c.y + 6);
      }
    }
    // 5) 본진 (map.core 또는 첫 path 끝)
    const coreCell = map.core || paths[0][paths[0].length - 1];
    const coreC = cellCenter(coreCell.col, coreCell.row);
    // 본진 외곽 글로우
    const corePulse = 0.4 + 0.2 * Math.sin(state.t * 0.05);
    ctx.strokeStyle = `rgba(255, 212, 121, ${corePulse})`;
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.arc(coreC.x, coreC.y, TD.cellW * 0.42, 0, Math.PI * 2);
    ctx.stroke();
    ctx.strokeStyle = `rgba(255, 212, 121, ${corePulse * 0.5})`;
    ctx.lineWidth = 6;
    ctx.beginPath();
    ctx.arc(coreC.x, coreC.y, TD.cellW * 0.42, 0, Math.PI * 2);
    ctx.stroke();
    // 본진 본체 (핵)
    ctx.fillStyle = '#1a2030';
    ctx.beginPath();
    ctx.arc(coreC.x, coreC.y, TD.cellW * 0.3, 0, Math.PI * 2);
    ctx.fill();
    ctx.fillStyle = '#ffd479';
    ctx.font = 'bold 22px Jua, sans-serif';
    ctx.fillText('🏰', coreC.x, coreC.y + 8);
    ctx.textAlign = 'start';
    // 6) Prep Phase Start 버튼 — 첫 라운드 시작 전
    if (state.tdPrepPhase) {
      drawTDStartButton();
    }
  }

  // 🏰 TD Prep Phase Start 버튼 — 상단 마진 영역에 배치 (40px 그리드 오프셋 활용)
  function drawTDStartButton() {
    const bw = 260, bh = 32;
    const bx = (W - bw) / 2;
    const by = 4;   // 상단 4px
    state._tdStartBtn = { x: bx, y: by, w: bw, h: bh };
    // 펄스 글로우
    const pulse = 0.6 + 0.4 * Math.sin(state.t * 0.08);
    ctx.save();
    ctx.shadowColor = '#7ad7ff';
    ctx.shadowBlur = 10 + 6 * pulse;
    ctx.fillStyle = '#2a3850';
    ctx.fillRect(bx, by, bw, bh);
    ctx.restore();
    ctx.strokeStyle = `rgba(122, 215, 255, ${0.6 + 0.4 * pulse})`;
    ctx.lineWidth = 2;
    ctx.strokeRect(bx, by, bw, bh);
    ctx.fillStyle = '#fff';
    ctx.font = 'bold 14px Jua, sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText('▶ 웨이브 시작 (타워 배치 후 클릭)', bx + bw / 2, by + bh / 2 + 5);
    ctx.textAlign = 'start';
  }
  function drawTower() {
    // 🏰 TD 모드: 메인 캐릭터 타워는 안 그림 (본진은 drawArena에서, 배치 타워는 별도)
    if (state.mode === 'defense') return;
    // 외곽 헥사 링 (천천히 회전) — 항상 그림 (캐릭터 이미지 있어도 분위기 유지)
    const ringRot = state.t * 0.004;
    ctx.strokeStyle = 'rgba(106, 196, 255, 0.22)';
    ctx.lineWidth = 1.5;
    ctx.beginPath();
    for (let i = 0; i < 6; i++) {
      const a = ringRot + i * Math.PI / 3;
      const px = CX + Math.cos(a) * 30;
      const py = CY + Math.sin(a) * 30;
      if (i === 0) ctx.moveTo(px, py); else ctx.lineTo(px, py);
    }
    ctx.closePath();
    ctx.stroke();

    // ===== 캐릭터 이미지가 있으면 본체 대신 이미지 사용 =====
    const charId = state.character || 'standard';
    const charImg = getCharacterImage(charId);
    if (charImg) {
      // 캐릭터 발판 (펄스 글로우)
      const charDef = CHARACTERS[charId] || {};
      const glowCol = charDef.color || '#7ad7ff';
      const pulse = 1 + Math.sin(state.t * 0.05) * 0.10;
      ctx.save();
      ctx.globalAlpha = 0.12;
      ctx.fillStyle = glowCol;
      ctx.beginPath(); ctx.arc(CX, CY + 14, 12 * pulse, 0, Math.PI * 2); ctx.fill();
      ctx.restore();
      // 고해상도 원본을 부드럽게 축소 (원본 비율 유지) — 또렷하고 세밀하게
      const meta = getCharacterImageMeta(charId) || { w: charImg.width, h: charImg.height };
      const target = 44; // 그리는 영역 한 변 길이 (px) — 디테일 보이도록 약간 키움
      let dw, dh;
      if (meta.w >= meta.h) { dw = target; dh = target * (meta.h / meta.w); }
      else { dh = target; dw = target * (meta.w / meta.h); }
      const dx = CX - dw / 2;
      const dy = CY - dh / 2 + 2; // 약간 아래로 (발판 위 서있는 느낌)
      ctx.imageSmoothingEnabled = true; ctx.imageSmoothingQuality = 'high';
      ctx.drawImage(charImg, dx, dy, dw, dh);
      ctx.imageSmoothingQuality = 'low';   // 이후 글로우 스프라이트는 가벼운 기본 품질로
      return;
    }

    // ===== Fallback: 기존 도트 타워 =====
    const pulse = 1 + Math.sin(state.t * 0.05) * 0.10;
    ctx.fillStyle = 'rgba(106, 196, 255, 0.06)';
    ctx.beginPath(); ctx.arc(CX, CY, 24 * pulse, 0, Math.PI*2); ctx.fill();
    ctx.fillStyle = '#1a2030';
    ctx.fillRect(CX - 12, CY - 12, 24, 24);
    ctx.strokeStyle = 'rgba(106, 196, 255, 0.35)';
    ctx.lineWidth = 1;
    ctx.strokeRect(CX - 12, CY - 12, 24, 24);
    ctx.fillStyle = '#6ac4ff';
    ctx.fillRect(CX - 12, CY - 12, 3, 3);
    ctx.fillRect(CX + 9,  CY - 12, 3, 3);
    ctx.fillRect(CX - 12, CY + 9,  3, 3);
    ctx.fillRect(CX + 9,  CY + 9,  3, 3);
    const diaRot = -state.t * 0.014;
    ctx.save();
    ctx.translate(CX, CY);
    ctx.rotate(diaRot);
    ctx.strokeStyle = 'rgba(160, 220, 255, 0.55)';
    ctx.lineWidth = 1.4;
    ctx.strokeRect(-7, -7, 14, 14);
    ctx.restore();
    const corePulse = 0.85 + 0.15 * Math.sin(state.t * 0.09);
    ctx.globalAlpha = corePulse;
    ctx.fillStyle = '#e0f4ff';
    ctx.fillRect(CX - 2, CY - 2, 4, 4);
    ctx.globalAlpha = 1;
  }
  // ====== 적 타입별 렌더러 (무채색 톤 + 모양으로 구분, 노이즈 최소화) ======
  function drawAsteroidE(e, x, y, slow) {
    const s = e.size;
    ctx.save(); ctx.translate(x, y); ctx.rotate(e.rotation);
    const base = slow ? '#6e8290' : '#7a6450';
    const dark = slow ? '#2c3c48' : '#352a1f';
    const lite = slow ? '#b2c2cc' : '#a89074';
    // 불규칙한 바위 실루엣 (한 번 생성 후 캐시 — 운석마다 고유 모양)
    if (!e._astPts) {
      const n = 9, pts = [];
      for (let i = 0; i < n; i++) { const a = (i / n) * Math.PI * 2; const rr = 0.74 + Math.random() * 0.36; pts.push([Math.cos(a) * rr, Math.sin(a) * rr]); }
      e._astPts = pts;
      e._craters = [[0.18,-0.12,0.22],[-0.28,0.26,0.16],[0.32,0.34,0.11],[-0.1,-0.34,0.09]];
    }
    ctx.beginPath();
    for (let i = 0; i < e._astPts.length; i++) { const X = e._astPts[i][0]*s, Y = e._astPts[i][1]*s; i ? ctx.lineTo(X, Y) : ctx.moveTo(X, Y); }
    ctx.closePath();
    // 입체 음영 (좌상단 광원) — 🚀 적 객체에 캐시 (size 스폰 후 고정, slow 색 2종)
    let g = slow ? e._astGS : e._astGN;
    if (!g) {
      g = ctx.createRadialGradient(-s*0.4, -s*0.4, s*0.1, 0, 0, s*1.25);
      g.addColorStop(0, lite); g.addColorStop(0.5, base); g.addColorStop(1, dark);
      if (slow) e._astGS = g; else e._astGN = g;
    }
    ctx.fillStyle = g; ctx.fill();
    ctx.strokeStyle = dark; ctx.lineWidth = 1.2; ctx.stroke();
    // 크레이터 (음각 느낌 — 어두운 원 + 밝은 테)
    for (const c of e._craters) {
      const cx = c[0]*s, cy = c[1]*s, cr = c[2]*s;
      ctx.fillStyle = dark; ctx.globalAlpha = 0.5;
      ctx.beginPath(); ctx.arc(cx, cy, cr, 0, Math.PI*2); ctx.fill();
      ctx.globalAlpha = 0.4; ctx.fillStyle = lite;
      ctx.beginPath(); ctx.arc(cx - cr*0.3, cy - cr*0.3, cr*0.5, 0, Math.PI*2); ctx.fill();
    }
    ctx.globalAlpha = 1;
    ctx.restore();
  }

  function drawIceE(e, x, y, slow) {
    const s = e.size;
    ctx.save(); ctx.translate(x, y); ctx.rotate(e.rotation * 0.4);
    const base = slow ? '#6aa0c0' : '#7fb8d8', dark = slow ? '#244a5e' : '#2a5070', lite = '#e4f5ff';
    // 서리 글로우
    ctx.fillStyle = slow ? 'rgba(120,190,230,0.16)' : 'rgba(150,210,255,0.18)';
    ctx.beginPath(); ctx.arc(0, 0, s * 1.45, 0, Math.PI*2); ctx.fill();
    // 결정 본체 (다이아) — 면 그라데이션 — 🚀 적 객체에 캐시
    let g = slow ? e._iceGS : e._iceGN;
    if (!g) {
      g = ctx.createLinearGradient(-s*0.6, -s, s*0.4, s);
      g.addColorStop(0, lite); g.addColorStop(0.45, base); g.addColorStop(1, dark);
      if (slow) e._iceGS = g; else e._iceGN = g;
    }
    const dia = () => { ctx.beginPath(); ctx.moveTo(0, -s); ctx.lineTo(s*0.72, 0); ctx.lineTo(0, s); ctx.lineTo(-s*0.72, 0); ctx.closePath(); };
    dia(); ctx.fillStyle = g; ctx.fill();
    // 결정면 라인 (패싯)
    ctx.strokeStyle = 'rgba(255,255,255,0.45)'; ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(0, -s); ctx.lineTo(0, s); ctx.moveTo(-s*0.72, 0); ctx.lineTo(s*0.72, 0); ctx.stroke();
    // 외곽 + 하이라이트
    dia(); ctx.strokeStyle = dark; ctx.lineWidth = 1.2; ctx.stroke();
    ctx.fillStyle = lite; ctx.beginPath(); ctx.arc(-s*0.22, -s*0.32, s*0.13, 0, Math.PI*2); ctx.fill();
    ctx.restore();
  }

  function drawDroneE(e, x, y, slow) {
    const s = e.size;
    ctx.save(); ctx.translate(x, y);
    ctx.rotate(Math.sin(state.t * 0.12 + e.seed) * 0.05);
    const base = slow ? '#5a7888' : '#6a727e', dark = slow ? '#23404e' : '#2a2e36', metal = '#aab4c0';
    // 측면 윙/스러스터
    ctx.fillStyle = dark;
    ctx.fillRect(-s*1.45, -s*0.32, s*0.55, s*0.64); ctx.fillRect(s*0.9, -s*0.32, s*0.55, s*0.64);
    // 본체 (육각 금속) — 그라데이션 — 🚀 적 객체에 캐시
    let g = slow ? e._drGS : e._drGN;
    if (!g) {
      g = ctx.createLinearGradient(0, -s, 0, s);
      g.addColorStop(0, metal); g.addColorStop(0.5, base); g.addColorStop(1, dark);
      if (slow) e._drGS = g; else e._drGN = g;
    }
    const hex = () => { ctx.beginPath(); for (let k=0;k<6;k++){ const a=(Math.PI*2/6)*k; const px=Math.cos(a)*s, py=Math.sin(a)*s*0.82; k?ctx.lineTo(px,py):ctx.moveTo(px,py);} ctx.closePath(); };
    hex(); ctx.fillStyle = g; ctx.fill();
    hex(); ctx.strokeStyle = dark; ctx.lineWidth = 1.2; ctx.stroke();
    // 글로우 눈 (펄스 — 드론 정체성)
    const pulse = 0.5 + 0.5 * Math.sin(state.t * 0.22 + e.seed);
    const ec = slow ? '120,180,255' : '255,70,70';
    ctx.save(); ctx.globalCompositeOperation = 'lighter';
    ctx.fillStyle = `rgba(${ec},${0.25 + pulse*0.3})`; ctx.beginPath(); ctx.arc(0, 0, s*0.75, 0, Math.PI*2); ctx.fill();
    ctx.restore();
    ctx.fillStyle = `rgba(${ec},${0.85 + pulse*0.15})`; ctx.beginPath(); ctx.arc(0, 0, s*0.34, 0, Math.PI*2); ctx.fill();
    ctx.fillStyle = '#fff'; ctx.beginPath(); ctx.arc(-s*0.1, -s*0.1, s*0.12, 0, Math.PI*2); ctx.fill();
    ctx.restore();
  }

  function drawPlasmaE(e, x, y, slow) {
    const s = e.size;
    ctx.save(); ctx.translate(x, y);
    const pulse = 1 + Math.sin(state.t * 0.14 + e.seed) * 0.1;
    const colA = slow ? '#8fb0e0' : '#cf70e8', colB = slow ? '#34487a' : '#5a2070';
    // 🚀 그라디언트는 기본 반경으로 1회 생성 후 캐시, 펄스는 ctx.scale로 재현 (slow 색 2종)
    let pg = slow ? e._plGS : e._plGN;
    if (!pg) {
      const gg = ctx.createRadialGradient(0, 0, 0, 0, 0, s*2.1);
      gg.addColorStop(0, '#ffffff'); gg.addColorStop(0.3, colA); gg.addColorStop(1, 'rgba(0,0,0,0)');
      const cc = ctx.createRadialGradient(-s*0.25, -s*0.25, 0, 0, 0, s);
      cc.addColorStop(0, '#ffffff'); cc.addColorStop(0.55, colA); cc.addColorStop(1, colB);
      pg = { glow: gg, core: cc };
      if (slow) e._plGS = pg; else e._plGN = pg;
    }
    // 외곽 에너지 글로우 (가산)
    ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.scale(pulse, pulse);
    ctx.fillStyle = pg.glow; ctx.beginPath(); ctx.arc(0, 0, s*2.1, 0, Math.PI*2); ctx.fill();
    ctx.restore();
    // 코어 오브
    ctx.save(); ctx.scale(pulse, pulse);
    ctx.fillStyle = pg.core; ctx.beginPath(); ctx.arc(0, 0, s, 0, Math.PI*2); ctx.fill();
    ctx.restore();
    // 전기 스파크
    ctx.save(); ctx.globalCompositeOperation = 'lighter';
    ctx.strokeStyle = `rgba(255,255,255,${0.35 + 0.4*Math.sin(state.t*0.3 + e.seed)})`; ctx.lineWidth = 1;
    for (let k = 0; k < 3; k++) { const a = state.t*0.09 + e.seed + k*2.1; ctx.beginPath(); ctx.moveTo(Math.cos(a)*s*0.6, Math.sin(a)*s*0.6); ctx.lineTo(Math.cos(a)*s*1.55, Math.sin(a)*s*1.55); ctx.stroke(); }
    ctx.restore();
    ctx.restore();
  }

  function drawCrystalE(e, x, y, slow) {
    const s = e.size;
    ctx.save(); ctx.translate(x, y); ctx.rotate(e.rotation * 0.3);
    const base = slow ? '#5aa6b6' : '#4ec090', dark = slow ? '#1f4a52' : '#1a5040', lite = '#e0ffee';
    // 보석 글로우
    ctx.fillStyle = slow ? 'rgba(120,200,210,0.14)' : 'rgba(110,230,170,0.16)';
    ctx.beginPath(); ctx.arc(0, 0, s*1.4, 0, Math.PI*2); ctx.fill();
    // 육각 — 면마다 명암 다르게 (보석 컷팅 느낌)
    const pts = [];
    for (let k = 0; k < 6; k++) { const a = (Math.PI*2/6)*k - Math.PI/2; pts.push([Math.cos(a)*s, Math.sin(a)*s]); }
    for (let k = 0; k < 6; k++) {
      const p1 = pts[k], p2 = pts[(k+1)%6];
      ctx.fillStyle = (k % 2) ? base : dark;
      ctx.beginPath(); ctx.moveTo(0, 0); ctx.lineTo(p1[0], p1[1]); ctx.lineTo(p2[0], p2[1]); ctx.closePath(); ctx.fill();
    }
    // 외곽 + 하이라이트
    ctx.strokeStyle = lite; ctx.lineWidth = 1;
    ctx.beginPath(); pts.forEach((p, i) => i ? ctx.lineTo(p[0], p[1]) : ctx.moveTo(p[0], p[1])); ctx.closePath(); ctx.stroke();
    ctx.fillStyle = lite; ctx.beginPath(); ctx.arc(-s*0.18, -s*0.34, s*0.14, 0, Math.PI*2); ctx.fill();
    ctx.restore();
  }

  // ===== 🌌 v267 — 특수 보스 (고유 외형 + 등장 연출) =====
  // draw 함수: (0,0) 중심 로컬 좌표. fill=본체색, eyeGlow=안광 강도(0~1)
