      apply: (st) => {
        let boosted = 0;
        for (const a of st.tower.abilities) {
          if (isAtMax(a)) continue;
          const before = a.level;
          a.level = Math.min(maxLvFor(a.id), a.level + 3);
          if (a.level > before) boosted++;
        }
        if (boosted > 0) toast(`✨ 신의 의지: 능력 ${boosted}개 +3 레벨`);
      }, unlockBy: 'achievement:asc7' },
    eternityLight: { name: '영원의 빛', icon: '🌅', rarity: 'legendary',
