          { label: '맡긴다', desc: '다음 라운드 시작 시 적 전부 정지', resolve() { state._eventFreeze = 180; return '🔮 다음 라운드, 시간이 멈춥니다.'; } },
          { label: '사양한다', desc: '운명은 흐르는 대로', resolve() { return '셀레네가 수정구를 거둔다.'; } },
