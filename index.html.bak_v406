<!doctype html>
<html lang="ko">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, user-scalable=no, viewport-fit=cover" />
<meta name="mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="theme-color" content="#0b0d12" />
<link rel="manifest" href="./manifest.json" />
<link rel="apple-touch-icon" href="./icons/icon-192.png" />
<link rel="icon" href="./icons/icon-192.png" />
<!-- 🚀 가챠 배너 이미지 사전 로드 — 페이지 로드 즉시 다운로드 시작 -->
<link rel="preload" as="image" href="./icons/gacha-aria.png" fetchpriority="low" />
<link rel="preload" as="image" href="./icons/gacha-misaki.png" fetchpriority="low" />
<!-- 둥글둥글한 한글 폰트 (Jua = 주아체, Black Han Sans = 굵은 제목용) -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Jua&family=Black+Han+Sans&display=swap" rel="stylesheet">
<!-- Supabase JS SDK (글로벌 랭킹용) — 키 미설정 시 자동 비활성 -->
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2.45.4/dist/umd/supabase.min.js"></script>
<title>Dot Defense</title>
<style>
  /* 🚫 스크롤바 전역 숨김 — PC/모바일 모두 시각적으로 깔끔하게 (스크롤 기능은 유지) */
  * {
    scrollbar-width: none;        /* Firefox */
    -ms-overflow-style: none;     /* IE/구 Edge */
  }
  *::-webkit-scrollbar {
    display: none;                /* Chrome, Safari, Edge (Webkit) */
    width: 0; height: 0;
  }
  html, body {
    margin: 0; padding: 0;
    height: 100vh;
    height: 100dvh; /* 모바일 동적 viewport 대응 (주소창 표시/숨김 변화 반영) */
    width: 100vw;
    background: #0b0d12; color: #e8eaf0;
    /* 둥글둥글한 캐주얼 게임 폰트 — Jua가 핵심, 시스템 폰트로 fallback */
    font-family: 'Jua', 'Pretendard', 'Apple SD Gothic Neo', 'Malgun Gothic', system-ui, sans-serif;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
    touch-action: none;
    -webkit-user-select: none; user-select: none;
    -webkit-tap-highlight-color: transparent;
    overscroll-behavior: none;
    /* 노치/홈 인디케이터 안전 영역 */
    padding: env(safe-area-inset-top) env(safe-area-inset-right) env(safe-area-inset-bottom) env(safe-area-inset-left);
    box-sizing: border-box;
  }
  /* 🎨 디자인 토큰 — 색/라운딩/섀도우 통일 (전 화면 공통) */
  :root {
    --bg: #0b0d12; --panel: #1f2735; --panel-hi: #2a3550;
    --border: #3a4256; --accent: #7ad7ff; --accent-2: #5870a0;
    --gold: #ffd479; --text: #e8eaf0; --text-dim: #9aa3b3;
    --radius: 10px; --radius-sm: 8px;
    --shadow: 0 4px 14px rgba(0,0,0,0.42);
    --glow: 0 0 14px rgba(122,215,255,0.22);
  }
  /* 게임 wrap — transform 기준점 명시 + 정확한 측정용 */
  #wrap {
    transform-origin: center center;
    will-change: transform;
  }
  #wrap { display: flex; gap: 12px; }
  /* 세로 모드: 패널을 캔버스 아래로 쌓고 터치 친화적으로 크게 */
  #wrap.portrait { flex-direction: column; }
  #wrap.portrait #panel {
    width: 644px; height: auto;
    font-size: 15px;
    padding: 16px;
    gap: 12px;
  }
  /* 능력 행 높이를 고정해서 빈 슬롯/채워진 슬롯 관계없이 패널 크기가 일정 (몰입 유지) */
  .ability-row { box-sizing: border-box; }   /* 높이 제약 제거 — 설명 길이에 맞춰 자동 확장 */
  #wrap.portrait .ability-row { padding: 10px 12px; }
  #wrap.portrait .ability-row button { padding: 12px 14px; font-size: 14px; min-height: 44px; }

  /* 능력 카테고리 탭 */
  .ab-tabs { display: flex; gap: 4px; }
  .ab-tab {
    flex: 1; padding: 8px 6px;
    background: #1a1f2b; color: #9aa3b3;
    border: 1px solid #2a2f3a;
    font-family: inherit; font-size: 11px;
    cursor: pointer; touch-action: manipulation;
  }
  .ab-tab.active { background: #3d5380; color: #fff; border-color: #5870a0; }
  .ab-tab span { color: #ffd479; font-weight: bold; margin-left: 4px; }
  #wrap.portrait .ab-tab { font-size: 13px; padding: 12px 8px; min-height: 44px; }

  /* === 능력 목록 접기/펴기 === */
  /* 세로 모드: 능력창은 절대 위치 오버레이 — 아래에서 슬라이드 업, 게임 화면 위로 덮음.
     게임 크기는 변하지 않음. 가로 모드는 기존대로 인라인 표시. */
  .ability-toggle {
    display: none;
    width: 100%;
    padding: 12px;
    background: #1f2735;
    color: #e8eaf0;
    border: 1px solid #3a4256;
    font-family: inherit;
    font-size: 13px;
    cursor: pointer;
    touch-action: manipulation;
  }
  .ability-toggle:hover { background: #2a3550; }
  #wrap.portrait .ability-toggle { display: block; padding: 14px; font-size: 14px; min-height: 48px; }
  #wrap.portrait #panel { position: relative; }
  #wrap.portrait #abilities {
    position: absolute;
    left: 12px; right: 12px;
    bottom: var(--abilities-anchor, 220px);
    max-height: 60vh;
    overflow-y: auto;
    background: rgba(20, 24, 34, 0.96);
    border: 1px solid #2a2f3a;
    border-radius: 6px;
    padding: 10px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    box-sizing: border-box;
    /* 자기 키(100%) + anchor 거리 + 여유 — 토글/배속 영역 아래로 완전히 숨김 */
    transform: translateY(calc(100% + var(--abilities-anchor, 220px) + 20px));
    transition: transform 0.35s cubic-bezier(0.2, 0.7, 0.2, 1);
    z-index: 5;
    box-shadow: 0 -8px 20px rgba(0, 0, 0, 0.5);
    pointer-events: none;
  }
  #wrap.portrait #abilities.expanded {
    transform: translateY(0);
    pointer-events: auto;
  }
  /* portrait — padding/높이만 키우고 font-size 동일하게 (텍스트 크기 변동 방지) */
  #wrap.portrait #randomBtn { padding: 14px 10px; font-size: 14px; min-height: 52px; }
  #wrap.portrait .speed-btn { padding: 14px 0; font-size: 14px; min-height: 48px; }
  #wrap.portrait #stats { font-size: 14px; }
  button { touch-action: manipulation; }
  canvas {
    background: #11141c;
    /* image-rendering: pixelated 제거 — DPR 고해상도로 렌더링하므로 텍스트 antialiasing 살림.
       게임 도트 느낌은 작은 사각형 그리기 자체로 유지됨. */
    image-rendering: auto;
    border: 2px solid #2a2f3a;
    box-shadow: 0 0 40px rgba(120, 180, 255, 0.08);
  }
  #panel {
    width: 260px; height: 640px;
    background: #141822; border: 2px solid #2a2f3a;
    padding: 12px; box-sizing: border-box;
    display: flex; flex-direction: column; gap: 6px;   /* v230: 10 → 6 더 빡빡하게 */
    font-size: 12px;
  }
  /* v230 — hr divider 더 얇게 (능력 영역 위 공간 절약) */
  #panel hr { margin: 2px 0; }
  /* === v230 — 능력 영역 확장을 위한 스탯 컴팩트화 + 핵심(라운드/골드) 강조 === */
  #stats { line-height: 1.3; }
  #stats .row { display: flex; justify-content: space-between; align-items: baseline; }
  #stats .label { color: #6b7283; }

  /* === 🔝 PRIMARY (라운드/골드) — 더 크게, 더 강조 === */
  #stats .row.primary {
    font-size: 20px;                  /* 18 → 20 */
    font-weight: bold;
    padding: 8px 10px;
    margin: 3px 0;
    background: rgba(20, 24, 34, 0.7);
    border-left: 4px solid;            /* 3 → 4 */
    border-radius: 0 4px 4px 0;
    line-height: 1.15;
  }
  #stats .row.primary .label {
    font-size: 11px;
    font-weight: normal;
    color: #9aa3b3;
    letter-spacing: 2px;
    text-transform: uppercase;
  }
  #stats .row.round { border-left-color: #7ad7ff; }
  #stats .row.round span:last-child {
    color: #7ad7ff;
    text-shadow: 0 0 10px rgba(122,215,255,0.55);
    font-size: 22px;                   /* 라운드 값 살짝 더 크게 */
  }
  #stats .row.gold { border-left-color: #ffd479; }
  #stats .row.gold span:last-child {
    color: #ffd479;
    text-shadow: 0 0 10px rgba(255,212,121,0.55);
    font-size: 22px;                   /* 골드 값 살짝 더 크게 */
  }

  /* === 🟡 SECONDARY (시간/점수/적 수) — 압축 === */
  #stats .row.secondary {
    font-size: 12px;                   /* 13 → 12 */
    padding: 1px 4px;                  /* 2 → 1 */
  }
  #stats .row.secondary .label { font-size: 10px; color: #7a8090; }
  #stats .row.secondary span:last-child {
    font-weight: bold; color: #cfd6e3;
  }

  /* === ⚪ TERTIARY (레벨/누적처치) — 더 작고 묻힘 === */
  .stats-tertiary-group {
    margin-top: 4px;                   /* 6 → 4 */
    padding-top: 4px;                  /* 6 → 4 */
    border-top: 1px solid rgba(58,66,86,0.4);
    display: flex; flex-direction: column; gap: 0;
  }
  #stats .row.tertiary {
    font-size: 10px;
    padding: 0 2px;                    /* 1 → 0 */
    color: #7a8090;
  }
  #stats .row.tertiary .label { font-size: 10px; color: #5a5f6a; }
  #stats .row.tertiary span:last-child {
    font-weight: normal; color: #9aa3b3;
  }

  /* === 📊 BAR — 더 얇게 === */
  #panel .bar { height: 5px; }         /* 8 → 5 */

  /* === 📱 PORTRAIT MODE — 모바일에서 가독성 키움 === */
  #wrap.portrait #stats .row.primary {
    font-size: 24px;                   /* 22 → 24 */
    padding: 10px 14px;
  }
  #wrap.portrait #stats .row.primary .label { font-size: 13px; }
  #wrap.portrait #stats .row.round span:last-child,
  #wrap.portrait #stats .row.gold span:last-child { font-size: 26px; }
  #wrap.portrait #stats .row.secondary { font-size: 14px; padding: 1px 4px; }
  #wrap.portrait #stats .row.secondary .label { font-size: 12px; }
  #wrap.portrait #stats .row.tertiary { font-size: 11px; }
  #wrap.portrait #stats .row.tertiary .label { font-size: 11px; }
  .bar { background: #1a1f2b; height: 8px; border: 1px solid #2a2f3a; position: relative; overflow: hidden; }
  .bar > i { display:block; height:100%; background:#52e07a; transition: width .15s; }
  .bar.danger > i { background: #ff5b6e; }
  .bar.warn   > i { background: #ffd479; }
  hr { border: 0; border-top: 1px solid #2a2f3a; margin: 4px 0; }
  button {
    font-family: inherit; font-size: 12px;
    background: #1f2735; color: #e8eaf0;
    border: 1px solid #3a4256; padding: 6px 8px; cursor: pointer;
    transition: background .1s, transform .08s ease-out, box-shadow .12s;
  }
  button:hover:not(:disabled) { background: #2a3550; }
  button:disabled { opacity: 0.4; cursor: not-allowed; }
  /* 🎯 v226 — 전역 버튼 클릭 피드백 (눌림 인식)
     :active 동안 살짝 축소 + 외곽 글로우 → "내가 눌렀다" 명확히. */
  button:active:not(:disabled) {
    transform: scale(0.96);
    box-shadow: 0 0 0 2px rgba(122, 215, 255, 0.18);
  }
  /* 카드/타일류 클릭 가능 요소 — 같은 피드백 패턴 */
  .codex-card, .char-card, .ability-row, .mode-card, .gacha-result-card, .gacha-pickup-icon {
    transition: transform .08s ease-out, box-shadow .12s, background .12s;
  }
  /* 🎬 v243 — 범용 행 접힘 애니메이션 (능력 삭제 등 모든 리스트에서 재사용) */
  .row-collapsing {
    overflow: hidden !important;
    transition:
      max-height 220ms cubic-bezier(0.4, 0, 0.2, 1),
      opacity 180ms ease-out,
      margin 220ms cubic-bezier(0.4, 0, 0.2, 1),
      padding 220ms cubic-bezier(0.4, 0, 0.2, 1),
      border-width 220ms cubic-bezier(0.4, 0, 0.2, 1) !important;
    pointer-events: none !important;
  }
  .row-collapsing.collapsed {
    max-height: 0 !important;
    opacity: 0 !important;
    margin-top: 0 !important;
    margin-bottom: 0 !important;
    padding-top: 0 !important;
    padding-bottom: 0 !important;
    border-top-width: 0 !important;
    border-bottom-width: 0 !important;
  }
  /* 🎬 v243 — 신규 행 부드러운 등장 (fade-in + slide-down) */
  @keyframes _row-fade-in {
    0%   { opacity: 0; transform: translateY(-6px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  .row-fade-in { animation: _row-fade-in 200ms ease-out; }
  /* 🎬 v243 — 모달 페이드 인/아웃 (모든 다이얼로그에서 재사용) */
  @keyframes _modal-fade-in {
    0%   { opacity: 0; }
    100% { opacity: 1; }
  }
  @keyframes _modal-fade-out {
    0%   { opacity: 1; }
    100% { opacity: 0; }
  }
  .modal-anim-in  { animation: _modal-fade-in 160ms ease-out; }
  .modal-anim-out { animation: _modal-fade-out 160ms ease-in forwards; }
  /* 🎬 v243 — 화면 페이드 아웃 (전환 시 이전 화면이 부드럽게 사라짐) */
  @keyframes _screen-fade-out {
    0%   { opacity: 1; }
    100% { opacity: 0; }
  }
  .screen.screen-fade-out {
    animation: _screen-fade-out 150ms ease-in forwards;
  }
  /* 🌌 v245 — ANCIENT 유물 강조 펄스 (가챠 배너 + 결과 카드) */
  @keyframes _ancient-pulse {
    0%, 100% { box-shadow: 0 0 8px rgba(255,136,255,0.5); }
    50%      { box-shadow: 0 0 18px rgba(255,136,255,0.9); }
  }
  /* 🌌 v249 — 가챠 배너 ANCIENT 유물 픽업 칩 (오른쪽 상단 부유) */
  .gacha-banner-ancient-chip {
    position: absolute;
    top: 14px;
    right: 14px;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    background: linear-gradient(135deg, rgba(40,15,55,0.92), rgba(20,5,30,0.92));
    border: 2px solid #ff88ff;
    border-radius: 10px;
    box-shadow: 0 0 14px rgba(255,136,255,0.6);
    animation: _ancient-pulse 1.6s ease-in-out infinite;
    z-index: 5;
    pointer-events: none;
  }
  .gacha-banner-ancient-chip img {
    width: 40px; height: 40px;
    image-rendering: pixelated;
    object-fit: contain;
    flex-shrink: 0;
  }
  .ancient-chip-text {
    display: flex; flex-direction: column;
    gap: 1px;
    color: #fff;
    font-size: 11px;
    line-height: 1.2;
  }
  .ancient-chip-label {
    color: #ff88ff;
    font-weight: bold;
    font-size: 10px;
    letter-spacing: 0.5px;
  }
  .ancient-chip-name {
    color: #fff;
    font-weight: bold;
    font-size: 12px;
  }
  .ancient-chip-rate {
    color: #ffaaee;
    font-size: 10px;
  }
  @media (max-width: 480px) {
    .gacha-banner-ancient-chip { top: 10px; right: 10px; padding: 6px 9px; gap: 6px; }
    .gacha-banner-ancient-chip img { width: 32px; height: 32px; }
    .ancient-chip-label { font-size: 9px; }
    .ancient-chip-name  { font-size: 11px; }
    .ancient-chip-rate  { font-size: 9px; }
  }
  .codex-card:active, .char-card:not(.locked):active, .mode-card:active {
    transform: scale(0.98);
  }
  /* 🎯 v226 — 숫자 변경 펄스 (스타더스트/결정/골드 등) */
  @keyframes _num-pulse {
    0%   { color: #88ff88; text-shadow: 0 0 8px rgba(136,255,136,0.7); transform: scale(1.15); }
    100% { color: inherit; text-shadow: inherit; transform: scale(1); }
  }
  ._num-pulse {
    display: inline-block;
    animation: _num-pulse 0.5s ease-out;
  }
  /* 🎯 v226 — 비용 감소 (소비) 펄스 */
  @keyframes _num-pulse-down {
    0%   { color: #ff8a98; transform: scale(1.12); }
    100% { color: inherit; transform: scale(1); }
  }
  ._num-pulse-down {
    display: inline-block;
    animation: _num-pulse-down 0.45s ease-out;
  }
  /* 🎯 v226 — 화면 진입 페이드 */
  @keyframes _screen-fade-in {
    0%   { opacity: 0; transform: translateY(6px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  .screen.show {
    animation: _screen-fade-in 0.18s ease-out;
  }
  /* 🛡 v207 — font-size 고정 + min-height 고정 으로 텍스트 길이/portrait 전환 시 크기 변동 방지 */
  #randomBtn {
    width: 100%; padding: 10px; font-weight: bold;
    font-size: 14px;
    min-height: 44px;
    line-height: 1.2;
    white-space: nowrap;       /* 텍스트 줄바꿈 방지 → 버튼 높이 변동 X */
    overflow: hidden;
    text-overflow: ellipsis;
    box-sizing: border-box;
  }
  .relic-view-btn {
    width: 100%; padding: 10px;
    background: linear-gradient(135deg, #2a2010, #1a1408);
    color: #ffd479;
    border: 1.5px solid #5a4220;
    font-family: inherit; font-size: 12px; font-weight: bold;
    cursor: pointer;
    border-radius: 0;
    margin-top: 4px;
    box-shadow: 0 0 8px rgba(255,212,121,0.15);
    transition: background .25s, box-shadow .25s, border-color .25s, color .25s;
  }
  .relic-view-btn:hover:not(.empty) {
    background: linear-gradient(135deg, #3a2c14, #221a0c);
    box-shadow: 0 0 14px rgba(255,212,121,0.35);
  }
  /* 빈 상태 — 흐릿한 안내 */
  .relic-view-btn.empty {
    background: #141822;
    color: #5a5f6a;
    border-color: #2a2f3a;
    box-shadow: none;
    font-weight: normal;
  }
  .relic-view-btn.empty:hover {
    background: #1a1f2b;
    color: #7a8090;
  }
  #wrap.portrait .relic-view-btn { padding: 14px; font-size: 14px; min-height: 48px; }
  .ability-row {
    display: grid; grid-template-columns: 1fr auto auto;
    gap: 4px; align-items: center;
    padding: 6px; background: #1a1f2b; border: 1px solid #242a38;
  }
  .ability-row.empty { color: #4a5163; text-align:center; padding: 8px; }
  .ability-name {
    display: flex; flex-direction: column;
    min-width: 0;            /* grid 자식이 자유롭게 줄어들 수 있게 (긴 텍스트 wrap 가능하게) */
    overflow: hidden;        /* 컬럼 자체는 부풀지 않게 */
  }
  .ability-name b { color: #e8eaf0; word-break: keep-all; overflow-wrap: anywhere; }
  .ability-name small {
    color: #6b7283;
    display: block;          /* 인라인 → 블록으로 (다음 줄 wrap 잘 되게) */
    white-space: normal;     /* 줄바꿈 허용 */
    word-break: keep-all;    /* 한글 단어 단위 줄바꿈 */
    overflow-wrap: anywhere; /* 영문/숫자 너무 길면 어디서나 break */
    line-height: 1.4;
    margin-top: 2px;
  }
  /* === 능력 아이콘 (img 또는 fallback) === */
  .ability-img-icon, .ability-img-fallback {
    border-radius: 3px;
    flex-shrink: 0;
    vertical-align: middle;
  }
  .ability-row .row-header {
    display: flex; align-items: center; gap: 6px;
    margin-bottom: 2px;
  }
  .codex-card .card-header {
    display: flex; align-items: center; gap: 8px;
    margin-bottom: 4px;
  }

  /* === 능력 태그 칩 (광역/슬로우/관통 등) === */
  .ability-tag-row {
    display: flex; flex-wrap: wrap; gap: 3px;
    margin-top: 3px; margin-bottom: 2px;
  }
  .ability-tag {
    display: inline-block;
    font-size: 10px;
    padding: 1px 5px;
    border: 1px solid currentColor;
    border-radius: 3px;
    background: rgba(255, 255, 255, 0.04);
    line-height: 1.2;
    white-space: nowrap;
  }
  #wrap.portrait .ability-tag { font-size: 12px; padding: 2px 6px; }
  .codex-card .ability-tag-row { margin-top: 5px; margin-bottom: 5px; }
  .codex-card .ability-tag { font-size: 11px; }

  /* === 강화 버튼 — 살 수 있는지 한눈에 인지 === */
  .ability-row.affordable {
    border-color: #5a4a20;
    box-shadow: inset 0 0 0 1px rgba(255,212,121,0.15);
  }
  .ability-row.affordable button[data-act="up"] {
    border-color: #ffd479;
    background: #2a2418;
    color: #ffd479;
  }
  .ability-row.affordable button[data-act="up"]:hover { background: #3a311e; }
  .ability-row button[data-act="up"] {
    color: #9aa3b3;
  }
  .ability-row.maxed { border-left: 3px solid #52e07a; }
  /* 🗑 v261 — rm 버튼 폭 고정: ✕ ↔ ❗ 콘텐츠가 바뀌어도 폭 불변 → 강화 버튼과 절대 안 겹침 */
  .ability-row button[data-act="rm"] {
    width: 40px;
    min-width: 40px;
    max-width: 40px;
    padding-left: 2px;
    padding-right: 2px;
    text-align: center;
    flex-shrink: 0;
    box-sizing: border-box;
  }
  #wrap.portrait .ability-row button[data-act="rm"] {
    width: 46px; min-width: 46px; max-width: 46px;
  }
  /* 🗑 v260 — 2단계 삭제: 첫 클릭 후 "다시 누르면 삭제" 무장 상태 */
  .ability-row button[data-act="rm"].rm-armed {
    background: #c0392b !important;
    color: #fff !important;
    border-color: #ff6b5b !important;
    font-weight: bold;
    animation: _rm-armed-pulse 0.8s ease-in-out infinite;
    position: relative;
    overflow: hidden;
  }
  @keyframes _rm-armed-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(255,107,91,0.0); }
    50%      { box-shadow: 0 0 8px 1px rgba(255,107,91,0.7); }
  }
  /* 무장 해제까지 남은 시간 바 (하단) */
  .ability-row button[data-act="rm"].rm-armed::after {
    content: '';
    position: absolute;
    left: 0; bottom: 0; height: 2px;
    width: 100%;
    background: #ffd479;
    transform-origin: left center;
    animation: _rm-armed-bar 2s linear forwards;
  }
  @keyframes _rm-armed-bar {
    0%   { transform: scaleX(1); }
    100% { transform: scaleX(0); }
  }
  /* 랜덤 능력 획득 버튼 — 살 수 있을 때 강조 */
  #randomBtn:not(:disabled) {
    border-color: #ffd479;
    color: #ffd479;
  }
  /* 🎴 TD 뽑기 카드 — 등급별 반짝임 */
  .td-draw-card { transition: transform .15s; overflow: hidden; }
  .td-draw-card:hover { transform: translateY(-2px); }
  .td-draw-card::before {
    content: ''; position: absolute; inset: 0;
    border-radius: 5px; pointer-events: none;
    background: transparent; transition: background .3s;
  }
  /* R — 파란 잔잔한 글로우 */
  .td-draw-card.td-card-r {
    border-color: #88e0ff !important;
    box-shadow: 0 0 8px rgba(136, 224, 255, 0.45);
    animation: tdRPulse 2.4s ease-in-out infinite;
  }
  @keyframes tdRPulse {
    0%, 100% { box-shadow: 0 0 8px rgba(136, 224, 255, 0.45); }
    50% { box-shadow: 0 0 14px rgba(136, 224, 255, 0.75); }
  }
  /* SR — 주황·노란 강한 펄스 + 빛줄기 */
  .td-draw-card.td-card-sr {
    border-color: #ffaa55 !important;
    box-shadow: 0 0 12px rgba(255, 170, 85, 0.6);
    animation: tdSRPulse 1.8s ease-in-out infinite;
    background: linear-gradient(135deg, #1a1822 0%, #2a1c12 50%, #1a1822 100%) !important;
  }
  @keyframes tdSRPulse {
    0%, 100% { box-shadow: 0 0 12px rgba(255, 170, 85, 0.6); }
    50% { box-shadow: 0 0 22px rgba(255, 170, 85, 0.95); }
  }
  .td-draw-card.td-card-sr::before {
    background: linear-gradient(45deg, transparent 30%, rgba(255, 200, 100, 0.15) 50%, transparent 70%);
    background-size: 200% 200%;
    animation: tdSRShine 3s linear infinite;
  }
  @keyframes tdSRShine {
    0% { background-position: -100% -100%; }
    100% { background-position: 200% 200%; }
  }
  /* SSR — 무지개 회전 + 강한 글로우 + 반짝이 */
  .td-draw-card.td-card-ssr {
    border-color: #ff80ff !important;
    box-shadow: 0 0 20px rgba(255, 128, 255, 0.8), 0 0 40px rgba(255, 200, 100, 0.5);
    animation: tdSSRGlow 1.5s ease-in-out infinite;
    background: linear-gradient(135deg, #220c2a 0%, #2a0c1c 50%, #221c0c 100%) !important;
  }
  @keyframes tdSSRGlow {
    0%, 100% {
      box-shadow: 0 0 20px rgba(255, 128, 255, 0.8), 0 0 40px rgba(255, 200, 100, 0.5);
      filter: hue-rotate(0deg);
    }
    50% {
      box-shadow: 0 0 32px rgba(255, 200, 100, 1), 0 0 60px rgba(255, 128, 255, 0.7);
      filter: hue-rotate(30deg);
    }
  }
  .td-draw-card.td-card-ssr::before {
    background: linear-gradient(60deg,
      transparent 25%, rgba(255, 128, 255, 0.20) 40%,
      rgba(255, 220, 120, 0.25) 50%, rgba(122, 215, 255, 0.20) 60%,
      transparent 75%);
    background-size: 250% 250%;
    animation: tdSSRShine 2.4s linear infinite;
  }
  @keyframes tdSSRShine {
    0% { background-position: -150% -150%; }
    100% { background-position: 250% 250%; }
  }

  /* 🏰 TD 타워 뽑기 버튼 */
  #tdDrawBtn {
    width: 100%; padding: 10px; font-weight: bold;
    background: #1f2735; color: #ffd479; border: 1px solid #ffd479;
    cursor: pointer; font-family: inherit; font-size: 13px;
    touch-action: manipulation;
  }
  #tdDrawBtn:disabled { color: #666; border-color: #2a2f3a; cursor: not-allowed; opacity: 0.5; }
  #tdDrawBtn.holding {
    background: #2a3a18; color: #88ff88; border-color: #88ff88;
    animation: tdHoldingPulse 1.6s ease-in-out infinite;
  }
  @keyframes tdHoldingPulse {
    0%, 100% { box-shadow: 0 0 0 rgba(136, 255, 136, 0); }
    50% { box-shadow: 0 0 12px rgba(136, 255, 136, 0.5); }
  }
  .toast {
    position:absolute; left:50%; top:20px;
    /* 🎬 v243 — 위에서 살짝 내려오는 등장 / 위로 사라지는 효과 */
    transform: translateX(-50%) translateY(-8px);
    background: rgba(20,24,34,0.95); color:#fff; padding:8px 14px;
    border:1px solid #3a4256; font-size:12px; pointer-events:none;
    opacity:0;
    transition: opacity .22s ease-out, transform .22s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
  #abilities { display:flex; flex-direction:column; gap:4px; }
  /* 가로 모드: abilities가 남은 공간을 차지하면서 내부 스크롤 → 배속/컨트롤 영역 안 가림 */
  #wrap:not(.portrait) #abilities {
    flex: 1 1 0;
    min-height: 0;
    overflow-y: auto;
    padding-right: 2px;
  }
  .footer { margin-top:auto; color:#4a5163; font-size:11px; text-align:center; }
  .speed-row { display:flex; gap:4px; margin-top:6px; }
  .speed-btn { flex:1; padding:6px 0; font-size:11px; }
  .speed-btn.active { background:#3d5380; color:#fff; border-color:#5870a0; }
  .hotkey-hint { margin-top:4px; font-size:11px; color:#4a5163; text-align:center; }
  #wrap.portrait .hotkey-hint { display: none; }     /* 휴대폰에선 단축키 안내 숨김 */
  #wrap.portrait .speed-btn { font-size: 14px; }

  /* ===== 메뉴 / 도감 화면 ===== */
  .screen {
    position: fixed; inset: 0;
    display: none;
    flex-direction: column;
    align-items: center; justify-content: safe center;
    background: #0b0d12;
    z-index: 10;
    padding: env(safe-area-inset-top) env(safe-area-inset-right) env(safe-area-inset-bottom) env(safe-area-inset-left);
    box-sizing: border-box;
    overflow-y: auto;
    overflow-x: hidden;
    touch-action: pan-y;
    -webkit-overflow-scrolling: touch;
  }
  .screen.show { display: flex; }
  /* 🌌 메뉴 배경 — 검정 → 은은한 우주 (중앙 네이비 글로우 + 성긴 별, 정적/차분) */
  #menu {
    background:
      radial-gradient(2px 2px at 12% 22%, rgba(255,255,255,0.5), transparent),
      radial-gradient(1px 1px at 28% 64%, rgba(200,220,255,0.45), transparent),
      radial-gradient(1.5px 1.5px at 47% 16%, rgba(255,255,255,0.4), transparent),
      radial-gradient(1px 1px at 63% 48%, rgba(190,215,255,0.4), transparent),
      radial-gradient(2px 2px at 79% 28%, rgba(255,255,255,0.45), transparent),
      radial-gradient(1px 1px at 88% 70%, rgba(200,220,255,0.4), transparent),
      radial-gradient(1px 1px at 34% 88%, rgba(255,255,255,0.35), transparent),
      radial-gradient(1.5px 1.5px at 71% 82%, rgba(190,215,255,0.35), transparent),
      radial-gradient(1px 1px at 8% 50%, rgba(255,255,255,0.3), transparent),
      radial-gradient(1px 1px at 93% 12%, rgba(200,220,255,0.35), transparent),
      radial-gradient(ellipse 72% 52% at 50% 30%, #14182c 0%, #0b0d12 70%);
  }
  #menu h1 {
    font-family: 'Black Han Sans', 'Jua', sans-serif;
    font-size: clamp(34px, 9vmin, 68px);  /* 둥근 굵은 폰트는 살짝 크게 */
    letter-spacing: clamp(2px, 0.8vmin, 6px);
    color: #7ad7ff;
    text-shadow: 0 0 30px rgba(122, 215, 255, 0.45);
    margin: 0 0 clamp(4px, 1.5vmin, 12px);
  }
  /* v218 — 데이터 초기화 버튼은 이제 설정 모달 안에 (settings-action-btn.danger 사용)
     이전 .reset-data-btn 클래스는 호환성 위해 남겨두지만 모달 내부 스타일 우선 */
  .reset-data-btn { /* deprecated — use .settings-action-btn.danger */ }
  /* 캐시 초기화 (업데이트) 버튼 (메뉴 좌측 상단) — 저장 데이터는 유지 */
  .update-cache-btn {
    position: absolute;
    top: 16px;
    left: 16px;
    padding: 8px 12px;
    background: #102028;
    color: #7ad7ff;
    border: 1px solid #2a5878;
    border-radius: 8px;
    font-family: inherit;
    font-size: 11px;
    cursor: pointer;
    touch-action: manipulation;
    transition: background .12s, box-shadow .12s;
  }
  .update-cache-btn:hover { background: #163240; box-shadow: 0 0 10px rgba(122,215,255,0.2); }
  .update-cache-btn:hover { background: #143040; color: #aaeaff; }
  /* 🎰 가챠 원형 버튼 — 우측 하단 캐릭터 이미지 (데이터 초기화 버튼과 겹치지 않게) */
  .gacha-circle-btn {
    position: absolute;
    bottom: 24px;
    right: 24px;
    width: 84px;
    height: 84px;
    border-radius: 50%;
    background: linear-gradient(135deg, #2a1c12 0%, #4a2820 50%, #2a1818 100%);
    border: 2px solid #ffaa55;
    color: #ffd479;
    font-family: inherit;
    cursor: pointer;
    touch-action: manipulation;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    overflow: hidden;
    padding: 0;
    box-shadow: 0 0 16px rgba(255, 170, 85, 0.4);
    animation: gacha-pulse 2s ease-in-out infinite;
  }
  .gacha-circle-btn:hover { box-shadow: 0 0 24px rgba(255, 200, 100, 0.7); transform: scale(1.05); }
  .gacha-circle-btn img {
    width: 100%; height: 100%;
    object-fit: contain;       /* 🐛 잘림 방지 — 캐릭터 전체 표시 */
    image-rendering: auto;     /* 🐛 일러스트 부드럽게 (도트화 X) */
    border-radius: 50%;
  }
  .gacha-circle-btn #gachaCircleEmoji { font-size: 24px; }
  .gacha-circle-btn .gacha-circle-label {
    position: absolute;
    bottom: -18px;
    font-size: 10px;
    color: #ffd479;
    font-weight: bold;
    width: 100%; text-align: center;
  }
  @keyframes gacha-pulse {
    0%, 100% { box-shadow: 0 0 16px rgba(255, 170, 85, 0.4); }
    50% { box-shadow: 0 0 24px rgba(255, 200, 100, 0.7); }
  }
  /* 새 버전 있을 때 — 강조 (펄스 + 컬러) */
  .update-cache-btn.update-needed {
    background: #4a2010;
    color: #ffaa66;
    border-color: #ff8844;
    font-weight: bold;
    animation: update-pulse 1.5s ease-in-out infinite;
  }
  .update-cache-btn.update-needed:hover { background: #5a3018; color: #ffcc88; }
  @keyframes update-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(255,136,68,0.6); }
    50% { box-shadow: 0 0 12px 4px rgba(255,136,68,0.5); }
  }
  #menu .subtitle {
    color: #6b7283;
    margin-bottom: clamp(12px, 5vmin, 50px);
    letter-spacing: clamp(2px, 0.6vmin, 4px);
    font-size: clamp(10px, 1.6vmin, 13px);
  }
  .menu-btn {
    padding: clamp(10px, 2vmin, 16px);
    font-size: clamp(13px, 1.9vmin, 16px);
    font-family: inherit;
    background: linear-gradient(180deg, #242d3f, #1a2230);
    color: var(--text, #e8eaf0);
    border: 1.5px solid var(--border, #3a4256);
    border-radius: var(--radius-sm, 9px);
    cursor: pointer;
    transition: background .12s, border-color .12s, transform .08s, box-shadow .12s;
    touch-action: manipulation;
    box-sizing: border-box;
    box-shadow: 0 2px 8px rgba(0,0,0,0.35), inset 0 1px 0 rgba(255,255,255,0.05);
  }
  .menu-btn:hover:not(:disabled) {
    background: linear-gradient(180deg, #2e3a55, #232d42); border-color: var(--accent-2, #5870a0);
    box-shadow: 0 4px 14px rgba(0,0,0,0.4), 0 0 12px rgba(122,215,255,0.18), inset 0 1px 0 rgba(255,255,255,0.08);
  }
  .menu-btn:active { transform: scale(0.97); }

  /* v218 — 메뉴 메인 컨테이너 (그룹화 + 그리드) */
  .menu-main {
    width: clamp(280px, 80vmin, 480px);
    display: flex; flex-direction: column;
    gap: clamp(8px, 1.6vmin, 16px);
    margin-top: clamp(6px, 1.5vmin, 12px);
  }
  /* v221 — 현재 선택 캐릭터 미리보기 (카드 스타일 — 가챠 결과 카드 톤 매치) */
  .menu-char-preview {
    --card-color: #7ad7ff;
    position: relative;
    display: flex; align-items: stretch; gap: 0;
    padding: 0;
    background: linear-gradient(135deg,
      color-mix(in srgb, var(--card-color) 15%, #0b0d12) 0%,
      #0c0e18 50%,
      #0a0d14 100%);
    border: 2px solid var(--card-color);
    border-radius: 6px;
    cursor: pointer;
    touch-action: manipulation;
    transition: transform .12s, box-shadow .12s;
    overflow: hidden;
    box-shadow: 0 0 8px color-mix(in srgb, var(--card-color) 30%, transparent);
  }
  .menu-char-preview:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 16px color-mix(in srgb, var(--card-color) 50%, transparent);
  }
  .menu-char-preview .preview-img-wrap {
    width: 56px; height: 56px;
    flex-shrink: 0;
    background: radial-gradient(circle at center,
      color-mix(in srgb, var(--card-color) 30%, #0b0d12),
      #0b0d12);
    display: flex; align-items: center; justify-content: center;
    border-right: 1px solid color-mix(in srgb, var(--card-color) 40%, transparent);
  }
  .menu-char-preview .preview-img-wrap img {
    width: 100%; height: 100%;
    object-fit: contain;       /* 🐛 잘림 방지 */
    image-rendering: auto;     /* 🐛 일러스트 부드럽게 */
  }
  .menu-char-preview .preview-info {
    flex: 1; min-width: 0;
    display: flex; flex-direction: column;
    gap: 2px;
    padding: 8px 10px 8px 12px;
    justify-content: center;
  }
  .menu-char-preview .preview-label {
    font-size: 9px;
    color: color-mix(in srgb, var(--card-color) 60%, #9aa3b3);
    letter-spacing: 2px;
    text-transform: uppercase;
    font-weight: bold;
  }
  .menu-char-preview .preview-name {
    font-size: 14px;
    font-weight: bold;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .menu-char-preview .preview-stars {
    font-size: 11px;
    letter-spacing: 1px;
  }
  .menu-char-preview .preview-arrow {
    font-size: 16px;
    color: var(--card-color);
    flex-shrink: 0;
    align-self: center;
    padding-right: 10px;
    opacity: 0.7;
  }
  /* 상단 라벨 띠 — 가챠 결과 카드의 rarity tag 매치 */
  .menu-char-preview .preview-rarity-tag {
    position: absolute;
    top: 0; left: 0;
    padding: 1px 6px;
    background: var(--card-color);
    color: #0b0d12;
    font-size: 9px;
    font-weight: bold;
    letter-spacing: 1px;
    border-radius: 0 0 4px 0;
  }
  /* 메인 CTA 그룹 — 새 게임/이어하기/난이도 */
  .menu-cta-group {
    display: flex; flex-direction: column; gap: 6px;
  }
  /* v223 — 빠른 시작 미리보기 (Primary 버튼 바로 아래 작은 텍스트) */
  .quick-start-preview {
    font-size: 11px;
    color: #6b7283;
    text-align: center;
    padding: 2px 0 4px;
    letter-spacing: 1px;
  }
  .quick-start-preview .qs-val {
    color: #9aa3b3;
    font-weight: bold;
  }
  /* Primary — 새 게임/이어하기. 큼 + 강조 */
  .menu-btn-primary {
    font-size: clamp(15px, 2.6vmin, 20px);
    font-weight: bold;
    padding: clamp(14px, 2.6vmin, 20px);
    background: linear-gradient(135deg, #2e3c5e, #1f2840);
    border-color: #6a82b8;
    color: #ffffff;
    box-shadow: 0 0 14px rgba(122,215,255,0.18), 0 3px 12px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.1);
  }
  .menu-btn-primary:hover:not(:disabled) {
    background: linear-gradient(135deg, #354270, #2a3045);
    border-color: #7a90c0;
    box-shadow: 0 0 12px rgba(122, 215, 255, 0.25);
  }
  /* 🔄 v228 — "처음부터 다시" — 진행 중일 때 startBtn에 적용 (이어하기와 시각 구분) */
  .menu-btn-restart {
    background: linear-gradient(135deg, #2a1818, #1a0c0c) !important;
    border-color: #5a3038 !important;
    color: #ffaabb !important;
    font-size: clamp(13px, 1.9vmin, 16px) !important;   /* 작게 — 부수적 액션 */
    padding: clamp(10px, 2vmin, 14px) !important;
    font-weight: normal !important;
  }
  .menu-btn-restart:hover:not(:disabled) {
    background: linear-gradient(135deg, #3a1820, #2a1010) !important;
  }
  /* Secondary — 난이도 등 */
  .menu-btn-secondary {
    font-size: clamp(12px, 1.7vmin, 14px);
    padding: clamp(8px, 1.5vmin, 12px);
    color: #ffd479;
    border-color: #5a4220;
    background: #1a1408;
  }
  /* 그룹 헤더 */
  .menu-section {
    display: flex; flex-direction: column; gap: 6px;
    margin-top: 4px;
  }
  .menu-section-label {
    font-size: clamp(10px, 1.4vmin, 12px);
    color: #6b7283;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding-left: 4px;
  }
  /* 2~3컬럼 그리드 */
  .menu-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 6px;
  }
  .menu-grid-3 { grid-template-columns: repeat(3, 1fr); }
  .menu-grid-2 { grid-template-columns: repeat(2, 1fr); }
  .menu-btn-grid {
    padding: clamp(10px, 1.8vmin, 14px) clamp(6px, 1.2vmin, 10px);
    font-size: clamp(11px, 1.6vmin, 14px);
  }
  .menu-btn-wide {
    width: 100%;
    margin-top: 4px;
  }
  /* 닉네임 — 하단 카드 */
  .nickname-display {
    margin-top: clamp(10px, 2vmin, 18px);
    font-size: clamp(11px, 1.6vmin, 13px);
    color: #9aa3b3;
    cursor: pointer;
    padding: 6px 12px;
    border-radius: 6px;
    border: 1px solid #2a2f3a;
    background: rgba(20,24,34,0.5);
    touch-action: manipulation;
  }
  .nickname-display:hover { background: rgba(40,48,68,0.5); color: #cfd6e3; }
  .nickname-display #nickname-text { color: #7ad7ff; font-weight: bold; }

  /* 설정 버튼 (우상단) */
  .settings-btn {
    position: absolute;
    top: 16px; right: 16px;
    width: 40px; height: 40px;
    padding: 0;
    background: #1f2735;
    color: #cfd6e3;
    border: 1px solid #3a4256;
    border-radius: 8px;
    font-size: 18px;
    cursor: pointer;
    touch-action: manipulation;
    z-index: 11;
    transition: background .12s, border-color .12s;
  }
  .settings-btn:hover { background: #2a3550; border-color: #5870a0; color: #ffffff; }

  /* 설정 모달 */
  .settings-modal-overlay {
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.7);
    z-index: 9990;
    display: flex; align-items: center; justify-content: center;
    padding: 16px;
    box-sizing: border-box;
    backdrop-filter: blur(4px);
  }
  .settings-modal-content {
    background: linear-gradient(180deg, #1a2030, #11151e);
    border: 1px solid #3a4256;
    border-radius: 14px;
    width: 100%; max-width: 420px;
    max-height: 90vh; overflow-y: auto;
    display: flex; flex-direction: column;
    box-shadow: 0 16px 48px rgba(0,0,0,0.6), inset 0 1px 0 rgba(255,255,255,0.05), 0 0 30px rgba(122,215,255,0.07);
  }
  .settings-modal-header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 14px 18px;
    border-bottom: 1px solid #2a2f3a;
  }
  .settings-modal-header h3 {
    margin: 0; font-size: 16px; color: #7ad7ff; letter-spacing: 2px;
    text-shadow: 0 0 14px rgba(122,215,255,0.35);
  }
  .settings-modal-close {
    width: 32px; height: 32px; padding: 0;
    background: linear-gradient(180deg, #242d3f, #1a2230); color: #9aa3b3;
    border: 1px solid #3a4256; border-radius: 8px;
    font-size: 14px; cursor: pointer;
    touch-action: manipulation; transition: background .12s, color .12s, box-shadow .12s;
  }
  .settings-modal-close:hover { background: linear-gradient(180deg, #2e3950, #222a3d); color: #ffffff; box-shadow: 0 0 10px rgba(122,215,255,0.2); }
  .settings-modal-body { padding: 16px; display: flex; flex-direction: column; gap: 16px; }
  .settings-section {
    padding: 12px; background: linear-gradient(180deg, #14181f, #0e1119);
    border: 1px solid #2a2f3a; border-radius: 9px;
  }
  .settings-section.danger { border-color: #5a3038; background: #1a0c10; }
  .settings-section-title {
    font-size: 13px; font-weight: bold; color: #cfd6e3;
    margin-bottom: 4px;
  }
  .settings-section.danger .settings-section-title { color: #ff8a98; }
  .settings-section-desc {
    font-size: 11px; color: #6b7283;
    margin-bottom: 10px; line-height: 1.5;
  }
  .settings-action-btn {
    width: 100%; padding: 10px;
    background: #1f2735; color: #cfd6e3;
    border: 1px solid #3a4256; border-radius: 6px;
    font-family: inherit; font-size: 13px; font-weight: bold;
    cursor: pointer; touch-action: manipulation;
  }
  .settings-action-btn:hover { background: #2a3550; }
  .settings-action-btn.danger { color: #ff8a98; border-color: #5a3038; }
  .settings-action-btn.danger:hover { background: #2a1018; color: #ffaabb; }

  #codex {
    padding: 24px;
    align-items: stretch;
    box-sizing: border-box;
  }
  .codex-header {
    display: flex; justify-content: space-between; align-items: center;
    max-width: 900px; width: 100%;
    margin: 0 auto 14px;
    padding-bottom: 10px;
    border-bottom: 1px solid rgba(122,215,255,0.16);
  }
  .codex-header h2 { margin: 0; font-size: 22px; letter-spacing: 6px; color: var(--accent, #7ad7ff); text-shadow: 0 0 14px rgba(122,215,255,0.35); }
  .codex-back {
    padding: 10px 18px;
    background: linear-gradient(180deg, #242d3f, #1a2230); color: var(--text, #e8eaf0);
    border: 1px solid var(--border, #3a4256);
    border-radius: var(--radius-sm, 8px);
    cursor: pointer; font-family: inherit; font-size: 13px;
    touch-action: manipulation;
    transition: background .12s, border-color .12s, box-shadow .12s;
    box-shadow: 0 2px 6px rgba(0,0,0,0.3);
  }
  .codex-back:hover { background: linear-gradient(180deg, #2e3a55, #232d42); border-color: var(--accent-2, #5870a0); box-shadow: 0 0 10px rgba(122,215,255,0.2); }
  .codex-tabs {
    display: flex; gap: 8px;
    max-width: 900px; width: 100%;
    margin: 0 auto 12px;
    /* 🛡 v209 — 부모 .screen 의 touch-action: pan-y 로 인해 가로 터치 스크롤이 막혔던 문제 해결.
       탭 컨테이너 자체는 가로 pan + 세로 pan(부모 스크롤로 위임) 모두 허용. */
    touch-action: pan-x pan-y;
  }
  .codex-tab {
    padding: 10px 18px;
    background: linear-gradient(180deg, #232c3d, #1a2230); color: #9aa3b3;
    border: 1px solid #3a4256; border-radius: var(--radius-sm, 8px);
    cursor: pointer; font-family: inherit; font-size: 13px;
    touch-action: manipulation;
    transition: background .12s, border-color .12s, color .12s, box-shadow .12s;
  }
  .codex-tab:hover:not(.active) { background: linear-gradient(180deg, #2a3550, #202a3d); color: #cfd6e3; }
  .codex-tab.active {
    background: linear-gradient(180deg, #44598a, #354b76); color: #fff;
    border-color: #6a82b8; box-shadow: 0 0 12px rgba(122,215,255,0.22), inset 0 1px 0 rgba(255,255,255,0.08);
  }

  /* 🎯 v224 — 도감 필터 칩 (검색은 제거) */
  .codex-filter-chips {
    max-width: 900px; width: 100%;
    margin: 0 auto 10px;
    display: flex; gap: 6px; flex-wrap: wrap;
    padding: 0 4px;
    box-sizing: border-box;
    justify-content: center;
  }
  .codex-filter-chip {
    padding: 6px 14px;
    background: #1f2735; color: #9aa3b3;
    border: 1px solid #3a4256; border-radius: 14px;
    font-family: inherit; font-size: 12px;
    cursor: pointer; touch-action: manipulation;
    transition: background .12s, border-color .12s, color .12s;
  }
  .codex-filter-chip:hover:not(.active) { background: #2a3550; color: #cfd6e3; }
  .codex-filter-chip.active {
    background: linear-gradient(180deg, #44598a, #354b76); color: #fff;
    border-color: #6a82b8; box-shadow: 0 0 10px rgba(122,215,255,0.2);
  }
  /* 필터 결과 0개 — 메시지 */
  .codex-empty-msg {
    text-align: center; padding: 40px 20px;
    color: #6b7283; font-size: 13px;
    grid-column: 1 / -1;
  }

  #codex-list {
    max-width: 900px; width: 100%;
    margin: 0 auto;
    overflow-y: auto;
    flex: 1;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 10px;
    padding: 4px 4px 24px;
  }
  /* 🎴 v231 — 도감 캐릭터 카드 (R/SR/SSR 정보 카드) */
  .codex-char-card {
    grid-column: 1 / -1;     /* 1열 전체 폭 */
    max-width: 720px;
    margin: 0 auto;
    width: 100%;
  }
  .codex-char-card.locked { opacity: 0.6; }
  .codex-char-card .char-codex-header {
    display: flex; align-items: center; gap: 12px;
    margin-bottom: 10px;
  }
  .codex-char-card .char-codex-portrait {
    width: 72px; height: 72px;
    flex-shrink: 0;
    background: #0a0d18;
    border-radius: 6px;
    overflow: hidden;
    display: flex; align-items: center; justify-content: center;
  }
  .codex-char-card .char-codex-portrait img {
    width: 100%; height: 100%;
    object-fit: cover;
    image-rendering: pixelated;
  }
  .codex-char-card .char-codex-portrait.locked-portrait {
    background: #1a1f2b;
    font-size: 32px;
    color: #5a5f6a;
  }
  .codex-char-card .char-codex-meta {
    flex: 1; min-width: 0;
    display: flex; flex-direction: column; gap: 4px;
  }
  .codex-char-card .char-codex-name-row {
    display: flex; align-items: center; gap: 8px;
    flex-wrap: wrap;
  }
  .codex-char-card .char-codex-name {
    font-size: 18px; font-weight: bold;
  }
  .codex-char-card .char-codex-rarity {
    font-size: 10px;
    padding: 2px 8px;
    border: 1px solid;
    border-radius: 10px;
    font-weight: bold;
    letter-spacing: 1px;
  }
  .codex-char-card .char-codex-stars {
    font-size: 14px;
    letter-spacing: 1px;
    font-weight: bold;
  }
  .codex-char-card .char-codex-lock-hint {
    font-size: 11px;
    color: #7a8090;
    font-style: italic;
  }
  .codex-char-card .char-codex-desc {
    font-size: 12px;
    color: #cfd6e3;
    line-height: 1.5;
    margin-bottom: 12px;
    padding: 8px 10px;
    background: rgba(20,24,34,0.5);
    border-radius: 4px;
    border-left: 2px solid #2a2f3a;
  }
  .codex-char-card .char-codex-section {
    margin-top: 10px;
    padding-top: 8px;
    border-top: 1px solid #2a2f3a;
  }
  .codex-char-card .char-codex-section:first-of-type {
    margin-top: 0;
    padding-top: 0;
    border-top: 0;
  }
  .codex-char-card .char-codex-section-title {
    font-size: 10px;
    font-weight: bold;
    color: #9aa3b3;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .codex-char-card .char-codex-section-body {
    font-size: 12px;
    color: #cfd6e3;
    line-height: 1.6;
  }
  .codex-char-card .char-codex-recipe {
    padding: 4px 8px;
    margin-bottom: 3px;
    background: rgba(20,24,34,0.4);
    border-radius: 4px;
    font-size: 12px;
    line-height: 1.4;
  }
  .codex-char-card .char-codex-perk {
    display: flex; align-items: center; gap: 8px;
    padding: 5px 8px;
    margin-bottom: 3px;
    background: rgba(20,24,34,0.4);
    border-radius: 4px;
    font-size: 12px;
  }
  .codex-char-card .char-codex-perk.unlocked {
    background: rgba(255,212,121,0.08);
    border: 1px solid rgba(255,212,121,0.25);
  }
  .codex-char-card .char-codex-perk .perk-lv {
    font-weight: bold;
    font-size: 11px;
    min-width: 28px;
  }
  .codex-char-card .char-codex-perk .perk-name {
    flex: 1;
    font-weight: bold;
  }
  .codex-char-card .char-codex-perk .perk-status {
    font-size: 10px;
    color: #88ff88;
    font-weight: bold;
  }
  .codex-char-card .char-codex-perk-row {
    display: flex; align-items: center; gap: 8px;
    padding: 2px 8px;
    font-size: 11px;
    color: #6b7283;
  }
  .codex-char-card .char-codex-perk-row.has {
    color: #cfd6e3;
  }
  .codex-char-card .char-codex-perk-row .perk-lv-mini {
    font-weight: bold;
    color: #ffd479;
    min-width: 26px;
  }
  .codex-char-card .char-codex-perk-row.has .perk-lv-mini {
    color: #ffd060;
  }
  .codex-char-card .char-codex-perk-row .perk-text { flex: 1; }
  .codex-char-card .char-codex-perk-row .perk-check {
    color: #88ff88;
    font-size: 12px;
  }

  .codex-card {
    background: linear-gradient(180deg, #161b27, #11151e);
    border: 1px solid #2a2f3a;
    border-left: 4px solid #7ad7ff;
    border-radius: 9px;
    padding: 12px;
    font-size: 12px;
    line-height: 1.5;
    box-shadow: 0 2px 8px rgba(0,0,0,0.3);
  }
  .codex-card .name {
    font-weight: bold;
    font-size: 15px;
    margin-bottom: 4px;
  }
  .codex-card .desc {
    color: #c8cdd8;
    font-size: 12px;
  }
  .codex-card .recipe {
    margin-top: 8px;
    padding-top: 8px;
    border-top: 1px solid #2a2f3a;
    color: #9aa3b3;
    font-size: 11px;
  }
  .codex-card.locked {
    background: #0f1219;
    border-color: #232732;
    border-left-color: #2a2f3a !important;
  }
  .codex-card.locked .name { color: #4a5163; }
  .codex-card.locked .desc { color: #3a4153; font-style: italic; }

  /* ===== 기록 화면 ===== */
  #records, #recordDetail { padding: 24px; align-items: stretch; }
  #records-list, #record-detail-content {
    max-width: 720px; width: 100%; margin: 0 auto;
    overflow-y: auto; flex: 1; padding-bottom: 24px;
  }
  .record-card {
    display: flex;
    align-items: center;
    gap: 14px;
    background: linear-gradient(180deg, #161b27, #11151e);
    border: 1px solid #2a2f3a;
    border-radius: 10px;
    padding: 14px;
    margin-bottom: 8px;
    cursor: pointer;
    transition: background .12s, border-color .12s, transform .1s, box-shadow .12s;
    box-shadow: 0 2px 8px rgba(0,0,0,0.3);
  }
  .record-card:hover { background: linear-gradient(180deg, #1c222f, #141823); border-color: #3a4256; transform: translateY(-1px); box-shadow: 0 5px 16px rgba(0,0,0,0.42), 0 0 10px rgba(122,215,255,0.1); }
  .record-card.win { border-left: 4px solid #ffe070; }
  .record-card .rank {
    font-size: 26px; font-weight: bold; color: #7ad7ff;
    width: 44px; text-align: center;
  }
  .record-card.win .rank { color: #ffe070; }
  .record-card .info { flex: 1; }
  .record-card .score { font-size: 18px; font-weight: bold; color: #e8eaf0; }
  .record-card .meta { color: #9aa3b3; font-size: 12px; margin-top: 4px; }
  .record-card .arrow { color: #6b7283; font-size: 18px; }
  .record-empty { color: #6b7283; text-align: center; padding: 40px; }
  #record-detail-header {
    text-align: center; margin-bottom: 22px;
    background: linear-gradient(180deg, #161b27, #11151e);
    border: 1px solid #2a2f3a; border-radius: 12px;
    padding: 18px 16px; box-shadow: 0 3px 12px rgba(0,0,0,0.32);
  }
  #record-detail-header .big-score { font-size: 34px; font-weight: bold; color: #7ad7ff; margin-bottom: 6px; text-shadow: 0 0 18px rgba(122,215,255,0.4); }
  #record-detail-header.win { border-color: rgba(255,224,112,0.4); box-shadow: 0 3px 12px rgba(0,0,0,0.32), 0 0 18px rgba(255,224,112,0.12); }
  #record-detail-header.win .big-score { color: #ffe070; text-shadow: 0 0 18px rgba(255,224,112,0.45); }
  #record-detail-header .sub { color: #9aa3b3; font-size: 13px; }
  #record-detail-header .when { color: #6b7283; font-size: 11px; margin-top: 4px; }
  #record-detail-abilities {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 10px;
  }

  /* ===== 🎰 가챠 화면 ===== */
  #gachaScreen {
    padding: 16px;
    align-items: stretch;
    justify-content: flex-start;
    gap: 10px;
    max-width: 600px; width: 100%; margin: 0 auto;
  }
  /* 상단 바 — 작은 재화 표시 */
  .gacha-top-bar {
    display: flex; align-items: center; gap: 10px;
    padding: 4px 0 8px;
    border-bottom: 1px solid #2a2f3a;
  }
  .gacha-back-small {
    padding: 6px 12px !important;
    font-size: 14px !important;
  }
  .gacha-title {
    flex: 1; text-align: center;
    font-size: 18px; font-weight: bold; color: #e8eaf0;
    letter-spacing: 2px;
  }
  .gacha-currencies {
    display: flex; gap: 6px;
  }
  .gacha-cur-chip {
    background: linear-gradient(180deg, #1a2030, #11151e); border: 1px solid #2a3140;
    padding: 5px 11px; font-size: 12px;
    border-radius: 999px;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.04);
  }
  /* 🎴 풀스크린 배너 (명조 스타일) */
  .gacha-fullbanner {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
    max-height: 75vh;
    background: linear-gradient(135deg, #0a0c14, #050608);
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 12px;
  }
  .gacha-fullbanner-img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }
  .gacha-fullbanner-fallback {
    position: absolute; inset: 0;
    display: none; flex-direction: column;
    align-items: center; justify-content: center;
    color: #5a6275; text-align: center; padding: 20px;
  }
  /* 좌/우 배너 전환 화살표 */
  .gacha-banner-arrow {
    position: absolute;
    top: 50%; transform: translateY(-50%);
    width: 44px; height: 44px;
    background: rgba(20,24,34,0.65);
    color: #fff;
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 50%;
    font-size: 18px; cursor: pointer;
    backdrop-filter: blur(6px);
    transition: background .15s, transform .1s;
    z-index: 5;
    display: flex; align-items: center; justify-content: center;
    font-family: inherit;
  }
  .gacha-banner-arrow:hover { background: rgba(122,215,255,0.4); transform: translateY(-50%) scale(1.08); }
  .gacha-banner-arrow:active { transform: translateY(-50%) scale(0.95); }
  .gacha-arrow-left  { left: 8px; }
  .gacha-arrow-right { right: 8px; }
  /* 상단 좌측: 배너 타이틀 */
  .gacha-banner-top-overlay {
    position: absolute;
    top: 12px; left: 16px;
    z-index: 4;
    pointer-events: none;
  }
  .gacha-banner-name {
    font-size: 18px; font-weight: bold;
    color: #fff;
    text-shadow: 0 2px 8px rgba(0,0,0,0.85), 0 0 12px rgba(255,212,121,0.4);
    margin-bottom: 4px;
  }
  .gacha-banner-pickup-info {
    font-size: 11px; color: #cfd6e3;
    text-shadow: 0 1px 4px rgba(0,0,0,0.85);
    background: rgba(0,0,0,0.4);
    padding: 2px 8px; border-radius: 10px;
    display: inline-block;
    backdrop-filter: blur(4px);
  }
  /* 상단 우측: 컬렉션 진행도 칩 */
  .gacha-banner-collection-pill {
    position: absolute;
    top: 12px; right: 16px;
    background: rgba(0,0,0,0.5);
    color: #ffd479;
    font-size: 12px; font-weight: bold;
    padding: 5px 10px; border-radius: 12px;
    border: 1px solid rgba(255,212,121,0.3);
    backdrop-filter: blur(4px);
    z-index: 4;
  }
  /* 하단 오버레이: 뽑기 버튼만 (어두운 그라데이션 X — 일러스트 보존) */
  .gacha-banner-bottom-overlay {
    position: absolute;
    bottom: 12px; left: 12px; right: 12px;
    z-index: 4;
    display: flex; flex-direction: column; gap: 6px;
    pointer-events: none;   /* 자식 요소만 클릭 가능 */
  }
  .gacha-banner-bottom-overlay > * { pointer-events: auto; }
  /* 픽업 캐릭터 미니 아이콘 — 작게, 하단 오버레이 X (배너 우상단 작은 칩으로 통합) */
  .gacha-pickup-icons {
    display: flex; gap: 4px;
    align-items: center;
    flex-wrap: wrap;
    justify-content: flex-end;
    margin-bottom: 4px;
  }
  .gacha-pickup-icon {
    display: flex; align-items: center; gap: 4px;
    background: rgba(0,0,0,0.55);
    border: 1px solid rgba(255,255,255,0.15);
    padding: 3px 7px 3px 3px;
    border-radius: 12px;
    font-size: 10px;
    backdrop-filter: blur(6px);
    box-shadow: 0 2px 6px rgba(0,0,0,0.5);
  }
  .gacha-pickup-icon img {
    width: 18px; height: 18px;
    border-radius: 50%;
    object-fit: cover;
  }
  .gacha-pickup-icon.tier-ssr { border-color: #ff80ff; box-shadow: 0 0 8px rgba(255,128,255,0.5); }
  .gacha-pickup-icon.tier-sr  { border-color: #ffaa55; }
  .gacha-pickup-icon.tier-r   { border-color: #88e0ff; }
  .gacha-pickup-icon.tier-ssr .gacha-pickup-rate { color: #ff80ff; font-weight: bold; }
  .gacha-pickup-icon.tier-sr .gacha-pickup-rate  { color: #ffaa55; }
  .gacha-pickup-icon.tier-r .gacha-pickup-rate   { color: #88e0ff; }
  .gacha-pickup-rate { font-size: 9px; }
  /* 뽑기 버튼 행 — 일러스트 가리지 않도록 본체에 backdrop-filter 적용 */
  .gacha-pull-row {
    display: flex; gap: 8px;
  }
  .gacha-pull-btn-overlay {
    flex: 1;
    padding: 12px 10px;
    background: rgba(20,24,34,0.55);
    color: #fff;
    border: 1.5px solid rgba(255,255,255,0.25);
    font-family: inherit;
    cursor: pointer;
    transition: background .12s, border-color .12s, transform .08s, box-shadow .15s;
    touch-action: manipulation;
    display: flex; flex-direction: column;
    align-items: center; gap: 3px;
    border-radius: 8px;
    backdrop-filter: blur(10px);
    box-shadow: 0 4px 14px rgba(0,0,0,0.5);
    text-shadow: 0 1px 2px rgba(0,0,0,0.7);
  }
  .gacha-pull-btn-overlay:hover:not(:disabled) {
    background: rgba(42,53,80,0.75);
    border-color: rgba(122,215,255,0.8);
    transform: translateY(-2px);
  }
  .gacha-pull-btn-overlay:active { transform: scale(0.97); }
  .gacha-pull-btn-overlay:disabled { opacity: 0.55; cursor: not-allowed; }
  .gacha-pull-btn-overlay.primary {
    border-color: rgba(255,212,121,0.85);
    background: rgba(58,42,16,0.6);
    color: #ffe070;
    box-shadow: 0 4px 14px rgba(0,0,0,0.5), 0 0 14px rgba(255,212,121,0.35);
  }
  .gacha-pull-btn-overlay.primary:hover:not(:disabled) {
    background: rgba(78,56,22,0.75);
    box-shadow: 0 4px 14px rgba(0,0,0,0.5), 0 0 22px rgba(255,212,121,0.6);
  }
  /* 보조 액션 (배너 밖) */
  .gacha-secondary-actions {
    display: flex; flex-direction: column; gap: 8px;
    padding: 0 12px 16px;
  }
  .gacha-secondary-btn {
    width: 100%;
    padding: 9px 12px;
    background: linear-gradient(180deg, #2a2410, #1d1908);
    border: 1px solid #ffd479;
    border-radius: 8px;
    color: #ffd479;
    font-family: inherit; font-size: 12px;
    cursor: pointer;
    transition: background .12s, box-shadow .12s, transform .08s;
  }
  .gacha-secondary-btn:hover { background: linear-gradient(180deg, #3a3014, #2a230c); box-shadow: 0 0 12px rgba(255,212,121,0.28); }
  .gacha-secondary-btn:active { transform: scale(0.98); }
  /* 모바일 — 작은 화면에서 화살표 더 작게 */
  @media (max-width: 480px) {
    .gacha-banner-arrow { width: 36px; height: 36px; font-size: 15px; }
    .gacha-banner-name { font-size: 15px; }
    .gacha-banner-pickup-info { font-size: 10px; }
  }
  /* (구) 중앙 배너 — 백워드 호환용 (사용 X) */
  .gacha-banner-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
    max-height: 320px;
    background: linear-gradient(135deg, #1a1f2e, #0c0e18);
    border: 1px solid #2a2f3a;
    border-radius: 8px;
    overflow: hidden;
    display: flex; align-items: center; justify-content: center;
  }
  .gacha-banner-img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }
  .gacha-banner-fallback {
    flex-direction: column; align-items: center; justify-content: center;
    color: #5a6275;
    text-align: center; padding: 20px;
  }
  .gacha-banner-sparkles {
    font-size: 48px;
    animation: gacha-shimmer 2s ease-in-out infinite;
  }
  .gacha-banner-title {
    font-size: 28px; font-weight: bold; color: #7ad7ff;
    text-shadow: 0 0 18px rgba(122,215,255,0.45);
    letter-spacing: 6px; margin: 8px 0 4px;
  }
  .gacha-banner-sub {
    font-size: 14px; color: #9aa3b3; letter-spacing: 2px;
  }
  .gacha-banner-hint {
    margin-top: 18px; font-size: 11px; color: #4a5163;
  }
  @keyframes gacha-shimmer {
    0%, 100% { opacity: 0.6; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.1); }
  }
  /* 배너 위 오버레이 (컬렉션 + 확률) */
  .gacha-banner-overlay {
    position: absolute; bottom: 0; left: 0; right: 0;
    background: linear-gradient(transparent, rgba(0,0,0,0.7));
    padding: 12px;
    display: flex; justify-content: space-between; align-items: flex-end;
    font-size: 11px;
  }
  .gacha-collection-mini { color: #ffd479; font-weight: bold; }
  .gacha-rates-mini { color: #9aa3b3; }
  /* 결과 표시 */
  .gacha-result {
    min-height: 30px;
    text-align: center;
    font-size: 13px;
    padding: 4px;
  }
  /* 뽑기 버튼 */
  .gacha-buttons {
    display: flex; gap: 10px;
    margin-top: 6px;
  }
  .gacha-pull-btn {
    flex: 1;
    padding: 14px 12px;
    background: #1f2735; color: #e8eaf0;
    border: 2px solid #3a4256;
    font-family: inherit;
    cursor: pointer;
    transition: background .12s, border-color .12s, transform .08s;
    touch-action: manipulation;
    display: flex; flex-direction: column; align-items: center; gap: 4px;
    border-radius: 6px;
  }
  .gacha-pull-btn:hover:not(:disabled) { background: #2a3550; border-color: #5870a0; transform: translateY(-1px); }
  .gacha-pull-btn:active { transform: scale(0.97); }
  .gacha-pull-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .gacha-pull-btn.primary {
    border-color: #ffd479;
    background: linear-gradient(135deg, #2a2418, #1a1810);
    color: #ffd479;
  }
  .gacha-pull-btn.primary:hover:not(:disabled) { background: linear-gradient(135deg, #3a311e, #2a2418); }
  .gacha-pull-label { font-size: 15px; font-weight: bold; }
  .gacha-pull-cost { font-size: 13px; color: #9aa3b3; }
  /* 컬렉션 (접기/펼치기) */
  .gacha-collection-details {
    margin-top: 6px;
    background: #141822;
    border: 1px solid #2a2f3a;
    border-radius: 6px;
    padding: 10px 14px;
  }
  .gacha-collection-details summary {
    cursor: pointer;
    font-size: 13px;
    color: #9aa3b3;
    user-select: none;
  }
  .gacha-collection-details summary:hover { color: #c8cdd8; }
  .gacha-collection-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
    gap: 6px;
    margin-top: 10px;
  }
  .gacha-refund-info {
    margin-top: 10px; padding-top: 8px;
    border-top: 1px solid #2a2f3a;
    text-align: center; color: #6b7283; font-size: 10px;
  }

  /* ===== 가챠 결과 화면 ===== */
  #gachaResultScreen {
    padding: 12px;
    align-items: center;
    justify-content: center;
    gap: 12px;
    box-sizing: border-box;
    /* 컨텐츠가 화면을 넘어가면 안 잘리게 — 단, 카드 자체는 그리드로 항상 fit */
    overflow-y: auto;
  }
  .gacha-result-title {
    font-size: 26px; font-weight: bold; color: #ffd479;
    letter-spacing: 4px;
    text-shadow: 0 0 20px rgba(255, 212, 121, 0.5);
  }
  /* 🎴 10연 결과 — 5×2 그리드 고정 (스크롤 없이 한 화면에) */
  .gacha-result-cards {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 8px;
    justify-content: center;
    width: 100%;
    max-width: 720px;
    box-sizing: border-box;
    padding: 4px;
    /* 화면 잘림 방지 — 컨테이너 자체 스크롤 X, 카드 크기로 조절 */
    overflow: hidden;
  }
  /* 1회 뽑기 — 카드 1개일 때 그리드 1열 + 큰 카드 */
  .gacha-result-cards.single {
    grid-template-columns: 200px;
    max-width: 220px;
  }
  .gacha-result-card {
    --rarity-color: #7ad7ff;
    position: relative;
    width: 100%;
    min-width: 0;        /* grid 자식이 콘텐츠로 인해 부풀지 않게 */
    background: #0c0e18;
    border: 2px solid var(--rarity-color);
    border-radius: 9px;
    overflow: hidden;
    display: flex; flex-direction: column;
    opacity: 0;
    transform: translateY(24px) scale(0.6) rotate(-4deg);
    /* 🎬 v250 — 순차 등장: animation-delay 는 JS 에서 inline 으로 설정 (카드별 stagger) */
    animation: _gacha-card-reveal 0.45s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }
  @keyframes _gacha-card-reveal {
    0%   { opacity: 0; transform: translateY(24px) scale(0.6) rotate(-4deg); }
    60%  { opacity: 1; transform: translateY(-4px) scale(1.05) rotate(1deg); }
    100% { opacity: 1; transform: translateY(0) scale(1) rotate(0deg); }
  }
  /* 🎬 v250 — SSR/ANCIENT 강조 펄스 (등장 후 한 번 더 빛남) */
  @keyframes _gacha-card-rarity-burst {
    0%   { box-shadow: 0 0 0 0 var(--rarity-color); }
    50%  { box-shadow: 0 0 24px 4px var(--rarity-color); }
    100% { box-shadow: 0 0 0 0 var(--rarity-color); }
  }
  .gacha-result-card.rarity-ssr,
  .gacha-result-card.rarity-ancient {
    /* 등장 + 펄스 같이 (delay 는 inline) */
    animation: _gacha-card-reveal 0.45s cubic-bezier(0.34, 1.56, 0.64, 1) forwards,
               _gacha-card-rarity-burst 0.8s ease-out;
  }
  .gacha-result-card .card-rarity-tag {
    text-align: center;
    padding: 3px;
    background: var(--rarity-color);
    color: #0b0d12;
    font-weight: bold;
    font-size: 10px;
    letter-spacing: 1px;
  }
  .gacha-result-card .card-portrait {
    aspect-ratio: 1 / 1;     /* 카드 폭에 비례한 정사각 portrait */
    display: flex; align-items: center; justify-content: center;
    font-size: clamp(28px, 7vw, 48px);
    background: radial-gradient(circle at center, color-mix(in srgb, var(--rarity-color) 25%, #0b0d12), #0b0d12);
    position: relative;
  }
  .gacha-result-card .card-name {
    text-align: center;
    padding: 4px 2px 2px;
    font-size: clamp(10px, 1.8vw, 12px);
    font-weight: bold;
    color: var(--rarity-color);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .gacha-result-card .card-status {
    text-align: center;
    padding: 1px 2px 4px;
    font-size: clamp(8px, 1.4vw, 10px);
    color: #9aa3b3;
    min-height: 14px;
  }
  /* 1회 결과 — 큰 카드일 때 폰트도 크게 */
  .gacha-result-cards.single .card-portrait { font-size: 64px; }
  .gacha-result-cards.single .card-name { font-size: 14px; }
  .gacha-result-cards.single .card-status { font-size: 11px; }
  .gacha-result-card .card-status.new {
    color: #88ff88;
    font-weight: bold;
  }
  /* 등급별 이펙트 */
  /* R 등급 — 부드러운 청록 글로우 */
  .gacha-result-card.rarity-r {
    box-shadow: 0 0 12px rgba(122, 215, 255, 0.3);
  }
  /* SR 등급 — 보라 광채 + 빛 펄스 */
  .gacha-result-card.rarity-sr {
    box-shadow: 0 0 20px rgba(192, 132, 255, 0.6), inset 0 0 20px rgba(192, 132, 255, 0.15);
    animation: gacha-card-in 0.4s ease-out forwards, gacha-sr-pulse 2s ease-in-out infinite 0.5s;
  }
  .gacha-result-card.rarity-sr::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(135deg, transparent 30%, rgba(192, 132, 255, 0.18) 50%, transparent 70%);
    background-size: 200% 200%;
    animation: gacha-sr-shimmer 3s linear infinite;
    pointer-events: none;
  }
  @keyframes gacha-sr-pulse {
    0%, 100% { box-shadow: 0 0 20px rgba(192, 132, 255, 0.5), inset 0 0 20px rgba(192, 132, 255, 0.15); }
    50%      { box-shadow: 0 0 30px rgba(192, 132, 255, 0.9), inset 0 0 25px rgba(192, 132, 255, 0.25); }
  }
  @keyframes gacha-sr-shimmer {
    0% { background-position: -100% -100%; }
    100% { background-position: 100% 100%; }
  }
  /* SSR 등급 — 무지개 빛기둥 + 강한 폭발 + 스파클 */
  .gacha-result-card.rarity-ssr {
    box-shadow: 0 0 28px rgba(255, 212, 121, 0.8), inset 0 0 28px rgba(255, 215, 0, 0.25);
    animation: gacha-card-in 0.5s ease-out forwards, gacha-ssr-glow 1.5s ease-in-out infinite 0.5s;
  }
  .gacha-result-card.rarity-ssr::before {
    content: '';
    position: absolute; inset: -2px;
    background: linear-gradient(135deg,
      #ff66bb 0%, #ffd479 25%, #66ffcc 50%, #88aaff 75%, #ff66bb 100%);
    background-size: 400% 400%;
    animation: gacha-rainbow 4s linear infinite;
    z-index: -1;
    border-radius: 8px;
    filter: blur(4px);
  }
  .gacha-result-card.rarity-ssr::after {
    content: '✨';
    position: absolute;
    top: 6px; right: 6px;
    font-size: 22px;
    animation: gacha-ssr-spark 1.8s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes gacha-ssr-glow {
    0%, 100% { box-shadow: 0 0 28px rgba(255, 212, 121, 0.7), inset 0 0 28px rgba(255, 215, 0, 0.20); }
    50%      { box-shadow: 0 0 45px rgba(255, 180, 200, 1), 0 0 60px rgba(255, 212, 121, 0.6), inset 0 0 35px rgba(255, 215, 0, 0.35); }
  }
  @keyframes gacha-rainbow {
    0% { background-position: 0% 0%; }
    100% { background-position: 200% 200%; }
  }
  @keyframes gacha-ssr-spark {
    0%, 100% { transform: scale(1) rotate(0deg); opacity: 0.9; }
    50%      { transform: scale(1.4) rotate(180deg); opacity: 1; }
  }
  /* 카드 등장 지연 — 순차 등장 */
  .gacha-result-card:nth-child(1) { animation-delay: 0.0s, 0.5s; }
  .gacha-result-card:nth-child(2) { animation-delay: 0.1s, 0.6s; }
  .gacha-result-card:nth-child(3) { animation-delay: 0.2s, 0.7s; }
  .gacha-result-card:nth-child(4) { animation-delay: 0.3s, 0.8s; }
  .gacha-result-card:nth-child(5) { animation-delay: 0.4s, 0.9s; }
  .gacha-result-card:nth-child(6) { animation-delay: 0.5s, 1.0s; }
  .gacha-result-card:nth-child(7) { animation-delay: 0.6s, 1.1s; }
  .gacha-result-card:nth-child(8) { animation-delay: 0.7s, 1.2s; }
  .gacha-result-card:nth-child(9) { animation-delay: 0.8s, 1.3s; }
  .gacha-result-card:nth-child(10) { animation-delay: 0.9s, 1.4s; }
  /* 요약 + 액션 */
  .gacha-result-summary {
    text-align: center;
    font-size: 14px;
    color: #ffd479;
    padding: 6px 12px;
    background: #141822;
    border: 1px solid #2a2f3a;
    border-radius: 4px;
    min-height: 24px;
  }
  .gacha-result-actions {
    display: flex; gap: 12px;
    margin-top: 8px;
  }

  /* ===== 강화소 ===== */
  #shop { padding: 24px; align-items: stretch; }
  #shop-list {
    max-width: 900px; width: 100%; margin: 0 auto;
    overflow-y: auto; overflow-x: hidden; flex: 1;
    display: flex; flex-direction: column;
    gap: 6px;
    padding: 0 10px 24px;
    box-sizing: border-box;
  }
  /* 카테고리 헤더 */
  .shop-category-header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 14px 4px 6px;
    margin-top: 8px;
    border-bottom: 2px solid rgba(122,215,255,0.18);
  }
  .shop-category-header:first-child { margin-top: 0; }
  .shop-category-header .cat-label {
    font-size: 17px; font-weight: bold; letter-spacing: 1px;
  }
  .shop-category-header .cat-progress {
    color: #6b7283; font-size: 12px;
  }
  /* 카테고리 내 카드 그리드 — 2열 (모바일은 1열) */
  .shop-category-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 8px;
    margin-top: 4px;
    min-width: 0;
  }
  .shop-card { min-width: 0; }
  .shop-card .name, .shop-card .desc, .shop-card .lv {
    overflow-wrap: anywhere;
  }
  .shop-card {
    background: linear-gradient(180deg, #161b27, #11151e);
    border: 1px solid #2a2f3a;
    border-left: 4px solid #7ad7ff;
    border-radius: 9px;
    padding: 12px 14px;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 12px;
    align-items: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.3);
  }
  .shop-card.maxed { border-left-color: #52e07a; opacity: 0.75; }
  .shop-card .name { font-weight: bold; font-size: 14px; margin-bottom: 4px; }
  .shop-card .desc { font-size: 12px; color: #c8cdd8; line-height: 1.3; }
  .shop-card .lv {
    color: #9bb3ff; font-size: 11px; margin-top: 4px;
  }
  /* Lv 진행도 바 */
  .shop-lv-bar {
    height: 3px; background: #1a1f2b; margin-top: 5px; overflow: hidden;
    border-radius: 2px;
  }
  .shop-lv-bar > i {
    display: block; height: 100%; background: #7ad7ff;
    transition: width 0.3s;
  }
  .shop-buy {
    background: linear-gradient(180deg, #2a2410, #1d1908); color: #ffd479;
    border: 1px solid #ffd479; border-radius: 8px; padding: 10px 16px;
    font-family: inherit; font-size: 13px; cursor: pointer;
    touch-action: manipulation; min-width: 90px;
    transition: background .12s, box-shadow .12s, transform .08s;
  }
  .shop-buy:hover:not(:disabled) { background: linear-gradient(180deg, #3a3014, #2a230c); box-shadow: 0 0 12px rgba(255,212,121,0.3); }
  .shop-buy:active:not(:disabled) { transform: scale(0.97); }
  .shop-buy:disabled { opacity: 0.4; cursor: not-allowed; border-color: #3a4256; color: #6b7283; }
  .shop-buy.maxed { color: #52e07a; border-color: #52e07a; }
  .stardust-bar {
    text-align: center;
    margin: 0 auto 16px;
    max-width: 720px; width: 100%;
    padding: 10px;
    background: #141822;
    border: 1px solid #2a2f3a;
    color: #ffd479;
    font-size: 16px;
  }

  /* ===== 캐릭터 선택 화면 ===== */
  #characterScreen { padding: 24px; align-items: stretch; }
  /* === 모드 선택 카드 === */
  #modeScreen { padding: 0; align-items: stretch; }
  .mode-card {
    display: flex;
    align-items: center;
    gap: 18px;
    padding: 18px;
    background: linear-gradient(135deg, #1a1f2b 0%, #0f1219 100%);
    border: 2px solid #2a2f3a;
    border-radius: 12px;
    cursor: pointer;
    color: inherit;
    text-align: left;
    font: inherit;
    transition: border-color 0.15s, transform 0.1s, box-shadow 0.15s;
    box-sizing: border-box;
    width: 100%;
  }
  .mode-card:hover {
    border-color: #7ad7ff;
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(122,215,255,0.15);
  }
  .mode-card:active { transform: translateY(0); }
  .mode-card[data-mode="defense"]:hover { border-color: #ffd479; box-shadow: 0 6px 20px rgba(255,212,121,0.2); }
  .mode-icon { font-size: 48px; flex-shrink: 0; }
  .mode-info { flex: 1; min-width: 0; }
  .mode-name { font-size: 18px; font-weight: bold; color: #fff; margin-bottom: 4px; }
  .mode-desc { font-size: 12px; color: #cfd6e3; line-height: 1.4; margin-bottom: 8px; }
  .mode-tags { display: flex; gap: 6px; flex-wrap: wrap; }
  .mode-tag {
    font-size: 10px; padding: 3px 8px; background: rgba(122,215,255,0.12);
    border: 1px solid rgba(122,215,255,0.3); border-radius: 10px; color: #88c4d8;
  }
  .mode-card[data-mode="defense"] .mode-tag {
    background: rgba(255,212,121,0.12);
    border-color: rgba(255,212,121,0.3);
    color: #ddc080;
  }
  #character-list {
    max-width: 960px; width: 100%; margin: 0 auto;
    overflow-y: auto; flex: 1;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 10px;
    /* 하단 패딩 — 플로팅 시작 버튼 (약 130px + safe-area) 와 겹치지 않게 */
    padding: 0 10px calc(150px + env(safe-area-inset-bottom));
  }
  /* 🎴 v221 — 캐릭터 선택 hero 카드 (가챠 결과 카드 톤 — 큰 버전) */
  .char-hero {
    --card-color: #7ad7ff;
    position: relative;
    max-width: 960px; width: 100%;
    margin: 0 auto 12px;
    padding: 0;
    background: linear-gradient(135deg,
      color-mix(in srgb, var(--card-color) 12%, #0b0d12) 0%,
      #0c0e18 60%,
      #0a0d14 100%);
    border: 2px solid var(--card-color);
    border-radius: 12px;
    display: flex; align-items: stretch; gap: 0;
    box-sizing: border-box;
    overflow: hidden;
    box-shadow: 0 4px 16px rgba(0,0,0,0.4), 0 0 14px color-mix(in srgb, var(--card-color) 28%, transparent);
  }
  /* 상단 라벨 띠 — 가챠 카드 rarity tag 매치 */
  .char-hero .hero-rarity-tag {
    position: absolute;
    top: 0; left: 0;
    padding: 3px 10px;
    background: var(--card-color);
    color: #0b0d12;
    font-size: 11px;
    font-weight: bold;
    letter-spacing: 2px;
    border-radius: 0 0 6px 0;
    z-index: 1;
  }
  .char-hero .hero-img-wrap {
    width: 120px; height: 120px;
    flex-shrink: 0;
    background: radial-gradient(circle at center,
      color-mix(in srgb, var(--card-color) 25%, #0b0d12),
      #0b0d12);
    display: flex; align-items: center; justify-content: center;
    border-right: 1px solid color-mix(in srgb, var(--card-color) 30%, transparent);
  }
  .char-hero .hero-img-wrap img {
    width: 100%; height: 100%;
    object-fit: contain;       /* 🐛 잘림 방지 — 일러스트 전체 표시 (cover 크롭 X) */
    image-rendering: auto;     /* 🐛 일러스트는 부드럽게 (pixelated 도트화 X) */
  }
  .char-hero .hero-info {
    flex: 1; min-width: 0;
    display: flex; flex-direction: column;
    gap: 6px;
    padding: 14px 18px;
    justify-content: center;
  }
  .char-hero .hero-label {
    font-size: 10px;
    color: color-mix(in srgb, var(--card-color) 70%, #9aa3b3);
    letter-spacing: 3px;
    text-transform: uppercase;
    font-weight: bold;
  }
  .char-hero .hero-name-row {
    display: flex; align-items: center; gap: 10px;
    flex-wrap: wrap;
  }
  .char-hero .hero-name {
    font-size: 22px;
    font-weight: bold;
    text-shadow: 0 0 12px color-mix(in srgb, var(--card-color) 50%, transparent);
  }
  .char-hero .hero-desc {
    font-size: 12px;
    color: #cfd6e3;
    line-height: 1.5;
  }
  .char-hero .hero-stars {
    font-size: 14px;
    letter-spacing: 1px;
  }
  /* 모바일 좁은 화면에선 컴팩트 */
  @media (max-width: 480px) {
    .char-hero .hero-img-wrap { width: 88px; height: 88px; }
    .char-hero .hero-info { padding: 10px 12px; }
    .char-hero .hero-name { font-size: 18px; }
  }
  .char-card {
    background: linear-gradient(180deg, #161b27, #11151e);
    border: 2px solid #2a2f3a;
    border-left: 4px solid #7ad7ff;
    border-radius: 10px;
    padding: 10px 12px;
    cursor: pointer;
    transition: background .12s, border-color .12s, transform .1s, box-shadow .12s;
    box-shadow: 0 2px 8px rgba(0,0,0,0.3);
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }
  /* 카드 내부 — 헤더 (이미지 + 이름 + 등급) */
  .char-card .char-header {
    display: flex;
    align-items: center;
    gap: 8px;
    min-width: 0;
  }
  .char-card .char-portrait-wrap {
    width: 44px; height: 44px;
    flex-shrink: 0;
    background: #000;
    border-radius: 4px;
    overflow: hidden;
  }
  .char-card .char-portrait-wrap img {
    width: 100%; height: 100%;
    object-fit: contain;
    image-rendering: pixelated;
  }
  .char-card .char-header-text {
    flex: 1; min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .char-card .char-name-row {
    display: flex; align-items: center; gap: 6px;
    min-width: 0;
  }
  .char-card .char-rarity-pill {
    flex-shrink: 0;
    padding: 1px 6px;
    border: 1px solid;
    border-radius: 3px;
    font-size: 10px;
    font-weight: bold;
    letter-spacing: 1px;
  }
  .char-card:hover:not(.locked) { background: linear-gradient(180deg, #1c222f, #141823); transform: translateY(-1px); box-shadow: 0 5px 16px rgba(0,0,0,0.42), 0 0 10px rgba(122,215,255,0.1); }
  .char-card.selected { border-color: #ffd479; background: linear-gradient(180deg, #1c2333, #141a28); box-shadow: 0 2px 9px rgba(0,0,0,0.32), 0 0 12px rgba(255,212,121,0.18); }
  /* v232 — 잠긴 캐릭터: 정보 가독성은 유지하되 시각적으로 "흑백 vs 컬러" 명확 구분 */
  .char-card.locked {
    cursor: default;
    filter: grayscale(0.85) brightness(0.8);   /* 카드 전체 흑백 처리 */
    border-left-color: #3a4256 !important;     /* 등급색 무력화 */
  }
  .char-card.locked .char-portrait-wrap {
    filter: grayscale(1) brightness(0.6);      /* 포트레이트는 완전 흑백 */
  }
  .char-card.locked:hover { filter: grayscale(0.75) brightness(0.9); }   /* 호버 시 살짝 밝아짐 (관심 표시) */
  .char-card .char-name { font-size: 14px; font-weight: bold; flex: 1; min-width: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .char-card .char-desc { font-size: 12px; color: #c8cdd8; line-height: 1.4; word-break: keep-all; }
  .char-card .char-lock { font-size: 11px; color: #ff8a98; margin-top: 6px; }
  .char-card .char-selected-tag { font-size: 11px; color: #ffd479; margin-top: 6px; font-weight: bold; }
  .char-card .char-start { font-size: 11px; color: #9aa3b3; margin-top: 6px; }
  .char-card .char-passive { font-size: 11px; color: #b0b8c5; margin-top: 4px; line-height: 1.45; }
  .char-card .char-passive b { color: #cfd6e3; font-weight: 700; }

  /* ===== 업적 화면 ===== */
  #achievementsScreen { padding: 24px; align-items: stretch; }
  #achievements-list {
    max-width: 720px; width: 100%; margin: 0 auto;
    overflow-y: auto; flex: 1;
    padding-bottom: 24px;
  }
  .achievement-summary {
    text-align: center;
    margin: 0 auto 14px;
    max-width: 720px; width: 100%;
    padding: 12px;
    background: linear-gradient(180deg, #161b27, #11151e);
    border: 1px solid #2a2f3a; border-radius: 10px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.28);
    color: #c8cdd8;
    font-size: 14px;
  }
  .achievement-summary b { color: #ffd479; }
  .achievement-card {
    display: flex; gap: 14px;
    align-items: center;
    background: linear-gradient(180deg, #161b27, #11151e);
    border: 1px solid #2a2f3a;
    border-left: 4px solid #4a5163;
    border-radius: 9px;
    padding: 14px;
    margin-bottom: 6px;
    box-shadow: 0 2px 7px rgba(0,0,0,0.28);
  }
  .achievement-card.unlocked {
    border-left-color: #ffd479;
    background: linear-gradient(180deg, #1c2333, #141a28);
    box-shadow: 0 2px 9px rgba(0,0,0,0.32), 0 0 9px rgba(255,212,121,0.1);
  }
  .achievement-card .ach-icon {
    font-size: 22px;
    width: 36px;
    text-align: center;
    color: #4a5163;
  }
  .achievement-card.unlocked .ach-icon { color: #ffd479; }
  .achievement-card .ach-info { flex: 1; min-width: 0; }
  .achievement-card .ach-name {
    font-weight: bold;
    font-size: 14px;
    margin-bottom: 4px;
    color: #9aa3b3;
  }
  .achievement-card.unlocked .ach-name { color: #ffd479; }
  .achievement-card .ach-desc {
    color: #c8cdd8;
    font-size: 12px;
    margin-bottom: 6px;
  }
  .achievement-card .ach-rewards {
    display: flex; gap: 6px;
    flex-wrap: wrap;
  }
  .achievement-card .ach-reward {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 3px 9px;
    font-size: 11px;
    border-radius: 6px;
  }
  .achievement-card .ach-reward b { font-weight: 800; opacity: 0.92; }
  .achievement-card .ach-reward img { width: 16px; height: 16px; flex-shrink: 0; image-rendering: auto; border-radius: 3px; }
  .achievement-card .ach-reward .ach-rico {
    width: 16px; height: 16px; flex-shrink: 0;
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: 3px; font-size: 10px; font-weight: bold; line-height: 1;
  }
  .achievement-card .ach-reward.stardust {
    background: #2a2410; color: #ffd479;
    border: 1px solid #5a4a18;
  }
  .achievement-card .ach-reward.character {
    background: #122030; color: #88c8ff;
    border: 1px solid #2a4878;
  }
  .achievement-card .ach-reward.ability {
    background: #102818; color: #88dda8;
    border: 1px solid #2a5a3a;
  }
  .achievement-card .ach-reward.title {
    background: #2a1e10; color: #ffd479;
    border: 1px solid #5a4220;
  }
  .achievement-card .ach-reward.relic {
    background: #1a1428; color: #c084ff;
    border: 1px solid #5a4080;
  }
  .achievement-card .ach-reward.title .rank-title {
    margin-right: 0;  /* title chip 안에선 여백 제거 */
  }
  .achievement-card .ach-reward.count {
    background: #182030; color: #9bb3ff;
    border: 1px solid #2a4878;
  }
  .achievement-card.repeat {
    border-left-color: #88c8ff;
  }
  .achievement-card.repeat.unlocked {
    background: #102030;
    border-left-color: #88c8ff;
  }
  .achievement-card.repeat .ach-icon { color: #88c8ff; }
  .achievement-card.repeat .ach-name { color: #88c8ff; }
  .ach-section-header {
    color: #9aa3b3;
    font-size: 12px;
    letter-spacing: 3px;
    padding: 14px 4px 6px;
    margin-top: 8px;
    border-bottom: 1px solid rgba(122,215,255,0.14);
  }
  .ach-section-header:first-child { margin-top: 0; }

  /* ===== 🎁 게임 결과 — 획득 보상 패널 + 메뉴 NEW 뱃지 (v322) ===== */
  .menu-btn, .menu-btn-grid, .nickname-display { position: relative; }
  .menu-new-dot {
    position: absolute; top: 6px; right: 8px;
    min-width: 17px; height: 17px; padding: 0 4px; box-sizing: border-box;
    background: linear-gradient(180deg, #ff6b7c, #d83a4e); color: #fff;
    font-size: 10px; font-weight: 900; line-height: 17px; text-align: center;
    border-radius: 999px; box-shadow: 0 0 8px rgba(255,91,110,0.6), 0 1px 3px rgba(0,0,0,0.4);
    pointer-events: none; z-index: 3;
    animation: newDotPulse 1.6s ease-in-out infinite;
  }
  @keyframes newDotPulse { 0%,100%{transform:scale(1);} 50%{transform:scale(1.16);} }
  .nickname-display .menu-new-dot { top: 50%; right: 8px; transform: translateY(-50%); animation: none; }

  .reward-overlay {
    display: none; position: fixed; inset: 0; z-index: 9993;
    background: rgba(6,8,14,0.74); backdrop-filter: blur(3px);
    align-items: center; justify-content: center; padding: 14px; box-sizing: border-box;
  }
  .reward-overlay.show { display: flex; }
  .reward-card {
    width: 100%; max-width: 440px; max-height: 86vh; display: flex; flex-direction: column;
    background: linear-gradient(180deg, #1a2030, #11151e);
    border: 1px solid #3a4256; border-radius: 16px;
    box-shadow: 0 18px 60px rgba(0,0,0,0.6), inset 0 1px 0 rgba(255,255,255,0.05), 0 0 40px rgba(122,215,255,0.08);
    padding: 18px 16px 14px; box-sizing: border-box;
    animation: rewardIn .34s cubic-bezier(.2,.9,.3,1.12);
  }
  @keyframes rewardIn { from{opacity:0; transform:translateY(16px) scale(.95);} to{opacity:1; transform:none;} }
  .reward-head { text-align: center; margin-bottom: 12px; }
  .reward-title { font-size: 19px; font-weight: bold; color: #ffd479; text-shadow: 0 0 16px rgba(255,212,121,0.4); }
  .reward-sub { display: block; font-size: 12px; color: #9aa3b3; margin-top: 4px; }
  .reward-body { overflow-y: auto; display: flex; flex-direction: column; gap: 8px; padding: 2px; }
  .reward-row {
    display: flex; align-items: center; gap: 12px; padding: 11px 12px;
    background: linear-gradient(180deg, #1c2333, #141a28); border: 1px solid #2a3140;
    border-radius: 11px; position: relative;
  }
  .reward-row.hot { border-color: rgba(255,212,121,0.5); box-shadow: 0 0 14px rgba(255,212,121,0.13); }
  .reward-ico {
    width: 46px; height: 46px; flex-shrink: 0; border-radius: 10px; overflow: hidden;
    display: flex; align-items: center; justify-content: center; font-size: 24px;
    background: #0e1320; border: 1px solid #2a3140;
  }
  .reward-ico img { width: 100%; height: 100%; object-fit: cover; image-rendering: pixelated; }
  .reward-txt { flex: 1; min-width: 0; }
  .reward-kind { font-size: 10px; letter-spacing: 1px; color: #7ad7ff; font-weight: bold; }
  .reward-name { font-size: 15px; font-weight: bold; color: #e8eaf0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .reward-name .title-plate, .reward-name .title-emblem { vertical-align: middle; }
  .reward-desc { font-size: 11px; color: #9aa3b3; line-height: 1.35; white-space: normal; }
  .reward-new {
    position: absolute; top: -7px; right: -6px;
    background: linear-gradient(180deg, #ff6b7c, #d83a4e); color: #fff;
    font-size: 9px; font-weight: 900; letter-spacing: .5px; padding: 2px 7px; border-radius: 999px;
    box-shadow: 0 2px 8px rgba(255,91,110,0.5); transform: rotate(7deg);
  }
  .reward-currency { display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; margin-top: 6px; }
  .reward-currency span {
    font-size: 12px; color: #cfd6e3; background: #0e1320;
    border: 1px solid #2a3140; border-radius: 999px; padding: 6px 13px;
  }
  .reward-ok {
    margin-top: 14px; padding: 13px; width: 100%;
    font-family: inherit; font-size: 15px; font-weight: bold; color: #0b0d12; cursor: pointer;
    background: linear-gradient(180deg, #ffe49a, #ffd479); border: none; border-radius: 11px;
    box-shadow: 0 4px 14px rgba(255,212,121,0.3); transition: transform .08s, box-shadow .12s;
    touch-action: manipulation;
  }
  .reward-ok:hover { box-shadow: 0 6px 20px rgba(255,212,121,0.45); }
  .reward-ok:active { transform: scale(.98); }
  .reward-foot { text-align: center; font-size: 11px; color: #6b7283; margin-top: 9px; }
</style>
</head>
<body>
<!-- ===== 메뉴 화면 (v218 — 그룹화 + 그리드 레이아웃) ===== -->
<div id="menu" class="screen show">
  <!-- 상단 좌측: 캐시 업데이트 -->
  <button id="updateCacheBtn" class="update-cache-btn" title="캐시만 지우고 최신 버전으로 업데이트 (저장 데이터는 유지)">🔄 업데이트</button>
  <!-- 상단 우측: 설정 (데이터 초기화/동기화 모음) -->
  <button id="settingsBtn" class="settings-btn" title="설정">⚙</button>
  <!-- 🎰 가챠 원형 버튼 — 우측 하단 -->
  <button id="gachaBtn" class="gacha-circle-btn" title="🎰 가챠">
    <span id="gachaCircleEmoji">🎰</span>
    <div class="gacha-circle-label">가챠</div>
  </button>

  <!-- 타이틀 -->
  <h1>DOT DEFENSE</h1>
  <div class="subtitle">픽셀 디펜스 · 능력 조합 빌더</div>

  <!-- 메인 컨테이너 — 그룹별 정렬 -->
  <div class="menu-main">
    <!-- 🎴 현재 선택 캐릭터 미리보기 (클릭 시 캐릭터 선택 화면으로) -->
    <div id="menu-char-preview" class="menu-char-preview" title="클릭하여 캐릭터 변경">
      <!-- 동적으로 채워짐 — refreshMenuCharPreview() -->
    </div>

    <!-- 메인 CTA: 이어하기 / 빠른 시작 / 새 게임 / 난이도 -->
    <div class="menu-cta-group">
      <button id="continueBtn" class="menu-btn menu-btn-primary" style="display:none;">▶ 이어하기</button>
      <button id="startBtn" class="menu-btn menu-btn-primary">▶ 새 게임</button>
      <!-- 빠른 시작 미리보기 (마지막 설정 표시) -->
      <div id="quickStartPreview" class="quick-start-preview" style="display:none;"></div>
      <!-- 설정 변경 (빠른 시작 가능할 때만 노출) -->
      <button id="changeSettingsBtn" class="menu-btn menu-btn-secondary" style="display:none;">⚙ 캐릭터 변경</button>
      <button id="difficultyBtn" class="menu-btn menu-btn-secondary" style="display:none">⚡ 난이도: 기본</button>
    </div>

    <!-- 그룹 1: 진행 관리 -->
    <div class="menu-section">
      <div class="menu-section-label">⭐ 진행 관리</div>
      <div class="menu-grid">
        <button id="shopBtn" class="menu-btn menu-btn-grid">⭐ 강화소</button>
        <button id="abilityPermaBtn" class="menu-btn menu-btn-grid">🌟 능력 영구</button>
      </div>
    </div>

    <!-- 그룹 2: 컬렉션 -->
    <div class="menu-section">
      <div class="menu-section-label">📚 컬렉션</div>
      <div class="menu-grid menu-grid-2">
        <button id="codexBtn" class="menu-btn menu-btn-grid">도감</button>
        <button id="charCollectionBtn" class="menu-btn menu-btn-grid">캐릭터</button>
      </div>
      <div class="menu-grid menu-grid-2">
        <button id="achievementsBtn" class="menu-btn menu-btn-grid">업적</button>
        <button id="recordsBtn" class="menu-btn menu-btn-grid">기록</button>
      </div>
    </div>

    <!-- 글로벌 랭킹 (와이드) -->
    <button id="globalRankBtn" class="menu-btn menu-btn-wide">🌐 글로벌 랭킹</button>
  </div>

  <!-- 닉네임 (하단) -->
  <div class="nickname-display" id="nickname-display" title="클릭하여 닉네임 변경">
    닉네임: <span id="nickname-text">-</span> ✏️
  </div>
</div>

<!-- ===== 설정 모달 (v218) — 데이터 초기화 / 동기화 / 캐시 새로고침 모음 ===== -->
<div id="settingsModal" class="settings-modal-overlay" style="display:none;">
  <div class="settings-modal-content">
    <div class="settings-modal-header">
      <h3>⚙ 설정</h3>
      <button id="settingsModalClose" class="settings-modal-close" title="닫기">✕</button>
    </div>
    <div class="settings-modal-body">
      <!-- 동기화 섹션 (로그인 상태에서만) -->
      <div class="settings-section" id="settingsSyncSection" style="display:none;">
        <div class="settings-section-title">🔄 데이터 동기화</div>
        <div class="settings-section-desc">현재 진행도를 서버에 강제 푸시 + 풀</div>
        <button id="manualSyncBtn" class="settings-action-btn">🔄 지금 동기화</button>
      </div>
      <!-- 위험 영역 -->
      <div class="settings-section danger">
        <div class="settings-section-title">⚠ 위험 영역</div>
        <div class="settings-section-desc">개발/디버그용. 로컬 데이터 삭제 시 서버는 유지됨.</div>
        <button id="resetDataBtn" class="settings-action-btn danger" title="개발용: 모든 저장 데이터 초기화">🗑 데이터 초기화</button>
      </div>
    </div>
  </div>
</div>

<!-- ===== 🔐 인증 모달 (회원가입 / 로그인) ===== -->
<div id="authModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.95); z-index:9997; align-items:center; justify-content:center; padding:8px; box-sizing:border-box;">
  <div style="background:linear-gradient(180deg,#1d2333,#161a24); border:2px solid #7ad7ff; border-radius:14px; max-width:420px; width:100%; max-height:calc(100dvh - 16px); display:flex; flex-direction:column; box-shadow:0 0 44px rgba(122,215,255,0.4), 0 12px 40px rgba(0,0,0,0.5); overflow:hidden;">
    <div style="padding:16px 18px 8px; flex-shrink:0;">
      <div style="font-size:20px; font-weight:bold; color:#7ad7ff; margin-bottom:6px; text-shadow:0 0 12px rgba(122,215,255,0.4);">🔐 계정</div>
      <div id="authModalSubtitle" style="color:#9aa3b3; font-size:12px; line-height:1.4;">
        같은 기기에선 자동 로그인됩니다. 비밀번호는 다른 기기 접속 시 필요.
      </div>
    </div>
    <!-- 탭 -->
    <div style="display:flex; padding:0 18px; gap:0; flex-shrink:0; border-bottom:1px solid #2a2f3a;">
      <button id="authTabSignup" class="auth-tab active" data-tab="signup">새 계정</button>
      <button id="authTabLogin" class="auth-tab" data-tab="login">기존 계정 불러오기</button>
    </div>
    <div style="padding:14px 18px; flex:1 1 auto; overflow-y:auto; min-height:0;">
      <!-- 회원가입 폼 -->
      <div id="authSignupForm">
        <input id="signupNicknameInput" type="text" maxlength="12" placeholder="닉네임 (1~12자, 한/영/숫자)" class="auth-input" />
        <input id="signupPasswordInput" type="password" placeholder="비밀번호 (4자 이상)" class="auth-input" />
        <input id="signupPasswordConfirm" type="password" placeholder="비밀번호 확인" class="auth-input" />
        <div id="signupError" class="auth-err"></div>
        <button id="signupSubmitBtn" class="auth-btn primary">계정 만들기</button>
      </div>
      <!-- 로그인 폼 -->
      <div id="authLoginForm" style="display:none;">
        <input id="loginNicknameInput" type="text" maxlength="12" placeholder="닉네임" class="auth-input" />
        <input id="loginPasswordInput" type="password" placeholder="비밀번호" class="auth-input" />
        <div id="loginError" class="auth-err"></div>
        <button id="loginSubmitBtn" class="auth-btn primary">로그인 + 데이터 불러오기</button>
        <div style="color:#ff8866; font-size:11px; margin-top:10px; line-height:1.4; padding:8px; background:#241510; border-radius:4px;">
          ⚠ 로그인 시 현재 기기의 데이터는 서버 데이터로 <b>덮어쓰여집니다</b>. 진행 중인 게스트 데이터가 있다면 먼저 회원가입을 권장.
        </div>
      </div>
    </div>
    <div style="padding:10px 18px 14px; flex-shrink:0; border-top:1px solid #2a2f3a; display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:8px;">
      <button id="authSkipBtn" style="background:none; color:#5a5f6a; font-size:11px; border:none; cursor:pointer; text-decoration:underline;">닉네임만 설정 (백업 없음) →</button>
      <button id="authCloseBtn" style="background:#2a2f3a; color:#9aa3b3; border:1px solid #3a4256; padding:6px 14px; border-radius:6px; font-size:12px; cursor:pointer; display:none;">닫기</button>
    </div>
  </div>
</div>

<style>
  .auth-tab {
    flex: 1; background: none; border: none;
    color: #5a5f6a; padding: 10px 8px;
    font-family: inherit; font-size: 13px; cursor: pointer;
    border-bottom: 2px solid transparent;
    transition: color 0.15s, border-color 0.15s;
  }
  .auth-tab:hover { color: #aaeaff; }
  .auth-tab.active {
    color: #7ad7ff; border-bottom-color: #7ad7ff; font-weight: bold;
    text-shadow: 0 0 8px rgba(122,215,255,0.4);
  }
  .auth-input {
    width: 100%; box-sizing: border-box;
    background: #0d1119; border: 1.5px solid #2a2f3a;
    color: #fff; padding: 11px 14px; border-radius: 8px;
    font-family: inherit; font-size: 14px; margin-bottom: 8px;
    transition: border-color .12s, box-shadow .12s;
  }
  .auth-input:focus { outline: none; border-color: #7ad7ff; box-shadow: 0 0 0 3px rgba(122,215,255,0.15); }
  .auth-err {
    color: #ff8888; font-size: 12px; margin-bottom: 8px;
    min-height: 16px; line-height: 1.4;
  }
  .auth-btn {
    width: 100%; padding: 12px;
    border: none; border-radius: 8px;
    font-family: inherit; font-size: 14px; font-weight: bold;
    cursor: pointer; transition: opacity 0.15s;
  }
  .auth-btn.primary {
    background: linear-gradient(180deg, #8fe0ff, #5cc4f0); color: #042230;
    box-shadow: 0 3px 12px rgba(122,215,255,0.3);
    transition: filter .12s, box-shadow .12s, opacity .15s;
  }
  .auth-btn.primary:hover:not(:disabled) { filter: brightness(1.08); box-shadow: 0 4px 16px rgba(122,215,255,0.45); }
  .auth-btn.primary:disabled { opacity: 0.5; cursor: not-allowed; }
</style>

<!-- ===== 🌐 닉네임 입력 모달 (첫 실행 시) ===== -->
<div id="nicknameModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.92); z-index:9998; align-items:center; justify-content:center; padding:8px; box-sizing:border-box;">
  <div style="position:relative; background:linear-gradient(180deg,#1d2333,#161a24); border:2px solid #7ad7ff; border-radius:14px; max-width:420px; width:100%; max-height:100vh; max-height:calc(100dvh - 16px); display:flex; flex-direction:column; box-shadow:0 0 44px rgba(122,215,255,0.4), 0 12px 40px rgba(0,0,0,0.5); overflow:hidden;">
    <!-- 닫기 X (첫 실행 시 숨김) -->
    <button id="nicknameCloseBtn" title="닫기" style="position:absolute; top:10px; right:10px; z-index:2; width:30px; height:30px; padding:0; display:flex; align-items:center; justify-content:center; background:#222a3a; color:#9aa3b3; border:1px solid #3a4256; border-radius:8px; font-size:16px; cursor:pointer; transition:background .12s,color .12s;">✕</button>
    <!-- 헤더 (고정) -->
    <div style="padding:14px 44px 6px 18px; flex-shrink:0;">
      <div style="font-size:20px; font-weight:bold; color:#7ad7ff; margin-bottom:4px; text-shadow:0 0 12px rgba(122,215,255,0.4);">👋 환영합니다!</div>
      <div style="color:#9aa3b3; font-size:12px; line-height:1.4;">
        글로벌 랭킹에 표시될 닉네임을 정해주세요. (1~12자, 한/영/숫자)
      </div>
    </div>
    <!-- 본문 (스크롤 가능) -->
    <div style="padding:6px 18px; flex:1 1 auto; overflow-y:auto; min-height:0;">
      <input id="nicknameInput" type="text" maxlength="12" placeholder="예: 도트마스터" style="width:100%; box-sizing:border-box; background:#0f1219; border:2px solid #2a2f3a; color:#fff; padding:10px 14px; border-radius:8px; font-family:inherit; font-size:17px; text-align:center; margin-bottom:8px;" />
      <div id="nicknameError" style="color:#ff8888; font-size:12px; margin-bottom:8px; min-height:16px;"></div>
      <div>
        <div style="color:#ffd479; font-size:13px; font-weight:bold; margin-bottom:6px;">🏆 칭호 (업적 달성으로 해금)</div>
        <div id="title-preview" style="background:#0f1219; border:1px solid #2a2f3a; border-radius:6px; padding:8px 12px; margin-bottom:6px; text-align:center; font-size:14px; min-height:22px;"></div>
        <div id="title-unlock-hint" style="background:#241510; border:1px solid #aa5530; border-radius:6px; padding:8px 12px; margin-bottom:6px; font-size:12px; color:#ffaa88; line-height:1.5; display:none;"></div>
        <div id="title-picker" class="title-picker-grid"></div>
      </div>
    </div>
    <!-- 푸터 (고정) -->
    <div style="padding:10px 18px 14px; flex-shrink:0; border-top:1px solid #2a2f3a;">
      <button id="nicknameSubmit" style="width:100%; background:#7ad7ff; color:#000; border:none; padding:12px; border-radius:8px; font-weight:bold; font-size:15px; cursor:pointer;">확인</button>
      <div id="nicknameAccountActions" style="display:flex; gap:6px; margin-top:8px; flex-wrap:wrap; justify-content:center;">
        <!-- 계정 상태에 따라 동적 표시 -->
      </div>
      <div style="color:#5a5f6a; font-size:11px; margin-top:8px; text-align:center;">
        나중에 메뉴 하단에서 변경 가능
      </div>
    </div>
  </div>
</div>

<!-- ===== 🌐 글로벌 랭킹 화면 ===== -->
<div id="globalRankScreen" class="screen">
  <div class="codex-header">
    <h2>🌐 글로벌 랭킹</h2>
    <button id="globalRankBack" class="codex-back">← 메뉴로</button>
  </div>
  <!-- 시즌 정보 + 리셋 카운트다운 -->
  <div id="rank-season-bar" style="background:linear-gradient(90deg,#1a1a2e,#1a2030); border:1px solid #3a4250; border-radius:8px; margin:0 12px 10px; padding:10px 14px; display:flex; justify-content:space-between; align-items:center; gap:10px; flex-wrap:wrap; font-size:13px;">
    <div>
      <span style="color:#ffd479; font-weight:bold;">🏁 주간 시즌</span>
      <span style="color:#7a8090; font-size:11px; margin-left:6px;">매주 월 00:00 KST 리셋</span>
    </div>
    <div id="rank-countdown" style="color:#88ccff; font-weight:bold; font-family:monospace;">- - - - -</div>
  </div>
  <!-- 🏰 모드별 탭 — 디펜스 비활성화로 클래식 단일 (탭 숨김) -->
  <div class="codex-tabs" id="rank-mode-tabs" style="display:none; margin:0 auto 8px; justify-content:center; max-width:520px;">
    <button class="codex-tab active" data-rankmode="standard">⚔️ 클래식</button>
  </div>
  <div id="globalRank-status" style="text-align:center; color:#9aa3b3; padding:30px; font-size:14px;">불러오는 중...</div>
  <div id="globalRank-top10" style="padding:0 12px;"></div>
  <div id="globalRank-divider" style="display:none; height:1px; background:#2a2f3a; margin:18px 12px 12px; position:relative;">
    <span style="position:absolute; top:-9px; left:50%; transform:translateX(-50%); background:#0b0d12; padding:0 12px; color:#9aa3b3; font-size:11px;">⋯ 중간 생략 ⋯</span>
  </div>
  <div id="globalRank-me" style="padding:0 12px 20px;"></div>
  <div style="text-align:center; padding:14px; color:#5a5f6a; font-size:11px; display:flex; gap:8px; justify-content:center; flex-wrap:wrap;">
    <button id="globalRankRefresh" style="background:#1a1f2b; border:1px solid #2a2f3a; color:#9aa3b3; padding:8px 18px; border-radius:6px; cursor:pointer; font-family:inherit; font-size:12px;">🔄 새로고침</button>
    <!-- 마지막 게임 결과 강제 재제출 (랭킹 갱신이 안 보일 때) -->
    <button id="globalRankResubmit" style="background:#1a2418; border:1px solid #88ff88; color:#88ff88; padding:8px 18px; border-radius:6px; cursor:pointer; font-family:inherit; font-size:12px;">🔁 내 점수 재제출</button>
  </div>
</div>

<style>
  /* 랭킹 행 스타일 */
  .rank-row {
    display: grid;
    /* minmax(0, 1fr) → 1fr 컬럼이 콘텐츠보다 작게 줄어들 수 있어야 ellipsis 작동 */
    /* 점수 컬럼은 min 140px 확보 (천만 자리 + 콤마 + 패딩 여유) */
    grid-template-columns: 40px minmax(0, 1fr) minmax(140px, max-content);
    gap: 10px;
    align-items: center;
    padding: 10px 12px;
    border-bottom: 1px solid #1a1f2b;
    font-size: 13px;
  }
  .rank-row:hover { background: rgba(122,215,255,0.04); }
  .rank-row.me {
    background: linear-gradient(90deg, rgba(122,215,255,0.18), rgba(122,215,255,0.06));
    border: 2px solid #7ad7ff;
    border-radius: 6px;
    box-shadow: 0 0 12px rgba(122,215,255,0.3);
    padding: 12px;
  }
  .rank-num {
    text-align: center; font-weight: bold; font-size: 15px;
    color: #9aa3b3;
  }
  .rank-row.rank-1 .rank-num { color: #ffd479; font-size: 18px; }
  .rank-row.rank-2 .rank-num { color: #c8d4e6; font-size: 17px; }
  .rank-row.rank-3 .rank-num { color: #cd8856; font-size: 16px; }
  .rank-info {
    display: flex; flex-direction: column; gap: 2px;
    min-width: 0;          /* grid item이 콘텐츠 폭만큼 강제 확장하는 것 방지 */
    overflow: hidden;
  }
  /* 칭호 + 닉네임 한 줄 — 길면 폰트 자동 축소, 그래도 넘치면 말줄임표 */
  .rank-nick {
    font-weight: bold; color: #fff; font-size: 14px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 0;
  }
  /* 닉네임 길이 기반 자동 축소 (모바일 가독성 유지) */
  .rank-nick.len-md  { font-size: 12.5px; letter-spacing: -0.2px; }   /* 8~11자 */
  .rank-nick.len-lg  { font-size: 11px;   letter-spacing: -0.3px; }   /* 12~15자 */
  .rank-nick.len-xl  { font-size: 10px;   letter-spacing: -0.4px; }   /* 16자+ */
  /* 칭호도 닉네임과 같이 축소 (잘림 방지) */
  .rank-nick.len-md .rank-title { font-size: 11px; }
  .rank-nick.len-lg .rank-title { font-size: 10px; margin-right: 3px; }
  .rank-nick.len-xl .rank-title { font-size: 9px;  margin-right: 2px; }
  .rank-nick > span { display: inline; }
  .rank-meta {
    font-size: 11px; color: #7a8090;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .rank-score {
    text-align: right;
    font-weight: bold; color: #ffd479; font-size: 15px;
    white-space: nowrap;
    padding-left: 6px;
    min-width: 130px;   /* 보장 폭 — 어떤 큰 점수도 안 잘림 */
  }

  /* === 캐릭터 선택 화면 플로팅 시작 버튼 === */
  .char-floating-bar {
    position: fixed;
    left: 0; right: 0;
    bottom: 0;
    background: linear-gradient(to top, #0b0d12 50%, rgba(11,13,18,0.85) 90%, rgba(11,13,18,0));
    padding: 18px 16px calc(18px + env(safe-area-inset-bottom));
    z-index: 50;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    pointer-events: none;
  }
  .char-floating-bar > * { pointer-events: auto; }
  .char-floating-selected {
    font-size: 13px;
    color: #9aa3b3;
    background: rgba(20,24,34,0.9);
    padding: 6px 14px;
    border-radius: 14px;
    border: 1px solid #2a2f3a;
  }
  .char-start-btn {
    background: linear-gradient(135deg, #7ad7ff, #5870a0);
    color: #0b0d12;
    border: 2px solid #aae6ff;
    border-radius: 12px;
    padding: 14px 36px;
    font-family: inherit;
    font-size: 17px;
    font-weight: bold;
    cursor: pointer;
    box-shadow: 0 6px 24px rgba(122,215,255,0.5);
    transition: transform 0.1s, box-shadow 0.15s;
    min-width: 240px;
    touch-action: manipulation;
  }
  .char-start-btn:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(122,215,255,0.7);
  }
  .char-start-btn:active:not(:disabled) { transform: translateY(0); }
  .char-start-btn:disabled {
    background: #2a2f3a;
    color: #5a5f6a;
    border-color: #3a4256;
    box-shadow: none;
    cursor: not-allowed;
  }

  /* === 🏆 칭호 스타일 === */
  .rank-title { font-size: 12px; margin-right: 4px; }
  .title-normal { color: var(--c, #9aa3b3); }
  .title-bold {
    color: var(--c, #ffd479);
    font-weight: bold;
  }
  .title-glow {
    color: var(--c, #ffd479);
    font-weight: bold;
    text-shadow: 0 0 6px var(--c, #ffd479), 0 0 12px var(--c, #ffd479);
  }
  .title-rainbow {
    font-weight: bold;
    background: linear-gradient(90deg,
      #ff8888, #ffaa44, #ffe070, #88ff88,
      #88ccff, #c084ff, #ff80ff, #ff8888);
    background-size: 200% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    animation: title-rainbow-shift 3s linear infinite;
    text-shadow: none;
    filter: drop-shadow(0 0 4px rgba(255,200,255,0.5));
  }
  @keyframes title-rainbow-shift {
    from { background-position: 0% 0; }
    to   { background-position: 200% 0; }
  }
  /* === 🎖 칭호 커스텀 엠블럼(SVG) + 플레이트 배너 === */
  .title-emblem {
    display: inline-block; width: 13px; height: 13px; line-height: 0;
    vertical-align: -0.16em; margin-right: 2px;
    color: var(--c, #ffe0a0);   /* rainbow 칭호(색 없음)는 골드 폴백 */
  }
  .title-emblem svg { width: 100%; height: 100%; display: block; fill: currentColor; }
  .title-glow .title-emblem, .title-plate .title-emblem { filter: drop-shadow(0 0 3px currentColor); }
  /* 좁은 행에서 엠블럼 축소 (줄 높이 안 깨지게) */
  .rank-nick.len-md .title-emblem { width: 12px; height: 12px; }
  .rank-nick.len-lg .title-emblem { width: 11px; height: 11px; }
  .rank-nick.len-xl .title-emblem { width: 10px; height: 10px; }
  /* 고등급 플레이트 — 텍스트를 감싸는 장식 배너 (compact + 줄바꿈 금지) */
  .title-plate {
    display: inline-flex; align-items: center; gap: 3px;
    padding: 0 8px; border-radius: 5px; font-size: 11px; line-height: 1.2;
    background: linear-gradient(180deg, #1c2030, #0b0d15);
    border: 1px solid var(--c, #c8a8ff);
    box-shadow: 0 0 7px var(--c, #c8a8ff), inset 0 1px 0 rgba(255,255,255,0.12);
    position: relative; vertical-align: middle; white-space: nowrap; max-width: 100%;
    margin: 0 7px 0 5px;   /* 끝 보석(±3px 돌출)이 옆 텍스트(닉네임 등) 침범 방지 */
  }
  .rank-nick > span.title-plate { display: inline-flex; }   /* .rank-nick>span{display:inline} 덮어쓰기 방지 */
  .title-plate .tp-text { font-weight: bold; white-space: nowrap; line-height: 1; position: relative; top: 0.5px; }   /* 한글 광학 세로중앙 보정 */
  /* 양끝 다이아 보석 장식 */
  .title-plate::before, .title-plate::after {
    content: ''; position: absolute; top: 50%; width: 5px; height: 5px;
    background: var(--c, #c8a8ff); transform: translateY(-50%) rotate(45deg);
    box-shadow: 0 0 5px var(--c, #c8a8ff);
  }
  .title-plate::before { left: -3px; }
  .title-plate::after  { right: -3px; }
  /* 🎀 카테고리별 모양 차별화 */
  /* 캐릭터 — 둥근 + 다이아 (기본 장식 유지) */
  .title-plate.tp-char { border-radius: 6px; }
  /* 난이도(승천/초월) — 각진 계급장 + 화살촉 양끝 */
  .title-plate.tp-rank { border-radius: 2px; }
  .title-plate.tp-rank::before, .title-plate.tp-rank::after { width: 7px; height: 9px; transform: translateY(-50%); box-shadow: none; }
  .title-plate.tp-rank::before { left: -5px; clip-path: polygon(100% 0, 0 50%, 100% 100%); }
  .title-plate.tp-rank::after  { right: -5px; clip-path: polygon(0 0, 100% 50%, 0 100%); }
  /* 시즌 — 알약(메달 리본) + 원형 장식 */
  .title-plate.tp-season { border-radius: 999px; padding: 1px 12px; }
  .title-plate.tp-season::before, .title-plate.tp-season::after { width: 6px; height: 6px; border-radius: 50%; transform: translateY(-50%); }
  /* 그랜드 — 둥근 + (무지개 글로우는 tp-rainbow가 담당) */
  .title-plate.tp-grand { border-radius: 6px; }
  /* 🌌 초월 — 프리미엄 우주 플레이트 (둥근 + 깊은 보라 + 4각 별 + 강한 다중 글로우) */
  .title-plate.tp-trans {
    border-radius: 7px;
    background: linear-gradient(180deg, #261b40, #0a0612);
    border: 1px solid var(--c, #b48cf0);
    box-shadow: 0 0 9px var(--c, #9966ff), 0 0 17px rgba(150,100,255,0.32), inset 0 1px 0 rgba(255,255,255,0.18), inset 0 0 8px rgba(150,100,255,0.18);
  }
  .title-plate.tp-trans::before, .title-plate.tp-trans::after {
    width: 8px; height: 8px; box-shadow: none; transform: translateY(-50%);
    clip-path: polygon(50% 0, 60% 40%, 100% 50%, 60% 60%, 50% 100%, 40% 60%, 0 50%, 40% 40%);
  }
  .title-plate.tp-trans::before { left: -5px; }
  .title-plate.tp-trans::after  { right: -5px; }
  /* 무지개 등급 플레이트 — 색만 담당 (모양은 위 변형이 결정, 순서상 색 override 마지막) */
  .title-plate.tp-rainbow {
    border-color: #ff9ad6;
    box-shadow: 0 0 8px rgba(255,140,220,0.7), inset 0 1px 0 rgba(255,255,255,0.14);
  }
  .title-plate.tp-rainbow::before, .title-plate.tp-rainbow::after { background: #ff9ad6; box-shadow: 0 0 5px #ff9ad6; }

  /* === 칭호 선택 그리드 (닉네임 모달용) === */
  .title-picker-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(112px, 1fr));
    gap: 7px;
    /* max-height 제거 — 부모 (모달 본문)가 스크롤 처리하므로 그리드 자체는 자유롭게 늘어남 */
    padding: 8px;
    background: #0c0e15;
    border: 1px solid #232838;
    border-radius: 10px;
  }
  .title-pick-item {
    background: linear-gradient(180deg, #1e2433, #161a25);
    border: 1.5px solid #2c3242;
    border-radius: 8px;
    padding: 8px;
    cursor: pointer;
    font-size: 11px;
    text-align: center;
    transition: border-color 0.15s, background 0.15s, transform 0.1s, box-shadow 0.15s;
    display: flex; align-items: center; justify-content: center; min-height: 30px;
  }
  .title-pick-item:hover {
    background: linear-gradient(180deg, #2a3245, #1e2433);
    border-color: #4a546a; transform: translateY(-1px);
    box-shadow: 0 3px 10px rgba(0,0,0,0.4), 0 0 10px rgba(122,215,255,0.12);
  }
  .title-pick-item.selected {
    border-color: var(--gold, #ffd479);
    background: linear-gradient(180deg, #2e2814, #1d1a0c);
    box-shadow: 0 0 12px rgba(255,212,121,0.35), inset 0 1px 0 rgba(255,255,255,0.08);
  }
  .title-pick-item.locked {
    opacity: 0.32;
    cursor: not-allowed;
    filter: grayscale(0.6);
  }
  .title-pick-item.locked:hover { transform: none; box-shadow: none; }
</style>

<!-- ===== 🎮 치트 모달 (123123123 입력 시) ===== -->
<!-- ===== 💎 유물 상세 모달 (게임 중 보유 유물 확인) ===== -->
<!-- 🏰 TD 모드 타워 배치/강화 인라인 패널 (게임 흐름 방해 없도록 하단 고정) -->
<!-- pointer-events:none on outer + auto on inner → 게임 캔버스 클릭은 패널을 통과해 적/슬롯에 닿음 -->
<div id="tdTowerModal" style="display:none; position:fixed; left:0; right:0; bottom:0; background:transparent; pointer-events:none; z-index:9992; align-items:flex-end; justify-content:center; padding:0 6px 6px; box-sizing:border-box;">
  <div style="background:rgba(11, 13, 20, 0.96); border:2px solid #7ad7ff; border-radius:10px 10px 6px 6px; max-width:520px; width:100%; max-height:240px; display:flex; flex-direction:column; box-shadow:0 -4px 20px rgba(122,215,255,0.25); overflow:hidden; pointer-events:auto;">
    <div style="padding:8px 12px; flex-shrink:0; display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid #2a2f3a;">
      <div id="td-modal-title" style="font-size:13px; font-weight:bold; color:#7ad7ff;">🏰 타워 배치</div>
      <button id="tdTowerModalClose" style="background:#2a2f3a; color:#fff; border:none; padding:4px 10px; border-radius:6px; cursor:pointer; font-size:11px;">✕</button>
    </div>
    <div id="td-tower-list" style="padding:8px 10px; flex:1; overflow-y:auto;"></div>
  </div>
</div>

<div id="dmgStatsModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.85); z-index:9991; align-items:center; justify-content:center; padding:10px; box-sizing:border-box;">
  <div style="background:#0b0d14; border:2px solid #88e0ff; border-radius:10px; max-width:600px; width:100%; max-height:90vh; max-height:90dvh; display:flex; flex-direction:column; box-shadow:0 0 40px rgba(136,224,255,0.3); overflow:hidden;">
    <div style="padding:14px 16px; flex-shrink:0; display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid #2a2f3a;">
      <div style="font-size:18px; font-weight:bold; color:#88e0ff;">📊 능력별 데미지 통계</div>
      <button id="dmgStatsClose" style="background:#2a2f3a; color:#fff; border:none; padding:6px 12px; border-radius:6px; cursor:pointer; font-size:12px;">✕ 닫기</button>
    </div>
    <div id="dmg-stats-list" style="padding:12px; flex:1; overflow-y:auto;"></div>
  </div>
</div>

<div id="relicDetailModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.85); z-index:9990; align-items:center; justify-content:center; padding:10px; box-sizing:border-box;">
  <div style="background:#0b0d14; border:2px solid #ffd479; border-radius:10px; max-width:520px; width:100%; max-height:90vh; max-height:90dvh; display:flex; flex-direction:column; box-shadow:0 0 40px rgba(255,212,121,0.3); overflow:hidden;">
    <!-- 헤더 -->
    <div style="padding:14px 16px; flex-shrink:0; display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid #2a2f3a;">
      <div style="font-size:18px; font-weight:bold; color:#ffd479;">보유 유물 <span id="relic-detail-count" style="font-size:13px; color:#9aa3b3; font-weight:normal;">0개</span></div>
      <button id="relicDetailClose" style="background:#2a2f3a; color:#fff; border:none; padding:6px 12px; border-radius:6px; cursor:pointer; font-size:12px;">✕ 닫기</button>
    </div>
    <!-- 본문 -->
    <div id="relic-detail-list" style="padding:12px; flex:1; overflow-y:auto;"></div>
  </div>
</div>

<div id="cheatModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.85); z-index:9999; align-items:center; justify-content:center; padding:20px;">
  <div style="background:#1a1f2b; border:2px solid #ffd479; border-radius:12px; padding:24px; max-width:480px; width:100%; max-height:90vh; overflow:auto; box-shadow:0 0 40px rgba(255,212,121,0.4);">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px;">
      <div style="font-size:22px; font-weight:bold; color:#ffd479;">🎮 치트 모드</div>
      <button id="cheatClose" style="background:none; border:1px solid #5a5f6a; color:#fff; padding:4px 12px; border-radius:6px; cursor:pointer;">✕</button>
    </div>
    <div style="color:#9aa3b3; font-size:12px; margin-bottom:16px; line-height:1.5;">
      💎 결정 = 가챠 재화 · ⭐ 스타더스트 = 강화소 재화
    </div>

    <!-- 빠른 버튼 -->
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-bottom:16px;">
      <button class="cheat-btn" data-cmd="crystal 10">💎 +10 결정</button>
      <button class="cheat-btn" data-cmd="crystal 100">💎 +100 결정</button>
      <button class="cheat-btn" data-cmd="crystal 1000">💎 +1000 결정</button>
      <button class="cheat-btn" data-cmd="stardust 10000">⭐ +10000 스타더스트</button>
      <button class="cheat-btn" data-cmd="stardust 100000">⭐ +100000 스타더스트</button>
      <button class="cheat-btn" data-cmd="unlock all" style="grid-column:1/-1;">🔓 모든 가챠 캐릭터 해금</button>
    </div>

    <!-- 커스텀 명령어 입력 -->
    <div style="margin-top:12px;">
      <div style="color:#9aa3b3; font-size:11px; margin-bottom:6px;">커스텀 명령어 (Enter):</div>
      <div style="display:flex; gap:6px;">
        <input id="cheatInput" type="text" placeholder="예: crystal 50" style="flex:1; background:#0f1219; border:1px solid #2a2f3a; color:#fff; padding:8px 10px; border-radius:6px; font-family:inherit; font-size:14px;" />
        <button id="cheatSubmit" style="background:#ffd479; color:#000; border:none; padding:8px 16px; border-radius:6px; font-weight:bold; cursor:pointer;">적용</button>
      </div>
      <div style="color:#7a8090; font-size:10px; margin-top:6px; line-height:1.4;">
        명령어: <code style="color:#ffd479">crystal N</code> · <code style="color:#ffd479">stardust N</code> · <code style="color:#ffd479">unlock all</code> · <code style="color:#ffd479">unlock sakura/luna/aria/misaki/marine/solar/gravitas</code>
      </div>
    </div>

    <!-- 피드백 -->
    <div id="cheatFeedback" style="margin-top:14px; padding:10px 12px; background:#0f1219; border-radius:6px; font-size:13px; color:#88ff88; min-height:20px; line-height:1.4;"></div>
  </div>
</div>

<style>
  .cheat-btn {
    background:#0f1219; border:1px solid #2a2f3a; color:#fff;
    padding:10px 12px; border-radius:6px; cursor:pointer;
    font-family:inherit; font-size:13px; transition:background 0.15s;
  }
  .cheat-btn:hover { background:#2a2f3a; }
  .cheat-btn:active { background:#ffd479; color:#000; }
</style>

