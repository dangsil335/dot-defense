          ? `rgba(${Math.min(255,AR+60)},${Math.min(255,AG+60)},${Math.min(255,AB+60)},1)`
          : `rgba(${(AR*0.4)|0},${(AG*0.35)|0},${(AB*0.5)|0},1)`;
        const bg = g.createRadialGradient(x, y, 0, x, y, rad);
        bg.addColorStop(0, tint); bg.addColorStop(1, 'rgba(0,0,0,0)');
        g.fillStyle = bg; g.beginPath(); g.arc(x, y, rad, 0, Math.PI*2); g.fill();
      }
      g.globalAlpha = 1; g.globalCompositeOperation = 'source-over';
      g.restore();
      // 미세 그레인 (평평함 제거 = 도트 질감)
      const id = g.getImageData(0, 0, D, D), d = id.data;
      for (let i = 0; i < d.length; i += 4) { if (d[i+3] === 0) continue; const nz = (Math.random()*2-1)*6; d[i]+=nz; d[i+1]+=nz; d[i+2]+=nz; }
      g.putImageData(id, 0, 0);
      // 림 페이드 — 중앙 불투명 → 가장자리 투명 (우주로 자연스럽게 녹음)
