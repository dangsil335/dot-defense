    },
    // 🌐 triple — Asc 10+: 3갈래 (좌/중/우 동시 압박)
    triple: {
      name: '삼중 미로',
      paths: [
        // 경로 A — 좌측 (col 0~2)
        [
          {col:0, row:0}, {col:1, row:0}, {col:2, row:0},
          {col:2, row:1}, {col:2, row:2}, {col:2, row:3}, {col:2, row:4},
          {col:1, row:4}, {col:0, row:4},
          {col:0, row:5}, {col:0, row:6}, {col:0, row:7}, {col:0, row:8},
          {col:1, row:8}, {col:2, row:8}, {col:3, row:8}, {col:4, row:8},
          {col:4, row:9}, {col:5, row:9},
        ],
        // 경로 B — 중앙 (col 3~6)
        [
          {col:4, row:0}, {col:5, row:0},
          {col:5, row:1}, {col:5, row:2}, {col:5, row:3}, {col:5, row:4}, {col:5, row:5}, {col:5, row:6}, {col:5, row:7}, {col:5, row:8},
          {col:5, row:9},
        ],
        // 경로 C — 우측 (col 7~9, A의 거울)
        [
          {col:9, row:0}, {col:8, row:0}, {col:7, row:0},
          {col:7, row:1}, {col:7, row:2}, {col:7, row:3}, {col:7, row:4},
          {col:8, row:4}, {col:9, row:4},
          {col:9, row:5}, {col:9, row:6}, {col:9, row:7}, {col:9, row:8},
          {col:8, row:8}, {col:7, row:8}, {col:6, row:8},
          {col:6, row:9}, {col:5, row:9},
        ],
      ],
      slots: [
        // 좌측 경로 사이
        {col:0, row:1}, {col:1, row:1}, {col:3, row:1},
        {col:0, row:2}, {col:1, row:2}, {col:3, row:2},
        {col:0, row:3}, {col:1, row:3}, {col:3, row:3},
        {col:3, row:4},
        {col:1, row:5}, {col:2, row:5}, {col:3, row:5},
        {col:1, row:6}, {col:2, row:6}, {col:3, row:6},
        {col:1, row:7}, {col:2, row:7}, {col:3, row:7},
        // 우측 경로 사이
        {col:6, row:1}, {col:8, row:1}, {col:9, row:1},
        {col:6, row:2}, {col:8, row:2}, {col:9, row:2},
        {col:6, row:3}, {col:8, row:3}, {col:9, row:3},
        {col:6, row:4},
        {col:6, row:5}, {col:7, row:5}, {col:8, row:5},
        {col:6, row:6}, {col:7, row:6}, {col:8, row:6},
        {col:6, row:7}, {col:7, row:7}, {col:8, row:7},
      ],
      core: {col:5, row:9},
      spawns: [{col:0, row:0}, {col:4, row:0}, {col:9, row:0}],
    },
  };
  // 🏰 승천별 맵 선택 — Asc 0~4: basic, 5~9: twin, 10+: triple
  function pickMapForAscension(asc) {
    if (asc >= 10) return 'triple';
    if (asc >= 5)  return 'twin';
    return 'basic';
  }
  // 셀 → 적이 이 셀에 도달했을 때의 path index 찾기
  function pathIndexOf(map, cell) {
    for (let i = 0; i < map.path.length; i++) {
      if (map.path[i].col === cell.col && map.path[i].row === cell.row) return i;
    }
    return -1;
  }
  // 현재 active 맵 가져오기 (state.tdMapId 기준, 기본 'basic')
  function getActiveTDMap() {
    return TD_MAPS[(state && state.tdMapId) || 'basic'] || TD_MAPS.basic;
  }
  const MAX_ALIVE_BASE = 80;    // 기본값 — 강화/승천으로 동적 변경
  function getMaxAlive() {
    let v = MAX_ALIVE_BASE;
    if (typeof state !== 'undefined' && state && state.metaMods) v += (state.metaMods.maxAliveBonus || 0);
    if (typeof state !== 'undefined' && state && state.asc) v += (state.asc.maxAliveAdd || 0);
    if (typeof state !== 'undefined' && state && state.relicEffects) v += (state.relicEffects.maxAliveAdd || 0);
    return v;
  }
  const MAX_ALIVE = MAX_ALIVE_BASE;  // 레거시 참조용 (UI 등에서 사용)
  const MAX_SLOTS = 6;          // 액티브/패시브 각각 6칸씩
  function maxActiveSlots() {
    const metaBonus = (META.upgrades && META.upgrades.extraSlot) || 0;
    const charMod = (typeof state !== 'undefined' && state && state.metaMods) ? (state.metaMods.slotMod || 0) : 0;
    const relicMod = (typeof state !== 'undefined' && state && state.relicEffects) ? (state.relicEffects.bonusActiveSlot || 0) : 0;
    return MAX_SLOTS + metaBonus + charMod + relicMod;
  }
  function maxPassiveSlots() {
    const relicMod = (typeof state !== 'undefined' && state && state.relicEffects) ? (state.relicEffects.bonusPassiveSlot || 0) : 0;
    const metaMod = (typeof state !== 'undefined' && state && state.metaMods) ? (state.metaMods.passiveSlotBonus || 0) : 0;  // 🆕 v280
    return MAX_SLOTS + relicMod + metaMod;
  }
  function activeCount() { return state.tower.abilities.filter(a => !ABILITY_DEFS[a.id].isPassive).length; }
  function passiveCount() { return state.tower.abilities.filter(a => ABILITY_DEFS[a.id].isPassive).length; }
  // 역호환
  function activeMaxSlots() { return maxActiveSlots(); }
  const FPS = 60;
  // 🚀 좌표·색이 전부 상수인 로컬좌표 그라디언트 캐시 (탄환 트레일류 — 매 프레임 재생성 제거)
  let _missileTrailG = null, _blackholeGlowG = null, _tornadoCoreG = null, _eclipseCoronaG = null;

  // ===== 능력 정의 (각 능력은 독립적인 공격) =====
  // 각 ability instance: { id, level, cooldown, ...각 ability별 상태 }
  // def에는 init(ab), tick(ab), draw?(ab) 메서드가 있음
  const ABILITY_DEFS = {
    shot: {
      name: '샷', baseCost: 30, color: '#ffe28a',
      desc: lv => `단발 유도 · DMG ${1+lv}`,
      init(ab) { ab.cooldown = 0; },
      tick(ab) {
        if (--ab.cooldown > 0) return;
        const target = findNearestEnemy(ARENA_R + 50);
        if (!target) return;
        const [tx, ty] = enemyXY(target);
        const ang = Math.atan2(ty - CY, tx - CX);
        fireBullet(ang, 1 + ab.level, '#ffe28a', target);
        ab.cooldown = 22;
      },
    },
    multi: {
      name: '멀티샷', baseCost: 45, color: '#7ad7ff',
      desc: lv => `${2+lv}발 V편대 · 가운데 유도 · DMG ${1+Math.floor(lv/2)}`,
      // 가운데 탄환만 적을 유도. 사이드 탄환은 가운데 탄환의 진행 방향을
      // 추종하여 함께 휜다 (편대 비행처럼).
      init(ab) { ab.cooldown = 20; },
      tick(ab) {
        if (--ab.cooldown > 0) return;
        const target = findNearestEnemy(ARENA_R + 50);
        if (!target) return;
        const [tx, ty] = enemyXY(target);
        const base = Math.atan2(ty - CY, tx - CX);
        const n = 2 + ab.level;
        const spread = Math.min(Math.PI * 0.5, (n - 1) * 0.22);
        const leaderIdx = Math.floor((n - 1) / 2);
        const leaderOff = n === 1 ? 0 : (-spread/2 + spread * (leaderIdx/(n-1)));
        const dmg = 1 + Math.floor(ab.level / 2);

        // 가운데 (리더 — 유도)
        const leader = fireBullet(base + leaderOff, dmg, '#7ad7ff', target);

        // 사이드 (리더 방향 따라감)
        for (let i = 0; i < n; i++) {
          if (i === leaderIdx) continue;
          const off = n === 1 ? 0 : (-spread/2 + spread * (i/(n-1)));
          fireBullet(base + off, dmg, '#7ad7ff', null, leader, off - leaderOff);
        }
        ab.cooldown = Math.max(35, 55 - ab.level * 2);
      },
    },
    nova: {
      name: '노바', baseCost: 55, color: '#b890ff',
      desc: lv => `확장 충격파 · DMG ${3+lv*2}`,
      // 충격파가 중심에서 외곽까지 퍼지며, 지나가는 모든 적에 1회 데미지
      init(ab) { ab.cooldown = 60; ab.waves = []; },
      tick(ab) {
        const dmg = 3 + ab.level * 2;
        for (const w of ab.waves) {
          w.prevR = w.r;
          w.r += 5;
          for (const e of state.enemies) {
            if (w.hit.has(e) || e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            const d = Math.hypot(ex - CX, ey - CY);
            if (d >= w.prevR - 10 && d <= w.r + 10) {
              damageEnemy(e, dmg);
              spawnParticles(ex, ey, '#b890ff', 3);
              w.hit.add(e);
            }
          }
        }
        compactInPlace(ab.waves, _predWaveArena);
        if (--ab.cooldown > 0) return;
        ab.waves.push({ r: CORE_R, prevR: CORE_R, hit: new Set() });
        ab.cooldown = Math.max(50, 110 - ab.level * 6);
      },
      draw(ab) {
        // 💥 충격파 — 두꺼운 발광 밴드 + 밝은 선행 엣지 (퍼지는 에너지 파동)
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        for (const w of ab.waves) {
          const prog = w.r / (ARENA_R + 30), a = Math.max(0, 1 - prog);
          // 링 밴드(도넛) — 차분한 보라
          ctx.globalAlpha = a * 0.28; ctx.fillStyle = '#9a6ce0';
          ctx.beginPath(); ctx.arc(CX, CY, w.r, 0, Math.PI*2);
          ctx.arc(CX, CY, Math.max(0, w.r - 9 - prog*16), 0, Math.PI*2, true); ctx.fill('evenodd');
          // 선행 엣지 (부드러운 라벤더 — 흰빛/눈부심 완화)
          ctx.globalAlpha = a * 0.5; ctx.strokeStyle = '#c8b0f0'; ctx.lineWidth = 2 + (1-prog)*2.2;
          ctx.beginPath(); ctx.arc(CX, CY, w.r, 0, Math.PI*2); ctx.stroke();
        }
        ctx.restore(); ctx.globalAlpha = 1;
      },
    },
    laser: {
      name: '레이저', baseCost: 50, color: '#ff5b6e',
      desc: lv => `관통 빔 · DMG ${4+lv*2}`,
      // 가장 가까운 적 방향으로 아레나 끝까지 관통 빔
      init(ab) { ab.cooldown = 30; ab.fx = 0; ab.fxAng = 0; },
      tick(ab) {
        if (ab.fx > 0) ab.fx--;
        if (--ab.cooldown > 0) return;
        const target = findNearestEnemy(ARENA_R + 50);
        if (!target) return;
        const [tx, ty] = enemyXY(target);
        const ang = Math.atan2(ty - CY, tx - CX);
        const len = ARENA_R + 20;
        const ex = CX + Math.cos(ang) * len;
        const ey = CY + Math.sin(ang) * len;
        const dmg = 4 + ab.level * 2;
        for (const e of state.enemies) {
          const [px, py] = enemyXY(e);
          if (distPointSegmentSq(px, py, CX, CY, ex, ey) < 144) {
            damageEnemy(e, dmg);
            spawnParticles(px, py, '#ff5b6e', 3);
          }
        }
        ab.fxAng = ang;
        ab.fx = 8;
        // 쿨다운도 레벨 따라 단축 (75 고정 → max 35, lv8=43)
        ab.cooldown = Math.max(35, 75 - ab.level * 4);
      },
      draw(ab) {
        if (ab.fx <= 0) return;
        const len = ARENA_R + 20;
        const ex = CX + Math.cos(ab.fxAng) * len;
        const ey = CY + Math.sin(ab.fxAng) * len;
        glowBeam(CX, CY, ex, ey, '#ff5b6e', 6, ab.fx / 8);   // 🌟 글로우 빔
      },
    },
    chain: {
      name: '체인', baseCost: 50, color: '#88e0ff',
      desc: lv => `${2+lv}회 연쇄 · DMG ${4+lv*2}`,
      // 첫 타깃은 아레나 전역에서, 연쇄는 인근 적으로
      init(ab) { ab.cooldown = 40; ab.fx = 0; ab.fxPoints = []; },
      tick(ab) {
        if (ab.fx > 0) ab.fx--;
        if (--ab.cooldown > 0) return;
        const first = findNearestEnemy(ARENA_R + 50);
        if (!first) return;
        const dmg = 4 + ab.level * 2;   // ⚖ v269 — DMG 10→20 (연쇄 광역 효율 ↑)
        const chains = 2 + ab.level;
        const hit = new Set();
        let current = first;
        const points = [[CX, CY]];
        for (let i = 0; i < chains; i++) {
          if (!current) break;
          const [cx, cy] = enemyXY(current);
          points.push([cx, cy]);
          damageEnemy(current, dmg);
          spawnParticles(cx, cy, '#88e0ff', 3);
          hit.add(current);
          let next = null, best = 140*140;
          for (const e of state.enemies) {
            if (hit.has(e) || e.hp <= 0) continue;
            const [ex2, ey2] = enemyXY(e);
            const d2 = (ex2-cx)*(ex2-cx) + (ey2-cy)*(ey2-cy);
            if (d2 < best) { best = d2; next = e; }
          }
          current = next;
        }
        ab.fxPoints = points;
        ab.fx = 10;
        ab.cooldown = Math.max(60, 90 - ab.level * 4);
      },
      draw(ab) {
        if (ab.fx <= 0 || ab.fxPoints.length < 2) return;
        const a = ab.fx / 10;
        const path = () => {
          ctx.beginPath(); ctx.moveTo(ab.fxPoints[0][0], ab.fxPoints[0][1]);
          for (let i = 1; i < ab.fxPoints.length; i++) {
            const p1 = ab.fxPoints[i-1], p2 = ab.fxPoints[i];
            const mx = (p1[0]+p2[0])/2 + (Math.random()-0.5)*12, my = (p1[1]+p2[1])/2 + (Math.random()-0.5)*12;
            ctx.lineTo(mx, my); ctx.lineTo(p2[0], p2[1]);
          }
        };
        ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.lineCap = 'round'; ctx.lineJoin = 'round';
        ctx.globalAlpha = a * 0.4; ctx.strokeStyle = '#88e0ff'; ctx.lineWidth = 7; path(); ctx.stroke();   // 글로우
        ctx.globalAlpha = a;       ctx.strokeStyle = '#e0f6ff'; ctx.lineWidth = 2; path(); ctx.stroke();   // 코어
        ctx.restore(); ctx.globalAlpha = 1;
      },
    },
    orbital: {
      name: '오비탈', baseCost: 60, color: '#52e07a',
      desc: lv => `${1+lv}개 위성 · 적 거리 추적 궤도 · DMG ${3+lv*2}`,
      // 모든 위성이 같은 반경에서 회전. 그 반경이 "가장 가까운 적까지의 거리"를
      // 부드럽게 추종 → 궤도가 숨쉬듯 늘었다 줄었다 함.
      // 레벨업: +1 위성, +회전속도
      init(ab) {
        ab.angle = 0;
        ab.radius = 150;
        ab.targetRadius = 150;
        ab.hits = new Map();
      },
      tick(ab) {
        // 회전 속도: 레벨업 시 가속
        const rotSpeed = 0.030 + ab.level * 0.008;
        ab.angle += rotSpeed;

        // 가장 가까운 적까지의 거리로 궤도 반경 목표값 갱신
        const target = findNearestEnemy(ARENA_R + 100);
        if (target) {
          const [tx, ty] = enemyXY(target);
          ab.targetRadius = Math.hypot(tx - CX, ty - CY);
        }
        // 부드러운 추종 (프레임당 5% 접근)
        ab.radius += (ab.targetRadius - ab.radius) * 0.05;
        ab.radius = Math.max(50, Math.min(ARENA_R - 10, ab.radius));

        // 히트 쿨다운 정리
        for (const [e, cd] of ab.hits) {
          if (cd <= 1 || e.hp <= 0) ab.hits.delete(e);
          else ab.hits.set(e, cd - 1);
        }

        const count = 1 + ab.level;
        // ⚖ v263 — 딜량 상향: DMG 1+lv → 3+lv*2 (회전검날 등 동급 회전 능력 수준)
        //   + 히트 쿨다운 30 → 18 프레임 (같은 적 재타격 빈도 ↑)
        const dmg = 3 + ab.level * 2;
        for (let i = 0; i < count; i++) {
          const a = ab.angle + (Math.PI * 2 / count) * i;
          const ox = CX + Math.cos(a) * ab.radius;
          const oy = CY + Math.sin(a) * ab.radius;
          for (const e of state.enemies) {
            if (ab.hits.has(e) || e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            const rr = e.size + 6;
            if ((ox-ex)*(ox-ex) + (oy-ey)*(oy-ey) < rr*rr) {
              damageEnemy(e, dmg);
              ab.hits.set(e, 18);
              spawnParticles(ex, ey, '#52e07a', 3);
            }
          }
        }
      },
      draw(ab) {
        const count = 1 + ab.level;
        // 궤도 path (옅게)
        ctx.strokeStyle = 'rgba(82, 224, 122, 0.12)';
        ctx.lineWidth = 1;
        ctx.beginPath(); ctx.arc(CX, CY, ab.radius, 0, Math.PI*2); ctx.stroke();
        // 위성 (발광 오브)
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        const _sp = getGlowSprite('#52e07a');
        for (let i = 0; i < count; i++) {
          const a = ab.angle + (Math.PI * 2 / count) * i;
          const ox = CX + Math.cos(a) * ab.radius, oy = CY + Math.sin(a) * ab.radius;
          ctx.drawImage(_sp, ox - 10, oy - 10, 20, 20);
        }
        ctx.restore();
      },
    },

    // ===== 추가 확장 능력 =====
    scatter: {
      name: '산탄', baseCost: 40, color: '#ffb070',
      desc: lv => `${6+lv*2}방향 산탄 · DMG ${2+lv*2}`,
      // 클래식: 360° 균등 분산. TD: 가장 가까운 적 방향의 좁은 cone (효율 보정).
      init(ab) { ab.cooldown = 30; },
      tick(ab) {
        if (--ab.cooldown > 0) return;
        const n = 6 + ab.level * 2;
        const dmg = 2 + ab.level * 2;
        // 🏰 TD: 좁은 부채꼴 (0.45π ≈ 81°) · 클래식: 360°
        const narrowSpread = Math.PI * 0.45;
        tdDirectionalFan(n, narrowSpread, (ang) => {
          fireBullet(ang, dmg, '#ffb070', null);
        });
        ab.cooldown = Math.max(35, 80 - ab.level * 5);
      },
    },

    mortar: {
      name: '포격', baseCost: 70, color: '#ff7050',
      desc: lv => `광역 폭격 · DMG ${3+lv*2} · 반경 ${50+lv*8}`,
      // 최고 HP 적 위치에 폭격 → 그 주변 모든 적에 데미지.
      init(ab) { ab.cooldown = 90; ab.fx = []; },
      tick(ab) {
        for (const e of ab.fx) e.life--;
        compactInPlace(ab.fx, _alivePredLife);
        if (--ab.cooldown > 0) return;
        let target = null, best = -1;
        for (const e of state.enemies) {
          { const _s = e.isBoss ? e.hp + 1e9 : e.hp; if (_s > best) { best = _s; target = e; } }
        }
        if (!target) return;
        const [tx, ty] = enemyXY(target);
        const radius = 50 + ab.level * 8;
        const dmg = 3 + ab.level * 2;
        for (const e of state.enemies) {
          if (e.hp <= 0) continue;
          const [ex, ey] = enemyXY(e);
          if ((ex-tx)*(ex-tx) + (ey-ty)*(ey-ty) < radius*radius) {
            damageEnemy(e, dmg);
            spawnParticles(ex, ey, '#ff7050', 4);
          }
        }
        ab.fx.push({ x: tx, y: ty, r: radius, life: 20 });
        ab.cooldown = Math.max(50, 100 - ab.level * 6);
      },
      draw(ab) {
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        for (const e of ab.fx) {
          const t = 1 - e.life / 20, a = e.life / 20;
          ctx.globalAlpha = a * 0.4; ctx.fillStyle = '#ff7050';
          ctx.beginPath(); ctx.arc(e.x, e.y, e.r*t, 0, Math.PI*2); ctx.arc(e.x, e.y, Math.max(0, e.r*t - 8), 0, Math.PI*2, true); ctx.fill('evenodd');
          ctx.globalAlpha = a; ctx.strokeStyle = '#ffd0a0'; ctx.lineWidth = 3; ctx.beginPath(); ctx.arc(e.x, e.y, e.r*t, 0, Math.PI*2); ctx.stroke();
        }
        ctx.restore(); ctx.globalAlpha = 1;
      },
    },

    thunder: {
      name: '벼락', baseCost: 60, color: '#ffe070',
      desc: lv => `${1+lv}마리 무작위 낙뢰 · DMG ${3+lv*2}`,
      // 매 발동마다 무작위 적 N마리에 하늘에서 낙뢰.
      init(ab) { ab.cooldown = 50; ab.bolts = []; },
      tick(ab) {
        for (const b of ab.bolts) b.life--;
        compactInPlace(ab.bolts, _alivePredLife);
        if (--ab.cooldown > 0) return;
        const count = 1 + ab.level;
        const dmg = 3 + ab.level * 2;
        const pool = state.enemies.filter(e => e.hp > 0);
        for (let i = 0; i < count && pool.length > 0; i++) {
          const idx = Math.floor(Math.random() * pool.length);
          const target = pool.splice(idx, 1)[0];
          const [tx, ty] = enemyXY(target);
          damageEnemy(target, dmg);
          spawnParticles(tx, ty, '#ffe070', 6);
          ab.bolts.push({ x: tx, y: ty, life: 10 });
        }
        ab.cooldown = Math.max(25, 60 - ab.level * 5);
      },
      draw(ab) {
        ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.lineCap = 'round'; ctx.lineJoin = 'round';
        for (const b of ab.bolts) {
          const a = b.life / 10, seg = 6;
          const zig = () => { ctx.beginPath(); ctx.moveTo(b.x, 0);
            for (let i = 1; i <= seg; i++) { const yy = (b.y/seg)*i; const xx = b.x + (i < seg ? (Math.sin(i*9.7 + b.x)*7) : 0); ctx.lineTo(xx, yy); } };
          ctx.globalAlpha = a * 0.4; ctx.strokeStyle = '#ffe070'; ctx.lineWidth = 6; zig(); ctx.stroke();   // 글로우
          ctx.globalAlpha = a;       ctx.strokeStyle = '#fff8c0'; ctx.lineWidth = 2; zig(); ctx.stroke();   // 코어
          ctx.globalAlpha = a; ctx.fillStyle = '#fff8c0'; ctx.beginPath(); ctx.arc(b.x, b.y, 6*a, 0, Math.PI*2); ctx.fill(); // 착탄 섬광
        }
        ctx.restore(); ctx.globalAlpha = 1;
      },
    },

    // ========== 🎰 가챠 SR — ⚡ 레비나 (번개술사) ==========
    stormBrand: {
      name: '연쇄 낙뢰', baseCost: 120, color: '#7cc8ff',
      desc: lv => `${2+lv}회 연쇄 + 감전 · DMG ${6+lv*3}`,
      init(ab) { ab.cooldown = 40; ab.fx = 0; ab.fxPoints = []; },
      tick(ab) {
        if (ab.fx > 0) ab.fx--;
        if (--ab.cooldown > 0) return;
        const first = findNearestEnemy(ARENA_R + 50);
        if (!first) return;
        const dmg = 6 + ab.level * 3;
        const chains = 2 + ab.level;
        const stunDur = Math.floor((0.6 + ab.level * 0.08) * 60);
        const hit = new Set();
        let current = first;
        const points = [[CX, CY]];
        for (let i = 0; i < chains; i++) {
          if (!current) break;
          const [cx, cy] = enemyXY(current);
          points.push([cx, cy]);
          damageEnemy(current, dmg);
          if (!current.isBoss) current.timeStopped = Math.max(current.timeStopped || 0, state.t + stunDur);
          current.slowFrames = Math.max(current.slowFrames || 0, stunDur);
          spawnParticles(cx, cy, '#7cc8ff', 3);
          hit.add(current);
          let next = null, best = 150 * 150;
          for (const e of state.enemies) {
            if (hit.has(e) || e.hp <= 0) continue;
            const [ex2, ey2] = enemyXY(e);
            const d2 = (ex2 - cx) * (ex2 - cx) + (ey2 - cy) * (ey2 - cy);
            if (d2 < best) { best = d2; next = e; }
          }
          current = next;
        }
        ab.fxPoints = points;
        ab.fx = 10;
        ab.cooldown = Math.max(45, 75 - ab.level * 4);
      },
      draw(ab) {
        if (ab.fx <= 0 || ab.fxPoints.length < 2) return;
        const a = ab.fx / 10;
        const path = () => {
          ctx.beginPath(); ctx.moveTo(ab.fxPoints[0][0], ab.fxPoints[0][1]);
          for (let i = 1; i < ab.fxPoints.length; i++) {
            const p1 = ab.fxPoints[i - 1], p2 = ab.fxPoints[i];
            const mx = (p1[0] + p2[0]) / 2 + (Math.random() - 0.5) * 14, my = (p1[1] + p2[1]) / 2 + (Math.random() - 0.5) * 14;
            ctx.lineTo(mx, my); ctx.lineTo(p2[0], p2[1]);
          }
        };
        ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.lineCap = 'round'; ctx.lineJoin = 'round';
        ctx.globalAlpha = a * 0.4; ctx.strokeStyle = '#7cc8ff'; ctx.lineWidth = 7; path(); ctx.stroke();
        ctx.globalAlpha = a;       ctx.strokeStyle = '#dff2ff'; ctx.lineWidth = 2; path(); ctx.stroke();
        ctx.restore(); ctx.globalAlpha = 1;
      },
    },
    levinLash: {
      name: '전격 낙인', isCombo: true, baseCost: 160, color: '#7cc8ff',
      desc: lv => `${4+lv}회 연쇄 + 강감전 · 끝점 방전 · DMG ${10+lv*5}`,
      init(ab) { ab.cooldown = 60; ab.fx = 0; ab.fxPoints = []; },
      tick(ab) {
        if (ab.fx > 0) ab.fx--;
        if (--ab.cooldown > 0) return;
        const first = findNearestEnemy(ARENA_R + 50);
        if (!first) return;
        const dmg = 10 + ab.level * 5;
        const chains = 4 + ab.level;
        const stunDur = Math.floor((1.0 + ab.level * 0.1) * 60);
        const hit = new Set();
        let current = first;
        const points = [[CX, CY]];
        let lastX = CX, lastY = CY;
        for (let i = 0; i < chains; i++) {
          if (!current) break;
          const [cx, cy] = enemyXY(current);
          points.push([cx, cy]); lastX = cx; lastY = cy;
          damageEnemy(current, dmg);
          if (!current.isBoss) current.timeStopped = Math.max(current.timeStopped || 0, state.t + stunDur);
          current.slowFrames = Math.max(current.slowFrames || 0, stunDur);
          spawnParticles(cx, cy, '#7cc8ff', 4);
          hit.add(current);
          let next = null, best = 160 * 160;
          for (const e of state.enemies) {
            if (hit.has(e) || e.hp <= 0) continue;
            const [ex2, ey2] = enemyXY(e);
            const d2 = (ex2 - cx) * (ex2 - cx) + (ey2 - cy) * (ey2 - cy);
            if (d2 < best) { best = d2; next = e; }
          }
          current = next;
        }
        const blastR = 70;
        for (const e of state.enemies) {
          if (e.hp <= 0 || hit.has(e)) continue;
          const [ex, ey] = enemyXY(e);
          if ((ex - lastX) * (ex - lastX) + (ey - lastY) * (ey - lastY) < blastR * blastR) damageEnemy(e, dmg * 0.6);
        }
        spawnParticles(lastX, lastY, '#dff2ff', 12);
        ab.fxPoints = points;
        ab.fx = 12;
        ab.cooldown = Math.max(60, 100 - ab.level * 5);
      },
      draw(ab) {
        if (ab.fx <= 0 || ab.fxPoints.length < 2) return;
        const a = ab.fx / 12;
        const path = () => {
          ctx.beginPath(); ctx.moveTo(ab.fxPoints[0][0], ab.fxPoints[0][1]);
          for (let i = 1; i < ab.fxPoints.length; i++) {
            const p1 = ab.fxPoints[i - 1], p2 = ab.fxPoints[i];
            const mx = (p1[0] + p2[0]) / 2 + (Math.random() - 0.5) * 16, my = (p1[1] + p2[1]) / 2 + (Math.random() - 0.5) * 16;
            ctx.lineTo(mx, my); ctx.lineTo(p2[0], p2[1]);
          }
        };
        ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.lineCap = 'round'; ctx.lineJoin = 'round';
        ctx.globalAlpha = a * 0.45; ctx.strokeStyle = '#7cc8ff'; ctx.lineWidth = 9; path(); ctx.stroke();
        ctx.globalAlpha = a;        ctx.strokeStyle = '#eaf7ff'; ctx.lineWidth = 2.5; path(); ctx.stroke();
        ctx.restore(); ctx.globalAlpha = 1;
      },
    },
    tempestVeil: {
      name: '뇌우의 장막', isCombo: true, isTriple: true, baseCost: 240, color: '#7cc8ff',
      desc: lv => `회전 뇌우장 · 0.4s마다 자동 감전 · DMG ${16+lv*8} · 광역`,
      init(ab) { ab.cooldown = 0; ab.ang = 0; ab.pulses = []; ab._radius = 160; },
      tick(ab) {
        ab.ang += 0.06;
        for (const p of ab.pulses) p.life--;
        compactInPlace(ab.pulses, _alivePredLife);
        if (--ab.cooldown > 0) return;
        const radius = 150 + ab.level * 10;
        const dmg = 16 + ab.level * 8;
        const stunDur = Math.floor((0.8 + ab.level * 0.06) * 60);
        let any = false;
        for (const e of state.enemies) {
          if (e.hp <= 0) continue;
          const [ex, ey] = enemyXY(e);
          if ((ex - CX) * (ex - CX) + (ey - CY) * (ey - CY) <= radius * radius) {
            damageEnemy(e, dmg);
            if (!e.isBoss) e.timeStopped = Math.max(e.timeStopped || 0, state.t + Math.floor(stunDur * 0.5));
            e.slowFrames = Math.max(e.slowFrames || 0, stunDur);
            spawnParticles(ex, ey, '#7cc8ff', 3);
            any = true;
          }
        }
        if (any) ab.pulses.push({ r: radius, life: 12 });
        ab._radius = radius;
        ab.cooldown = 24;
      },
      draw(ab) {
        const radius = ab._radius || 160;
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        ctx.globalAlpha = 0.18 + 0.08 * Math.sin(state.t * 0.2);
        ctx.strokeStyle = '#7cc8ff'; ctx.lineWidth = 2;
        ctx.beginPath(); ctx.arc(CX, CY, radius, 0, Math.PI * 2); ctx.stroke();
        for (let i = 0; i < 4; i++) {
          const a0 = ab.ang + i * Math.PI / 2;
          ctx.globalAlpha = 0.5; ctx.strokeStyle = '#eaf7ff'; ctx.lineWidth = 2.5;
          ctx.beginPath(); ctx.arc(CX, CY, radius, a0, a0 + 0.5); ctx.stroke();
        }
        for (const p of ab.pulses) {
          const a = p.life / 12;
          ctx.globalAlpha = a * 0.4; ctx.strokeStyle = '#dff2ff'; ctx.lineWidth = 4;
          ctx.beginPath(); ctx.arc(CX, CY, p.r, 0, Math.PI * 2); ctx.stroke();
        }
        ctx.restore(); ctx.globalAlpha = 1;
      },
    },
    stormSovereign: {
      name: '폭풍군주', isCombo: true, isTriple: true, isEighth: true, baseCost: 340, color: '#7cc8ff',
      desc: lv => `초고압 뇌격 + 분기 낙뢰 · DMG ${30+lv*15} · 초광역 감전`,
      init(ab) { ab.cooldown = 30; ab.pulses = []; ab.bolts = []; ab._radius = 220; },
      tick(ab) {
        for (const p of ab.pulses) p.life--;
        for (const b of ab.bolts) b.life--;
        compactInPlace(ab.pulses, _alivePredLife);
        compactInPlace(ab.bolts, _alivePredLife);
        if (--ab.cooldown > 0) return;
        const radius = 200 + ab.level * 12;
        const dmg = 30 + ab.level * 15;
        const stunDur = Math.floor((1.2 + ab.level * 0.1) * 60);
        for (const e of state.enemies) {
          if (e.hp <= 0) continue;
          const [ex, ey] = enemyXY(e);
          if ((ex - CX) * (ex - CX) + (ey - CY) * (ey - CY) <= radius * radius) {
            damageEnemy(e, dmg);
            if (!e.isBoss) e.timeStopped = Math.max(e.timeStopped || 0, state.t + stunDur);
            e.slowFrames = Math.max(e.slowFrames || 0, stunDur);
            ab.bolts.push({ x: ex, y: ey, life: 10 });
          }
        }
        ab.pulses.push({ r: radius, life: 16 });
        ab._radius = radius;
        ab.cooldown = Math.max(45, 80 - ab.level * 3);
      },
      draw(ab) {
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        for (const p of ab.pulses) {
          const a = p.life / 16;
          ctx.globalAlpha = a * 0.5; ctx.strokeStyle = '#7cc8ff'; ctx.lineWidth = 6;
          ctx.beginPath(); ctx.arc(CX, CY, p.r * (1 - a * 0.1), 0, Math.PI * 2); ctx.stroke();
          ctx.globalAlpha = a; ctx.strokeStyle = '#eaf7ff'; ctx.lineWidth = 2;
          ctx.beginPath(); ctx.arc(CX, CY, p.r * (1 - a * 0.1), 0, Math.PI * 2); ctx.stroke();
        }
        for (const b of ab.bolts) {
          const a = b.life / 10;
          ctx.globalAlpha = a; ctx.fillStyle = '#eaf7ff';
          ctx.beginPath(); ctx.arc(b.x, b.y, 5 * a, 0, Math.PI * 2); ctx.fill();
        }
        ctx.restore(); ctx.globalAlpha = 1;
      },
    },

    turret: {
      name: '터렛', baseCost: 70, color: '#88aaff',
      desc: lv => `${2+lv}개 보조포 · DMG ${1+lv} · 빠른 연사`,
      // 타워 주변 N개의 미니 포탑이 각자 가장 가까운 적에게 연사.
      init(ab) { ab.angle = 0; ab.cooldowns = []; },
      tick(ab) {
        const count = 2 + ab.level;
        while (ab.cooldowns.length < count) ab.cooldowns.push(0);
        while (ab.cooldowns.length > count) ab.cooldowns.pop();
        ab.angle += 0.004;
        const radius = 50;
        for (let i = 0; i < count; i++) {
          if (--ab.cooldowns[i] > 0) continue;
          const a = ab.angle + (Math.PI * 2 / count) * i;
          const tx = CX + Math.cos(a) * radius;
          const ty = CY + Math.sin(a) * radius;
          let target = null, best = Infinity;
          for (const e of state.enemies) {
            if (e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            const d2 = (ex-tx)*(ex-tx) + (ey-ty)*(ey-ty);
            if (d2 < best) { best = d2; target = e; }
          }
          if (target) {
            const [tex, tey] = enemyXY(target);
            const ang = Math.atan2(tey - ty, tex - tx);
            state.bullets.push({
              x: tx, y: ty,
              vx: Math.cos(ang)*7, vy: Math.sin(ang)*7,
              dmg: 1 + ab.level, life: 80, color: '#88aaff',
              target: null, leader: null, offsetAngle: 0,
              sourceId: state.currentAbilityId || null,
            });
            ab.cooldowns[i] = Math.max(12, 30 - ab.level * 2);
          }
        }
      },
      draw(ab) {
        const count = 2 + ab.level;
        const radius = 50;
        for (let i = 0; i < count; i++) {
          const a = ab.angle + (Math.PI * 2 / count) * i;
          const tx = CX + Math.cos(a) * radius, ty = CY + Math.sin(a) * radius;
          ctx.fillStyle = '#2a3346'; ctx.beginPath(); ctx.arc(tx, ty, 5, 0, Math.PI*2); ctx.fill();   // 금속 포탑
          ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.drawImage(getGlowSprite('#88aaff'), tx - 8, ty - 8, 16, 16); ctx.restore(); // 발광 코어
        }
      },
    },

    boomerang: {
      name: '부메랑', baseCost: 65, color: '#ffaa44',
      desc: lv => `왕복 ${1+lv}개 · DMG ${3+lv*2}`,
      // 던지면 멀리 갔다가 타워로 돌아오는 회전체. 갈 때와 올 때 모두 타격.
      init(ab) { ab.cooldown = 60; ab.boomerangs = []; },
      tick(ab) {
        const dmg = 3 + ab.level * 2;
        for (const b of ab.boomerangs) {
          b.life--;
          b.rotation += 0.35;
          if (b.phase === 'out') {
            b.t++;
            if (b.t >= b.outDuration) { b.phase = 'in'; b.hit = new Set(); }
          } else {
            const dx = CX - b.x, dy = CY - b.y;
            const d = Math.hypot(dx, dy);
            if (d < 20) { b.life = 0; continue; }
            b.vx = (dx/d) * 6; b.vy = (dy/d) * 6;
          }
          b.x += b.vx; b.y += b.vy;
          for (const e of state.enemies) {
            if (b.hit.has(e) || e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            const r = e.size + 8;
            if ((b.x-ex)*(b.x-ex) + (b.y-ey)*(b.y-ey) < r*r) {
              damageEnemy(e, dmg);
              b.hit.add(e);
              spawnParticles(ex, ey, '#ffaa44', 3);
            }
          }
        }
        compactInPlace(ab.boomerangs, _alivePredLife);
        if (--ab.cooldown > 0) return;
        const count = 1 + ab.level;
        for (let i = 0; i < count; i++) {
          const target = findNearestEnemy(ARENA_R + 100);
          if (!target) break;
          const [tx, ty] = enemyXY(target);
          const ang = Math.atan2(ty - CY, tx - CX) + (i - (count-1)/2) * 0.4;
          ab.boomerangs.push({
            x: CX, y: CY,
            vx: Math.cos(ang) * 6, vy: Math.sin(ang) * 6,
            t: 0, outDuration: 35, phase: 'out',
            rotation: 0, life: 220, hit: new Set(),
          });
        }
        ab.cooldown = Math.max(60, 120 - ab.level * 5);
      },
      draw(ab) {
        for (const b of ab.boomerangs) {
          ctx.save(); ctx.translate(b.x, b.y);
          ctx.globalCompositeOperation = 'lighter';
          ctx.drawImage(getGlowSprite('#ffaa44'), -13, -13, 26, 26);   // 글로우
          ctx.rotate(b.rotation);
          ctx.fillStyle = '#ffe0a0';
          ctx.fillRect(-8, -2, 16, 4); ctx.fillRect(-2, -8, 4, 16);     // 회전 십자 날
          ctx.restore();
        }
      },
    },

    tornado: {
      name: '회오리', baseCost: 65, color: '#88ffcc',
      desc: lv => `${1+lv}개 떠도는 회오리 · DMG ${1+lv}`,
      // 아레나를 무작위로 떠도는 N개의 AOE. 부딪힌 적에게 데미지.
      init(ab) { ab.tornadoes = []; ab.hits = new Map(); },
      tick(ab) {
        const want = 1 + ab.level;
        while (ab.tornadoes.length < want) {
          const a = Math.random() * Math.PI * 2;
          const r = Math.random() * (ARENA_R - 60);
          ab.tornadoes.push({
            x: CX + Math.cos(a) * r,
            y: CY + Math.sin(a) * r,
            vx: (Math.random() - 0.5) * 4,
            vy: (Math.random() - 0.5) * 4,
            rot: 0,
          });
        }
        while (ab.tornadoes.length > want) ab.tornadoes.pop();
        for (const [e, cd] of ab.hits) {
          if (cd <= 1 || e.hp <= 0) ab.hits.delete(e);
          else ab.hits.set(e, cd - 1);
        }
        const dmg = 1 + ab.level;
        const tR = 38;
        for (const t of ab.tornadoes) {
          t.x += t.vx; t.y += t.vy;
          t.rot += 0.22;
          const dx = t.x - CX, dy = t.y - CY;
          const d = Math.hypot(dx, dy);
          if (d > ARENA_R - tR) {
            const nx = dx/d, ny = dy/d;
            const dot = t.vx*nx + t.vy*ny;
            t.vx -= 2*dot*nx; t.vy -= 2*dot*ny;
            t.x = CX + nx*(ARENA_R - tR);
            t.y = CY + ny*(ARENA_R - tR);
          }
          if (Math.random() < 0.02) {
            t.vx += (Math.random() - 0.5) * 0.5;
            t.vy += (Math.random() - 0.5) * 0.5;
          }
          const sp = Math.hypot(t.vx, t.vy);
          if (sp > 4) { t.vx = t.vx/sp*4; t.vy = t.vy/sp*4; }
          if (sp < 1.5) { t.vx = t.vx/sp*1.5; t.vy = t.vy/sp*1.5; }
          for (const e of state.enemies) {
            if (ab.hits.has(e) || e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            if ((ex-t.x)*(ex-t.x) + (ey-t.y)*(ey-t.y) < tR*tR) {
              damageEnemy(e, dmg);
              ab.hits.set(e, 25);
              spawnParticles(ex, ey, '#88ffcc', 2);
            }
          }
        }
      },
      draw(ab) {
        for (const t of ab.tornadoes) {
          ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.translate(t.x, t.y); ctx.lineCap = 'round';
          // 소용돌이 — 동심 호 밴드 (반경별 다른 속도 회전, 가산 글로우)
          for (let i = 0; i < 4; i++) {
            const rr2 = 10 + i * 9, sp = t.rot * 2.2 * (1 + i*0.25) + i;
            ctx.globalAlpha = 0.5 - i*0.08; ctx.strokeStyle = '#9bffd0'; ctx.lineWidth = 3 - i*0.4;
            ctx.beginPath(); ctx.arc(0, 0, rr2, sp, sp + 2.4); ctx.stroke();
            ctx.beginPath(); ctx.arc(0, 0, rr2, sp + Math.PI, sp + Math.PI + 1.8); ctx.stroke();
          }
          // 오비팅 위스프 점
          ctx.globalAlpha = 0.5; ctx.fillStyle = '#ddffee';
          for (let k = 0; k < 6; k++) { const a = t.rot * 3 + k*(Math.PI*2/6), r = 14 + (k%3)*8; ctx.beginPath(); ctx.arc(Math.cos(a)*r, Math.sin(a)*r, 1.6, 0, Math.PI*2); ctx.fill(); }
          // 중심 글로우 (로컬좌표 상수 — 캐시)
          ctx.globalAlpha = 1;
          if (!_tornadoCoreG) { _tornadoCoreG = ctx.createRadialGradient(0, 0, 0, 0, 0, 18); _tornadoCoreG.addColorStop(0, '#ddffee'); _tornadoCoreG.addColorStop(0.5, 'rgba(136,255,204,0.4)'); _tornadoCoreG.addColorStop(1, 'rgba(136,255,204,0)'); }
          ctx.fillStyle = _tornadoCoreG; ctx.beginPath(); ctx.arc(0, 0, 18, 0, Math.PI*2); ctx.fill();
          ctx.restore();
        }
        ctx.globalAlpha = 1;
      },
    },

    beam: {
      name: '광선', baseCost: 70, color: '#ff66bb',
      desc: lv => `회전 빔 · DPS ${1+lv}`,
      // 타워에서 끊임없이 방출되며 천천히 회전. 빔이 지나가는 적 모두 데미지.
      init(ab) { ab.angle = 0; ab.hits = new Map(); },
      tick(ab) {
        const rotSpeed = 0.012 + ab.level * 0.003;
        ab.angle += rotSpeed;
        for (const [e, cd] of ab.hits) {
          if (cd <= 1 || e.hp <= 0) ab.hits.delete(e);
          else ab.hits.set(e, cd - 1);
        }
        const len = ARENA_R + 20;
        const ex = CX + Math.cos(ab.angle) * len;
        const ey = CY + Math.sin(ab.angle) * len;
        const dmg = 1 + ab.level;
        for (const e of state.enemies) {
          if (ab.hits.has(e) || e.hp <= 0) continue;
          const [px, py] = enemyXY(e);
          if (distPointSegmentSq(px, py, CX, CY, ex, ey) < 100) {
            damageEnemy(e, dmg);
            ab.hits.set(e, 20);
            spawnParticles(px, py, '#ff66bb', 2);
          }
        }
      },
      draw(ab) {
        const len = ARENA_R + 20;
        const ex = CX + Math.cos(ab.angle) * len;
        const ey = CY + Math.sin(ab.angle) * len;
        glowBeam(CX, CY, ex, ey, '#ff66bb', 4, 0.85);   // 🌟 글로우 회전 빔
      },
    },

    sniper: {
      name: '저격', baseCost: 75, color: '#aaffaa',
      desc: lv => `최강 적 저격 · DMG ${5+lv*3}`,
      init(ab) { ab.cooldown = 60; },
      tick(ab) {
        if (--ab.cooldown > 0) return;
        let target = null, best = -1;
        for (const e of state.enemies) {
          { const _s = e.isBoss ? e.hp + 1e9 : e.hp; if (_s > best) { best = _s; target = e; } }
        }
        if (!target) return;
        const [tx, ty] = enemyXY(target);
        const ang = Math.atan2(ty - CY, tx - CX);
        state.bullets.push({
          x: CX, y: CY,
          vx: Math.cos(ang) * 14, vy: Math.sin(ang) * 14,
          dmg: 5 + ab.level * 3, life: 60, color: '#aaffaa',
          target, leader: null, offsetAngle: 0,
          sourceId: state.currentAbilityId || null,
        });
        ab.cooldown = Math.max(40, 80 - ab.level * 3);
      },
    },

    frost: {
      name: '빙결', baseCost: 50, color: '#88ddff',
      desc: lv => `슬로우 충격파 · DMG ${2+lv*2} · ${((50+lv*15)/60).toFixed(1)}s 슬로우`,
      init(ab) { ab.cooldown = 60; ab.waves = []; },
      tick(ab) {
        const dmg = 2 + ab.level * 2;
        const slowDur = 50 + ab.level * 15;
        // 🏰 TD: 슬로우/펄스 반경을 사거리 캡으로 제한
        const maxR = tdMaxEffectRadius(ARENA_R + 30);
        for (const w of ab.waves) {
          w.prevR = w.r; w.r += 4.5;
          for (const e of state.enemies) {
            if (w.hit.has(e) || e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            const d = Math.hypot(ex - CX, ey - CY);
            if (d >= w.prevR - 10 && d <= w.r + 10 && d <= maxR) {
              damageEnemy(e, dmg);
              e.slowFrames = Math.max(e.slowFrames || 0, slowDur);
              spawnParticles(ex, ey, '#88ddff', 3);
              w.hit.add(e);
            }
          }
        }
        compactInPlace(ab.waves, w => w.r < maxR);
        if (--ab.cooldown > 0) return;
        ab.waves.push({ r: CORE_R, prevR: CORE_R, hit: new Set() });
        ab.cooldown = Math.max(45, 100 - ab.level * 5);
      },
      draw(ab) {
        // ❄️ 빙결 — 들쭉날쭉 얼음 결정 테두리 + 바깥으로 뻗는 서리 가시 + 옅은 얼음 채움 (사르르)
        for (const w of ab.waves) {
          const prog = w.r / (ARENA_R + 30), a = Math.max(0, 1 - prog);
          // 서리 채움 (안쪽 옅게)
          ctx.globalAlpha = a * 0.12; ctx.fillStyle = '#bfe8ff';
          ctx.beginPath(); ctx.arc(CX, CY, w.r, 0, Math.PI*2); ctx.fill();
          // 결정 테두리 (톱니)
          ctx.globalAlpha = a * 0.9; ctx.strokeStyle = '#e4f6ff'; ctx.lineWidth = 2;
          ctx.beginPath();
          const seg = 30;
          for (let i = 0; i <= seg; i++) {
            const ang = (i / seg) * Math.PI * 2;
            const jag = (i % 2 === 0) ? w.r : w.r - 5 - Math.sin(i*1.7 + w.r*0.1)*3;
            const px = CX + Math.cos(ang)*jag, py = CY + Math.sin(ang)*jag;
            i ? ctx.lineTo(px, py) : ctx.moveTo(px, py);
          }
          ctx.closePath(); ctx.stroke();
          // 뻗는 얼음 가시
          ctx.globalAlpha = a * 0.7; ctx.strokeStyle = '#a8dcff'; ctx.lineWidth = 1.5;
          for (let i = 0; i < 12; i++) {
            const ang = (i / 12) * Math.PI * 2 + w.r * 0.008;
            ctx.beginPath();
            ctx.moveTo(CX + Math.cos(ang)*(w.r-4), CY + Math.sin(ang)*(w.r-4));
            ctx.lineTo(CX + Math.cos(ang)*(w.r+7), CY + Math.sin(ang)*(w.r+7));
            ctx.stroke();
          }
        }
        ctx.globalAlpha = 1;
      },
    },

    missile: {
      name: '미사일', baseCost: 65, color: '#bb88ff',
      desc: lv => `유도 미사일 · DMG ${3+lv*2} · 광역 ${30+lv*5}`,
      init(ab) { ab.cooldown = 80; ab.missiles = []; },
      tick(ab) {
        const dmg = 3 + ab.level * 2;
        const explodeR = 30 + ab.level * 5;
        for (const m of ab.missiles) {
          if (!m.target || m.target.hp <= 0) {
            let best = Infinity, t = null;
            for (const e of state.enemies) {
              if (e.hp <= 0) continue;
              const [ex, ey] = enemyXY(e);
              const d2 = (m.x-ex)*(m.x-ex) + (m.y-ey)*(m.y-ey);
              if (d2 < best) { best = d2; t = e; }
            }
            m.target = t;
          }
          if (m.target) {
            const [tx, ty] = enemyXY(m.target);
            const curAng = Math.atan2(m.vy, m.vx);
            const wantAng = Math.atan2(ty - m.y, tx - m.x);
            let diff = wantAng - curAng;
            while (diff > Math.PI) diff -= Math.PI * 2;
            while (diff < -Math.PI) diff += Math.PI * 2;
            const turn = 0.15;
            const c = Math.max(-turn, Math.min(turn, diff));
            const a = curAng + c;
            m.vx = Math.cos(a) * 5; m.vy = Math.sin(a) * 5;
          }
          m.x += m.vx; m.y += m.vy; m.life--;
          for (const e of state.enemies) {
            if (e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            if ((m.x-ex)*(m.x-ex) + (m.y-ey)*(m.y-ey) < (e.size + 4)*(e.size + 4)) {
              for (const e2 of state.enemies) {
                if (e2.hp <= 0) continue;
                const [ex2, ey2] = enemyXY(e2);
                if ((m.x-ex2)*(m.x-ex2) + (m.y-ey2)*(m.y-ey2) < explodeR*explodeR) {
                  damageEnemy(e2, dmg);
                  spawnParticles(ex2, ey2, '#bb88ff', 3);
                }
              }
              m.life = 0;
              break;
            }
          }
          if ((m.x-CX)*(m.x-CX) + (m.y-CY)*(m.y-CY) > (ARENA_R+30)*(ARENA_R+30)) m.life = 0;
        }
        compactInPlace(ab.missiles, _alivePredLife);
        if (--ab.cooldown > 0) return;
        const count = 1 + Math.floor(ab.level / 2);
        for (let i = 0; i < count; i++) {
          const ang = Math.random() * Math.PI * 2;
          ab.missiles.push({
            x: CX, y: CY,
            vx: Math.cos(ang) * 3, vy: Math.sin(ang) * 3,
            target: null, life: 200,
          });
        }
        ab.cooldown = Math.max(40, 90 - ab.level * 4);
      },
      draw(ab) {
        for (const m of ab.missiles) {
          const ang = Math.atan2(m.vy, m.vx);
          ctx.save(); ctx.translate(m.x, m.y); ctx.rotate(ang);
          ctx.save(); ctx.globalCompositeOperation = 'lighter';
          // 화염 분사 꼬리 (로컬좌표 상수 그라디언트 — 캐시)
          if (!_missileTrailG) { _missileTrailG = ctx.createLinearGradient(-4, 0, -18, 0); _missileTrailG.addColorStop(0, 'rgba(255,200,130,0.9)'); _missileTrailG.addColorStop(1, 'rgba(255,120,40,0)'); }
          ctx.fillStyle = _missileTrailG; ctx.beginPath(); ctx.moveTo(-4, -3); ctx.lineTo(-18, 0); ctx.lineTo(-4, 3); ctx.closePath(); ctx.fill();
          // 발광 탄두
          ctx.drawImage(getGlowSprite('#bb88ff'), -9, -8, 18, 18);
          ctx.restore();
          // 탄두 코어 (방향성)
          ctx.fillStyle = '#efe6ff'; ctx.beginPath(); ctx.moveTo(7, 0); ctx.lineTo(-3, -3); ctx.lineTo(-3, 3); ctx.closePath(); ctx.fill();
          ctx.restore();
        }
      },
    },

    fire: {
      name: '불꽃', baseCost: 50, color: '#ff7733',
      desc: lv => `타워 화염장 · DPS ${1+lv} · 반경 ${100+lv*10}`,
      // 타워 주변 영구 화염장. 들어온 적에게 주기적 데미지.
      init(ab) { ab.hits = new Map(); ab.particles = []; },
      tick(ab) {
        for (const [e, cd] of ab.hits) {
          if (cd <= 1 || e.hp <= 0) ab.hits.delete(e);
          else ab.hits.set(e, cd - 1);
        }
        const radius = 100 + ab.level * 10;
        const dmg = 1 + ab.level;
        for (const e of state.enemies) {
          if (ab.hits.has(e) || e.hp <= 0) continue;
          const [ex, ey] = enemyXY(e);
          const d2 = (ex-CX)*(ex-CX) + (ey-CY)*(ey-CY);
          if (d2 < radius*radius) {
            damageEnemy(e, dmg);
            ab.hits.set(e, 22);
            spawnParticles(ex, ey, '#ff7733', 2);
          }
        }
        if (Math.random() < 0.4) {
          const a = Math.random() * Math.PI * 2;
          const r = 20 + Math.random() * (radius - 20);
          ab.particles.push({
            x: CX + Math.cos(a) * r,
            y: CY + Math.sin(a) * r,
            vy: -0.5 - Math.random(),
            life: 25 + Math.random() * 15,
          });
        }
        for (const p of ab.particles) { p.life--; p.y += p.vy; }
        compactInPlace(ab.particles, _alivePredLife);
      },
      draw(ab) {
        const radius = 100 + ab.level * 10;
        ctx.fillStyle = 'rgba(255, 119, 51, 0.05)';
        ctx.beginPath(); ctx.arc(CX, CY, radius, 0, Math.PI*2); ctx.fill();
        ctx.strokeStyle = 'rgba(255, 119, 51, 0.20)';
        ctx.lineWidth = 2;
        ctx.beginPath(); ctx.arc(CX, CY, radius, 0, Math.PI*2); ctx.stroke();
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        for (const p of ab.particles) {
          const a = Math.max(0, p.life / 40); ctx.globalAlpha = a;
          const col = a > 0.6 ? '#ffd060' : '#ff6a30';   // 오래될수록 붉게
          const r = 2 + a * 4;
          ctx.drawImage(getGlowSprite(col), p.x - r, p.y - r, r*2, r*2);
        }
        ctx.restore(); ctx.globalAlpha = 1;
      },
    },

    iceLance: {
      name: '얼음창', baseCost: 55, color: '#aaddff',
      desc: lv => `관통 얼음창 · DMG ${3+lv*2} · 슬로우`,
      // 직선으로 날아가는 큰 얼음창. 관통 + 슬로우.
      init(ab) { ab.cooldown = 50; ab.lances = []; },
      tick(ab) {
        const dmg = 3 + ab.level * 2;
        const slowDur = 60 + ab.level * 15;
        for (const l of ab.lances) {
          l.x += l.vx; l.y += l.vy; l.life--;
          for (const e of state.enemies) {
            if (l.hit.has(e) || e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            if ((l.x-ex)*(l.x-ex) + (l.y-ey)*(l.y-ey) < (e.size + 4)*(e.size + 4)) {
              damageEnemy(e, dmg);
              e.slowFrames = Math.max(e.slowFrames || 0, slowDur);
              l.hit.add(e);
              spawnParticles(ex, ey, '#aaddff', 3);
            }
          }
          if ((l.x-CX)*(l.x-CX) + (l.y-CY)*(l.y-CY) > (ARENA_R+30)*(ARENA_R+30)) l.life = 0;
        }
        compactInPlace(ab.lances, _alivePredLife);
        if (--ab.cooldown > 0) return;
        const target = findNearestEnemy(ARENA_R + 50);
        if (!target) return;
        const [tx, ty] = enemyXY(target);
        const ang = Math.atan2(ty - CY, tx - CX);
        ab.lances.push({
          x: CX, y: CY,
          vx: Math.cos(ang) * 8, vy: Math.sin(ang) * 8,
          ang, life: 90, hit: new Set(),
        });
        ab.cooldown = Math.max(35, 65 - ab.level * 4);
      },
      draw(ab) {
        for (const l of ab.lances) {
          ctx.save(); ctx.translate(l.x, l.y); ctx.rotate(l.ang);
          ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.drawImage(getGlowSprite('#88ddff'), -18, -9, 36, 18); ctx.restore();
          // 뾰족한 얼음 창
          ctx.fillStyle = '#e4f5ff';
          ctx.beginPath(); ctx.moveTo(16, 0); ctx.lineTo(-2, -4); ctx.lineTo(-13, -2); ctx.lineTo(-13, 2); ctx.lineTo(-2, 4); ctx.closePath(); ctx.fill();
          ctx.fillStyle = '#7fc4ec'; ctx.beginPath(); ctx.moveTo(16, 0); ctx.lineTo(2, -2); ctx.lineTo(2, 2); ctx.closePath(); ctx.fill();
          ctx.restore();
        }
      },
    },

    mine: {
      name: '지뢰', baseCost: 60, color: '#a0c060',
      desc: lv => `지뢰 ${3+lv}개 · DMG ${4+lv*2} · 폭발 ${40+lv*8}`,
      // 아레나 무작위 위치에 지뢰 설치. 적이 접근하면 폭발.
      init(ab) { ab.cooldown = 0; ab.mines = []; ab.explosions = []; },
      tick(ab) {
        const dmg = 4 + ab.level * 2;
        const explodeR = 40 + ab.level * 8;
        for (const e of ab.explosions) e.life--;
        compactInPlace(ab.explosions, _alivePredLife);
        for (const m of ab.mines) {
          for (const e of state.enemies) {
            if (e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            if ((m.x-ex)*(m.x-ex) + (m.y-ey)*(m.y-ey) < 22*22) {
              for (const e2 of state.enemies) {
                if (e2.hp <= 0) continue;
                const [ex2, ey2] = enemyXY(e2);
                if ((m.x-ex2)*(m.x-ex2) + (m.y-ey2)*(m.y-ey2) < explodeR*explodeR) {
                  damageEnemy(e2, dmg);
                  spawnParticles(ex2, ey2, '#a0c060', 4);
                }
              }
              ab.explosions.push({ x: m.x, y: m.y, r: explodeR, life: 14 });
              m.exploded = true;
              break;
            }
          }
        }
        compactInPlace(ab.mines, _predNotExploded);
        const targetCount = 3 + ab.level;
        if (ab.mines.length < targetCount) {
          if (--ab.cooldown <= 0) {
            const a = Math.random() * Math.PI * 2;
            const r = ENEMY_MIN_R + Math.random() * (ENEMY_MAX_R - ENEMY_MIN_R - 20);
            ab.mines.push({ x: CX + Math.cos(a) * r, y: CY + Math.sin(a) * r });
            ab.cooldown = Math.max(15, 45 - ab.level * 3);
          }
        }
      },
      draw(ab) {
        // 지뢰 (어두운 장치 + 깜빡이는 발광 램프)
        for (const m of ab.mines) {
          ctx.fillStyle = '#2a3320'; ctx.beginPath(); ctx.arc(m.x, m.y, 5, 0, Math.PI*2); ctx.fill();
          const pulse = 0.5 + 0.5 * Math.sin(state.t * 0.18 + m.x);
          ctx.save(); ctx.globalCompositeOperation = 'lighter';
          const r = 5 + pulse*4; ctx.globalAlpha = 0.5 + pulse*0.5;
          ctx.drawImage(getGlowSprite('#ff5032'), m.x - r, m.y - r, r*2, r*2);
          ctx.restore(); ctx.globalAlpha = 1;
        }
        // 폭발 (글로우 버스트)
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        for (const e of ab.explosions) {
          const t = 1 - e.life / 14, a = e.life / 14;
          ctx.globalAlpha = a * 0.5; ctx.fillStyle = '#bfe060'; ctx.beginPath(); ctx.arc(e.x, e.y, e.r*t, 0, Math.PI*2); ctx.fill();
          ctx.globalAlpha = a; ctx.strokeStyle = '#ffe080'; ctx.lineWidth = 3; ctx.beginPath(); ctx.arc(e.x, e.y, e.r*t, 0, Math.PI*2); ctx.stroke();
        }
        ctx.restore(); ctx.globalAlpha = 1;
      },
    },

    drone: {
      name: '드론', baseCost: 65, color: '#9b88ff',
      desc: lv => `${1+lv}개 자율 드론 · 유도 사격 · DMG ${2+lv*2}`,
      // 자율 비행 유닛이 적을 추적하며 유도탄 사격 (적정 거리 유지).
      init(ab) { ab.drones = []; },
      tick(ab) {
        const want = 1 + ab.level;
        while (ab.drones.length < want) {
          const a = Math.random() * Math.PI * 2;
          ab.drones.push({
            x: CX + Math.cos(a) * 80, y: CY + Math.sin(a) * 80,
            vx: 0, vy: 0, cooldown: 0,
          });
        }
        while (ab.drones.length > want) ab.drones.pop();
        // ⚖ v271 — DMG 9→18 (명중 보강과 함께)
        const dmg = 2 + ab.level * 2;
        const speed = 2.6;
        for (const d of ab.drones) {
          let target = null, best = Infinity;
          for (const e of state.enemies) {
            if (e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            const d2 = (d.x-ex)*(d.x-ex) + (d.y-ey)*(d.y-ey);
            if (d2 < best) { best = d2; target = e; }
          }
          if (target) {
            const [tx, ty] = enemyXY(target);
            const dx = tx - d.x, dy = ty - d.y;
            const dist = Math.hypot(dx, dy);
            const ideal = 120;
            if (dist > ideal + 20)      { d.vx = (dx/dist) * speed;        d.vy = (dy/dist) * speed; }
            else if (dist < ideal - 20) { d.vx = -(dx/dist) * speed * 0.5; d.vy = -(dy/dist) * speed * 0.5; }
            else                        { d.vx *= 0.8; d.vy *= 0.8; }
            d.cooldown--;
            if (d.cooldown <= 0) {
              const ang = Math.atan2(dy, dx);
              // 🛡 v271 — 유도탄으로 변경: target 지정 → 적이 움직여도 추적 (직사라 다 빗나가던 문제 해결)
              state.bullets.push({
                x: d.x, y: d.y,
                vx: Math.cos(ang) * 8, vy: Math.sin(ang) * 8,
                dmg, life: 110, color: '#9b88ff',
                target: target, leader: null, offsetAngle: 0,
                sourceId: state.currentAbilityId || null,
              });
              d.cooldown = Math.max(12, 26 - ab.level);
            }
          } else {
            const ang = Math.atan2(CY - d.y, CX - d.x) + Math.PI / 2;
            d.vx = Math.cos(ang) * speed * 0.5;
            d.vy = Math.sin(ang) * speed * 0.5;
          }
          d.x += d.vx; d.y += d.vy;
          const ddx = d.x - CX, ddy = d.y - CY;
          const dd = Math.hypot(ddx, ddy);
          if (dd > ARENA_R - 20) {
            d.x = CX + ddx/dd * (ARENA_R - 20);
            d.y = CY + ddy/dd * (ARENA_R - 20);
          }
        }
      },
      draw(ab) {
        for (const d of ab.drones) {
          ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.drawImage(getGlowSprite('#9b88ff'), d.x - 10, d.y - 8, 20, 16); ctx.restore();
          ctx.fillStyle = '#2c2840'; ctx.fillRect(d.x - 6, d.y - 1, 2, 3); ctx.fillRect(d.x + 4, d.y - 1, 2, 3);  // 날개
          ctx.fillStyle = '#cabfff'; ctx.fillRect(d.x - 5, d.y - 3, 10, 6);                                          // 본체
          ctx.fillStyle = '#ffffff'; ctx.fillRect(d.x - 1, d.y - 1, 2, 2);                                           // 코어
        }
      },
    },

    meteor: {
      name: '운석', baseCost: 75, color: '#dd6633',
      desc: lv => `대형 운석 낙하 · DMG ${10+lv*5} · 반경 ${80+lv*15}`,
      // 큰 운석이 무작위 위치에 낙하. 거대 광역 + 큰 데미지, 긴 쿨다운.
      init(ab) { ab.cooldown = 180; ab.falling = []; ab.craters = []; },
      tick(ab) {
        for (const c of ab.craters) c.life--;
        compactInPlace(ab.craters, _alivePredLife);
        for (const f of ab.falling) {
          f.t++;
          if (f.t >= f.fall) {
            const radius = 80 + ab.level * 15;
            const dmg = 10 + ab.level * 5;
            for (const e of state.enemies) {
              if (e.hp <= 0) continue;
              const [ex, ey] = enemyXY(e);
              if ((f.x-ex)*(f.x-ex) + (f.y-ey)*(f.y-ey) < radius*radius) {
                damageEnemy(e, dmg);
                spawnParticles(ex, ey, '#dd6633', 5);
              }
            }
            ab.craters.push({ x: f.x, y: f.y, r: radius, life: 25 });
            f.done = true;
          }
        }
        compactInPlace(ab.falling, _predNotDone);
        if (--ab.cooldown > 0) return;
        const a = Math.random() * Math.PI * 2;
        const r = Math.random() * (ARENA_R - 40);
        ab.falling.push({ x: CX + Math.cos(a) * r, y: CY + Math.sin(a) * r, t: 0, fall: 45 });
        ab.cooldown = Math.max(80, 200 - ab.level * 8);
      },
      draw(ab) {
        for (const f of ab.falling) {
          const progress = f.t / f.fall;
          const my = f.y - (1 - progress) * 200;
          const ms = 11 + progress * 7;
          // 착탄 예고 링
          ctx.globalAlpha = 0.22 + progress * 0.4;
          ctx.strokeStyle = '#ff7038'; ctx.lineWidth = 2;
          ctx.beginPath(); ctx.arc(f.x, f.y, 13 + progress * 26, 0, Math.PI*2); ctx.stroke();
          ctx.globalAlpha = 1;
          // 불꽃 꼬리 (위로 길게 — 그라데이션, 가산)
          ctx.save(); ctx.globalCompositeOperation = 'lighter';
          const tg = ctx.createLinearGradient(f.x, my, f.x, my - ms*4.6);
          tg.addColorStop(0, 'rgba(255,180,90,0.85)'); tg.addColorStop(1, 'rgba(255,110,40,0)');
          ctx.fillStyle = tg;
          ctx.beginPath(); ctx.moveTo(f.x - ms*0.6, my); ctx.lineTo(f.x + ms*0.6, my); ctx.lineTo(f.x, my - ms*4.6); ctx.closePath(); ctx.fill();
          ctx.restore();
          // 운석 본체 (둥근 바위 + 음영)
          const g = ctx.createRadialGradient(f.x - ms*0.4, my - ms*0.4, ms*0.1, f.x, my, ms*1.25);
          g.addColorStop(0, '#b88a58'); g.addColorStop(0.5, '#7a5436'); g.addColorStop(1, '#392316');
          ctx.fillStyle = g;
          ctx.beginPath(); ctx.arc(f.x, my, ms, 0, Math.PI*2); ctx.fill();
          // 달궈진 앞면 글로우 (가산)
          ctx.save(); ctx.globalCompositeOperation = 'lighter';
          ctx.fillStyle = 'rgba(255,140,60,0.55)';
          ctx.beginPath(); ctx.arc(f.x, my + ms*0.25, ms*0.7, 0, Math.PI*2); ctx.fill();
          ctx.restore();
          // 크레이터 점
          ctx.fillStyle = 'rgba(40,24,16,0.55)';
          ctx.beginPath(); ctx.arc(f.x - ms*0.3, my - ms*0.15, ms*0.22, 0, Math.PI*2); ctx.fill();
        }
        // 착탄 폭발 (불 링)
        for (const c of ab.craters) {
          const t = 1 - c.life / 25;
          ctx.save(); ctx.globalCompositeOperation = 'lighter';
          ctx.globalAlpha = c.life / 25;
          ctx.strokeStyle = '#ffb060'; ctx.lineWidth = 3;
          ctx.beginPath(); ctx.arc(c.x, c.y, c.r * t, 0, Math.PI*2); ctx.stroke();
          ctx.globalAlpha = (c.life / 25) * 0.5; ctx.fillStyle = '#ff7030';
          ctx.beginPath(); ctx.arc(c.x, c.y, c.r * t * 0.6, 0, Math.PI*2); ctx.fill();
          ctx.restore();
        }
        ctx.globalAlpha = 1;
      },
    },

    blackhole: {
      name: '블랙홀', baseCost: 80, color: '#a060d0',
      desc: lv => `중력장 · DMG ${3+lv*3}/tick · 강제 흡인`,
      // 무작위 위치에 블랙홀 생성. 적을 강제로 끌어당기며 주기 데미지.
      init(ab) { ab.cooldown = 240; ab.holes = []; },
      tick(ab) {
        const dmg = 3 + ab.level * 3;   // ⚖ v269 — 흡인 유틸 + 딜 보강 (18→27/tick)
        const pullR = 110 + ab.level * 10;
        for (const h of ab.holes) {
          h.life--; h.tick--;
          for (const e of state.enemies) {
            if (e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            const dx = h.x - ex, dy = h.y - ey;
            const dist = Math.hypot(dx, dy);
            if (dist < pullR && dist > 5) {
              const pullSpeed = (1 - dist / pullR) * 2.2;
              const newEx = ex + (dx/dist) * pullSpeed;
              const newEy = ey + (dy/dist) * pullSpeed;
              e.angle = Math.atan2(newEy - CY, newEx - CX);
              e.radius = Math.hypot(newEx - CX, newEy - CY);
              e.targetRadius = e.radius; e._xyT = -1; // 🚀 위치 메모 무효화
              if (h.tick <= 0 && dist < pullR * 0.7) {
                damageEnemy(e, dmg);
                spawnParticles(ex, ey, '#a060d0', 2);
              }
            }
          }
          if (h.tick <= 0) h.tick = 14;
        }
        compactInPlace(ab.holes, _alivePredLife);
        if (--ab.cooldown > 0) return;
        const a = Math.random() * Math.PI * 2;
        const r = 60 + Math.random() * (ARENA_R - 100);
        ab.holes.push({ x: CX + Math.cos(a) * r, y: CY + Math.sin(a) * r, life: 180, tick: 14 });
        ab.cooldown = Math.max(180, 300 - ab.level * 10);
      },
      draw(ab) {
        for (const h of ab.holes) {
          const pullR = 110 + ab.level * 10;
          ctx.save(); ctx.translate(h.x, h.y);
          // 흡인 범위
          ctx.strokeStyle = 'rgba(160,96,208,0.12)'; ctx.lineWidth = 2;
          ctx.beginPath(); ctx.arc(0, 0, pullR, 0, Math.PI*2); ctx.stroke();
          // 보라 강착 글로우 (탑다운, 회전 X) — 부드러운 라디얼 (로컬좌표 상수 — 캐시)
          ctx.save(); ctx.globalCompositeOperation = 'lighter';
          if (!_blackholeGlowG) { _blackholeGlowG = ctx.createRadialGradient(0, 0, 9, 0, 0, 32); _blackholeGlowG.addColorStop(0, 'rgba(200,140,255,0.5)'); _blackholeGlowG.addColorStop(0.5, 'rgba(160,90,230,0.24)'); _blackholeGlowG.addColorStop(1, 'rgba(160,90,230,0)'); }
          ctx.fillStyle = _blackholeGlowG; ctx.beginPath(); ctx.arc(0, 0, 32, 0, Math.PI*2); ctx.fill();
          ctx.restore();
          // 사건의 지평선 (검정 + 보라 림)
          ctx.fillStyle = '#0a0410'; ctx.beginPath(); ctx.arc(0, 0, 13, 0, Math.PI*2); ctx.fill();
          ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.strokeStyle = '#c878f0'; ctx.lineWidth = 2.5; ctx.beginPath(); ctx.arc(0, 0, 13, 0, Math.PI*2); ctx.stroke(); ctx.restore();
          ctx.restore();
        }
      },
    },

    sword: {
      name: '회전검', baseCost: 60, color: '#cccccc',
      desc: lv => `${1+lv}개 회전 검날 · DMG ${3+lv*2}`,
      // 타워 중심에서 뻗어 회전하는 거대 검날. 검 따라 적 데미지.
      init(ab) { ab.angle = 0; ab.hits = new Map(); },
      tick(ab) {
        ab.angle += 0.04 + ab.level * 0.006;
        for (const [e, cd] of ab.hits) {
          if (cd <= 1 || e.hp <= 0) ab.hits.delete(e);
          else ab.hits.set(e, cd - 1);
        }
        const count = 1 + ab.level;
        const dmg = 3 + ab.level * 2;
        const swordLen = 130;
        const minR = 30;
        for (let i = 0; i < count; i++) {
          const a = ab.angle + (Math.PI * 2 / count) * i;
          const x1 = CX + Math.cos(a) * minR;
          const y1 = CY + Math.sin(a) * minR;
          const x2 = CX + Math.cos(a) * swordLen;
          const y2 = CY + Math.sin(a) * swordLen;
          for (const e of state.enemies) {
            if (ab.hits.has(e) || e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            if (distPointSegmentSq(ex, ey, x1, y1, x2, y2) < (e.size + 6)*(e.size + 6)) {
              damageEnemy(e, dmg);
              ab.hits.set(e, 22);
              spawnParticles(ex, ey, '#cccccc', 3);
            }
          }
        }
      },
      draw(ab) {
        const count = 1 + ab.level;
        const swordLen = 130;
        const minR = 30;
        for (let i = 0; i < count; i++) {
          const a = ab.angle + (Math.PI * 2 / count) * i;
          const x1 = CX + Math.cos(a) * minR;
          const y1 = CY + Math.sin(a) * minR;
          const x2 = CX + Math.cos(a) * swordLen;
          const y2 = CY + Math.sin(a) * swordLen;
          glowBeam(x1, y1, x2, y2, '#cfe0ff', 6, 0.92);   // 🌟 글로우 검날
          // 검 끝 반짝
          ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.fillStyle = '#ffffff';
          ctx.beginPath(); ctx.arc(x2, y2, 3, 0, Math.PI*2); ctx.fill(); ctx.restore();
        }
      },
    },

    starfall: {
      name: '별빛', baseCost: 55, color: '#ffe070',
      // 사거리(targetRange): 타워 중심에서 이 거리 내의 적만 표적. 별 폭발 반경(radius)은 별도.
      desc: lv => `사거리 ${160+lv*8} · ${3+Math.ceil(lv/2)}개 별 · DMG ${6+lv*3} · 폭발 ${30+lv*4}`,
      range: lv => 160 + lv * 8,   // 표적 사거리
      init(ab) { ab.cooldown = 90; ab.stars = []; ab.flashes = []; },
      tick(ab) {
        for (const f of ab.flashes) f.life--;
        compactInPlace(ab.flashes, _alivePredLife);
        // 낙하 진행 — 부드러운 50프레임 동안 강하 (이전 30 → 60 으로 늘려 끊김 완화)
        const FALL_FRAMES = 50;
        for (const s of ab.stars) {
          s.t++;
          if (s.t >= FALL_FRAMES) {
            const radius = 30 + ab.level * 4;
            const dmg = 6 + ab.level * 3;
            for (const e of state.enemies) {
              if (e.hp <= 0) continue;
              const [ex, ey] = enemyXY(e);
              if ((s.x-ex)*(s.x-ex) + (s.y-ey)*(s.y-ey) < radius*radius) {
                damageEnemy(e, dmg);
                spawnParticles(ex, ey, '#ffe070', 3);
              }
            }
            ab.flashes.push({ x: s.x, y: s.y, r: radius, life: 14 });
            s.done = true;
          }
        }
        compactInPlace(ab.stars, _predNotDone);
        if (--ab.cooldown > 0) return;
        const count = 3 + Math.ceil(ab.level / 2);
        const targetRange = 160 + ab.level * 8;
        // 🎯 표적 — 타워 사거리 내의 적만 (전 맵을 때리던 문제 해결)
        const pool = state.enemies.filter(e => {
          if (e.hp <= 0) return false;
          const [ex, ey] = enemyXY(e);
          return (ex - CX) * (ex - CX) + (ey - CY) * (ey - CY) <= targetRange * targetRange;
        });
        if (pool.length === 0) {
          ab.cooldown = 20;   // 적 없으면 짧게 대기 후 재시도
          return;
        }
        for (let i = 0; i < count; i++) {
          // 사거리 내 무작위 적에 ±20px 오프셋
          const target = pool[Math.floor(Math.random() * pool.length)];
          const [tx, ty] = enemyXY(target);
          const sx = tx + (Math.random() - 0.5) * 40;
          const sy = ty + (Math.random() - 0.5) * 40;
          // 스타거 작게 (-i*2) — 시각적 연속성 ↑
          ab.stars.push({ x: sx, y: sy, t: -i * 2 });
        }
        ab.cooldown = Math.max(45, 100 - ab.level * 5);
      },
      draw(ab) {
        const FALL_FRAMES = 50;
        for (const s of ab.stars) {
          if (s.t < 0) continue;
          const progress = s.t / FALL_FRAMES;
          const my = s.y - (1 - progress) * 160;
          // 모션 트레일 — 5단 점진 페이드 (끊김 완화 — 이전 단일 사각형 → 여러 단)
          ctx.fillStyle = '#ffe070';
          for (let k = 0; k < 5; k++) {
            ctx.globalAlpha = 0.5 - k * 0.09;
            ctx.fillRect(s.x - 2, my - 4 - k * 7, 4, 6);
          }
          // 헤드 — 좀 더 크게
          ctx.globalAlpha = 1;
          ctx.fillStyle = '#ffffff'; ctx.fillRect(s.x - 4, my - 4, 8, 8);
          ctx.fillStyle = '#ffe070';
          ctx.fillRect(s.x - 6, my - 1, 12, 2);
          ctx.fillRect(s.x - 1, my - 6, 2, 12);
          // 그림자
          ctx.fillStyle = `rgba(0, 0, 0, ${0.2 + progress * 0.3})`;
          ctx.beginPath(); ctx.arc(s.x, s.y, 4 + progress * 8, 0, Math.PI*2); ctx.fill();
        }
        for (const f of ab.flashes) { const t = 1 - f.life / 14; glowBurst(f.x, f.y, f.r * t, f.life / 14, '#ffe070'); }
        ctx.globalAlpha = 1;
      },
    },

    timeStop: {
      name: '시간정지', baseCost: 90, color: '#dde0ff',
      desc: lv => `매 주기 모든 적 ${(0.7+lv*0.15).toFixed(1)}s 정지`,
      // 일정 주기로 모든 적의 움직임을 정지시킴 (slowFrames 강제 부여)
      init(ab) { ab.cooldown = 240; ab.fxLife = 0; },
      tick(ab) {
        if (ab.fxLife > 0) ab.fxLife--;
        if (--ab.cooldown > 0) return;
        const dur = Math.floor((0.7 + ab.level * 0.15) * 60);
        const bossDur = Math.floor(dur * 0.4);  // 보스는 슬로우만 (40% 지속), 정지 면역
        for (const e of state.enemies) {
          if (e.hp <= 0) continue;
          if (e.isBoss) {
            // 보스: 짧은 슬로우만 (시간정지 면역)
            e.slowFrames = Math.max(e.slowFrames || 0, bossDur);
          } else {
            e.slowFrames = Math.max(e.slowFrames || 0, dur);
            e.timeStopped = state.t + dur;
          }
        }
        ab.fxLife = 30;
        ab.cooldown = Math.max(160, 360 - ab.level * 18);
        shake(8, 8);
      },
      draw(ab) {
        if (ab.fxLife <= 0) return;
        const a = ab.fxLife / 30;
        // 풀스크린 번쩍임 → 가장자리 비네팅 효과로 변경 (눈 부담 ↓)
        ctx.globalAlpha = a * 0.18;
        const grad = ctx.createRadialGradient(CX, CY, CX * 0.4, CX, CY, CX * 1.1);
        grad.addColorStop(0, 'rgba(221, 224, 255, 0)');
        grad.addColorStop(1, '#dde0ff');
        ctx.fillStyle = grad;
        ctx.fillRect(0, 0, W, H);
        ctx.globalAlpha = 1;
      },
    },

    clone: {
      name: '분신', baseCost: 80, color: '#ffaaff',
      desc: lv => `${1+Math.floor(lv/2)}개 분신 타워 · ${(4+lv).toFixed(0)}s 지속`,
      // 임시 분신 타워가 옆에 생겨서 같이 사격
      init(ab) { ab.clones = []; ab.spawnCD = 60; },
      tick(ab) {
        for (const c of ab.clones) {
          c.life--;
          c.fireCD--;
          if (c.fireCD <= 0) {
            // 가장 가까운 적
            let t = null, best = Infinity;
            for (const e of state.enemies) {
              if (e.hp <= 0) continue;
              const [ex, ey] = enemyXY(e);
              const d2 = (c.x-ex)*(c.x-ex) + (c.y-ey)*(c.y-ey);
              if (d2 < best) { best = d2; t = e; }
            }
            if (t) {
              const [tx, ty] = enemyXY(t);
              const ang = Math.atan2(ty - c.y, tx - c.x);
              state.bullets.push({
                x: c.x, y: c.y,
                vx: Math.cos(ang) * 7, vy: Math.sin(ang) * 7,
                dmg: 2 + ab.level, life: 80, color: '#ffaaff',
                target: t, leader: null, offsetAngle: 0,
                sourceId: state.currentAbilityId || null,
              });
              c.fireCD = 22;
            }
          }
        }
        compactInPlace(ab.clones, _alivePredLife);
        if (--ab.spawnCD > 0) return;
        const want = 1 + Math.floor(ab.level / 2);
        if (ab.clones.length < want) {
          const dur = Math.floor((4 + ab.level) * 60);
          const a = Math.random() * Math.PI * 2;
          ab.clones.push({
            x: CX + Math.cos(a) * 50, y: CY + Math.sin(a) * 50,
            life: dur, fireCD: 0,
          });
          ab.spawnCD = 240;
        } else ab.spawnCD = 60;
      },
      draw(ab) {
        for (const c of ab.clones) {
          const alpha = Math.min(1, c.life / 30) * 0.85;
          ctx.globalAlpha = alpha;
          // 타워 미니 버전
          ctx.fillStyle = 'rgba(255, 170, 255, 0.20)';
          ctx.beginPath(); ctx.arc(c.x, c.y, 16, 0, Math.PI*2); ctx.fill();
          ctx.fillStyle = '#5a2a5a'; ctx.fillRect(c.x - 8, c.y - 8, 16, 16);
          ctx.fillStyle = '#ffaaff'; ctx.fillRect(c.x - 6, c.y - 6, 12, 12);
          ctx.fillStyle = '#ffeeff'; ctx.fillRect(c.x - 2, c.y - 2, 4, 4);
          ctx.globalAlpha = 1;
        }
      },
    },

    magnet: {
      name: '자석', baseCost: 70, color: '#ffaa44',
      desc: lv => `${(2+lv*0.3).toFixed(1)}s 마다 한 곳으로 집결 + 폭발 · DMG ${10+lv*6}`,
      // 일정 주기로 무작위 위치에 자장 생성 → 적 끌어모음 → 폭발
      init(ab) { ab.cooldown = 180; ab.events = []; },
      tick(ab) {
        const dmg = 10 + ab.level * 6;   // ⚖ v269 — DPS 4→13 (집결 광역기 보강)
        const pullR = 140 + ab.level * 12;
        for (const ev of ab.events) {
          ev.t++;
          // 단계 1: 끌어당김 (0~60 프레임)
          if (ev.t <= 60) {
            for (const e of state.enemies) {
              if (e.hp <= 0) continue;
              const [ex, ey] = enemyXY(e);
              const dx = ev.x - ex, dy = ev.y - ey;
              const d = Math.hypot(dx, dy);
              if (d < pullR && d > 5) {
                const sp = (1 - d / pullR) * 3.5;
                const newEx = ex + (dx/d) * sp;
                const newEy = ey + (dy/d) * sp;
                e.angle = Math.atan2(newEy - CY, newEx - CX);
                e.radius = Math.hypot(newEx - CX, newEy - CY);
                e.targetRadius = e.radius; e._xyT = -1; // 🚀 위치 메모 무효화
              }
            }
          }
          // 단계 2: 폭발 (60 프레임에 1회)
          if (ev.t === 60) {
            for (const e of state.enemies) {
              if (e.hp <= 0) continue;
              const [ex, ey] = enemyXY(e);
              if ((ev.x-ex)*(ev.x-ex) + (ev.y-ey)*(ev.y-ey) < (pullR * 0.6) * (pullR * 0.6)) {
                damageEnemy(e, dmg);
                spawnParticles(ex, ey, '#ffaa44', 4);
              }
            }
            shake(10, 8);
          }
        }
        compactInPlace(ab.events, e => e.t < 80);
        if (--ab.cooldown > 0) return;
        const a = Math.random() * Math.PI * 2;
        const r = 60 + Math.random() * (ARENA_R - 100);
        ab.events.push({ x: CX + Math.cos(a) * r, y: CY + Math.sin(a) * r, t: 0 });
        ab.cooldown = Math.max(80, Math.floor((2 + ab.level * 0.3) * 60));   // ⚖ v269 — 7초→4.4초
      },
      draw(ab) {
        const pullR = 140 + ab.level * 12;
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        for (const ev of ab.events) {
          if (ev.t < 60) {
            const prog = ev.t / 60;
            // 수축하는 자장 링
            ctx.globalAlpha = 0.25 + prog * 0.35; ctx.strokeStyle = '#ffaa44'; ctx.lineWidth = 2;
            ctx.beginPath(); ctx.arc(ev.x, ev.y, pullR * (1 - prog * 0.3), 0, Math.PI*2); ctx.stroke();
            // 안쪽으로 빨려드는 글로우 입자
            for (let k = 0; k < 8; k++) {
              const pa = state.t * 0.16 + k * (Math.PI * 2 / 8), pr = pullR*(1-prog*0.55) * (0.5 + 0.4*Math.sin(state.t*0.05+k));
              ctx.globalAlpha = 0.5 + 0.3*Math.sin(state.t*0.06+k); ctx.fillStyle = '#ffd070';
              ctx.beginPath(); ctx.arc(ev.x + Math.cos(pa)*pr, ev.y + Math.sin(pa)*pr, 1.8, 0, 7); ctx.fill();
            }
            // 점점 밝아지는 코어
            ctx.globalAlpha = 0.5 + prog*0.5;
            const cg = ctx.createRadialGradient(ev.x, ev.y, 0, ev.x, ev.y, 8 + prog*6);
            cg.addColorStop(0, '#fff0c0'); cg.addColorStop(1, 'rgba(255,170,68,0)');
            ctx.fillStyle = cg; ctx.beginPath(); ctx.arc(ev.x, ev.y, 8 + prog*6, 0, Math.PI*2); ctx.fill();
          } else {
            // 폭발 버스트 (블룸 + 링)
            const t = (ev.t - 60) / 20, a = 1 - t;
            ctx.globalAlpha = a * 0.5;
            const g = ctx.createRadialGradient(ev.x, ev.y, 0, ev.x, ev.y, pullR*0.6*t);
            g.addColorStop(0, 'rgba(255,224,140,0.7)'); g.addColorStop(0.5, 'rgba(255,170,68,0.3)'); g.addColorStop(1, 'rgba(255,170,68,0)');
            ctx.fillStyle = g; ctx.beginPath(); ctx.arc(ev.x, ev.y, pullR*0.6*t, 0, Math.PI*2); ctx.fill();
            ctx.globalAlpha = a; ctx.strokeStyle = '#ffd070'; ctx.lineWidth = 2.5*(1-t*0.5); ctx.beginPath(); ctx.arc(ev.x, ev.y, pullR*0.6*t, 0, Math.PI*2); ctx.stroke();
          }
        }
        ctx.restore(); ctx.globalAlpha = 1;
      },
    },

    railgun: {
      name: '레일건', baseCost: 95, color: '#88eeff',
      desc: lv => `차징 거대 빔 · DMG ${15+lv*8} · 직선 관통`,
      // 차징 시간 동안 시각 표시 → 발사 시 가장 적 많은 라인으로 거대 빔
      init(ab) { ab.cooldown = 90; ab.chargeFrames = 0; ab.fireFx = 0; ab.fireAng = 0; ab.fireDuration = 14; },
      tick(ab) {
        if (ab.fireFx > 0) ab.fireFx--;
        if (ab.chargeFrames > 0) {
          ab.chargeFrames--;
          if (ab.chargeFrames === 0) {
            // 발사 — 가장 가까운 적 방향
            const target = findNearestEnemy(ARENA_R + 100);
            if (target) {
              const [tx, ty] = enemyXY(target);
              const ang = Math.atan2(ty - CY, tx - CX);
              const len = ARENA_R + 20;
              const ex = CX + Math.cos(ang) * len, ey = CY + Math.sin(ang) * len;
              const dmg = 15 + ab.level * 8;
              for (const e of state.enemies) {
                if (e.hp <= 0) continue;
                const [px, py] = enemyXY(e);
                if (distPointSegmentSq(px, py, CX, CY, ex, ey) < 256) {  // 두꺼운 빔 (16px)
                  damageEnemy(e, dmg);
                  spawnParticles(px, py, '#88eeff', 6);
                }
              }
              ab.fireAng = ang;
              ab.fireFx = ab.fireDuration;
              shake(18, 12);
            }
            ab.cooldown = Math.max(100, 180 - ab.level * 6);
          }
        }
        if (ab.chargeFrames > 0) return;
        if (--ab.cooldown > 0) return;
        // 차징 시작
        ab.chargeFrames = 60;
      },
      draw(ab) {
        // 차징 시각 (회전 입자가 타워로 모임)
        if (ab.chargeFrames > 0) {
          const prog = 1 - ab.chargeFrames / 60;
          for (let k = 0; k < 8; k++) {
            const pa = state.t * 0.15 + k * (Math.PI * 2 / 8);
            const pr = 60 * (1 - prog) + 30;
            ctx.fillStyle = `rgba(136, 238, 255, ${0.4 + prog * 0.5})`;
            ctx.fillRect(CX + Math.cos(pa) * pr - 1, CY + Math.sin(pa) * pr - 1, 3, 3);
          }
          // 차징 게이지 원
          ctx.strokeStyle = '#88eeff';
          ctx.lineWidth = 2;
          ctx.beginPath();
          ctx.arc(CX, CY, 28, -Math.PI/2, -Math.PI/2 + prog * Math.PI * 2);
          ctx.stroke();
        }
        // 발사 빔
        if (ab.fireFx > 0) {
          const a = ab.fireFx / ab.fireDuration;
          const len = ARENA_R + 20;
          const ex = CX + Math.cos(ab.fireAng) * len;
          const ey = CY + Math.sin(ab.fireAng) * len;
          ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.lineCap = 'round';
          ctx.globalAlpha = a * 0.3; ctx.strokeStyle = '#88eeff'; ctx.lineWidth = 28;
          ctx.beginPath(); ctx.moveTo(CX, CY); ctx.lineTo(ex, ey); ctx.stroke();
          ctx.globalAlpha = a * 0.85; ctx.lineWidth = 14; ctx.stroke();
          ctx.globalAlpha = a; ctx.strokeStyle = '#ffffff'; ctx.lineWidth = 4; ctx.stroke();
          ctx.restore(); ctx.globalAlpha = 1;
        }
      },
    },

    fury: {
      name: '분노', baseCost: 60, color: '#ff4466',
      desc: lv => `활성 적 5마리당 데미지 +${lv*5}% (모든 능력 영향)`,
      // 패시브 — 적 수에 비례 데미지 증가. damageEnemy에서 알아서 적용됨.
      init(ab) {},
      tick(ab) {
        if (!state.metaMods) return;
        const perma = 1 + getAbilityPermaBonus('fury');   // 🌟 영구강화
        const enemyCount = state.enemies.length;
        const bonus = Math.floor(enemyCount / 5) * (ab.level * 0.05) * perma;
        // 🛡 v256 — additive stacking (패시브 + 콤보 동시 보유 시 합산)
        state.metaMods.furyBonus += bonus;
      },
      draw(ab) {
        // 타워 주변 빨간 오라 (적 많을수록 진해짐)
        if (!state.metaMods || !state.metaMods.furyBonus) return;
        const intensity = Math.min(1, state.metaMods.furyBonus * 4);
        if (intensity < 0.1) return;
        ctx.fillStyle = `rgba(255, 68, 102, ${intensity * 0.25})`;
        ctx.beginPath(); ctx.arc(CX, CY, 40, 0, Math.PI*2); ctx.fill();
      },
    },

    reaper: {
      name: '수확자', baseCost: 100, color: '#9966ff',
      desc: lv => `HP ${8+lv*3}% 이하 적 즉사 · 처치 시 +${2+lv}G`,
      // 패시브 — 매 프레임 HP가 임계점 이하인 적 사망 처리
      init(ab) { ab.cooldown = 0; },
      tick(ab) {
        if (--ab.cooldown > 0) return;
        const perma = 1 + getAbilityPermaBonus('reaper');   // 🌟 영구강화 (임계 + 골드 ↑)
        const threshold = ((8 + ab.level * 3) / 100) * perma;
        const bonusGold = Math.ceil((2 + ab.level) * perma);
        for (const e of state.enemies) {
          if (e.hp <= 0 || e.isBoss) continue;  // 보스는 즉사 면역
          if (e.hp / e.maxHp <= threshold) {
            const [ex, ey] = enemyXY(e);
            // 즉사 표시
            state.damageNumbers.push({
              x: ex, y: ey - e.size - 4, vy: -1,
              text: 'EXECUTE', color: '#9966ff', life: 30, size: 12,
            });
            spawnParticles(ex, ey, '#9966ff', 10);
            // 💀 추가 보상 — 즉사 시 추가 골드
            state.gold += bonusGold;
            if (state.relicEffects) state.relicEffects.goldEarnedTotal = (state.relicEffects.goldEarnedTotal || 0) + bonusGold;
            state.damageNumbers.push({
              x: ex, y: ey - e.size - 14, vy: -1.2,
              text: `+${bonusGold}G`, color: '#ffd479', life: 32, size: 11,
            });
            damageEnemy(e, e.hp * 2);  // 확실히 죽임
          }
        }
        ab.cooldown = 6;  // 6프레임마다 검사 (전 적 매프레임은 무거움)
      },
    },

    // ========== 신규 액티브 능력 8종 ==========
    plasmaArc: {
      name: '플라즈마호', baseCost: 60, color: '#ff66ff',
      desc: lv => `${2+lv}마리 동시 플라즈마 호 · DMG ${2+lv}`,
      init(ab) { ab.cooldown = 50; ab.fx = []; },
      tick(ab) {
        for (const f of ab.fx) f.life--;
        compactInPlace(ab.fx, _alivePredLife);
        if (--ab.cooldown > 0) return;
        const pool = state.enemies.filter(e => e.hp > 0);
        if (pool.length === 0) return;
        pool.sort((a, b) => Math.hypot(enemyXY(a)[0]-CX, enemyXY(a)[1]-CY) - Math.hypot(enemyXY(b)[0]-CX, enemyXY(b)[1]-CY));
        const targets = pool.slice(0, 2 + ab.level);
        const dmg = 2 + ab.level;
        const points = [[CX, CY]];
        for (const t of targets) {
          const [tx, ty] = enemyXY(t);
          damageEnemy(t, dmg);
          points.push([tx, ty]);
          spawnParticles(tx, ty, '#ff66ff', 4);
        }
        ab.fx.push({ points, life: 14 });
        ab.cooldown = Math.max(35, 70 - ab.level * 3);
      },
      draw(ab) {
        ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.lineCap = 'round';
        for (const f of ab.fx) {
          const a = f.life / 14;
          for (let i = 1; i < f.points.length; i++) {
            ctx.globalAlpha = a * 0.4; ctx.strokeStyle = '#ff66ff'; ctx.lineWidth = 6;
            ctx.beginPath(); ctx.moveTo(f.points[0][0], f.points[0][1]); ctx.lineTo(f.points[i][0], f.points[i][1]); ctx.stroke();
            ctx.globalAlpha = a; ctx.strokeStyle = '#ffd6ff'; ctx.lineWidth = 1.5; ctx.stroke();
          }
        }
        ctx.restore(); ctx.globalAlpha = 1;
      },
    },
    gravityWell: {
      name: '중력장', baseCost: 75, color: '#8866cc',
      desc: lv => `사정거리 밖 적을 가장자리로 끌어당기는 중력장 · 슬로우 · DMG ${1+lv}/주기 · 반경 ${120+lv*12}`,
      // 🪐 사정거리 밖 적을 "가장자리까지만" 천천히 끌어당김(중앙으로 X) + 안에서 슬로우. 레벨업할수록 인력 ↑.
      init(ab) { ab.tickT = 20; },
      tick(ab) {
        const radius = 120 + ab.level * 12;       // 중력장 사정거리
        const pullR = radius * 1.7;               // 흡인 범위 (이 밖은 영향 없음)
        const dmg = 1 + ab.level;
        const pull = 0.35 + ab.level * 0.1;       // 끌어당기는 속도 (가장자리까지만)
        ab.tickT--;
        for (const e of state.enemies) {
          if (e.hp <= 0) continue;
          const [ex, ey] = enemyXY(e);
          const d2 = (ex - CX) * (ex - CX) + (ey - CY) * (ey - CY);
          if (d2 < radius * radius) {
            e.slowFrames = Math.max(e.slowFrames || 0, 40);   // 사정거리 안: 슬로우만 (중앙으로 더 안 당김)
          } else if (d2 < pullR * pullR && !e._cart && e.radius !== undefined) {
            // 사정거리 밖 → 가장자리(radius)까지만 끌어당김 (중앙으로는 안 끌고 감)
            e.radius = Math.max(radius, e.radius - pull);
            if (e.targetRadius !== undefined) e.targetRadius = Math.max(radius, e.targetRadius - pull);
            e._xyT = -1; // 🚀 위치 메모 무효화
          }
        }
        if (ab.tickT <= 0) {
          // 데미지 틱 간격 완화: 14 → 20프레임 (30% 너프, 클러스터 폭딜 완화)
          ab.tickT = 20;
          for (const e of state.enemies) {
            if (e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            if ((ex-CX)*(ex-CX) + (ey-CY)*(ey-CY) < radius*radius) {
              damageEnemy(e, dmg);
              spawnParticles(ex, ey, '#8866cc', 1);
            }
          }
        }
      },
      draw(ab) {
        const radius = 120 + ab.level * 12;
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        // 가장자리 비네트 (중앙 투명)
        const fg = ctx.createRadialGradient(CX, CY, radius*0.55, CX, CY, radius);
        fg.addColorStop(0, 'rgba(136,102,204,0)'); fg.addColorStop(1, 'rgba(136,102,204,0.13)');
        ctx.fillStyle = fg; ctx.beginPath(); ctx.arc(CX, CY, radius, 0, Math.PI*2); ctx.fill();
        ctx.globalAlpha = 0.3; ctx.strokeStyle = '#a888e0'; ctx.lineWidth = 1.5; ctx.beginPath(); ctx.arc(CX, CY, radius, 0, Math.PI*2); ctx.stroke();
        // 천천히 선회하는 글로우 입자
        for (let k = 0; k < 8; k++) {
          const pa = state.t * 0.03 + k * (Math.PI * 2 / 8), pr = radius * (0.5 + 0.3 * Math.sin(state.t * 0.02 + k));
          ctx.globalAlpha = 0.4 + 0.3*Math.sin(state.t*0.05+k); ctx.fillStyle = '#bfa0f0';
          ctx.beginPath(); ctx.arc(CX + Math.cos(pa)*pr, CY + Math.sin(pa)*pr, 1.8, 0, 7); ctx.fill();
        }
        ctx.restore(); ctx.globalAlpha = 1;
      },
    },
    piercer: {
      name: '관통탄', baseCost: 55, color: '#88ffaa',
      desc: lv => `${1+lv}발 관통탄 · 거리 비례 · DMG ${1+lv}~${3+lv*3}`,
      // 변경: 일반 관통 → 거리에 비례해 데미지 증가 (외곽에서 최대)
      init(ab) { ab.cooldown = 30; ab.bolts = []; },
      tick(ab) {
        const baseDmg = 1 + ab.level;
        const maxDmg = 3 + ab.level * 3;
        for (const b of ab.bolts) {
          b.x += b.vx; b.y += b.vy; b.life--;
          const dist = Math.hypot(b.x - CX, b.y - CY);
          const ratio = Math.min(1, dist / ARENA_R);
          const curDmg = baseDmg + (maxDmg - baseDmg) * ratio;
          for (const e of state.enemies) {
            if (b.hit.has(e) || e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            if ((b.x-ex)*(b.x-ex) + (b.y-ey)*(b.y-ey) < (e.size + 4)*(e.size + 4)) {
              damageEnemy(e, curDmg);
              b.hit.add(e);
              spawnParticles(ex, ey, '#88ffaa', 2);
            }
          }
          if ((b.x-CX)*(b.x-CX) + (b.y-CY)*(b.y-CY) > (ARENA_R+30)*(ARENA_R+30)) b.life = 0;
        }
        compactInPlace(ab.bolts, _alivePredLife);
        if (--ab.cooldown > 0) return;
        const n = 1 + ab.level;
        const target = findNearestEnemy(ARENA_R + 50);
        const base = target ? Math.atan2(enemyXY(target)[1]-CY, enemyXY(target)[0]-CX) : Math.random()*Math.PI*2;
        for (let i = 0; i < n; i++) {
          const ang = base + (i - (n-1)/2) * 0.15;
          ab.bolts.push({
            x: CX, y: CY,
            vx: Math.cos(ang) * 12, vy: Math.sin(ang) * 12,
            ang, life: 75, hit: new Set(),
          });
        }
        ab.cooldown = Math.max(25, 50 - ab.level * 2);
      },
      draw(ab) {
        for (const b of ab.bolts) {
          const dist = Math.hypot(b.x - CX, b.y - CY);
          const ratio = Math.min(1, dist / ARENA_R);
          const w = 4 + ratio * 5;
          ctx.save();
          ctx.translate(b.x, b.y); ctx.rotate(b.ang);
          // 거리에 따라 두꺼워지는 탄환 (시각적 변화)
          ctx.fillStyle = '#88ffaa'; ctx.fillRect(-10 - ratio * 4, -w/2, 20 + ratio * 8, w);
          ctx.fillStyle = '#ddffee'; ctx.fillRect(-8 - ratio * 3, -w/2 + 1, 16 + ratio * 6, w - 2);
          // 외곽일 때 빛나는 효과
          if (ratio > 0.6) {
            ctx.globalAlpha = (ratio - 0.6) * 2;
            ctx.fillStyle = '#ffffff'; ctx.fillRect(-4, -w/2 + 2, 8, w - 4);
            ctx.globalAlpha = 1;
          }
          ctx.restore();
        }
      },
    },
    echoBlast: {
      name: '진동파', baseCost: 60, color: '#aaee88',
      desc: lv => `3연속 진동 충격파 · DMG ${2+lv*2}`,
      // 중앙에서 사방으로 퍼지는 동심 진동 파동 (3겹 리플)
      init(ab) { ab.cooldown = 80; ab.rings = []; },
      tick(ab) {
        const dmg = 2 + ab.level * 2;
        const maxR = ARENA_R + 30;
        for (const w of ab.rings) {
          if (w.delay > 0) { w.delay--; continue; }
          w.prevR = w.r; w.r += 6.5;
          for (const e of state.enemies) {
            if (w.hit.has(e) || e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            const d = Math.hypot(ex - CX, ey - CY);
            if (d >= w.prevR - 12 && d <= w.r + 12) { damageEnemy(e, dmg); w.hit.add(e); spawnParticles(ex, ey, '#aaee88', 3); }
          }
        }
        compactInPlace(ab.rings, w => w.delay > 0 || w.r < maxR);
        if (--ab.cooldown > 0) return;
        for (let k = 0; k < 3; k++) ab.rings.push({ r: CORE_R, prevR: CORE_R, delay: k * 7, hit: new Set() });
        ab.cooldown = Math.max(60, 130 - ab.level * 6);
      },
      draw(ab) {
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        for (const w of ab.rings) {
          if (w.delay > 0) continue;
          const prog = w.r / (ARENA_R + 30), a = Math.max(0, 1 - prog);
          // 동심 진동 파동 — 소프트 밴드 + 밝은 선행 엣지
          ctx.globalAlpha = a * 0.22; ctx.strokeStyle = '#88dda0'; ctx.lineWidth = 11 - prog*6;
          ctx.beginPath(); ctx.arc(CX, CY, w.r, 0, Math.PI*2); ctx.stroke();
          ctx.globalAlpha = a * 0.6; ctx.strokeStyle = '#c8ffd8'; ctx.lineWidth = 2.4;
          ctx.beginPath(); ctx.arc(CX, CY, w.r, 0, Math.PI*2); ctx.stroke();
        }
        ctx.restore(); ctx.globalAlpha = 1;
      },
    },
    rocketSwarm: {
      name: '돌진로켓', baseCost: 70, color: '#ff8866',
      desc: lv => `적 밀집 방향 일렬 ${4+lv}발 돌격 · DMG ${4+lv*3} · 광역 ${30+lv*5}`,
      // 변경: 360도 산발 → 적이 많은 방향으로 시간차 일렬 발사
      init(ab) { ab.cooldown = 90; ab.rockets = []; ab.explosions = []; ab.queue = []; },
      tick(ab) {
        const dmg = 4 + ab.level * 3;
        const exR = 30 + ab.level * 5;
        for (const e of ab.explosions) e.life--;
        compactInPlace(ab.explosions, _alivePredLife);
        // 시간차 발사
        for (let i = ab.queue.length - 1; i >= 0; i--) {
          ab.queue[i].t++;
          if (ab.queue[i].t >= 0) {
            const launch = ab.queue.splice(i, 1)[0];
            ab.rockets.push({
              x: CX, y: CY,
              vx: Math.cos(launch.ang) * 5, vy: Math.sin(launch.ang) * 5,
              ang: launch.ang, life: 100,
            });
          }
        }
        for (const r of ab.rockets) {
          r.x += r.vx; r.y += r.vy; r.life--;
          r.vx *= 1.025; r.vy *= 1.025;
          for (const e of state.enemies) {
            if (e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            if ((r.x-ex)*(r.x-ex) + (r.y-ey)*(r.y-ey) < (e.size + 4)*(e.size + 4)) {
              for (const e2 of state.enemies) {
                if (e2.hp <= 0) continue;
                const [ex2, ey2] = enemyXY(e2);
                if ((r.x-ex2)*(r.x-ex2) + (r.y-ey2)*(r.y-ey2) < exR*exR) {
                  damageEnemy(e2, dmg);
                  spawnParticles(ex2, ey2, '#ff8866', 3);
                }
              }
              ab.explosions.push({ x: r.x, y: r.y, r: exR, life: 12 });
              r.life = 0;
              break;
            }
          }
          if ((r.x-CX)*(r.x-CX) + (r.y-CY)*(r.y-CY) > (ARENA_R+30)*(ARENA_R+30)) r.life = 0;
        }
        compactInPlace(ab.rockets, _alivePredLife);
        if (--ab.cooldown > 0) return;
        // 가장 적이 많은 방향 찾기 (8개 구역 검사)
        let bestAng = 0, bestCount = -1;
        for (let k = 0; k < 8; k++) {
          const testAng = (Math.PI * 2 / 8) * k;
          let count = 0;
          for (const e of state.enemies) {
            if (e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            const ang = Math.atan2(ey - CY, ex - CX);
            let diff = ang - testAng;
            while (diff > Math.PI) diff -= Math.PI * 2;
            while (diff < -Math.PI) diff += Math.PI * 2;
            if (Math.abs(diff) < 0.5) count++;
          }
          if (count > bestCount) { bestCount = count; bestAng = testAng; }
        }
        const n = 4 + ab.level;
        for (let i = 0; i < n; i++) {
          ab.queue.push({ ang: bestAng + (Math.random() - 0.5) * 0.18, t: -i * 8 });
        }
        ab.cooldown = Math.max(70, 130 - ab.level * 4);
      },
      draw(ab) {
        for (const r of ab.rockets) {
          const ang = Math.atan2(r.vy, r.vx);
          ctx.save();
          ctx.translate(r.x, r.y); ctx.rotate(ang);
          ctx.fillStyle = '#ff8866'; ctx.fillRect(-5, -2, 10, 4);
          ctx.fillStyle = '#ffd0a0'; ctx.fillRect(-3, -1, 6, 2);
          // 꼬리불꽃
          ctx.globalAlpha = 0.4;
          ctx.fillStyle = '#ffaa66';
          ctx.fillRect(-9, -1, 4, 2);
          ctx.globalAlpha = 1;
          ctx.restore();
        }
        for (const e of ab.explosions) {
          const t = 1 - e.life / 12;
          ctx.globalAlpha = e.life / 12;
          ctx.fillStyle = '#ff8866';
          ctx.beginPath(); ctx.arc(e.x, e.y, e.r * t, 0, Math.PI*2); ctx.fill();
        }
        ctx.globalAlpha = 1;
      },
    },
    homingBlade: {
      name: '닌자검', baseCost: 65, color: '#ffaacc',
      desc: lv => `${2+lv}회 워프 베기 · DMG ${4+lv*3}`,
      // 변경: 유도 회전검 → 적을 차례로 워프하며 베는 닌자 검
      init(ab) { ab.cooldown = 80; ab.slashes = []; },
      tick(ab) {
        for (const s of ab.slashes) s.life--;
        compactInPlace(ab.slashes, _alivePredLife);
        if (--ab.cooldown > 0) return;
        const dmg = 4 + ab.level * 3;
        const warps = 2 + ab.level;
        const hit = new Set();
        let prevX = CX, prevY = CY;
        for (let i = 0; i < warps; i++) {
          let next = null, best = Infinity;
          for (const e of state.enemies) {
            if (hit.has(e) || e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            const d2 = (ex-prevX)*(ex-prevX) + (ey-prevY)*(ey-prevY);
            if (d2 < best) { best = d2; next = e; }
          }
          if (!next) break;
          const [tx, ty] = enemyXY(next);
          damageEnemy(next, dmg);
          hit.add(next);
          ab.slashes.push({ x1: prevX, y1: prevY, x2: tx, y2: ty, life: 18 });
          spawnParticles(tx, ty, '#ffaacc', 6);
          prevX = tx; prevY = ty;
        }
        ab.cooldown = Math.max(50, 100 - ab.level * 5);
      },
      draw(ab) {
        for (const s of ab.slashes) {
          ctx.globalAlpha = s.life / 18;
          // 외곽 빛
          ctx.strokeStyle = '#ffaacc'; ctx.lineWidth = 6;
          ctx.beginPath(); ctx.moveTo(s.x1, s.y1); ctx.lineTo(s.x2, s.y2); ctx.stroke();
          // 코어
          ctx.strokeStyle = '#ffe0ee'; ctx.lineWidth = 2;
          ctx.stroke();
          // 베인 자국 표시 (끝점에 작은 +자)
          ctx.fillStyle = '#ffe0ee';
          ctx.fillRect(s.x2 - 4, s.y2 - 1, 8, 2);
          ctx.fillRect(s.x2 - 1, s.y2 - 4, 2, 8);
        }
        ctx.globalAlpha = 1;
      },
    },
    stunBomb: {
      name: '마비탄', baseCost: 70, color: '#ffe080',
      desc: lv => `최강 적 ${(2+lv*0.4).toFixed(1)}s 완전 정지 · DMG ${10+lv*7}`,
      // 변경: 광역 기절 → 단일 최강 적 강력 마비 (단일 타깃 정밀 CC). 딜 상향 + 기절 비주얼 명확화.
      init(ab) { ab.cooldown = 180; ab.bolts = []; ab.stuns = []; },
      tick(ab) {
        const dmg = 10 + ab.level * 7;
        const stunDur = Math.floor((2 + ab.level * 0.4) * 60);
        // 기절 추적 갱신 (죽음/만료 제거)
        compactInPlace(ab.stuns, _predStunAlive);
        for (const b of ab.bolts) {
          b.x += b.vx; b.y += b.vy; b.life--;
          for (const e of state.enemies) {
            if (b.hit || e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            if ((b.x-ex)*(b.x-ex) + (b.y-ey)*(b.y-ey) < (e.size + 6)*(e.size + 6)) {
              damageEnemy(e, dmg);
              // 보스는 슬로우만 (40%), 일반 적은 완전 정지
              const isBoss = e.isBoss;
              const dur = isBoss ? Math.floor(stunDur * 0.4) : stunDur;
              e.slowFrames = Math.max(e.slowFrames || 0, dur);
              if (!isBoss) e.timeStopped = state.t + stunDur;
              ab.stuns.push({ e, until: state.t + dur });
              spawnParticles(ex, ey, '#ffe080', 14);
              b.hit = true;
              b.life = 0;
              break;
            }
          }
          if ((b.x-CX)*(b.x-CX) + (b.y-CY)*(b.y-CY) > (ARENA_R+30)*(ARENA_R+30)) b.life = 0;
        }
        compactInPlace(ab.bolts, _alivePredLife);
        if (--ab.cooldown > 0) return;
        // 가장 강한 적 선택
        let target = null, best = -1;
        for (const e of state.enemies) {
          { const _s = e.isBoss ? e.hp + 1e9 : e.hp; if (_s > best) { best = _s; target = e; } }
        }
        if (!target) return;
        const [tx, ty] = enemyXY(target);
        const ang = Math.atan2(ty - CY, tx - CX);
        ab.bolts.push({
          x: CX, y: CY,
          vx: Math.cos(ang) * 9, vy: Math.sin(ang) * 9,
          ang, life: 90, hit: false,
        });
        ab.cooldown = Math.max(110, 200 - ab.level * 8);
      },
      draw(ab) {
        // 🔆 기절된 적 — 전기 마비 크래클 (효과가 보이게)
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        for (const s of ab.stuns) {
          if (!s.e || s.e.hp <= 0) continue;
          const [ex, ey] = enemyXY(s.e); const sz = (s.e.size || 10);
          // 펄스 링
          ctx.globalAlpha = 0.35 + 0.3 * Math.sin(state.t * 0.4);
          ctx.strokeStyle = '#ffe070'; ctx.lineWidth = 1.5;
          ctx.beginPath(); ctx.arc(ex, ey, sz + 5, 0, Math.PI*2); ctx.stroke();
          // 전기 호 (지그재그) 3가닥
          ctx.strokeStyle = '#fff6c0'; ctx.lineWidth = 1.2;
          for (let k = 0; k < 3; k++) {
            const a0 = state.t * 0.3 + k * 2.1; ctx.beginPath();
            for (let s2 = 0; s2 <= 4; s2++) { const aa = a0 + s2 * 0.5, rr = sz + 3 + (s2 % 2 ? 3 : -2); const px = ex + Math.cos(aa)*rr, py = ey + Math.sin(aa)*rr; s2 ? ctx.lineTo(px, py) : ctx.moveTo(px, py); }
            ctx.stroke();
          }
          // 스파크 점
          ctx.fillStyle = '#fff8c0';
          for (let k = 0; k < 3; k++) { const a = state.t * 0.5 + k * 2.1; ctx.globalAlpha = 0.4 + 0.4 * Math.sin(state.t * 0.3 + k); ctx.beginPath(); ctx.arc(ex + Math.cos(a)*(sz+6), ey + Math.sin(a)*(sz+6), 1.4, 0, Math.PI*2); ctx.fill(); }
        }
        ctx.restore(); ctx.globalAlpha = 1;
        // ⚡ 마비탄 발사체 (글로우 전기 오브 + 트레일 + 스파크)
        for (const b of ab.bolts) {
          ctx.save(); ctx.globalCompositeOperation = 'lighter';
          const tg = ctx.createLinearGradient(b.x - b.vx*3, b.y - b.vy*3, b.x, b.y);
          tg.addColorStop(0, 'rgba(255,224,128,0)'); tg.addColorStop(1, 'rgba(255,238,160,0.6)');
          ctx.strokeStyle = tg; ctx.lineWidth = 5; ctx.lineCap = 'round';
          ctx.beginPath(); ctx.moveTo(b.x - b.vx*3, b.y - b.vy*3); ctx.lineTo(b.x, b.y); ctx.stroke();
          ctx.globalAlpha = 0.9; ctx.drawImage(getGlowSprite('#ffe070'), b.x - 12, b.y - 12, 24, 24);
          ctx.strokeStyle = '#fff8d0'; ctx.lineWidth = 1.2;
          for (let k = 0; k < 4; k++) { const a = state.t * 0.6 + k * 1.6; ctx.beginPath(); ctx.moveTo(b.x, b.y); ctx.lineTo(b.x + Math.cos(a)*9, b.y + Math.sin(a)*9); ctx.stroke(); }
          ctx.restore();
          ctx.fillStyle = '#fffce0'; ctx.beginPath(); ctx.arc(b.x, b.y, 3.5, 0, Math.PI*2); ctx.fill();
        }
      },
    },
    purgeWave: {
      name: '정화광선', baseCost: 75, color: '#ffaaff',
      desc: lv => `풀스크린 정화 점멸 · DMG ${20+lv*12} · 보호막 일괄 제거`,
      // 변경: 충격파 → 풀스크린 디버프 (즉시 모든 적 데미지 + 보호막 일괄 제거)
      init(ab) { ab.cooldown = 240; ab.fxLife = 0; },
      tick(ab) {
        if (ab.fxLife > 0) ab.fxLife--;
        if (--ab.cooldown > 0) return;
        // ⚖ v269 — DMG 58→116 (풀스크린 단발 + 보호막 카운터 제 역할)
        const dmg = 20 + ab.level * 12;
        let _marked = 0;
        for (const e of state.enemies) {
          if (e.hp <= 0) continue;
          const [ex, ey] = enemyXY(e);
          if (e.shieldHp > 0) {
            e.shieldHp = 0;
            spawnParticles(ex, ey, '#ffaaff', 7);   // 보호막 산산조각
          }
          damageEnemy(e, dmg);
          // 🟣 정화 마크 — 모든 적에 소량 반짝 (캡) → "전체가 정화됨"이 보이게
          if (_marked < 40) { spawnParticles(ex, ey, '#ffd0ff', 2); _marked++; }
        }
        ab.fxLife = 32;
        shake(7, 8);
        // ⚖ v269 — 쿨다운 3.5초→2.5초 (풀스크린 빈도 ↑)
        ab.cooldown = Math.max(90, 280 - ab.level * 16);
      },
      draw(ab) {
        if (ab.fxLife <= 0) return;
        const MAX = 32;
        const a = ab.fxLife / MAX;        // 1 → 0
        const prog = 1 - a;               // 0 → 1 (파동 확산 진행)
        ctx.save();
        ctx.globalCompositeOperation = 'lighter';
        // 🌊 정화 파동 — 중앙에서 아레나 끝까지 퍼지는 동심 링 2겹 (시차)
        for (let r = 0; r < 2; r++) {
          const rp = prog - r * 0.16;
          if (rp <= 0 || rp >= 1) continue;
          ctx.globalAlpha = (1 - rp) * 0.5;
          ctx.strokeStyle = '#ffd6ff';
          ctx.lineWidth = 7 * (1 - rp) + 2;
          ctx.beginPath(); ctx.arc(CX, CY, rp * ARENA_R * 1.12, 0, Math.PI * 2); ctx.stroke();
        }
        // 중앙 소프트 플래시 (초반 강 → 빠르게 감쇠)
        ctx.globalAlpha = a * a * 0.28;
        const cg = ctx.createRadialGradient(CX, CY, 0, CX, CY, ARENA_R * 0.75);
        cg.addColorStop(0, 'rgba(255,215,255,0.7)'); cg.addColorStop(1, 'rgba(255,170,255,0)');
        ctx.fillStyle = cg; ctx.beginPath(); ctx.arc(CX, CY, ARENA_R * 0.75, 0, Math.PI * 2); ctx.fill();
        ctx.restore();
        // 가장자리 비네팅 (은은 — 눈 부담 ↓)
        ctx.globalAlpha = a * 0.20;
        const grad = ctx.createRadialGradient(CX, CY, CX * 0.5, CX, CY, CX * 1.15);
        grad.addColorStop(0, 'rgba(255, 170, 255, 0)');
        grad.addColorStop(1, '#ffaaff');
        ctx.fillStyle = grad;
        ctx.fillRect(0, 0, W, H);
        ctx.globalAlpha = 1;
      },
    },

    // ========== 패시브 능력 — 시각 효과 없음, state.metaMods 통해 전체 게임플레이에 영향 ==========
    precision: {
      name: '정확', isPassive: true, baseCost: 60, color: '#a0d8ff',
      desc: lv => `모든 데미지 +${lv*10}%`,
      init() {},
      tick(ab) {
        if (!state.metaMods) return;
        const perma = 1 + getAbilityPermaBonus('precision');   // 🌟 영구강화
        // 🛡 v256 — additive stacking
        state.metaMods.precisionBonus += ab.level * 0.10 * perma;
      },
    },
    haste: {
      name: '신속', isPassive: true, baseCost: 65, color: '#80ffd0',
      desc: lv => `액티브 능력 쿨다운 -${lv*4}%`,
      init() {},
      tick(ab) {
        // 다른 액티브 능력의 쿨다운을 추가로 감소
        const perma = 1 + getAbilityPermaBonus('haste');   // 🌟 영구강화
        const mul = ab.level * 0.04 * perma / 60;
        for (const a of state.tower.abilities) {
          if (a === ab) continue;
          const d = ABILITY_DEFS[a.id];
          if (d.isPassive) continue;
          if (a.cooldown !== undefined && a.cooldown > 0) a.cooldown *= (1 - mul);
        }
      },
    },
    frenzy: {
      name: '광폭', isPassive: true, baseCost: 70, color: '#ff7777',
      desc: lv => `처치 시 3초간 데미지 +${lv*9}%`,
      init(ab) { ab.frames = 0; },
      tick(ab) {
        if (state.frenzyTrigger) { ab.frames = 180; state.frenzyTrigger = false; }
        const perma = 1 + getAbilityPermaBonus('frenzy');   // 🌟 영구강화
        if (ab.frames > 0) {
          ab.frames--;
          // 🛡 v256 — additive stacking (frame-reset 와 함께 동작 — 활성 시만 contribute)
          if (state.metaMods) state.metaMods.frenzyBonus += ab.level * 0.09 * perma;
        }
        // frames 0 일 땐 contribute 안 함 → resetSharedPassiveSlots 에서 자동 0
      },
    },
    vampiric: {
      name: '흡혈', isPassive: true, baseCost: 65, color: '#cc6699',
      desc: lv => `처치 시 +${lv} 골드 (고정)`,
      init() {},
      tick(ab) {
        if (!state.metaMods) return;
        const perma = 1 + getAbilityPermaBonus('vampiric');   // 🌟 영구강화
        // 💉 v276 — %→고정 +N 전환: 처치당 +lv 골드 (초반/후반 일관, 레벨업 체감 명확)
        state.metaMods.vampiricFlat += ab.level * perma;
      },
    },
    fortune: {
      name: '행운', isPassive: true, baseCost: 60, color: '#ffcc66',
      desc: lv => `처치 시 ${lv*5}% 확률 보너스 점수 (×5)`,
      init() {},
      tick(ab) {
        if (!state.metaMods) return;
        const perma = 1 + getAbilityPermaBonus('fortune');   // 🌟 영구강화 (점수 확률 +%)
        // 🛡 v256 — additive stacking (fortune + 행운연쇄 합산)
        state.metaMods.fortuneChance += ab.level * 0.05 * perma;
      },
    },
    mastery: {
      name: '숙련', isPassive: true, baseCost: 75, color: '#88aaff',
      desc: lv => `보유 액티브 수 × ${lv*4}% 데미지`,
      init() {},
      tick(ab) {
        if (!state.metaMods) return;
        const perma = 1 + getAbilityPermaBonus('mastery');   // 🌟 영구강화
        const n = state.tower.abilities.filter(a => !ABILITY_DEFS[a.id].isPassive).length;
        // 🛡 v256 — additive stacking
        state.metaMods.masteryBonus += n * ab.level * 0.04 * perma;
      },
    },
    scholar: {
      name: '연구', isPassive: true, baseCost: 60, color: '#bb99cc',
      desc: lv => `강화 비용 -${lv*4}%`,
      init() {},
      tick(ab) {
        if (!state.metaMods) return;
        const perma = 1 + getAbilityPermaBonus('scholar');   // 🌟 영구강화 (할인 +%)
        const discount = ab.level * 0.04 * perma;
        // 🛡 v256 — multiplicative stacking (scholar + scholarSnipe 곱연산 — 둘 다 효과 발휘)
        //   scholarMul (1=full cost) → 각 source 의 (1-discount) 를 곱해서 누적
        //   최종 cap 은 enhanceCost 에서 Math.max(0.45, ...) 로 처리됨
        state.metaMods.scholarMul *= (1 - Math.min(0.55, discount));
      },
    },
    ironwill: {
      name: '강철의지', isPassive: true, baseCost: 70, color: '#aaaaaa',
      desc: lv => `보스 추가 데미지 +${lv*15}%`,
      init() {},
      tick(ab) {
        if (!state.metaMods) return;
        const perma = 1 + getAbilityPermaBonus('ironwill');   // 🌟 영구강화
        // 🛡 v256 — additive stacking
        state.metaMods.ironwillBonus += ab.level * 0.15 * perma;
      },
    },
    executioner: {
      name: '처형', isPassive: true, baseCost: 70, color: '#cc4466',
      desc: lv => `50% 이하 HP 적에게 데미지 +${lv*15}%`,
      init() {},
      tick(ab) {
        if (!state.metaMods) return;
        const perma = 1 + getAbilityPermaBonus('executioner');   // 🌟 영구강화
        // 🛡 v256 — additive stacking
        state.metaMods.executionerBonus += ab.level * 0.15 * perma;
      },
    },
    resilience: {
      name: '불굴', isPassive: true, baseCost: 65, color: '#88cc88',
      // 50처치당 1스택 (lv 1당 +0.5%, 최대 lv당 +15%) — 과한 cap 너프
      desc: lv => `누적 50처치마다 데미지 +${(lv*0.5).toFixed(1)}% (최대 +${lv*15}%)`,
      init(ab) { ab.bonus = 0; },
      tick(ab) {
        if (!state.metaMods) return;
        const perma = 1 + getAbilityPermaBonus('resilience');   // 🌟 영구강화
        const stacks = Math.floor((state.totalKills || 0) / 50);
        const perStack = ab.level * 0.005 * perma;
        const max = ab.level * 0.15 * perma;
        ab.bonus = Math.min(max, stacks * perStack);
        // 🛡 v256 — additive stacking
        state.metaMods.resilienceBonus += ab.bonus;
      },
    },

    // ========== 조합 능력 (랜덤 풀에는 없음 — 두 기본 능력이 만나면 자동 합쳐짐) ==========
    shotgunBurst: {
      name: '기관산탄총', isCombo: true, baseCost: 140, color: '#ff8866',
      desc: lv => `폭발탄 ${8+lv*2}발 연사 · DMG ${5+lv*3} · 폭발 ${45+lv*8}`,
      // 매우 빠른 쿨다운으로 폭발탄 부채꼴을 쏟아부음. 각 탄환이 광역 폭발.
      init(ab) { ab.cooldown = 14; ab.explosions = []; },
      tick(ab) {
        for (const e of ab.explosions) e.life--;
        compactInPlace(ab.explosions, _alivePredLife);
        if (--ab.cooldown > 0) return;
        const target = findNearestEnemy(ARENA_R + 50);
        if (!target) return;
        const [tx, ty] = enemyXY(target);
        const base = Math.atan2(ty - CY, tx - CX);
        const n = 8 + ab.level * 2;
        // 🏰 TD: 좁은 spread (0.30π ≈ 54°) — 단일 줄 적 명중률 ↑
        // 클래식: 기존 spread (0.55π ≈ 99°)
        const spread = tdIsDefense() ? Math.PI * 0.30 : Math.PI * 0.55;
        const exR = 45 + ab.level * 8;
        for (let i = 0; i < n; i++) {
          const off = n === 1 ? 0 : (-spread/2 + spread * (i/(n-1)));
          state.bullets.push({
            x: CX, y: CY,
            vx: Math.cos(base+off)*7.5, vy: Math.sin(base+off)*7.5,
            dmg: 5 + ab.level * 3, life: 85, color: '#ff8866',
            target: null, leader: null, offsetAngle: 0,
            explodeRadius: exR, explodeAb: ab,
            size: 3, glow: true, tier: 'combo',
            sourceId: state.currentAbilityId || null,
          });
        }
        ab.cooldown = Math.max(14, 28 - ab.level * 2);
      },
      draw(ab) {
        for (const e of ab.explosions) {
          const t = 1 - e.life / 12;
          ctx.globalAlpha = e.life / 12;
          // 외곽 불꽃
          ctx.fillStyle = '#ff8866';
          ctx.beginPath(); ctx.arc(e.x, e.y, e.r * t, 0, Math.PI*2); ctx.fill();
          // 중심 화염
          ctx.globalAlpha = (e.life / 12) * 0.8;
          ctx.fillStyle = '#ffe080';
          ctx.beginPath(); ctx.arc(e.x, e.y, e.r * t * 0.55, 0, Math.PI*2); ctx.fill();
        }
        ctx.globalAlpha = 1;
      },
    },

    precisionBurst: {
      name: '정밀연사', isCombo: true, baseCost: 120, color: '#cce8ff',
      desc: lv => `${3+lv}발 전탄 유도 미니건 · DMG ${4+lv*2}`,
      // 미니건 스타일. 매우 빠른 쿨다운으로 전탄 유도 미사일 다발 사출.
      init(ab) { ab.cooldown = 8; },
      tick(ab) {
        if (--ab.cooldown > 0) return;
        const target = findNearestEnemy(ARENA_R + 50);
        if (!target) return;
        const [tx, ty] = enemyXY(target);
        const base = Math.atan2(ty - CY, tx - CX);
        const n = 3 + ab.level;
        const spread = Math.min(Math.PI * 0.5, n * 0.18);
        for (let i = 0; i < n; i++) {
          const off = n === 1 ? 0 : (-spread/2 + spread * (i/(n-1)));
          const b = fireBullet(base + off, 4 + ab.level * 2, '#cce8ff', target);
          b.size = 3; b.glow = true;
        }
        ab.cooldown = Math.max(8, 18 - ab.level);
      },
    },

    chainStorm: {
      name: '연쇄낙뢰', isCombo: true, baseCost: 140, color: '#ffee88',
      desc: lv => `${2+lv}곳 낙뢰 + ${3+lv}회 연쇄 · DMG ${8+lv*4}`,
      // 동시에 여러 적에게 거대 낙뢰가 떨어지고, 각 낙뢰가 길게 연쇄.
      init(ab) { ab.cooldown = 55; ab.bolts = []; ab.chains = []; },
      tick(ab) {
        for (const b of ab.bolts) b.life--;
        compactInPlace(ab.bolts, _alivePredLife);
        for (const c of ab.chains) c.life--;
        compactInPlace(ab.chains, _alivePredLife);
        if (--ab.cooldown > 0) return;
        const strikes = 2 + ab.level;
        const chainCount = 3 + ab.level;
        const dmg = 8 + ab.level * 4;
        const pool = state.enemies.filter(e => e.hp > 0);
        for (let i = 0; i < strikes && pool.length > 0; i++) {
          const idx = Math.floor(Math.random() * pool.length);
          const target = pool.splice(idx, 1)[0];
          const [tx, ty] = enemyXY(target);
          damageEnemy(target, dmg);
          spawnParticles(tx, ty, '#ffee88', 10);
          ab.bolts.push({ x: tx, y: ty, life: 14 });
          const hit = new Set([target]);
          let current = target;
          const points = [[tx, ty]];
          for (let j = 0; j < chainCount; j++) {
            let next = null, best = 200*200;  // 더 멀리 연쇄
            const [cx, cy] = enemyXY(current);
            for (const e of state.enemies) {
              if (hit.has(e) || e.hp <= 0) continue;
              const [ex, ey] = enemyXY(e);
              const d2 = (ex-cx)*(ex-cx) + (ey-cy)*(ey-cy);
              if (d2 < best) { best = d2; next = e; }
            }
            if (!next) break;
            const [nx, ny] = enemyXY(next);
            damageEnemy(next, dmg);
            hit.add(next); current = next;
            points.push([nx, ny]);
            spawnParticles(nx, ny, '#88e0ff', 5);
          }
          if (points.length > 1) ab.chains.push({ points, life: 14 });
        }
        ab.cooldown = Math.max(30, 60 - ab.level * 4);
      },
      draw(ab) {
        ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.lineCap = 'round';
        // 들쭉날쭉 빛나는 낙뢰
        for (const b of ab.bolts) {
          const a = b.life / 14, seg = 8, amp = 8;
          const zig = (lw, col, al) => { ctx.globalAlpha = al; ctx.strokeStyle = col; ctx.lineWidth = lw; ctx.beginPath(); ctx.moveTo(b.x, 0);
            for (let s=1;s<=seg;s++){ const yy=b.y*s/seg, xx=b.x+Math.sin(s*1.8+b.x)*amp*(1-s/seg); ctx.lineTo(xx,yy); } ctx.stroke(); };
          zig(7, '#ffee88', a*0.4); zig(3, '#fff6b0', a*0.85); zig(1.3, '#ffffff', a);
        }
        // 가산 글로우 연쇄 (외곽+코어)
        for (const c of ab.chains) {
          const a = c.life / 14;
          const path = () => { ctx.beginPath(); ctx.moveTo(c.points[0][0], c.points[0][1]); for (let i=1;i<c.points.length;i++) ctx.lineTo(c.points[i][0], c.points[i][1]); ctx.stroke(); };
          ctx.globalAlpha = a*0.35; ctx.strokeStyle = '#88e0ff'; ctx.lineWidth = 7; path();
          ctx.globalAlpha = a*0.85; ctx.strokeStyle = '#bff0ff'; ctx.lineWidth = 3; path();
          ctx.globalAlpha = a;      ctx.strokeStyle = '#ffffff'; ctx.lineWidth = 1.4; path();
          for (const p of c.points){ ctx.globalAlpha = a*0.7; ctx.fillStyle='#dff6ff'; ctx.beginPath(); ctx.arc(p[0],p[1],2.2,0,7); ctx.fill(); }
        }
        ctx.restore(); ctx.globalAlpha = 1;
      },
    },

    frostNova: {
      name: '빙결파동', isCombo: true, baseCost: 130, color: '#aaccff',
      desc: lv => `절대빙결 충격파 · DMG ${5+lv*3} · ${((200+lv*40)/60).toFixed(1)}s 슬로우`,
      // 빠른 쿨다운으로 강력한 빙결 파동을 연달아 발사. 데미지 + 매우 긴 슬로우.
      init(ab) { ab.cooldown = 30; ab.waves = []; },
      tick(ab) {
        const dmg = 5 + ab.level * 3;
        const slowDur = 200 + ab.level * 40;
        // 🏰 TD: 사거리 캡
        const maxR = tdMaxEffectRadius(ARENA_R + 30);
        for (const w of ab.waves) {
          w.prevR = w.r; w.r += 6;
          for (const e of state.enemies) {
            if (w.hit.has(e) || e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            const d = Math.hypot(ex - CX, ey - CY);
            if (d >= w.prevR - 12 && d <= w.r + 12 && d <= maxR) {
              damageEnemy(e, dmg);
              e.slowFrames = Math.max(e.slowFrames || 0, slowDur);
              spawnParticles(ex, ey, '#aaccff', 6);
              w.hit.add(e);
            }
          }
        }
        compactInPlace(ab.waves, w => w.r < maxR);
        if (--ab.cooldown > 0) return;
        ab.waves.push({ r: CORE_R, prevR: CORE_R, hit: new Set() });
        ab.cooldown = Math.max(28, 60 - ab.level * 4);
      },
      draw(ab) {
        for (const w of ab.waves) {
          const a = Math.max(0, 1 - w.r / (ARENA_R + 30));
          // 외곽 두꺼운 링
          ctx.globalAlpha = a;
          ctx.strokeStyle = '#aaccff'; ctx.lineWidth = 6;
          ctx.beginPath(); ctx.arc(CX, CY, w.r, 0, Math.PI*2); ctx.stroke();
          // 내부 빛
          ctx.globalAlpha = a * 0.6;
          ctx.strokeStyle = '#e0eeff'; ctx.lineWidth = 2;
          ctx.stroke();
        }
        ctx.globalAlpha = 1;
      },
    },

    twinBeam: {
      name: '쌍둥이빔', isCombo: true, baseCost: 150, color: '#ff77cc',
      desc: lv => `십자 회전 거대빔 · DMG ${4+lv*2}/tick`,
      // 십자 빔이 매우 두꺼워지고 데미지 틱이 빈번해짐. 회전 속도도 빠름.
      init(ab) { ab.angle = 0; ab.hits = new Map(); },
      tick(ab) {
        const rotSpeed = 0.022 + ab.level * 0.005;
        ab.angle += rotSpeed;
        for (const [e, cd] of ab.hits) {
          if (cd <= 1 || e.hp <= 0) ab.hits.delete(e);
          else ab.hits.set(e, cd - 1);
        }
        const len = ARENA_R + 20;
        const dmg = 4 + ab.level * 2;
        const halfThick = 18;
        for (let k = 0; k < 2; k++) {
          const ang = ab.angle + k * Math.PI / 2;
          const ex = CX + Math.cos(ang) * len;
          const ey = CY + Math.sin(ang) * len;
          const ex2 = CX - Math.cos(ang) * len;
          const ey2 = CY - Math.sin(ang) * len;
          for (const e of state.enemies) {
            if (ab.hits.has(e) || e.hp <= 0) continue;
            const [px, py] = enemyXY(e);
            if (distPointSegmentSq(px, py, ex2, ey2, ex, ey) < halfThick*halfThick) {
              damageEnemy(e, dmg);
              ab.hits.set(e, 10);  // 더 빠른 틱
              spawnParticles(px, py, '#ff77cc', 3);
            }
          }
        }
      },
      draw(ab) {
        const len = ARENA_R + 20;
        for (let k = 0; k < 2; k++) {
          const ang = ab.angle + k * Math.PI / 2;
          const ex = CX + Math.cos(ang) * len, ey = CY + Math.sin(ang) * len;
          const ex2 = CX - Math.cos(ang) * len, ey2 = CY - Math.sin(ang) * len;
          // 광역 광채 (옅음)
          ctx.globalAlpha = 0.25;
          ctx.strokeStyle = '#ff77cc'; ctx.lineWidth = 18;
          ctx.beginPath(); ctx.moveTo(ex2, ey2); ctx.lineTo(ex, ey); ctx.stroke();
          // 두꺼운 본체
          ctx.globalAlpha = 0.85;
          ctx.strokeStyle = '#ff77cc'; ctx.lineWidth = 8;
          ctx.stroke();
          // 코어
          ctx.globalAlpha = 1;
          ctx.strokeStyle = '#ffe0f5'; ctx.lineWidth = 3;
          ctx.stroke();
        }
        ctx.globalAlpha = 1;
      },
    },

    stormOrbit: {
      name: '폭풍궤도', isCombo: true, baseCost: 150, color: '#88ffe0',
      desc: lv => `${3+lv}개 거대 폭풍 위성 · DMG ${4+lv*3} · 강슬로우`,
      // 각 위성이 폭풍 필드(반경 45)를 끌고 다님. 그 필드 안의 모든 적에 데미지+슬로우.
      init(ab) {
        ab.angle = 0; ab.radius = 150; ab.targetRadius = 150; ab.hits = new Map();
      },
      tick(ab) {
        const rotSpeed = 0.05 + ab.level * 0.009;
        ab.angle += rotSpeed;
        const target = findNearestEnemy(ARENA_R + 100);
        if (target) {
          const [tx, ty] = enemyXY(target);
          ab.targetRadius = Math.hypot(tx - CX, ty - CY);
        }
        ab.radius += (ab.targetRadius - ab.radius) * 0.06;
        ab.radius = Math.max(50, Math.min(ARENA_R - 10, ab.radius));
        for (const [e, cd] of ab.hits) {
          if (cd <= 1 || e.hp <= 0) ab.hits.delete(e);
          else ab.hits.set(e, cd - 1);
        }
        const count = 3 + ab.level;
        const dmg = 4 + ab.level * 3;
        const reach = 45;  // 큰 폭풍 필드
        for (let i = 0; i < count; i++) {
          const a = ab.angle + (Math.PI * 2 / count) * i;
          const ox = CX + Math.cos(a) * ab.radius;
          const oy = CY + Math.sin(a) * ab.radius;
          for (const e of state.enemies) {
            if (ab.hits.has(e) || e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            const rr = e.size + reach;
            if ((ox-ex)*(ox-ex) + (oy-ey)*(oy-ey) < rr*rr) {
              damageEnemy(e, dmg);
              e.slowFrames = Math.max(e.slowFrames || 0, 120);
              ab.hits.set(e, 18);
              spawnParticles(ex, ey, '#88ffe0', 4);
            }
          }
        }
      },
      draw(ab) {
        const count = 3 + ab.level;
        const reach = 45;
        // 궤도
        ctx.strokeStyle = 'rgba(136, 255, 224, 0.12)'; ctx.lineWidth = 1;
        ctx.beginPath(); ctx.arc(CX, CY, ab.radius, 0, Math.PI*2); ctx.stroke();
        for (let i = 0; i < count; i++) {
          const a = ab.angle + (Math.PI * 2 / count) * i;
          const ox = CX + Math.cos(a) * ab.radius;
          const oy = CY + Math.sin(a) * ab.radius;
          // 거대 폭풍 필드
          ctx.fillStyle = 'rgba(136, 255, 224, 0.10)';
          ctx.beginPath(); ctx.arc(ox, oy, reach, 0, Math.PI*2); ctx.fill();
          ctx.strokeStyle = 'rgba(136, 255, 224, 0.35)'; ctx.lineWidth = 2;
          ctx.beginPath(); ctx.arc(ox, oy, reach * 0.7, 0, Math.PI*2); ctx.stroke();
          // 회전 입자
          for (let k = 0; k < 5; k++) {
            const pa = ab.angle * 3 + k * 1.2 + i;
            const pr = reach * 0.5;
            ctx.fillStyle = '#88ffe0';
            ctx.fillRect(ox + Math.cos(pa) * pr - 1, oy + Math.sin(pa) * pr - 1, 2, 2);
          }
          // 위성 본체
          ctx.fillStyle = '#1d2230'; ctx.fillRect(ox - 6, oy - 6, 12, 12);
          ctx.fillStyle = '#88ffe0'; ctx.fillRect(ox - 5, oy - 5, 10, 10);
          ctx.fillStyle = '#ddfff0'; ctx.fillRect(ox - 2, oy - 2, 4, 4);
        }
      },
    },

    steelBoomerang: {
      name: '강철부메랑', isCombo: true, baseCost: 160, color: '#ddcc88',
      desc: lv => `초중장갑 ${1+lv}개 · DMG ${35+lv*20}`,
      // 거대한 회전 도끼. 가는 길/돌아오는 길 모두 적을 관통하며 막대한 데미지.
      init(ab) { ab.cooldown = 60; ab.boomerangs = []; },
      tick(ab) {
        const dmg = 35 + ab.level * 20;
        for (const b of ab.boomerangs) {
          b.life--; b.rotation += 0.5;
          if (b.phase === 'out') {
            b.t++;
            if (b.t >= b.outDuration) { b.phase = 'in'; b.hit = new Set(); }
          } else {
            const dx = CX - b.x, dy = CY - b.y;
            const d = Math.hypot(dx, dy);
            if (d < 20) { b.life = 0; continue; }
            b.vx = (dx/d) * 6; b.vy = (dy/d) * 6;
          }
          b.x += b.vx; b.y += b.vy;
          for (const e of state.enemies) {
            if (b.hit.has(e) || e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            const r = e.size + 18;  // 큰 충돌 반경
            if ((b.x-ex)*(b.x-ex) + (b.y-ey)*(b.y-ey) < r*r) {
              damageEnemy(e, dmg);
              b.hit.add(e);
              spawnParticles(ex, ey, '#ddcc88', 8);
            }
          }
        }
        compactInPlace(ab.boomerangs, _alivePredLife);
        if (--ab.cooldown > 0) return;
        const count = 1 + ab.level;
        // 최강 적 추적
        let target = null, best = -1;
        for (const e of state.enemies) {
          { const _s = e.isBoss ? e.hp + 1e9 : e.hp; if (_s > best) { best = _s; target = e; } }
        }
        if (!target) return;
        const [tx, ty] = enemyXY(target);
        for (let i = 0; i < count; i++) {
          const ang = Math.atan2(ty - CY, tx - CX) + (i - (count-1)/2) * 0.35;
          ab.boomerangs.push({
            x: CX, y: CY,
            vx: Math.cos(ang) * 6, vy: Math.sin(ang) * 6,
            t: 0, outDuration: 45, phase: 'out',
            rotation: 0, life: 220, hit: new Set(),
          });
        }
        ab.cooldown = Math.max(50, 90 - ab.level * 4);
      },
      draw(ab) {
        for (const b of ab.boomerangs) drawSpinBoomerang(b, 14, '#e0cf90', '#ffd060');
      },
    },

    missileTurret: {
      name: '미사일터렛', isCombo: true, baseCost: 160, color: '#aacaff',
      desc: lv => `${4+lv}개 보조포 · 미사일 · DMG ${6+lv*4} · 폭발 ${50+lv*8}`,
      // 다수의 보조 포탑이 빠른 속도로 폭발 미사일을 쏟아냄.
      init(ab) { ab.angle = 0; ab.cooldowns = []; ab.missiles = []; ab.explosions = []; },
      tick(ab) {
        const count = 4 + ab.level;
        const dmg = 6 + ab.level * 4;
        const explodeR = 50 + ab.level * 8;
        while (ab.cooldowns.length < count) ab.cooldowns.push(0);
        while (ab.cooldowns.length > count) ab.cooldowns.pop();
        ab.angle += 0.005;
        for (const e of ab.explosions) e.life--;
        compactInPlace(ab.explosions, _alivePredLife);
        const radius = 55;
        // 발사
        for (let i = 0; i < count; i++) {
          if (--ab.cooldowns[i] > 0) continue;
          const a = ab.angle + (Math.PI * 2 / count) * i;
          const tx = CX + Math.cos(a) * radius;
          const ty = CY + Math.sin(a) * radius;
          let target = null, best = Infinity;
          for (const e of state.enemies) {
            if (e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            const d2 = (ex-tx)*(ex-tx) + (ey-ty)*(ey-ty);
            if (d2 < best) { best = d2; target = e; }
          }
          if (target) {
            const [tex, tey] = enemyXY(target);
            const ang = Math.atan2(tey - ty, tex - tx);
            ab.missiles.push({
              x: tx, y: ty,
              vx: Math.cos(ang) * 5, vy: Math.sin(ang) * 5,
              target, life: 180,
            });
            ab.cooldowns[i] = Math.max(18, 40 - ab.level * 2);
          }
        }
        // 미사일 이동
        for (const m of ab.missiles) {
          if (!m.target || m.target.hp <= 0) {
            let best = Infinity, t = null;
            for (const e of state.enemies) {
              if (e.hp <= 0) continue;
              const [ex, ey] = enemyXY(e);
              const d2 = (m.x-ex)*(m.x-ex) + (m.y-ey)*(m.y-ey);
              if (d2 < best) { best = d2; t = e; }
            }
            m.target = t;
          }
          if (m.target) {
            const [tx, ty] = enemyXY(m.target);
            const curAng = Math.atan2(m.vy, m.vx);
            const wantAng = Math.atan2(ty - m.y, tx - m.x);
            let diff = wantAng - curAng;
            while (diff > Math.PI) diff -= Math.PI * 2;
            while (diff < -Math.PI) diff += Math.PI * 2;
            const turn = 0.2;
            const c = Math.max(-turn, Math.min(turn, diff));
            const a = curAng + c;
            m.vx = Math.cos(a) * 5.5; m.vy = Math.sin(a) * 5.5;
          }
          m.x += m.vx; m.y += m.vy; m.life--;
          for (const e of state.enemies) {
            if (e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            if ((m.x-ex)*(m.x-ex) + (m.y-ey)*(m.y-ey) < (e.size + 3)*(e.size + 3)) {
              for (const e2 of state.enemies) {
                if (e2.hp <= 0) continue;
                const [ex2, ey2] = enemyXY(e2);
                if ((m.x-ex2)*(m.x-ex2) + (m.y-ey2)*(m.y-ey2) < explodeR*explodeR) {
                  damageEnemy(e2, dmg);
                  spawnParticles(ex2, ey2, '#aacaff', 4);
                }
              }
              ab.explosions.push({ x: m.x, y: m.y, r: explodeR, life: 14 });
              m.life = 0;
              break;
            }
          }
          if ((m.x-CX)*(m.x-CX) + (m.y-CY)*(m.y-CY) > (ARENA_R+30)*(ARENA_R+30)) m.life = 0;
        }
        compactInPlace(ab.missiles, _alivePredLife);
      },
      draw(ab) {
        const count = 4 + ab.level;
        const radius = 55;
        for (let i = 0; i < count; i++) {
          const a = ab.angle + (Math.PI * 2 / count) * i;
          const tx = CX + Math.cos(a) * radius;
          const ty = CY + Math.sin(a) * radius;
          ctx.fillStyle = '#1d2230'; ctx.fillRect(tx - 6, ty - 6, 12, 12);
          ctx.fillStyle = '#aacaff'; ctx.fillRect(tx - 5, ty - 5, 10, 10);
          ctx.fillStyle = '#dde8ff'; ctx.fillRect(tx - 2, ty - 2, 4, 4);
        }
        for (const m of ab.missiles) {
          const ang = Math.atan2(m.vy, m.vx);
          ctx.save();
          ctx.translate(m.x, m.y); ctx.rotate(ang);
          ctx.fillStyle = '#1d2230'; ctx.fillRect(-5, -3, 10, 6);
          ctx.fillStyle = '#aacaff'; ctx.fillRect(-4, -2, 8, 4);
          ctx.fillStyle = '#fff'; ctx.fillRect(-2, -1, 4, 2);
          ctx.fillStyle = 'rgba(170, 202, 255, 0.4)';
          ctx.fillRect(-7, -1, 4, 2);
          ctx.restore();
        }
        // 폭발 이펙트
        for (const e of ab.explosions) { const t = 1 - e.life / 14; glowBurst(e.x, e.y, e.r * t, e.life / 14, '#aacaff'); }
        ctx.globalAlpha = 1;
      },
    },

    frostfireSpear: {
      name: '빙화창', isCombo: true, baseCost: 140, color: '#ff88cc',
      desc: lv => `${2+lv}발 빙화창 · DMG ${9+lv*5} · 슬로우+화상`,
      // 화염+얼음을 같이 두른 창. 관통, 슬로우, 화상 DOT.
      init(ab) { ab.cooldown = 25; ab.lances = []; ab.burns = new Map(); },
      tick(ab) {
        const dmg = 9 + ab.level * 5;
        const slowDur = 90 + ab.level * 15;
        const burnDur = 90;
        const burnDmg = 2 + ab.level;
        for (const [e, info] of ab.burns) {
          if (e.hp <= 0) { ab.burns.delete(e); continue; }
          info.life--; info.tick--;
          if (info.tick <= 0) {
            damageEnemy(e, burnDmg);
            const [ex, ey] = enemyXY(e);
            spawnParticles(ex, ey, '#ff7733', 1);
            info.tick = 12;
          }
          if (info.life <= 0) ab.burns.delete(e);
        }
        for (const l of ab.lances) {
          l.x += l.vx; l.y += l.vy; l.life--;
          for (const e of state.enemies) {
            if (l.hit.has(e) || e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            if ((l.x-ex)*(l.x-ex) + (l.y-ey)*(l.y-ey) < (e.size + 5)*(e.size + 5)) {
              damageEnemy(e, dmg);
              e.slowFrames = Math.max(e.slowFrames || 0, slowDur);
              ab.burns.set(e, { life: burnDur, tick: 12 });
              l.hit.add(e);
              spawnParticles(ex, ey, '#ff88cc', 5);
            }
          }
          if ((l.x-CX)*(l.x-CX) + (l.y-CY)*(l.y-CY) > (ARENA_R+30)*(ARENA_R+30)) l.life = 0;
        }
        compactInPlace(ab.lances, _alivePredLife);
        if (--ab.cooldown > 0) return;
        const target = findNearestEnemy(ARENA_R + 50);
        if (!target) return;
        const [tx, ty] = enemyXY(target);
        const base = Math.atan2(ty - CY, tx - CX);
        const n = 2 + ab.level;
        const spread = Math.min(Math.PI * 0.4, (n - 1) * 0.2);
        for (let i = 0; i < n; i++) {
          const off = n === 1 ? 0 : (-spread/2 + spread * (i/(n-1)));
          const ang = base + off;
          ab.lances.push({
            x: CX, y: CY,
            vx: Math.cos(ang) * 8, vy: Math.sin(ang) * 8,
            ang, life: 95, hit: new Set(),
          });
        }
        ab.cooldown = Math.max(22, 45 - ab.level * 3);
      },
      draw(ab) {
        for (const l of ab.lances) {
          ctx.save();
          ctx.translate(l.x, l.y); ctx.rotate(l.ang);
          ctx.fillStyle = 'rgba(255, 136, 204, 0.35)';
          ctx.fillRect(-18, -5, 36, 10);
          ctx.fillStyle = '#ff7733'; ctx.fillRect(-14, -3, 14, 6);
          ctx.fillStyle = '#aaddff'; ctx.fillRect(0, -3, 14, 6);
          ctx.fillStyle = '#ffffff'; ctx.fillRect(-10, -1, 20, 2);
          ctx.restore();
        }
        for (const [e, info] of ab.burns) {
          if (info.tick > 9 || Math.random() > 0.3) continue;
          const [ex, ey] = enemyXY(e);
          ctx.fillStyle = '#ff7733';
          ctx.fillRect(ex + Math.random() * 8 - 4, ey - 8, 1, 2);
        }
      },
    },

    kamikazeDrone: {
      name: '자폭드론', isCombo: true, baseCost: 150, color: '#cc88ff',
      desc: lv => `${2+lv}개 자폭 드론 · DMG ${8+lv*4} · 폭발 ${60+lv*10}`,
      // 드론이 적을 향해 적극적으로 돌격하여 자폭. 큰 광역 폭발.
      init(ab) { ab.drones = []; ab.spawnCooldown = 0; ab.explosions = []; },
      tick(ab) {
        const dmg = 8 + ab.level * 4;
        const explodeR = 60 + ab.level * 10;
        for (const e of ab.explosions) e.life--;
        compactInPlace(ab.explosions, _alivePredLife);
        for (const d of ab.drones) {
          if (!d.target || d.target.hp <= 0) {
            let best = Infinity, t = null;
            for (const e of state.enemies) {
              if (e.hp <= 0) continue;
              const [ex, ey] = enemyXY(e);
              const d2 = (d.x-ex)*(d.x-ex) + (d.y-ey)*(d.y-ey);
              if (d2 < best) { best = d2; t = e; }
            }
            d.target = t;
          }
          if (d.target) {
            const [tx, ty] = enemyXY(d.target);
            const dx = tx - d.x, dy = ty - d.y;
            const dist = Math.hypot(dx, dy);
            d.vx = (dx/dist) * 4.8;
            d.vy = (dy/dist) * 4.8;
            if (dist < d.target.size + 8) {
              for (const e2 of state.enemies) {
                if (e2.hp <= 0) continue;
                const [ex2, ey2] = enemyXY(e2);
                if ((d.x-ex2)*(d.x-ex2) + (d.y-ey2)*(d.y-ey2) < explodeR*explodeR) {
                  damageEnemy(e2, dmg);
                  spawnParticles(ex2, ey2, '#cc88ff', 5);
                }
              }
              ab.explosions.push({ x: d.x, y: d.y, r: explodeR, life: 14 });
              d.exploded = true;
            }
          }
          d.x += d.vx; d.y += d.vy;
        }
        compactInPlace(ab.drones, _predNotExploded);
        const want = 2 + ab.level;
        if (ab.drones.length < want) {
          ab.spawnCooldown--;
          if (ab.spawnCooldown <= 0) {
            const a = Math.random() * Math.PI * 2;
            ab.drones.push({
              x: CX + Math.cos(a) * 30, y: CY + Math.sin(a) * 30,
              vx: 0, vy: 0, target: null,
            });
            ab.spawnCooldown = Math.max(25, 70 - ab.level * 4);
          }
        }
      },
      draw(ab) {
        for (const d of ab.drones) {
          const ang = Math.atan2(d.vy, d.vx);
          ctx.save();
          ctx.translate(d.x, d.y); ctx.rotate(ang);
          ctx.fillStyle = '#1d2230'; ctx.fillRect(-7, -4, 14, 8);
          ctx.fillStyle = '#cc88ff'; ctx.fillRect(-6, -3, 12, 6);
          const pulse = 0.5 + 0.5 * Math.sin(state.t * 0.35);
          ctx.fillStyle = `rgba(255, 80, 80, ${pulse})`;
          ctx.fillRect(-1, -1, 2, 2);
          ctx.restore();
        }
        for (const e of ab.explosions) { const t = 1 - e.life / 14; glowBurst(e.x, e.y, e.r * t, e.life / 14, '#cc88ff'); }
        ctx.globalAlpha = 1;
      },
    },

    cosmicCollapse: {
      name: '천체붕괴', isCombo: true, baseCost: 200, color: '#9933cc',
      desc: lv => `중력장 → 운석 강타 · DMG ${40+lv*25} · 반경 ${120+lv*15}`,
      // 1.5초 동안 블랙홀이 적을 빨아들인 뒤 거대 운석이 떨어져 폭발.
      init(ab) { ab.cooldown = 240; ab.events = []; },
      tick(ab) {
        // 데미지 대폭 상향: 20+lv*10 → 40+lv*25 (lv5 = 165, 약 2.4배) — 긴 차징 보상
        const dmg = 40 + ab.level * 25;
        const radius = 120 + ab.level * 15;
        const pullR = 150 + ab.level * 10;
        for (const ev of ab.events) {
          ev.t++;
          if (ev.t <= 90) {
            for (const e of state.enemies) {
              if (e.hp <= 0) continue;
              const [ex, ey] = enemyXY(e);
              const dx = ev.x - ex, dy = ev.y - ey;
              const dist = Math.hypot(dx, dy);
              if (dist < pullR && dist > 5) {
                const pullSpeed = (1 - dist / pullR) * 3.5;
                const newEx = ex + (dx/dist) * pullSpeed;
                const newEy = ey + (dy/dist) * pullSpeed;
                e.angle = Math.atan2(newEy - CY, newEx - CX);
                e.radius = Math.hypot(newEx - CX, newEy - CY);
                e.targetRadius = e.radius; e._xyT = -1; // 🚀 위치 메모 무효화
              }
            }
          }
          if (ev.t === 90) {
            for (const e of state.enemies) {
              if (e.hp <= 0) continue;
              const [ex, ey] = enemyXY(e);
              if ((ev.x-ex)*(ev.x-ex) + (ev.y-ey)*(ev.y-ey) < radius*radius) {
                damageEnemy(e, dmg);
                spawnParticles(ex, ey, '#9933cc', 8);
              }
            }
          }
        }
        compactInPlace(ab.events, e => e.t < 130);
        if (--ab.cooldown > 0) return;
        let bestX = CX, bestY = CY;
        let highEnemy = null, highBest = -1;
        for (const e of state.enemies) {
          if (e.hp > highBest) { highBest = e.hp; highEnemy = e; }
        }
        if (highEnemy) { const [hx, hy] = enemyXY(highEnemy); bestX = hx; bestY = hy; }
        ab.events.push({ x: bestX, y: bestY, t: 0 });
        // 쿨다운 단축: max 150→110, lv당 -15 (lv5 = 205)
        ab.cooldown = Math.max(110, 280 - ab.level * 15);
      },
      draw(ab) {
        for (const ev of ab.events) {
          const pullR = 150 + ab.level * 10;
          const radius = 120 + ab.level * 15;
          if (ev.t < 90) {
            const progress = ev.t / 90;
            ctx.save(); ctx.globalCompositeOperation = 'lighter';
            // 인력 비네트 + 빨려드는 나선 입자
            const fg = ctx.createRadialGradient(ev.x, ev.y, pullR*0.15, ev.x, ev.y, pullR);
            fg.addColorStop(0, 'rgba(170,90,230,0.16)'); fg.addColorStop(0.7, 'rgba(140,60,210,0.06)'); fg.addColorStop(1, 'rgba(140,60,210,0)');
            ctx.fillStyle = fg; ctx.beginPath(); ctx.arc(ev.x, ev.y, pullR, 0, Math.PI*2); ctx.fill();
            for (let k = 0; k < 10; k++) {
              const t=(state.t*0.02+k/10)%1, pr=14+(1-t)*(pullR*0.7-14), pa=state.t*0.13 + k*(Math.PI*2/10)+(1-t)*3.5;
              ctx.globalAlpha = 0.3+t*0.5; ctx.fillStyle = '#c89cf0';
              ctx.beginPath(); ctx.arc(ev.x+Math.cos(pa)*pr, ev.y+Math.sin(pa)*pr, 1.4+t*1.2, 0, 7); ctx.fill();
            }
            ctx.restore();
            // 사건의 지평선 (어두운 코어 + 글로우 테)
            ctx.fillStyle = '#160a26'; ctx.beginPath(); ctx.arc(ev.x, ev.y, 8 + progress * 8, 0, Math.PI*2); ctx.fill();
            ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.strokeStyle = 'rgba(200,150,255,0.8)'; ctx.lineWidth = 2; ctx.beginPath(); ctx.arc(ev.x, ev.y, 8+progress*8, 0, Math.PI*2); ctx.stroke(); ctx.restore();
            // 낙하 화구 (네모 제거)
            if (ev.t > 60) {
              const fp = (ev.t - 60) / 30, my = ev.y - (1 - fp) * 250, ms = 9 + fp * 7;
              ctx.save(); ctx.globalCompositeOperation = 'lighter';
              const tg = ctx.createLinearGradient(ev.x, my-46, ev.x, my); tg.addColorStop(0,'rgba(255,120,40,0)'); tg.addColorStop(1,'rgba(255,200,90,0.7)');
              ctx.fillStyle = tg; ctx.fillRect(ev.x-3, my-46, 6, 46);
              ctx.globalAlpha = 0.9; ctx.drawImage(getGlowSprite('#cc66ff'), ev.x-ms*1.6, my-ms*1.6, ms*3.2, ms*3.2);
              ctx.restore();
              const bg = ctx.createRadialGradient(ev.x-ms*0.3, my-ms*0.3, 1, ev.x, my, ms);
              bg.addColorStop(0,'#fff0ff'); bg.addColorStop(0.5,'#c060e0'); bg.addColorStop(1,'#3a1040');
              ctx.fillStyle = bg; ctx.beginPath(); ctx.arc(ev.x, my, ms, 0, Math.PI*2); ctx.fill();
            }
          } else {
            const tt = (ev.t - 90) / 40, a = 1 - tt;
            ctx.save(); ctx.globalCompositeOperation = 'lighter';
            ctx.globalAlpha = a * 0.5;
            const g = ctx.createRadialGradient(ev.x, ev.y, 0, ev.x, ev.y, radius*tt);
            g.addColorStop(0, 'rgba(220,180,255,0.7)'); g.addColorStop(0.5, 'rgba(153,51,204,0.3)'); g.addColorStop(1, 'rgba(153,51,204,0)');
            ctx.fillStyle = g; ctx.beginPath(); ctx.arc(ev.x, ev.y, radius*tt, 0, Math.PI*2); ctx.fill();
            ctx.globalAlpha = a; ctx.strokeStyle = '#d8b0ff'; ctx.lineWidth = 3*(1-tt*0.6); ctx.beginPath(); ctx.arc(ev.x, ev.y, radius*tt, 0, Math.PI*2); ctx.stroke();
            ctx.restore(); ctx.globalAlpha = 1;
          }
        }
      },
    },

    // ========== 트리플 조합 (히든) — 조합 능력 + 기본 능력이 만나면 형성 ==========
    ultraGatling: {
      name: '초연사총', isCombo: true, isTriple: true, baseCost: 200, color: '#ddeeff',
      desc: lv => `360도 ${12+lv*3}발 유도 미니건 · DMG ${6+lv*3}`,
      // 정밀연사 + 산탄 = 모든 방향으로 유도 미니건 사출
      init(ab) { ab.cooldown = 6; },
      tick(ab) {
        if (--ab.cooldown > 0) return;
        const n = 12 + ab.level * 3;
        const off = state.t * 0.03;
        let nearest = findNearestEnemy(ARENA_R + 50);
        for (let i = 0; i < n; i++) {
          const ang = (Math.PI * 2 / n) * i + off;
          const b = fireBullet(ang, 6 + ab.level * 3, '#ddeeff', nearest);
          b.size = 3; b.glow = true;
        }
        ab.cooldown = Math.max(14, 30 - ab.level * 2);
      },
    },
    absoluteThunder: {
      name: '절대빙뢰', isCombo: true, isTriple: true, baseCost: 220, color: '#ccddff',
      desc: lv => `${3+lv}곳 낙뢰 + ${4+lv}회 연쇄 · DMG ${10+lv*5} · 슬로우`,
      // 연쇄낙뢰 + 빙결 = 낙뢰 후 광역 슬로우
      init(ab) { ab.cooldown = 60; ab.bolts = []; ab.chains = []; },
      tick(ab) {
        for (const b of ab.bolts) b.life--;
        compactInPlace(ab.bolts, _alivePredLife);
        for (const c of ab.chains) c.life--;
        compactInPlace(ab.chains, _alivePredLife);
        if (--ab.cooldown > 0) return;
        const strikes = 3 + ab.level;
        const chainCount = 4 + ab.level;
        const dmg = 10 + ab.level * 5;
        const slowDur = 120 + ab.level * 20;
        const pool = state.enemies.filter(e => e.hp > 0);
        for (let i = 0; i < strikes && pool.length > 0; i++) {
          const idx = Math.floor(Math.random() * pool.length);
          const target = pool.splice(idx, 1)[0];
          const [tx, ty] = enemyXY(target);
          damageEnemy(target, dmg);
          target.slowFrames = Math.max(target.slowFrames || 0, slowDur);
          spawnParticles(tx, ty, '#ccddff', 10);
          ab.bolts.push({ x: tx, y: ty, life: 14 });
          const hit = new Set([target]);
          let current = target;
          const points = [[tx, ty]];
          for (let j = 0; j < chainCount; j++) {
            let next = null, best = 220 * 220;
            const [cx, cy] = enemyXY(current);
            for (const e of state.enemies) {
              if (hit.has(e) || e.hp <= 0) continue;
              const [ex, ey] = enemyXY(e);
              const d2 = (ex-cx)*(ex-cx) + (ey-cy)*(ey-cy);
              if (d2 < best) { best = d2; next = e; }
            }
            if (!next) break;
            const [nx, ny] = enemyXY(next);
            damageEnemy(next, dmg);
            next.slowFrames = Math.max(next.slowFrames || 0, slowDur);
            hit.add(next); current = next;
            points.push([nx, ny]);
            spawnParticles(nx, ny, '#ccddff', 5);
          }
          if (points.length > 1) ab.chains.push({ points, life: 14 });
        }
        ab.cooldown = Math.max(30, 70 - ab.level * 4);
      },
      draw(ab) {
        ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.lineCap = 'round';
        for (const b of ab.bolts) {
          const a = b.life / 14, seg = 8, amp = 8;
          const zig = (lw, col, al) => { ctx.globalAlpha = al; ctx.strokeStyle = col; ctx.lineWidth = lw; ctx.beginPath(); ctx.moveTo(b.x, 0);
            for (let s=1;s<=seg;s++){ const yy=b.y*s/seg, xx=b.x+Math.sin(s*1.8+b.x)*amp*(1-s/seg); ctx.lineTo(xx,yy); } ctx.stroke(); };
          zig(7, '#bcd8ff', a*0.4); zig(3, '#e0eeff', a*0.85); zig(1.3, '#ffffff', a);
        }
        for (const c of ab.chains) {
          const a = c.life / 14;
          const path = () => { ctx.beginPath(); ctx.moveTo(c.points[0][0], c.points[0][1]); for (let i=1;i<c.points.length;i++) ctx.lineTo(c.points[i][0], c.points[i][1]); ctx.stroke(); };
          ctx.globalAlpha = a*0.35; ctx.strokeStyle = '#aaccff'; ctx.lineWidth = 7; path();
          ctx.globalAlpha = a*0.85; ctx.strokeStyle = '#d8e8ff'; ctx.lineWidth = 3; path();
          ctx.globalAlpha = a;      ctx.strokeStyle = '#ffffff'; ctx.lineWidth = 1.4; path();
        }
        ctx.restore(); ctx.globalAlpha = 1;
      },
    },
    elementalStorm: {
      name: '원소폭풍', isCombo: true, isTriple: true, baseCost: 230, color: '#ffaaee',
      desc: lv => `빙결+화염 충격파 교차 · DMG ${8+lv*4} · 슬로우+화상`,
      // 빙결파동 + 불꽃 = 두 종류의 충격파가 번갈아 발사
      init(ab) { ab.cooldown = 50; ab.waves = []; ab.burns = new Map(); ab.toggle = 0; },
      tick(ab) {
        const dmg = 8 + ab.level * 4;
        const slowDur = 120;
        const burnDur = 80;
        for (const [e, info] of ab.burns) {
          if (e.hp <= 0) { ab.burns.delete(e); continue; }
          info.life--; info.tick--;
          if (info.tick <= 0) {
            damageEnemy(e, 2 + ab.level);
            const [ex, ey] = enemyXY(e);
            spawnParticles(ex, ey, '#ff7733', 1);
            info.tick = 12;
          }
          if (info.life <= 0) ab.burns.delete(e);
        }
        for (const w of ab.waves) {
          w.prevR = w.r; w.r += 6;
          for (const e of state.enemies) {
            if (w.hit.has(e) || e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            const d = Math.hypot(ex - CX, ey - CY);
            if (d >= w.prevR - 10 && d <= w.r + 10) {
              damageEnemy(e, dmg);
              if (w.type === 'frost') e.slowFrames = Math.max(e.slowFrames || 0, slowDur);
              else ab.burns.set(e, { life: burnDur, tick: 12 });
              spawnParticles(ex, ey, w.type === 'frost' ? '#aaccff' : '#ff7733', 3);
              w.hit.add(e);
            }
          }
        }
        compactInPlace(ab.waves, _predWaveArena);
        if (--ab.cooldown > 0) return;
        ab.waves.push({ r: CORE_R, prevR: CORE_R, hit: new Set(), type: ab.toggle === 0 ? 'frost' : 'fire' });
        ab.toggle = 1 - ab.toggle;
        ab.cooldown = Math.max(30, 60 - ab.level * 3);
      },
      draw(ab) {
        for (const w of ab.waves) {
          const a = Math.max(0, 1 - w.r / (ARENA_R + 30));
          ctx.globalAlpha = a;
          ctx.strokeStyle = w.type === 'frost' ? '#aaccff' : '#ff7733';
          ctx.lineWidth = 5;
          ctx.beginPath(); ctx.arc(CX, CY, w.r, 0, Math.PI*2); ctx.stroke();
        }
        ctx.globalAlpha = 1;
      },
    },
    fusionCannon: {
      name: '융합포', isCombo: true, isTriple: true, baseCost: 240, color: '#ff9966',
      desc: lv => `폭발탄 + 유도 미사일 · DMG ${10+lv*5} · 광역 ${60+lv*10}`,
      // 기관산탄총 + 미사일 = 유도 폭발탄 다발
      init(ab) { ab.cooldown = 20; ab.explosions = []; },
      tick(ab) {
        for (const e of ab.explosions) e.life--;
        compactInPlace(ab.explosions, _alivePredLife);
        if (--ab.cooldown > 0) return;
        const target = findNearestEnemy(ARENA_R + 100);
        if (!target) return;
        const [tx, ty] = enemyXY(target);
        const base = Math.atan2(ty - CY, tx - CX);
        const n = 5 + ab.level;
        const spread = Math.PI * 0.4;
        const exR = 60 + ab.level * 10;
        for (let i = 0; i < n; i++) {
          const off = n === 1 ? 0 : (-spread/2 + spread * (i/(n-1)));
          state.bullets.push({
            x: CX, y: CY,
            vx: Math.cos(base + off) * 6, vy: Math.sin(base + off) * 6,
            dmg: 10 + ab.level * 5, life: 100, color: '#ff9966',
            target: target, leader: null, offsetAngle: 0,
            explodeRadius: exR, explodeAb: ab,
            size: 4, glow: true, tier: 'triple',
            sourceId: state.currentAbilityId || null,
          });
        }
        ab.cooldown = Math.max(25, 45 - ab.level * 2);
      },
      draw(ab) {
        for (const e of ab.explosions) { const t = 1 - e.life / 12; glowBurst(e.x, e.y, e.r * t, e.life / 12, '#ff9966'); }
        ctx.globalAlpha = 1;
      },
    },
    galaxyOrbit: {
      name: '은하궤도', isCombo: true, isTriple: true, baseCost: 230, color: '#88ffff',
      desc: lv => `${3+lv}개 거대 회전체 + 폭풍 필드 · DMG ${8+lv*5}`,
      // 폭풍궤도 + 회전검 = 큰 검들이 폭풍 필드와 함께 회전
      init(ab) { ab.angle = 0; ab.hits = new Map(); ab.radius = 150; ab.targetRadius = 150; },
      tick(ab) {
        ab.angle += 0.05 + ab.level * 0.007;
        const target = findNearestEnemy(ARENA_R + 100);
        if (target) {
          const [tx, ty] = enemyXY(target);
          ab.targetRadius = Math.hypot(tx - CX, ty - CY);
        }
        ab.radius += (ab.targetRadius - ab.radius) * 0.05;
        ab.radius = Math.max(60, Math.min(ARENA_R - 10, ab.radius));
        for (const [e, cd] of ab.hits) {
          if (cd <= 1 || e.hp <= 0) ab.hits.delete(e);
          else ab.hits.set(e, cd - 1);
        }
        const count = 3 + ab.level;
        const dmg = 8 + ab.level * 5;
        const swordLen = 180;
        for (let i = 0; i < count; i++) {
          const a = ab.angle + (Math.PI * 2 / count) * i;
          const x1 = CX + Math.cos(a) * (ab.radius - swordLen/2);
          const y1 = CY + Math.sin(a) * (ab.radius - swordLen/2);
          const x2 = CX + Math.cos(a) * (ab.radius + swordLen/2);
          const y2 = CY + Math.sin(a) * (ab.radius + swordLen/2);
          for (const e of state.enemies) {
            if (ab.hits.has(e) || e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            if (distPointSegmentSq(ex, ey, x1, y1, x2, y2) < (e.size + 14) * (e.size + 14)) {
              damageEnemy(e, dmg);
              e.slowFrames = Math.max(e.slowFrames || 0, 60);
              ab.hits.set(e, 18);
              spawnParticles(ex, ey, '#88ffff', 4);
            }
          }
        }
      },
      draw(ab) {
        ctx.strokeStyle = 'rgba(136, 255, 255, 0.10)';
        ctx.lineWidth = 1;
        ctx.beginPath(); ctx.arc(CX, CY, ab.radius, 0, Math.PI*2); ctx.stroke();
        const count = 3 + ab.level;
        const swordLen = 180;
        for (let i = 0; i < count; i++) {
          const a = ab.angle + (Math.PI * 2 / count) * i;
          const x1 = CX + Math.cos(a) * (ab.radius - swordLen/2);
          const y1 = CY + Math.sin(a) * (ab.radius - swordLen/2);
          const x2 = CX + Math.cos(a) * (ab.radius + swordLen/2);
          const y2 = CY + Math.sin(a) * (ab.radius + swordLen/2);
          // 검날
          ctx.strokeStyle = '#666'; ctx.lineWidth = 12;
          ctx.beginPath(); ctx.moveTo(x1, y1); ctx.lineTo(x2, y2); ctx.stroke();
          ctx.strokeStyle = '#88ffff'; ctx.lineWidth = 7;
          ctx.stroke();
          ctx.strokeStyle = '#ddffff'; ctx.lineWidth = 3;
          ctx.stroke();
          // 폭풍 필드 (중심에 작은 원)
          const cx = CX + Math.cos(a) * ab.radius;
          const cy = CY + Math.sin(a) * ab.radius;
          ctx.fillStyle = 'rgba(136, 255, 255, 0.15)';
          ctx.beginPath(); ctx.arc(cx, cy, 30, 0, Math.PI*2); ctx.fill();
        }
      },
    },
    titanMissile: {
      name: '거대미사일', isCombo: true, isTriple: true, baseCost: 250, color: '#ffcc44',
      desc: lv => `초중량 폭격 부메랑 · DMG ${70+lv*35} · 광역`,
      // 강철부메랑 + 미사일 = 어마어마한 폭발 부메랑
      init(ab) { ab.cooldown = 90; ab.boomerangs = []; ab.explosions = []; },
      tick(ab) {
        const dmg = 70 + ab.level * 35;
        const exR = 100 + ab.level * 15;
        for (const e of ab.explosions) e.life--;
        compactInPlace(ab.explosions, _alivePredLife);
        for (const b of ab.boomerangs) {
          b.life--; b.rotation += 0.4;
          if (b.phase === 'out') {
            b.t++;
            if (b.t >= b.outDuration) { b.phase = 'in'; b.hit = new Set(); }
          } else {
            const dx = CX - b.x, dy = CY - b.y;
            const d = Math.hypot(dx, dy);
            if (d < 20) { b.life = 0; continue; }
            b.vx = (dx/d) * 5; b.vy = (dy/d) * 5;
          }
          b.x += b.vx; b.y += b.vy;
          for (const e of state.enemies) {
            if (b.hit.has(e) || e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            const r = e.size + 16;
            if ((b.x-ex)*(b.x-ex) + (b.y-ey)*(b.y-ey) < r*r) {
              // 광역 폭발
              for (const e2 of state.enemies) {
                if (e2.hp <= 0) continue;
                const [ex2, ey2] = enemyXY(e2);
                if ((ex-ex2)*(ex-ex2) + (ey-ey2)*(ey-ey2) < exR * exR) {
                  damageEnemy(e2, dmg);
                  spawnParticles(ex2, ey2, '#ffcc44', 5);
                }
              }
              ab.explosions.push({ x: ex, y: ey, r: exR, life: 16 });
              b.hit.add(e);
              shake(8, 6);
            }
          }
        }
        compactInPlace(ab.boomerangs, _alivePredLife);
        if (--ab.cooldown > 0) return;
        let target = null, best = -1;
        for (const e of state.enemies) {
          { const _s = e.isBoss ? e.hp + 1e9 : e.hp; if (_s > best) { best = _s; target = e; } }
        }
        if (!target) return;
        const [tx, ty] = enemyXY(target);
        const ang = Math.atan2(ty - CY, tx - CX);
        ab.boomerangs.push({
          x: CX, y: CY,
          vx: Math.cos(ang) * 5, vy: Math.sin(ang) * 5,
          t: 0, outDuration: 50, phase: 'out',
          rotation: 0, life: 250, hit: new Set(),
        });
        ab.cooldown = Math.max(60, 115 - ab.level * 3);
      },
      draw(ab) {
        for (const b of ab.boomerangs) drawSpinBoomerang(b, 22, '#ffcc44', '#ffaa30');
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        for (const e of ab.explosions) {
          const t = 1 - e.life / 16, a = Math.max(0, e.life / 16);
          ctx.globalAlpha = a * 0.5;
          const g = ctx.createRadialGradient(e.x, e.y, 0, e.x, e.y, e.r*t);
          g.addColorStop(0, 'rgba(255,240,170,0.7)'); g.addColorStop(0.5, 'rgba(255,170,48,0.3)'); g.addColorStop(1, 'rgba(255,170,48,0)');
          ctx.fillStyle = g; ctx.beginPath(); ctx.arc(e.x, e.y, e.r*t, 0, Math.PI*2); ctx.fill();
          ctx.globalAlpha = a * 0.9; ctx.strokeStyle = '#ffe0a0'; ctx.lineWidth = 2.5*(1-t*0.5); ctx.beginPath(); ctx.arc(e.x, e.y, e.r*t, 0, Math.PI*2); ctx.stroke();
        }
        ctx.restore(); ctx.globalAlpha = 1;
      },
    },

    // ========== 패시브 + 액티브 조합 ==========
    precisionShot: {
      name: '정밀사격', isCombo: true, baseCost: 110, color: '#a0d8ff',
      desc: lv => `크리티컬 단발 · DMG ${5+lv*3} · 50% ×2 · 전체 데미지 +${lv*8}%`,
      init(ab) { ab.cooldown = 0; },
      tick(ab) {
        // 🎯 정확 패시브 계승 — 모든 데미지 +8%/lv
        if (state.metaMods) {
          const own = ab.level * 0.08;
          state.metaMods.precisionBonus += own;  // 🛡 v256 — additive
        }
        if (--ab.cooldown > 0) return;
        const target = findNearestEnemy(ARENA_R + 50);
        if (!target) return;
        const [tx, ty] = enemyXY(target);
        const ang = Math.atan2(ty - CY, tx - CX);
        const crit = Math.random() < 0.5;
        const dmg = (5 + ab.level * 3) * (crit ? 2 : 1);
        const b = fireBullet(ang, dmg, crit ? '#ffe070' : '#a0d8ff', target);
        if (crit) { b.size = 4; b.glow = true; }
        ab.cooldown = Math.max(10, 18 - ab.level);
      },
    },
    rapidBarrage: {
      name: '미니건', isCombo: true, baseCost: 110, color: '#80ffd0',
      desc: lv => `1발씩 초고속 연사 · DMG ${2+lv} · 타 액티브 쿨다운 -${lv*5}%/초`,
      // 변경: 부채꼴 → 한 발씩 빠르게 연속 (미니건 정체성) + 신속 패시브 계승
      init(ab) { ab.cooldown = 0; },
      tick(ab) {
        // ⏩ 신속 패시브 계승 — 다른 액티브 쿨다운 비율 감소 (초당 lv*5%)
        const cdMul = ab.level * 0.05 / 60;
        for (const a of state.tower.abilities) {
          if (a === ab) continue;
          const d = ABILITY_DEFS[a.id];
          if (d.isPassive) continue;
          if (a.cooldown !== undefined && a.cooldown > 0) a.cooldown *= (1 - cdMul);
        }
        if (--ab.cooldown > 0) return;
        const target = findNearestEnemy(ARENA_R + 50);
        if (!target) return;
        const [tx, ty] = enemyXY(target);
        const ang = Math.atan2(ty - CY, tx - CX) + (Math.random() - 0.5) * 0.06;
        const dmg = 2 + ab.level;
        fireBullet(ang, dmg, '#80ffd0', target);
        ab.cooldown = Math.max(3, 8 - ab.level);
      },
    },
    frenzyWave: {
      name: '광기파동', isCombo: true, baseCost: 120, color: '#ff7777',
      desc: lv => `처치 누적 파동 · DMG ${5+lv*3} · 처치 시 3초 전체 데미지 +${lv*10}%`,
      init(ab) { ab.cooldown = 80; ab.waves = []; ab.killBuf = 0; ab.frenzyFrames = 0; },
      tick(ab) {
        // 🔥 광폭 패시브 계승 — 처치 시 3초간 전체 데미지 +10%/lv
        if (state.frenzyTrigger) ab.frenzyFrames = 180;
        if (state.metaMods) {
          if (ab.frenzyFrames > 0) {
            ab.frenzyFrames--;
            const own = ab.level * 0.10;
            state.metaMods.frenzyBonus += own;  // 🛡 v256 — additive
          }
        }
        const dmg = 5 + ab.level * 3;
        for (const w of ab.waves) {
          w.prevR = w.r; w.r += 6;
          for (const e of state.enemies) {
            if (w.hit.has(e) || e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            const d = Math.hypot(ex - CX, ey - CY);
            if (d >= w.prevR - 10 && d <= w.r + 10) {
              damageEnemy(e, dmg);
              spawnParticles(ex, ey, '#ff7777', 3);
              w.hit.add(e);
            }
          }
        }
        compactInPlace(ab.waves, _predWaveArena);
        if (state.frenzyTrigger) ab.killBuf++;
        if (--ab.cooldown > 0) return;
        ab.waves.push({ r: CORE_R, prevR: CORE_R, hit: new Set() });
        // 최근 처치 누적 → 쿨다운 단축
        const cdMul = Math.max(0.3, 1 - ab.killBuf * 0.05);
        ab.killBuf = Math.max(0, ab.killBuf - 1);
        ab.cooldown = Math.floor(Math.max(50, 110 - ab.level * 5) * cdMul);
      },
      draw(ab) {
        for (const w of ab.waves) {
          const a = Math.max(0, 1 - w.r / (ARENA_R + 30));
          ctx.globalAlpha = a; ctx.strokeStyle = '#ff7777'; ctx.lineWidth = 4;
          ctx.beginPath(); ctx.arc(CX, CY, w.r, 0, Math.PI*2); ctx.stroke();
        }
        ctx.globalAlpha = 1;
      },
    },
    lootBomb: {
      name: '약탈폭격', isCombo: true, baseCost: 130, color: '#cc6699',
      desc: lv => `광역 폭격 · DMG ${14+lv*10} · 폭격 처치 시 +35% 골드 + 전체 골드 +${lv*12}%`,
      init(ab) { ab.cooldown = 90; ab.fx = []; },
      tick(ab) {
        // 🩸 흡혈 패시브 효과 계승 — 모든 처치 골드 +12%/lv (vampiric 대체)
        if (state.metaMods) {
          state.metaMods.bonusGoldMul += ab.level * 0.12;  // 🛡 v256 — additive
        }
        for (const e of ab.fx) e.life--;
        compactInPlace(ab.fx, _alivePredLife);
        if (--ab.cooldown > 0) return;
        let target = null, best = -1;
        for (const e of state.enemies) { { const _s = e.isBoss ? e.hp + 1e9 : e.hp; if (_s > best) { best = _s; target = e; } } }
        if (!target) return;
        const [tx, ty] = enemyXY(target);
        const radius = 60 + ab.level * 10;
        // 데미지 대폭 상향: 8+lv*5 → 14+lv*10 (lv5 = 64, 약 2배)
        const dmg = 14 + ab.level * 10;
        for (const e of state.enemies) {
          if (e.hp <= 0) continue;
          const [ex, ey] = enemyXY(e);
          if ((ex-tx)*(ex-tx) + (ey-ty)*(ey-ty) < radius*radius) {
            const wasHp = e.hp;
            damageEnemy(e, dmg);
            if (wasHp > 0 && e.hp <= 0) {
              state.gold += Math.ceil(e.goldDrop * 0.35);
            }
            spawnParticles(ex, ey, '#cc6699', 4);
          }
        }
        ab.fx.push({ x: tx, y: ty, r: radius, life: 16 });
        // 쿨다운 단축: max 55→40, lv당 -6 (lv5 = 70 → 55)
        ab.cooldown = Math.max(40, 85 - ab.level * 6);
      },
      draw(ab) {
        for (const e of ab.fx) {
          const t = 1 - e.life / 16;
          ctx.globalAlpha = e.life / 16;
          ctx.strokeStyle = '#cc6699'; ctx.lineWidth = 4;
          ctx.beginPath(); ctx.arc(e.x, e.y, e.r * t, 0, Math.PI*2); ctx.stroke();
          ctx.globalAlpha = (e.life/16) * 0.7;
          ctx.fillStyle = '#ffcc66';
          ctx.fillRect(e.x - 3, e.y - 3, 6, 6);
        }
        ctx.globalAlpha = 1;
      },
    },
    luckyChain: {
      name: '행운연쇄', isCombo: true, baseCost: 120, color: '#ffcc66',
      desc: lv => `${3+lv}회 연쇄 · DMG ${6+lv*6} · 모든 처치 ${lv*8}% 확률 보너스 점수`,
      init(ab) { ab.cooldown = 60; ab.chains = []; },
      tick(ab) {
        // 🍀 행운 패시브 효과 계승 — 모든 처치에 확률적 점수 보너스 (lv당 +8%)
        if (state.metaMods) {
          state.metaMods.fortuneChance += ab.level * 0.08;  // 🛡 v256 — additive
        }
        for (const c of ab.chains) c.life--;
        compactInPlace(ab.chains, _alivePredLife);
        if (--ab.cooldown > 0) return;
        const first = findNearestEnemy(ARENA_R + 50);
        if (!first) return;
        // 데미지 상향: 4+lv*3 → 6+lv*6 (lv5 = 36, 약 2배)
        const dmg = 6 + ab.level * 6;
        const chains = 3 + ab.level;
        const hit = new Set();
        let current = first;
        const points = [[CX, CY]];
        for (let i = 0; i < chains; i++) {
          if (!current) break;
          const [cx, cy] = enemyXY(current);
          points.push([cx, cy]);
          const wasHp = current.hp;
          damageEnemy(current, dmg);
          if (wasHp > 0 && current.hp <= 0) {
            // 행운 보너스 점수 (kill score x3) — 🛡 v265 엔드리스 패널티 적용
            state.score += Math.ceil(20 * state.round * ((state.metaMods && state.metaMods.scoreMul) || 1) * endlessScorePenalty());
          }
          spawnParticles(cx, cy, '#ffcc66', 3);
          hit.add(current);
          let next = null, best = 160 * 160;
          for (const e of state.enemies) {
            if (hit.has(e) || e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            const d2 = (ex-cx)*(ex-cx) + (ey-cy)*(ey-cy);
            if (d2 < best) { best = d2; next = e; }
          }
          current = next;
        }
        ab.chains.push({ points, life: 12 });
        ab.cooldown = Math.max(40, 70 - ab.level * 4);
      },
      draw(ab) {
        for (const c of ab.chains) {
          ctx.globalAlpha = c.life / 12;
          ctx.strokeStyle = '#ffcc66'; ctx.lineWidth = 3;
          ctx.beginPath();
          ctx.moveTo(c.points[0][0], c.points[0][1]);
          for (let i = 1; i < c.points.length; i++) ctx.lineTo(c.points[i][0], c.points[i][1]);
          ctx.stroke();
        }
        ctx.globalAlpha = 1;
      },
    },
    masteryOrbit: {
      name: '통달궤도', isCombo: true, baseCost: 130, color: '#88aaff',
      desc: lv => `위성 수 = 액티브 보유 수 · DMG ${4+lv*3} · 액티브 수 × ${lv*5}% 전체 데미지`,
      init(ab) { ab.angle = 0; ab.hits = new Map(); ab.radius = 160; ab.targetRadius = 160; },
      tick(ab) {
        // 🎓 숙련 패시브 계승 — 보유 액티브 수 × 5%/lv 전체 데미지 보너스
        if (state.metaMods) {
          const n = state.tower.abilities.filter(a => !ABILITY_DEFS[a.id].isPassive).length;
          const own = n * ab.level * 0.05;
          state.metaMods.masteryBonus += own;  // 🛡 v256 — additive
        }
        ab.angle += 0.04 + ab.level * 0.005;
        const target = findNearestEnemy(ARENA_R + 100);
        if (target) {
          const [tx, ty] = enemyXY(target);
          ab.targetRadius = Math.hypot(tx - CX, ty - CY);
        }
        ab.radius += (ab.targetRadius - ab.radius) * 0.05;
        ab.radius = Math.max(50, Math.min(ARENA_R - 10, ab.radius));
        for (const [e, cd] of ab.hits) {
          if (cd <= 1 || e.hp <= 0) ab.hits.delete(e);
          else ab.hits.set(e, cd - 1);
        }
        const activeCount = Math.max(1, state.tower.abilities.filter(a => !ABILITY_DEFS[a.id].isPassive).length);
        const count = activeCount;
        const dmg = 4 + ab.level * 3;
        for (let i = 0; i < count; i++) {
          const a = ab.angle + (Math.PI * 2 / count) * i;
          const ox = CX + Math.cos(a) * ab.radius;
          const oy = CY + Math.sin(a) * ab.radius;
          for (const e of state.enemies) {
            if (ab.hits.has(e) || e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            const rr = e.size + 7;
            if ((ox-ex)*(ox-ex) + (oy-ey)*(oy-ey) < rr*rr) {
              damageEnemy(e, dmg);
              ab.hits.set(e, 25);
              spawnParticles(ex, ey, '#88aaff', 3);
            }
          }
        }
        ab.count = count;
      },
      draw(ab) {
        const count = ab.count || 1;
        ctx.strokeStyle = 'rgba(136, 170, 255, 0.10)'; ctx.lineWidth = 1;
        ctx.beginPath(); ctx.arc(CX, CY, ab.radius, 0, Math.PI*2); ctx.stroke();
        for (let i = 0; i < count; i++) {
          const a = ab.angle + (Math.PI * 2 / count) * i;
          const ox = CX + Math.cos(a) * ab.radius;
          const oy = CY + Math.sin(a) * ab.radius;
          ctx.fillStyle = '#1d2230'; ctx.fillRect(ox - 4, oy - 4, 8, 8);
          ctx.fillStyle = '#88aaff'; ctx.fillRect(ox - 3, oy - 3, 6, 6);
          ctx.fillStyle = '#ddeeff'; ctx.fillRect(ox - 1, oy - 1, 2, 2);
        }
      },
    },
    scholarSnipe: {
      name: '학자저격', isCombo: true, baseCost: 130, color: '#bb99cc',
      desc: lv => `최강 적 저격 · DMG ${12+lv*7} · 처치 시 쿨다운 -15% · 강화 비용 -${lv*5}%`,
      init(ab) { ab.cooldown = 50; },
      tick(ab) {
        // 📚 연구 패시브 계승 — 강화 비용 -5%/lv
        if (state.metaMods) {
          const own = 1 - ab.level * 0.05;
          state.metaMods.scholarMul *= own;  // 🛡 v256 — multiplicative stacking
        }
        if (--ab.cooldown > 0) return;
        let target = null, best = -1;
        for (const e of state.enemies) { { const _s = e.isBoss ? e.hp + 1e9 : e.hp; if (_s > best) { best = _s; target = e; } } }
        if (!target) return;
        const [tx, ty] = enemyXY(target);
        const ang = Math.atan2(ty - CY, tx - CX);
        const dmg = 12 + ab.level * 7;
        const wasHp = target.hp;
        // 즉발 사격 (초고속 탄)
        state.bullets.push({
          x: CX, y: CY,
          vx: Math.cos(ang) * 16, vy: Math.sin(ang) * 16,
          dmg, life: 60, color: '#bb99cc',
          target, leader: null, offsetAngle: 0, size: 3, glow: true, tier: 'combo',
          sourceId: state.currentAbilityId || null,
        });
        ab.cooldown = Math.max(25, 65 - ab.level * 4);
        // 학자 효과: 처치 가능성 시 다른 액티브 쿨 감소
        if (wasHp <= dmg * 1.2) {
          for (const a of state.tower.abilities) {
            if (a === ab || ABILITY_DEFS[a.id].isPassive) continue;
            if (a.cooldown !== undefined && a.cooldown > 0) a.cooldown *= 0.85;
          }
        }
      },
    },
    resolveBoomerang: {
      name: '결의부메랑', isCombo: true, baseCost: 140, color: '#aaaaaa',
      desc: lv => `보스 우선 추적 · DMG ${8+lv*6} · 보스 추가 데미지 +75% · 전체 보스 데미지 +${lv*18}%`,
      init(ab) { ab.cooldown = 70; ab.boomerangs = []; },
      tick(ab) {
        // 🛡 강철의지 패시브 계승 — 모든 능력 보스 데미지 +18%/lv
        if (state.metaMods) {
          const own = ab.level * 0.18;
          state.metaMods.ironwillBonus += own;  // 🛡 v256 — additive
        }
        const dmg = 8 + ab.level * 6;
        for (const b of ab.boomerangs) {
          b.life--; b.rotation += 0.4;
          if (b.phase === 'out') {
            b.t++;
            if (b.t >= b.outDuration) { b.phase = 'in'; b.hit = new Set(); }
          } else {
            const dx = CX - b.x, dy = CY - b.y;
            const d = Math.hypot(dx, dy);
            if (d < 20) { b.life = 0; continue; }
            b.vx = (dx/d) * 6; b.vy = (dy/d) * 6;
          }
          b.x += b.vx; b.y += b.vy;
          for (const e of state.enemies) {
            if (b.hit.has(e) || e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            const r = e.size + 10;
            if ((b.x-ex)*(b.x-ex) + (b.y-ey)*(b.y-ey) < r*r) {
              damageEnemy(e, dmg * (e.isBoss ? 1.75 : 1));
              b.hit.add(e);
              spawnParticles(ex, ey, '#aaaaaa', 4);
            }
          }
        }
        compactInPlace(ab.boomerangs, _alivePredLife);
        if (--ab.cooldown > 0) return;
        // 보스 우선, 없으면 최강 적
        let target = state.enemies.find(e => e.isBoss && e.hp > 0);
        if (!target) {
          let best = -1;
          for (const e of state.enemies) { { const _s = e.isBoss ? e.hp + 1e9 : e.hp; if (_s > best) { best = _s; target = e; } } }
        }
        if (!target) return;
        const [tx, ty] = enemyXY(target);
        const ang = Math.atan2(ty - CY, tx - CX);
        ab.boomerangs.push({
          x: CX, y: CY,
          vx: Math.cos(ang) * 6, vy: Math.sin(ang) * 6,
          t: 0, outDuration: 40, phase: 'out',
          rotation: 0, life: 220, hit: new Set(),
        });
        ab.cooldown = Math.max(40, 85 - ab.level * 4);
      },
      draw(ab) {
        for (const b of ab.boomerangs) drawSpinBoomerang(b, 10, '#c8d2dc', '#aad0ff');
      },
    },

    // ========== 대체 조합 (자유도) — 다른 파트너 조합 ==========
    headshot: {
      name: '헤드샷', isCombo: true, baseCost: 110, color: '#ffd0d0',
      desc: lv => `2.5초 풀차징 단발 · DMG ${25+lv*15}`,
      // 차징 후 강력 단발 — 풀충전(150프레임) 강제 → 최대 데미지로만 발사
      init(ab) { ab.cooldown = 0; ab.chargeFrames = 0; },
      tick(ab) {
        if (ab.cooldown > 0) { ab.cooldown--; return; }
        ab.chargeFrames++;
        if (ab.chargeFrames < 150) return;  // 2.5초 풀차징 강제
        const target = findNearestEnemy(ARENA_R + 50);
        if (!target) return;  // 풀차징 유지하면서 적 대기
        const ratio = 1;  // 풀차징 = 최대 데미지
        const [tx, ty] = enemyXY(target);
        const ang = Math.atan2(ty - CY, tx - CX);
        const dmg = 25 + ab.level * 15;
        state.bullets.push({
          x: CX, y: CY,
          vx: Math.cos(ang) * 20, vy: Math.sin(ang) * 20,
          dmg, life: 50, color: '#ffd0d0',
          target, leader: null, offsetAngle: 0,
          size: 3 + Math.floor(ratio * 3), glow: true, tier: 'combo',
          sourceId: state.currentAbilityId || null,
        });
        ab.chargeFrames = 0;
        ab.cooldown = Math.max(15, 35 - ab.level * 2);
      },
      draw(ab) {
        if (ab.chargeFrames < 60) return;
        // 차징 시각: 타워 주변에 빛 모임
        const prog = Math.min(1, (ab.chargeFrames - 60) / 90);
        for (let k = 0; k < 4; k++) {
          const pa = state.t * 0.2 + k * (Math.PI * 2 / 4);
          const pr = 30 * (1 - prog) + 20;
          ctx.fillStyle = `rgba(255, 208, 208, ${0.4 + prog * 0.5})`;
          ctx.fillRect(CX + Math.cos(pa) * pr - 1, CY + Math.sin(pa) * pr - 1, 3, 3);
        }
        if (prog > 0.4) {
          ctx.globalAlpha = (prog - 0.4) * 1.5;
          ctx.strokeStyle = '#ffd0d0'; ctx.lineWidth = 1.5;
          ctx.beginPath(); ctx.arc(CX, CY, 22, -Math.PI/2, -Math.PI/2 + prog * Math.PI * 2);
          ctx.stroke();
          ctx.globalAlpha = 1;
        }
      },
    },
    pelletGun: {
      name: '펠릿건', isCombo: true, baseCost: 120, color: '#ffaa88',
      desc: lv => `${10+lv*3}발 집중 산탄 · DMG ${5+lv*5}`,
      // 산탄을 좁히고 데미지 강화 — 단일 표적에 여러 발 명중되도록 조정
      init(ab) { ab.cooldown = 20; },
      tick(ab) {
        if (--ab.cooldown > 0) return;
        const target = findNearestEnemy(ARENA_R + 50);
        const base = target ? Math.atan2(enemyXY(target)[1] - CY, enemyXY(target)[0] - CX) : Math.random() * Math.PI * 2;
        const n = 10 + ab.level * 3;
        // 분산각 0.6π → 0.35π (단일 표적 명중률 ↑)
        const spread = Math.PI * 0.35;
        const dmg = 5 + ab.level * 5;
        for (let i = 0; i < n; i++) {
          const off = n === 1 ? 0 : (-spread/2 + spread * (i/(n-1)));
          fireBullet(base + off, dmg, '#ffaa88', null);
        }
        ab.cooldown = Math.max(15, 35 - ab.level);
      },
    },

    swordRain: {
      name: '천검우', isCombo: true, baseCost: 170, color: '#eeeecc',
      desc: lv => `거대 회전검 + ${4+lv*2}개 검 낙하 · DMG ${5+lv*3}`,
      // 타워 회전 거대 검 + 하늘에서 무작위로 떨어지는 검 비.
      init(ab) { ab.angle = 0; ab.hits = new Map(); ab.cooldown = 40; ab.falling = []; ab.flashes = []; },
      tick(ab) {
        const dmg = 5 + ab.level * 3;
        ab.angle += 0.05 + ab.level * 0.006;
        for (const [e, cd] of ab.hits) {
          if (cd <= 1 || e.hp <= 0) ab.hits.delete(e);
          else ab.hits.set(e, cd - 1);
        }
        const count = 2 + ab.level;
        const swordLen = 160;
        const minR = 30;
        for (let i = 0; i < count; i++) {
          const a = ab.angle + (Math.PI * 2 / count) * i;
          const x1 = CX + Math.cos(a) * minR;
          const y1 = CY + Math.sin(a) * minR;
          const x2 = CX + Math.cos(a) * swordLen;
          const y2 = CY + Math.sin(a) * swordLen;
          for (const e of state.enemies) {
            if (ab.hits.has(e) || e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            if (distPointSegmentSq(ex, ey, x1, y1, x2, y2) < (e.size + 10)*(e.size + 10)) {
              damageEnemy(e, dmg);
              ab.hits.set(e, 20);
              spawnParticles(ex, ey, '#eeeecc', 3);
            }
          }
        }
        for (const f of ab.flashes) f.life--;
        compactInPlace(ab.flashes, _alivePredLife);
        for (const s of ab.falling) {
          s.t++;
          if (s.t >= 30) {
            const radius = 40 + ab.level * 5;
            for (const e of state.enemies) {
              if (e.hp <= 0) continue;
              const [ex, ey] = enemyXY(e);
              if ((s.x-ex)*(s.x-ex) + (s.y-ey)*(s.y-ey) < radius*radius) {
                damageEnemy(e, dmg);
                spawnParticles(ex, ey, '#eeeecc', 3);
              }
            }
            ab.flashes.push({ x: s.x, y: s.y, r: radius, life: 12 });
            s.done = true;
          }
        }
        compactInPlace(ab.falling, _predNotDone);
        if (--ab.cooldown > 0) return;
        // TD: 적 위치 타격 / 클래식: 무작위
        const n = 4 + ab.level * 2;
        const positions = tdDropPositions(n, { offset: 35 });
        for (let i = 0; i < positions.length; i++) {
          ab.falling.push({ x: positions[i].x, y: positions[i].y, t: -i * 3 });
        }
        ab.cooldown = Math.max(40, 90 - ab.level * 5);
      },
      draw(ab) {
        const count = 2 + ab.level;
        const swordLen = 160;
        const minR = 30;
        for (let i = 0; i < count; i++) {
          const a = ab.angle + (Math.PI * 2 / count) * i;
          const x1 = CX + Math.cos(a) * minR;
          const y1 = CY + Math.sin(a) * minR;
          const x2 = CX + Math.cos(a) * swordLen;
          const y2 = CY + Math.sin(a) * swordLen;
          ctx.strokeStyle = '#888'; ctx.lineWidth = 11;
          ctx.beginPath(); ctx.moveTo(x1, y1); ctx.lineTo(x2, y2); ctx.stroke();
          ctx.strokeStyle = '#eeeecc'; ctx.lineWidth = 7;
          ctx.stroke();
          ctx.strokeStyle = '#ffffff'; ctx.lineWidth = 2;
          ctx.stroke();
          ctx.fillStyle = '#ffffff';
          ctx.fillRect(x2 - 3, y2 - 3, 6, 6);
        }
        for (const s of ab.falling) {
          if (s.t < 0) continue;
          const progress = s.t / 30;
          const my = s.y - (1 - progress) * 180;
          ctx.globalAlpha = 0.5;
          ctx.fillStyle = '#eeeecc';
          ctx.fillRect(s.x - 2, my - 28, 4, 25);
          ctx.globalAlpha = 1;
          ctx.fillStyle = '#888'; ctx.fillRect(s.x - 3, my - 14, 6, 28);
          ctx.fillStyle = '#eeeecc'; ctx.fillRect(s.x - 2, my - 12, 4, 24);
          ctx.fillStyle = '#ffffff'; ctx.fillRect(s.x - 1, my - 10, 2, 20);
          ctx.fillStyle = `rgba(0, 0, 0, ${0.2 + progress * 0.3})`;
          ctx.beginPath(); ctx.arc(s.x, s.y, 6 + progress * 10, 0, Math.PI*2); ctx.fill();
        }
        for (const f of ab.flashes) { const t = 1 - f.life / 12; glowBurst(f.x, f.y, f.r * t, f.life / 12, '#eeeecc'); }
        ctx.globalAlpha = 1;
      },
    },

    // ========== 신규 조합 능력 ==========
    plasmaBeam: {
      name: '플라즈마빔', isCombo: true, baseCost: 140, color: '#ff66ff',
      desc: lv => `연속 ${3+lv}분기 플라즈마 빔 · DMG ${5+lv*3}/tick`,
      // plasmaArc + laser — 끊임없이 분기되는 빔
      init(ab) { ab.angle = 0; ab.hits = new Map(); ab.fx = 0; },
      tick(ab) {
        ab.angle += 0.04;
        if (ab.fx > 0) ab.fx--;
        for (const [e, cd] of ab.hits) {
          if (cd <= 1 || e.hp <= 0) ab.hits.delete(e);
          else ab.hits.set(e, cd - 1);
        }
        const branches = 3 + ab.level;
        const dmg = 5 + ab.level * 3;
        const len = ARENA_R + 20;
        for (let k = 0; k < branches; k++) {
          const ang = ab.angle + (Math.PI * 2 / branches) * k;
          const ex = CX + Math.cos(ang) * len;
          const ey = CY + Math.sin(ang) * len;
          for (const e of state.enemies) {
            if (ab.hits.has(e) || e.hp <= 0) continue;
            const [px, py] = enemyXY(e);
            if (distPointSegmentSq(px, py, CX, CY, ex, ey) < 100) {
              damageEnemy(e, dmg);
              ab.hits.set(e, 15);
              spawnParticles(px, py, '#ff66ff', 2);
            }
          }
        }
      },
      draw(ab) {
        const branches = 3 + ab.level;
        const len = ARENA_R + 20;
        for (let k = 0; k < branches; k++) {
          const ang = ab.angle + (Math.PI * 2 / branches) * k;
          const ex = CX + Math.cos(ang) * len;
          const ey = CY + Math.sin(ang) * len;
          ctx.globalAlpha = 0.4;
          ctx.strokeStyle = '#ff66ff'; ctx.lineWidth = 8;
          ctx.beginPath(); ctx.moveTo(CX, CY); ctx.lineTo(ex, ey); ctx.stroke();
          ctx.globalAlpha = 0.85;
          ctx.lineWidth = 4;
          ctx.stroke();
          ctx.globalAlpha = 1;
          ctx.strokeStyle = '#ffccff'; ctx.lineWidth = 2;
          ctx.stroke();
        }
        ctx.globalAlpha = 1;
      },
    },
    voidField: {
      name: '공허장', isCombo: true, baseCost: 150, color: '#aa88dd',
      desc: lv => `초강력 슬로우장 · DMG ${5+lv*4}/주기 · 빙결 갱신`,
      // gravityWell + frost — 강화된 슬로우 필드 (끌어당김 X, 더 큰 반경 + 강한 슬로우)
      init(ab) { ab.tickT = 10; },
      tick(ab) {
        const radius = 170 + ab.level * 18;
        const dmg = 5 + ab.level * 4;
        ab.tickT--;
        for (const e of state.enemies) {
          if (e.hp <= 0) continue;
          const [ex, ey] = enemyXY(e);
          if ((ex-CX)*(ex-CX) + (ey-CY)*(ey-CY) < radius*radius) {
            // 매우 강한 슬로우 (지속 갱신, 더 긴 지속)
            e.slowFrames = Math.max(e.slowFrames || 0, 80);
          }
        }
        if (ab.tickT <= 0) {
          ab.tickT = 10;
          for (const e of state.enemies) {
            if (e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            if ((ex-CX)*(ex-CX) + (ey-CY)*(ey-CY) < radius*radius) {
              damageEnemy(e, dmg);
              spawnParticles(ex, ey, '#aa88dd', 1);
            }
          }
        }
      },
      draw(ab) {
        const radius = 170 + ab.level * 18;
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        const fg = ctx.createRadialGradient(CX, CY, radius*0.5, CX, CY, radius);
        fg.addColorStop(0, 'rgba(170,136,221,0)'); fg.addColorStop(1, 'rgba(170,136,221,0.15)');
        ctx.fillStyle = fg; ctx.beginPath(); ctx.arc(CX, CY, radius, 0, Math.PI*2); ctx.fill();
        ctx.globalAlpha = 0.32; ctx.strokeStyle = '#bf9ce6'; ctx.lineWidth = 2; ctx.beginPath(); ctx.arc(CX, CY, radius, 0, Math.PI*2); ctx.stroke();
        // 보이드 글로우 입자 (선회)
        for (let k = 0; k < 12; k++) {
          const pa = state.t * 0.04 + k * (Math.PI * 2 / 12), pr = radius * (0.5 + 0.35 * Math.sin(state.t * 0.025 + k));
          ctx.globalAlpha = 0.4 + 0.3*Math.sin(state.t*0.05+k); ctx.fillStyle = '#c4a4ee';
          ctx.beginPath(); ctx.arc(CX + Math.cos(pa)*pr, CY + Math.sin(pa)*pr, 2, 0, 7); ctx.fill();
        }
        // 서리 결정 다이아 (경계 근처)
        ctx.globalAlpha = 0.8; ctx.fillStyle = '#e0d4ff';
        for (let k = 0; k < 6; k++) {
          const pa = -state.t * 0.05 + k * (Math.PI * 2 / 6), pr = radius * 0.85;
          const px = CX + Math.cos(pa)*pr, py = CY + Math.sin(pa)*pr;
          ctx.beginPath(); ctx.moveTo(px,py-2.5); ctx.lineTo(px+1.5,py); ctx.lineTo(px,py+2.5); ctx.lineTo(px-1.5,py); ctx.closePath(); ctx.fill();
        }
        ctx.restore(); ctx.globalAlpha = 1;
      },
    },
    piercingChain: {
      name: '관통연쇄', isCombo: true, baseCost: 140, color: '#88ffcc',
      desc: lv => `관통 + ${2+lv}회 분열 · DMG ${4+lv*3}`,
      // piercer + chain — 관통탄이 적 맞히면 분열해서 인근 적으로
      init(ab) { ab.cooldown = 30; ab.bolts = []; },
      tick(ab) {
        const dmg = 4 + ab.level * 3;
        for (const b of ab.bolts) {
          b.x += b.vx; b.y += b.vy; b.life--;
          for (const e of state.enemies) {
            if (b.hit.has(e) || e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            if ((b.x-ex)*(b.x-ex) + (b.y-ey)*(b.y-ey) < (e.size + 4)*(e.size + 4)) {
              damageEnemy(e, dmg);
              b.hit.add(e);
              spawnParticles(ex, ey, '#88ffcc', 3);
              // 분열: 인근 적으로 새 탄환
              if (b.bounces > 0) {
                let next = null, best = 180 * 180;
                for (const e2 of state.enemies) {
                  if (b.hit.has(e2) || e2.hp <= 0) continue;
                  const [ex2, ey2] = enemyXY(e2);
                  const d2 = (b.x-ex2)*(b.x-ex2) + (b.y-ey2)*(b.y-ey2);
                  if (d2 < best) { best = d2; next = e2; }
                }
                if (next) {
                  const [nx, ny] = enemyXY(next);
                  const ang = Math.atan2(ny - b.y, nx - b.x);
                  ab.bolts.push({
                    x: b.x, y: b.y,
                    vx: Math.cos(ang) * 12, vy: Math.sin(ang) * 12,
                    ang, life: 50, hit: new Set(b.hit), bounces: b.bounces - 1,
                  });
                }
              }
            }
          }
          if ((b.x-CX)*(b.x-CX) + (b.y-CY)*(b.y-CY) > (ARENA_R+30)*(ARENA_R+30)) b.life = 0;
        }
        compactInPlace(ab.bolts, _alivePredLife);
        if (--ab.cooldown > 0) return;
        const n = 2;
        const target = findNearestEnemy(ARENA_R + 50);
        const base = target ? Math.atan2(enemyXY(target)[1]-CY, enemyXY(target)[0]-CX) : Math.random()*Math.PI*2;
        for (let i = 0; i < n; i++) {
          const ang = base + (i - (n-1)/2) * 0.2;
          ab.bolts.push({
            x: CX, y: CY,
            vx: Math.cos(ang) * 12, vy: Math.sin(ang) * 12,
            ang, life: 80, hit: new Set(), bounces: 2 + ab.level,
          });
        }
        ab.cooldown = Math.max(25, 50 - ab.level * 2);
      },
      draw(ab) {
        for (const b of ab.bolts) {
          ctx.save();
          ctx.translate(b.x, b.y); ctx.rotate(b.ang);
          ctx.fillStyle = '#88ffcc'; ctx.fillRect(-10, -3, 20, 6);
          ctx.fillStyle = '#ddffee'; ctx.fillRect(-8, -1, 16, 2);
          ctx.restore();
        }
      },
    },
    echoStorm: {
      name: '진동폭풍', isCombo: true, baseCost: 130, color: '#88ffaa',
      desc: lv => `4연속 거대 진동 충격파 · DMG ${8+lv*8}`,
      // echoBlast + nova — 중앙에서 퍼지는 거대 동심 진동 폭풍 (4겹 리플)
      init(ab) { ab.cooldown = 60; ab.rings = []; },
      tick(ab) {
        const dmg = 8 + ab.level * 8;
        const maxR = ARENA_R + 30;
        for (const w of ab.rings) {
          if (w.delay > 0) { w.delay--; continue; }
          w.prevR = w.r; w.r += 8;
          for (const e of state.enemies) {
            if (w.hit.has(e) || e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            const d = Math.hypot(ex - CX, ey - CY);
            if (d >= w.prevR - 16 && d <= w.r + 16) { damageEnemy(e, dmg); w.hit.add(e); spawnParticles(ex, ey, '#88ffaa', 4); }
          }
        }
        compactInPlace(ab.rings, w => w.delay > 0 || w.r < maxR);
        if (--ab.cooldown > 0) return;
        for (let k = 0; k < 4; k++) ab.rings.push({ r: CORE_R, prevR: CORE_R, delay: k * 6, hit: new Set() });
        ab.cooldown = Math.max(40, 95 - ab.level * 6);
      },
      draw(ab) {
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        for (const w of ab.rings) {
          if (w.delay > 0) continue;
          const prog = w.r / (ARENA_R + 30), a = Math.max(0, 1 - prog);
          // 거대 동심 진동 파동 — 두꺼운 소프트 밴드 + 밝은 선행 엣지
          ctx.globalAlpha = a * 0.24; ctx.strokeStyle = '#88ffaa'; ctx.lineWidth = 15 - prog*8;
          ctx.beginPath(); ctx.arc(CX, CY, w.r, 0, Math.PI*2); ctx.stroke();
          ctx.globalAlpha = a * 0.7; ctx.strokeStyle = '#d8ffe4'; ctx.lineWidth = 3;
          ctx.beginPath(); ctx.arc(CX, CY, w.r, 0, Math.PI*2); ctx.stroke();
        }
        ctx.restore(); ctx.globalAlpha = 1;
      },
    },
    rocketBarrage: {
      name: '로켓산탄', isCombo: true, baseCost: 140, color: '#ff7755',
      desc: lv => `${10+lv*3}발 산탄 로켓 폭격 · DMG ${10+lv*8} · 폭발 ${40+lv*7}`,
      // rocketSwarm + scatter — 산탄으로 사방에 폭발탄
      init(ab) { ab.cooldown = 60; ab.rockets = []; ab.explosions = []; },
      tick(ab) {
        // 데미지 상향: 5+lv*3 → 10+lv*8 (lv5 = 50, 약 2.5배) — 명중률 낮으니 한 방 강하게
        const dmg = 10 + ab.level * 8;
        const exR = 40 + ab.level * 7;
        for (const e of ab.explosions) e.life--;
        compactInPlace(ab.explosions, _alivePredLife);
        for (const r of ab.rockets) {
          r.x += r.vx; r.y += r.vy; r.life--;
          r.vx *= 1.03; r.vy *= 1.03;
          for (const e of state.enemies) {
            if (e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            if ((r.x-ex)*(r.x-ex) + (r.y-ey)*(r.y-ey) < (e.size + 4)*(e.size + 4)) {
              for (const e2 of state.enemies) {
                if (e2.hp <= 0) continue;
                const [ex2, ey2] = enemyXY(e2);
                if ((r.x-ex2)*(r.x-ex2) + (r.y-ey2)*(r.y-ey2) < exR*exR) {
                  damageEnemy(e2, dmg);
                  spawnParticles(ex2, ey2, '#ff7755', 3);
                }
              }
              ab.explosions.push({ x: r.x, y: r.y, r: exR, life: 14 });
              r.life = 0;
              break;
            }
          }
          if ((r.x-CX)*(r.x-CX) + (r.y-CY)*(r.y-CY) > (ARENA_R+30)*(ARENA_R+30)) r.life = 0;
        }
        compactInPlace(ab.rockets, _alivePredLife);
        if (--ab.cooldown > 0) return;
        const n = 10 + ab.level * 3;
        const off = Math.random() * Math.PI * 2;
        for (let i = 0; i < n; i++) {
          const ang = (Math.PI * 2 / n) * i + off + (Math.random() - 0.5) * 0.15;
          ab.rockets.push({
            x: CX, y: CY,
            vx: Math.cos(ang) * 4.5, vy: Math.sin(ang) * 4.5,
            ang, life: 80,
          });
        }
        ab.cooldown = Math.max(45, 90 - ab.level * 3);
      },
      draw(ab) {
        for (const r of ab.rockets) {
          const ang = Math.atan2(r.vy, r.vx);
          ctx.save();
          ctx.translate(r.x, r.y); ctx.rotate(ang);
          ctx.fillStyle = '#ff7755'; ctx.fillRect(-5, -2, 10, 4);
          ctx.fillStyle = '#ffd0a0'; ctx.fillRect(-3, -1, 6, 2);
          ctx.restore();
        }
        for (const e of ab.explosions) { const t = 1 - e.life / 14; glowBurst(e.x, e.y, e.r * t, e.life / 14, '#ff7755'); }
        ctx.globalAlpha = 1;
      },
    },
    bladeStorm: {
      name: '검풍', isCombo: true, baseCost: 150, color: '#ffccdd',
      desc: lv => `${2+lv}개 회전검 + ${3+lv}회 워프 베기 (강타 ×2)`,
      // homingBlade + sword — 회전검 (지속) + 주기적 워프 베기 (강력 단발)
      init(ab) { ab.angle = 0; ab.hits = new Map(); ab.cooldown = 70; ab.slashes = []; },
      tick(ab) {
        const dmg = 5 + ab.level * 3;
        // 회전검 (지속)
        ab.angle += 0.05 + ab.level * 0.006;
        for (const [e, cd] of ab.hits) {
          if (cd <= 1 || e.hp <= 0) ab.hits.delete(e);
          else ab.hits.set(e, cd - 1);
        }
        const count = 2 + ab.level;
        const swordLen = 150;
        const minR = 30;
        for (let i = 0; i < count; i++) {
          const a = ab.angle + (Math.PI * 2 / count) * i;
          const x1 = CX + Math.cos(a) * minR, y1 = CY + Math.sin(a) * minR;
          const x2 = CX + Math.cos(a) * swordLen, y2 = CY + Math.sin(a) * swordLen;
          for (const e of state.enemies) {
            if (ab.hits.has(e) || e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            if (distPointSegmentSq(ex, ey, x1, y1, x2, y2) < (e.size + 8) * (e.size + 8)) {
              damageEnemy(e, dmg);
              ab.hits.set(e, 18);
              spawnParticles(ex, ey, '#ffccdd', 3);
            }
          }
        }
        // 슬래시 이펙트 갱신
        for (const s of ab.slashes) s.life--;
        compactInPlace(ab.slashes, _alivePredLife);
        if (--ab.cooldown > 0) return;
        // 워프 베기 (강력 강타 — 회전검 데미지의 2배)
        const warps = 3 + ab.level;
        const hitSet = new Set();
        let prevX = CX, prevY = CY;
        for (let i = 0; i < warps; i++) {
          let next = null, best = Infinity;
          for (const e of state.enemies) {
            if (hitSet.has(e) || e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            const d2 = (ex-prevX)*(ex-prevX) + (ey-prevY)*(ey-prevY);
            if (d2 < best) { best = d2; next = e; }
          }
          if (!next) break;
          const [tx, ty] = enemyXY(next);
          damageEnemy(next, dmg * 2);
          hitSet.add(next);
          ab.slashes.push({ x1: prevX, y1: prevY, x2: tx, y2: ty, life: 18 });
          spawnParticles(tx, ty, '#ffccdd', 6);
          prevX = tx; prevY = ty;
        }
        ab.cooldown = Math.max(70, 120 - ab.level * 4);
      },
      draw(ab) {
        const count = 2 + ab.level;
        const swordLen = 150;
        const minR = 30;
        for (let i = 0; i < count; i++) {
          const a = ab.angle + (Math.PI * 2 / count) * i;
          const x1 = CX + Math.cos(a) * minR, y1 = CY + Math.sin(a) * minR;
          const x2 = CX + Math.cos(a) * swordLen, y2 = CY + Math.sin(a) * swordLen;
          ctx.strokeStyle = '#888'; ctx.lineWidth = 9;
          ctx.beginPath(); ctx.moveTo(x1, y1); ctx.lineTo(x2, y2); ctx.stroke();
          ctx.strokeStyle = '#ffccdd'; ctx.lineWidth = 5;
          ctx.stroke();
          ctx.strokeStyle = '#ffffff'; ctx.lineWidth = 1;
          ctx.stroke();
        }
        // 워프 슬래시 라인
        for (const s of ab.slashes) {
          ctx.globalAlpha = s.life / 18;
          ctx.strokeStyle = '#ffccdd'; ctx.lineWidth = 6;
          ctx.beginPath(); ctx.moveTo(s.x1, s.y1); ctx.lineTo(s.x2, s.y2); ctx.stroke();
          ctx.strokeStyle = '#ffe0ee'; ctx.lineWidth = 2;
          ctx.stroke();
        }
        ctx.globalAlpha = 1;
      },
    },
    magneticStun: {
      name: '자력기절', isCombo: true, baseCost: 140, color: '#ffd040',
      desc: lv => `집결 후 기절폭발 · DMG ${6+lv*4} · ${(1.5+lv*0.3).toFixed(1)}s 정지`,
      // stunBomb + magnet — 끌어모은 뒤 기절 폭발
      init(ab) { ab.cooldown = 120; ab.events = []; },
      tick(ab) {
        const dmg = 6 + ab.level * 4;
        const stunDur = Math.floor((1.5 + ab.level * 0.3) * 60);
        const pullR = 160 + ab.level * 12;
        for (const ev of ab.events) {
          ev.t++;
          if (ev.t <= 50) {
            for (const e of state.enemies) {
              if (e.hp <= 0) continue;
              const [ex, ey] = enemyXY(e);
              const dx = ev.x - ex, dy = ev.y - ey;
              const d = Math.hypot(dx, dy);
              if (d < pullR && d > 5) {
                const sp = (1 - d / pullR) * 4;
                const newEx = ex + (dx/d) * sp;
                const newEy = ey + (dy/d) * sp;
                e.angle = Math.atan2(newEy - CY, newEx - CX);
                e.radius = Math.hypot(newEx - CX, newEy - CY);
                e.targetRadius = e.radius; e._xyT = -1; // 🚀 위치 메모 무효화
              }
            }
          }
          if (ev.t === 50) {
            for (const e of state.enemies) {
              if (e.hp <= 0) continue;
              const [ex, ey] = enemyXY(e);
              if ((ev.x-ex)*(ev.x-ex) + (ev.y-ey)*(ev.y-ey) < (pullR*0.7)*(pullR*0.7)) {
                damageEnemy(e, dmg);
                // 보스는 슬로우만 (40%), 일반 적은 완전 정지
                const isBoss = e.isBoss;
                e.slowFrames = Math.max(e.slowFrames || 0, isBoss ? Math.floor(stunDur * 0.4) : stunDur);
                if (!isBoss) e.timeStopped = state.t + stunDur;
                spawnParticles(ex, ey, '#ffd040', 5);
              }
            }
            shake(12, 10);
          }
        }
        compactInPlace(ab.events, e => e.t < 70);
        if (--ab.cooldown > 0) return;
        const a = Math.random() * Math.PI * 2;
        const r = 60 + Math.random() * (ARENA_R - 100);
        ab.events.push({ x: CX + Math.cos(a) * r, y: CY + Math.sin(a) * r, t: 0 });
        ab.cooldown = Math.max(80, 150 - ab.level * 5);
      },
      draw(ab) {
        const pullR = 160 + ab.level * 12;
        for (const ev of ab.events) {
          if (ev.t < 50) {
            const prog = ev.t / 50;
            ctx.save(); ctx.globalCompositeOperation = 'lighter';
            ctx.globalAlpha = 0.3 + prog*0.3; ctx.strokeStyle = '#ffd040'; ctx.lineWidth = 2;
            ctx.beginPath(); ctx.arc(ev.x, ev.y, pullR * (1 - prog * 0.3), 0, Math.PI*2); ctx.stroke();
            // 빨려드는 글로우 입자
            for (let k = 0; k < 8; k++) {
              const pa = state.t * 0.16 + k * (Math.PI * 2 / 8), pr = pullR*(1-prog*0.55) * (0.5 + 0.4*Math.sin(state.t*0.05+k));
              ctx.globalAlpha = 0.5 + 0.3*Math.sin(state.t*0.06+k); ctx.fillStyle = '#ffe080';
              ctx.beginPath(); ctx.arc(ev.x + Math.cos(pa)*pr, ev.y + Math.sin(pa)*pr, 1.8, 0, 7); ctx.fill();
            }
            ctx.globalAlpha = 0.5 + prog*0.5;
            const cg = ctx.createRadialGradient(ev.x, ev.y, 0, ev.x, ev.y, 8 + prog*6);
            cg.addColorStop(0, '#fff4c0'); cg.addColorStop(1, 'rgba(255,208,64,0)');
            ctx.fillStyle = cg; ctx.beginPath(); ctx.arc(ev.x, ev.y, 8 + prog*6, 0, Math.PI*2); ctx.fill();
            ctx.restore(); ctx.globalAlpha = 1;
          } else {
            const t = (ev.t - 50) / 20;
            glowBurst(ev.x, ev.y, pullR * 0.7 * t, 1 - t, '#ffd040');
          }
        }
      },
    },
    purgeShot: {
      name: '정화저격', isCombo: true, baseCost: 150, color: '#ff88ff',
      desc: lv => `풀스크린 정화 + 거대 관통 빔 · DMG ${20+lv*12}`,
      // purgeWave + sniper — 풀스크린 점멸 + 최강 적 방향 거대 빔
      init(ab) { ab.cooldown = 100; ab.fxLife = 0; ab.fireFx = 0; ab.fireAng = 0; },
      tick(ab) {
        if (ab.fxLife > 0) ab.fxLife--;
        if (ab.fireFx > 0) ab.fireFx--;
        if (--ab.cooldown > 0) return;
        const dmg = 20 + ab.level * 12;
        // 보호막 일괄 제거
        for (const e of state.enemies) {
          if (e.hp <= 0) continue;
          if (e.shieldHp > 0) {
            e.shieldHp = 0;
            const [ex, ey] = enemyXY(e);
            spawnParticles(ex, ey, '#ff88ff', 6);
          }
        }
        ab.fxLife = 18;
        // 최강 적 방향 거대 빔
        let target = null, best = -1;
        for (const e of state.enemies) {
          { const _s = e.isBoss ? e.hp + 1e9 : e.hp; if (_s > best) { best = _s; target = e; } }
        }
        if (target) {
          const [tx, ty] = enemyXY(target);
          const ang = Math.atan2(ty - CY, tx - CX);
          const len = ARENA_R + 20;
          const ex = CX + Math.cos(ang) * len, ey = CY + Math.sin(ang) * len;
          for (const e of state.enemies) {
            if (e.hp <= 0) continue;
            const [px, py] = enemyXY(e);
            if (distPointSegmentSq(px, py, CX, CY, ex, ey) < 225) {
              damageEnemy(e, dmg);
              spawnParticles(px, py, '#ff88ff', 5);
            }
          }
          ab.fireAng = ang;
          ab.fireFx = 14;
          shake(16, 12);
        }
        ab.cooldown = Math.max(75, 130 - ab.level * 5);
      },
      draw(ab) {
        if (ab.fxLife > 0) {
          ctx.globalAlpha = (ab.fxLife / 18) * 0.18;
          const fxGrad = ctx.createRadialGradient(CX, CY, CX * 0.45, CX, CY, CX * 1.15);
          fxGrad.addColorStop(0, 'rgba(255, 136, 255, 0)');
          fxGrad.addColorStop(1, '#ff88ff');
          ctx.fillStyle = fxGrad;
          ctx.fillRect(0, 0, W, H);
          ctx.globalAlpha = 1;
        }
        if (ab.fireFx > 0) {
          const a = ab.fireFx / 14;
          const len = ARENA_R + 20;
          const ex = CX + Math.cos(ab.fireAng) * len, ey = CY + Math.sin(ab.fireAng) * len;
          ctx.globalAlpha = a * 0.3;
          ctx.strokeStyle = '#ff88ff'; ctx.lineWidth = 26;
          ctx.beginPath(); ctx.moveTo(CX, CY); ctx.lineTo(ex, ey); ctx.stroke();
          ctx.globalAlpha = a * 0.9;
          ctx.lineWidth = 12;
          ctx.stroke();
          ctx.globalAlpha = a;
          ctx.strokeStyle = '#ffffff'; ctx.lineWidth = 3;
          ctx.stroke();
          ctx.globalAlpha = 1;
        }
      },
    },
    // 패시브 + 액티브 신규 조합
    grandReaper: {
      name: '대수확자', isCombo: true, baseCost: 160, color: '#aa44aa',
      desc: lv => `HP ${15+lv*5}% 이하 적 즉사 · 처치 시 +${5+lv*2}G + 광역 폭발 · 저체력(50% 이하) 적 데미지 +${lv*18}%`,
      // executioner + reaper — 즉사 임계값 강화 + 처치 시 폭발 + 골드 보너스 + 처형 계승
      init(ab) { ab.cooldown = 0; ab.explosions = []; },
      tick(ab) {
        // ⚔ 처형 패시브 계승 — 모든 능력의 저체력 적 데미지 +18%/lv
        if (state.metaMods) {
          const own = ab.level * 0.18;
          state.metaMods.executionerBonus += own;  // 🛡 v256 — additive
        }
        for (const e of ab.explosions) e.life--;
        compactInPlace(ab.explosions, _alivePredLife);
        if (--ab.cooldown > 0) return;
        // 임계값 상향: 10+lv*3 → 15+lv*5 (lv5 = 40%, 베이스 수확자 32% 초과)
        const threshold = (15 + ab.level * 5) / 100;
        const explodeR = 60 + ab.level * 6;
        const explodeDmg = 5 + ab.level * 3;
        const bonusGold = 5 + ab.level * 2;  // 수확자 골드 보너스 계승 + 강화
        for (const e of state.enemies) {
          if (e.hp <= 0 || e.isBoss) continue;
          if (e.hp / e.maxHp <= threshold) {
            const [ex, ey] = enemyXY(e);
            state.damageNumbers.push({
              x: ex, y: ey - e.size - 4, vy: -1,
              text: 'REAP', color: '#aa44aa', life: 30, size: 12,
            });
            spawnParticles(ex, ey, '#aa44aa', 12);
            // 💀 골드 보너스 (수확자 계승)
            state.gold += bonusGold;
            if (state.relicEffects) state.relicEffects.goldEarnedTotal = (state.relicEffects.goldEarnedTotal || 0) + bonusGold;
            state.damageNumbers.push({
              x: ex, y: ey - e.size - 14, vy: -1.2,
              text: `+${bonusGold}G`, color: '#ffd479', life: 32, size: 11,
            });
            // 처치 시 광역 폭발
            for (const e2 of state.enemies) {
              if (e2 === e || e2.hp <= 0) continue;
              const [ex2, ey2] = enemyXY(e2);
              if ((ex-ex2)*(ex-ex2) + (ey-ey2)*(ey-ey2) < explodeR*explodeR) {
                damageEnemy(e2, explodeDmg);
                spawnParticles(ex2, ey2, '#aa44aa', 3);
              }
            }
            ab.explosions.push({ x: ex, y: ey, r: explodeR, life: 12 });
            damageEnemy(e, e.hp * 2);
          }
        }
        ab.cooldown = 6;
      },
      draw(ab) {
        for (const e of ab.explosions) {
          const t = 1 - e.life / 12;
          ctx.globalAlpha = e.life / 12;
          ctx.fillStyle = '#aa44aa';
          ctx.beginPath(); ctx.arc(e.x, e.y, e.r * t, 0, Math.PI*2); ctx.fill();
        }
        ctx.globalAlpha = 1;
      },
    },
    pyreShield: {
      name: '강철화염장', isCombo: true, baseCost: 140, color: '#ff4422',
      desc: lv => `타워 주변 화염장 · DPS ${2+lv*2} · 반경 ${130+lv*15} · 보스 추가 · 누적 처치 비례 데미지 (최대 +${lv*35}%)`,
      // resilience + fire — 강화된 영구 화염장 + 불굴 패시브 계승
      init(ab) { ab.hits = new Map(); ab.particles = []; },
      tick(ab) {
        // 💪 불굴 패시브 계승 — 50처치당 +1.8%/lv (최대 +60%/lv)
        if (state.metaMods) {
          const stacks = Math.floor((state.totalKills || 0) / 50);
          const own = Math.min(ab.level * 0.60, stacks * ab.level * 0.018);
          state.metaMods.resilienceBonus += own;  // 🛡 v256 — additive
        }
        for (const [e, cd] of ab.hits) {
          if (cd <= 1 || e.hp <= 0) ab.hits.delete(e);
          else ab.hits.set(e, cd - 1);
        }
        const radius = 130 + ab.level * 15;
        const dmg = 2 + ab.level * 2;
        for (const e of state.enemies) {
          if (ab.hits.has(e) || e.hp <= 0) continue;
          const [ex, ey] = enemyXY(e);
          if ((ex-CX)*(ex-CX) + (ey-CY)*(ey-CY) < radius*radius) {
            damageEnemy(e, dmg * (e.isBoss ? 1.5 : 1));
            ab.hits.set(e, 18);
            spawnParticles(ex, ey, '#ff4422', 2);
          }
        }
        if (Math.random() < 0.5) {
          const a = Math.random() * Math.PI * 2;
          const r = 25 + Math.random() * (radius - 25);
          ab.particles.push({
            x: CX + Math.cos(a) * r, y: CY + Math.sin(a) * r,
            vy: -0.6 - Math.random(), life: 25 + Math.random() * 15,
          });
        }
        for (const p of ab.particles) { p.life--; p.y += p.vy; }
        compactInPlace(ab.particles, _alivePredLife);
      },
      draw(ab) {
        const radius = 130 + ab.level * 15;
        ctx.fillStyle = 'rgba(255, 68, 34, 0.07)';
        ctx.beginPath(); ctx.arc(CX, CY, radius, 0, Math.PI*2); ctx.fill();
        ctx.strokeStyle = 'rgba(255, 68, 34, 0.30)'; ctx.lineWidth = 3;
        ctx.beginPath(); ctx.arc(CX, CY, radius, 0, Math.PI*2); ctx.stroke();
        for (const p of ab.particles) {
          ctx.globalAlpha = p.life / 40;
          ctx.fillStyle = '#ff4422'; ctx.fillRect(p.x - 2, p.y - 2, 3, 3);
          ctx.fillStyle = '#ffaa66'; ctx.fillRect(p.x, p.y - 1, 1, 1);
        }
        ctx.globalAlpha = 1;
      },
    },

    // ========== 신규 트리플 조합 (히든) ==========
    plasmaCataclysm: {
      name: '플라즈마대재앙', isCombo: true, isTriple: true, baseCost: 240, color: '#ff66ff',
      desc: lv => `회전 ${5+lv}분기 빔 + 자동 폭발 · DMG ${8+lv*5}`,
      // plasmaBeam + thunder — 분기 빔이 회전 + 적 위치에 낙뢰 폭발
      init(ab) { ab.angle = 0; ab.hits = new Map(); ab.bolts = []; ab.cooldown = 30; },
      tick(ab) {
        ab.angle += 0.05;
        for (const b of ab.bolts) b.life--;
        compactInPlace(ab.bolts, _alivePredLife);
        for (const [e, cd] of ab.hits) {
          if (cd <= 1 || e.hp <= 0) ab.hits.delete(e);
          else ab.hits.set(e, cd - 1);
        }
        const branches = 5 + ab.level;
        const dmg = 8 + ab.level * 5;
        const len = ARENA_R + 20;
        for (let k = 0; k < branches; k++) {
          const ang = ab.angle + (Math.PI * 2 / branches) * k;
          const ex = CX + Math.cos(ang) * len;
          const ey = CY + Math.sin(ang) * len;
          for (const e of state.enemies) {
            if (ab.hits.has(e) || e.hp <= 0) continue;
            const [px, py] = enemyXY(e);
            if (distPointSegmentSq(px, py, CX, CY, ex, ey) < 144) {
              damageEnemy(e, dmg);
              ab.hits.set(e, 14);
              spawnParticles(px, py, '#ff66ff', 3);
            }
          }
        }
        // 자동 낙뢰
        if (--ab.cooldown > 0) return;
        const strikeCount = 2 + Math.floor(ab.level / 2);
        const pool = state.enemies.filter(e => e.hp > 0);
        for (let i = 0; i < strikeCount && pool.length > 0; i++) {
          const idx = Math.floor(Math.random() * pool.length);
          const target = pool.splice(idx, 1)[0];
          const [tx, ty] = enemyXY(target);
          damageEnemy(target, dmg * 1.5);
          ab.bolts.push({ x: tx, y: ty, life: 14 });
          spawnParticles(tx, ty, '#ffaaff', 8);
        }
        ab.cooldown = 40;
      },
      draw(ab) {
        const branches = 5 + ab.level, len = ARENA_R + 20;
        // 회전 분기 빔 (가산 글로우)
        for (let k = 0; k < branches; k++) {
          const ang = ab.angle + (Math.PI * 2 / branches) * k;
          glowBeam(CX, CY, CX + Math.cos(ang)*len, CY + Math.sin(ang)*len, '#ff66ff', 4, 0.9);
        }
        // 들쭉날쭉 빛나는 낙뢰 (사각 막대 제거)
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        for (const b of ab.bolts) {
          const a = b.life / 14, seg = 8, amp = 8;
          const zig = (lw, col, al) => { ctx.globalAlpha = al; ctx.strokeStyle = col; ctx.lineWidth = lw; ctx.lineCap = 'round'; ctx.beginPath(); ctx.moveTo(b.x, 0);
            for (let s=1;s<=seg;s++){ const yy=b.y*s/seg, xx=b.x+Math.sin(s*1.7+b.x)*amp*(1-s/seg); ctx.lineTo(xx,yy); } ctx.stroke(); };
          zig(7, '#ff66ff', a*0.4); zig(3, '#ffaaff', a*0.85); zig(1.3, '#ffffff', a);
          ctx.globalAlpha = a*0.7; ctx.fillStyle = '#ffd6ff'; ctx.beginPath(); ctx.arc(b.x, b.y, 5*a, 0, 7); ctx.fill();
        }
        ctx.restore(); ctx.globalAlpha = 1;
      },
    },
    voidNova: {
      name: '공허폭발', isCombo: true, isTriple: true, baseCost: 250, color: '#aa66ff',
      desc: lv => `초거대 슬로우장 + 주기 폭격 · DMG ${12+lv*7} · 반경 ${220+lv*20}`,
      // voidField + missile — 영구 슬로우장 + 주기적 적 위치 폭격
      init(ab) { ab.bombT = 0; ab.explosions = []; },
      tick(ab) {
        const radius = 220 + ab.level * 20;
        const dmg = 12 + ab.level * 7;
        const exR = 90 + ab.level * 12;
        for (const e of ab.explosions) e.life--;
        compactInPlace(ab.explosions, _alivePredLife);
        // 영구 슬로우 (필드 안 모든 적)
        for (const e of state.enemies) {
          if (e.hp <= 0) continue;
          const [ex, ey] = enemyXY(e);
          if ((ex-CX)*(ex-CX) + (ey-CY)*(ey-CY) < radius*radius) {
            e.slowFrames = Math.max(e.slowFrames || 0, 100);
          }
        }
        // 주기 폭격 (HP 가장 많은 적 위치)
        ab.bombT--;
        if (ab.bombT <= 0) {
          ab.bombT = Math.max(35, 80 - ab.level * 4);
          let target = null, best = -1;
          for (const e of state.enemies) {
            if (e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            if ((ex-CX)*(ex-CX) + (ey-CY)*(ey-CY) > radius*radius) continue;
            { const _s = e.isBoss ? e.hp + 1e9 : e.hp; if (_s > best) { best = _s; target = e; } }
          }
          if (target) {
            const [tx, ty] = enemyXY(target);
            for (const e of state.enemies) {
              if (e.hp <= 0) continue;
              const [ex, ey] = enemyXY(e);
              if ((tx-ex)*(tx-ex) + (ty-ey)*(ty-ey) < exR*exR) {
                damageEnemy(e, dmg);
                spawnParticles(ex, ey, '#aa66ff', 4);
              }
            }
            ab.explosions.push({ x: tx, y: ty, r: exR, life: 14 });
            shake(8, 8);
          }
        }
      },
      draw(ab) {
        const radius = 220 + ab.level * 20;
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        // 공허 슬로우장 비네트 (가장자리만 — 중앙 투명)
        const fg = ctx.createRadialGradient(CX, CY, radius*0.55, CX, CY, radius);
        fg.addColorStop(0, 'rgba(170,102,255,0)'); fg.addColorStop(1, 'rgba(170,102,255,0.14)');
        ctx.fillStyle = fg; ctx.beginPath(); ctx.arc(CX, CY, radius, 0, Math.PI*2); ctx.fill();
        ctx.globalAlpha = 0.3; ctx.strokeStyle = '#b488ff'; ctx.lineWidth = 2; ctx.beginPath(); ctx.arc(CX, CY, radius, 0, Math.PI*2); ctx.stroke();
        // 천천히 선회하는 공허 입자 (작은 글로우 점, 궤도)
        ctx.globalAlpha = 1;
        for (let k = 0; k < 14; k++) {
          const pa = state.t * 0.03 + k * (Math.PI * 2 / 14);
          const pr = radius * (0.5 + 0.32 * Math.sin(state.t * 0.018 + k));
          const px = CX + Math.cos(pa)*pr, py = CY + Math.sin(pa)*pr;
          ctx.globalAlpha = 0.45 + 0.35*Math.sin(state.t*0.05+k);
          ctx.fillStyle = '#c8a0ff'; ctx.beginPath(); ctx.arc(px, py, 2, 0, 7); ctx.fill();
        }
        // 붕괴 폭발 펄스
        for (const e of ab.explosions) {
          const t = 1 - e.life / 14, a = Math.max(0, e.life / 14);
          ctx.globalAlpha = a * 0.5;
          const g = ctx.createRadialGradient(e.x, e.y, 0, e.x, e.y, e.r*t);
          g.addColorStop(0, 'rgba(220,190,255,0.7)'); g.addColorStop(0.5, 'rgba(170,102,255,0.3)'); g.addColorStop(1, 'rgba(170,102,255,0)');
          ctx.fillStyle = g; ctx.beginPath(); ctx.arc(e.x, e.y, e.r*t, 0, Math.PI*2); ctx.fill();
          ctx.globalAlpha = a * 0.9; ctx.strokeStyle = '#d8b8ff'; ctx.lineWidth = 2.5*(1-t*0.5); ctx.beginPath(); ctx.arc(e.x, e.y, e.r*t, 0, Math.PI*2); ctx.stroke();
        }
        ctx.restore(); ctx.globalAlpha = 1;
      },
    },
    siegeBeam: {
      name: '공성빔', isCombo: true, isTriple: true, baseCost: 260, color: '#88ddff',
      desc: lv => `차징 거대 분열빔 · DMG ${50+lv*35} · 다중 분기`,
      // piercingChain + railgun — 거대 빔이 모든 가까운 적에 분기
      init(ab) { ab.cooldown = 100; ab.chargeFrames = 0; ab.fireFx = 0; ab.fireBeams = []; },
      tick(ab) {
        if (ab.fireFx > 0) ab.fireFx--;
        if (ab.chargeFrames > 0) {
          ab.chargeFrames--;
          if (ab.chargeFrames === 0) {
            // 데미지 대폭 상향: 25+lv*15 → 50+lv*35 (lv4 = 190, 약 2.2배) — 트리플 차징 보상
            const dmg = 50 + ab.level * 35;
            const branchCount = 3 + ab.level;
            const pool = state.enemies.filter(e => e.hp > 0)
              .sort((a, b) => Math.hypot(enemyXY(a)[0]-CX, enemyXY(a)[1]-CY) - Math.hypot(enemyXY(b)[0]-CX, enemyXY(b)[1]-CY));
            const targets = pool.slice(0, branchCount);
            ab.fireBeams = [];
            for (const t of targets) {
              const [tx, ty] = enemyXY(t);
              const ang = Math.atan2(ty - CY, tx - CX);
              const len = ARENA_R + 20;
              const ex = CX + Math.cos(ang) * len, ey = CY + Math.sin(ang) * len;
              for (const e of state.enemies) {
                if (e.hp <= 0) continue;
                const [px, py] = enemyXY(e);
                if (distPointSegmentSq(px, py, CX, CY, ex, ey) < 256) {
                  damageEnemy(e, dmg);
                  spawnParticles(px, py, '#88ddff', 5);
                }
              }
              ab.fireBeams.push({ ang });
            }
            ab.fireFx = 16;
            shake(24, 16);
            // 쿨다운 단축: max 120→80, lv당 -12 (lv4 = 152)
            ab.cooldown = Math.max(80, 200 - ab.level * 12);
          }
        }
        if (ab.chargeFrames > 0) return;
        if (--ab.cooldown > 0) return;
        ab.chargeFrames = 60;
      },
      draw(ab) {
        if (ab.chargeFrames > 0) {
          const prog = 1 - ab.chargeFrames / 60;
          for (let k = 0; k < 10; k++) {
            const pa = state.t * 0.15 + k * (Math.PI * 2 / 10);
            const pr = 70 * (1 - prog) + 30;
            ctx.fillStyle = `rgba(136, 221, 255, ${0.4 + prog * 0.5})`;
            ctx.fillRect(CX + Math.cos(pa) * pr - 2, CY + Math.sin(pa) * pr - 2, 4, 4);
          }
          ctx.strokeStyle = '#88ddff'; ctx.lineWidth = 3;
          ctx.beginPath();
          ctx.arc(CX, CY, 32, -Math.PI/2, -Math.PI/2 + prog * Math.PI * 2);
          ctx.stroke();
        }
        if (ab.fireFx > 0) {
          const a = ab.fireFx / 16;
          const len = ARENA_R + 20;
          for (const beam of ab.fireBeams) {
            const ex = CX + Math.cos(beam.ang) * len, ey = CY + Math.sin(beam.ang) * len;
            ctx.globalAlpha = a * 0.3;
            ctx.strokeStyle = '#88ddff'; ctx.lineWidth = 32;
            ctx.beginPath(); ctx.moveTo(CX, CY); ctx.lineTo(ex, ey); ctx.stroke();
            ctx.globalAlpha = a * 0.9;
            ctx.lineWidth = 16;
            ctx.stroke();
            ctx.globalAlpha = a;
            ctx.strokeStyle = '#ffffff'; ctx.lineWidth = 5;
            ctx.stroke();
          }
          ctx.globalAlpha = 1;
        }
      },
    },

    // ========== 🎰 가챠 캐릭터 고유 능력 — R 등급 (3종) ==========
    // 1. 마린의 부유어뢰
    torpedo: {
      name: '부유어뢰', baseCost: 65, color: '#5599cc', isGachaUnique: true,
      desc: lv => `${2+lv}발 유도 어뢰 · DMG ${9+lv*4} · 광역 ${28+lv*5}`,
      init(ab) { ab.cooldown = 80; ab.torpedoes = []; ab.explosions = []; },
      tick(ab) {
        const dmg = 9 + ab.level * 4;   // 🆕 SR 승격 — 데미지 상향
        const exR = 28 + ab.level * 5;
        for (const e of ab.explosions) e.life--;
        compactInPlace(ab.explosions, _alivePredLife);
        for (const t of ab.torpedoes) {
          t.life--;
          if (!t.target || t.target.hp <= 0) {
            let best = Infinity, target = null;
            for (const e of state.enemies) {
              if (e.hp <= 0) continue;
              const [ex, ey] = enemyXY(e);
              const d2 = (t.x-ex)*(t.x-ex) + (t.y-ey)*(t.y-ey);
              if (d2 < best) { best = d2; target = e; }
            }
            t.target = target;
          }
          if (t.target) {
            const [tx, ty] = enemyXY(t.target);
            const curAng = Math.atan2(t.vy, t.vx);
            const wantAng = Math.atan2(ty - t.y, tx - t.x);
            let diff = wantAng - curAng;
            while (diff > Math.PI) diff -= Math.PI * 2;
            while (diff < -Math.PI) diff += Math.PI * 2;
            const c = Math.max(-0.10, Math.min(0.10, diff));
            const a = curAng + c;
            t.vx = Math.cos(a) * 4; t.vy = Math.sin(a) * 4;
          }
          t.x += t.vx; t.y += t.vy;
          for (const e of state.enemies) {
            if (e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            if ((t.x-ex)*(t.x-ex) + (t.y-ey)*(t.y-ey) < (e.size+5)*(e.size+5)) {
              for (const e2 of state.enemies) {
                if (e2.hp <= 0) continue;
                const [ex2, ey2] = enemyXY(e2);
                if ((t.x-ex2)*(t.x-ex2) + (t.y-ey2)*(t.y-ey2) < exR*exR) {
                  damageEnemy(e2, dmg);
                  spawnParticles(ex2, ey2, '#5599cc', 3);
                }
              }
              ab.explosions.push({x: t.x, y: t.y, r: exR, life: 14});
              t.life = 0;
              break;
            }
          }
          if ((t.x-CX)*(t.x-CX) + (t.y-CY)*(t.y-CY) > (ARENA_R+30)*(ARENA_R+30)) t.life = 0;
        }
        compactInPlace(ab.torpedoes, _alivePredLife);
        if (--ab.cooldown > 0) return;
        const n = 2 + ab.level;
        for (let i = 0; i < n; i++) {
          const ang = Math.random() * Math.PI * 2;
          ab.torpedoes.push({
            x: CX, y: CY,
            vx: Math.cos(ang) * 2.2, vy: Math.sin(ang) * 2.2,
            life: 180, target: null,
          });
        }
        ab.cooldown = Math.max(60, 110 - ab.level * 4);
      },
      draw(ab) {
        for (const t of ab.torpedoes) {
          const ang = Math.atan2(t.vy, t.vx);
          ctx.save(); ctx.translate(t.x, t.y); ctx.rotate(ang);
          ctx.save(); ctx.globalCompositeOperation = 'lighter';
          ctx.drawImage(getGlowSprite('#5599cc'), -9, -7, 18, 14);   // 글로우
          ctx.fillStyle = 'rgba(170,221,255,0.5)'; ctx.beginPath(); ctx.arc(-8, 0, 2, 0, Math.PI*2); ctx.arc(-12, 1, 1.5, 0, Math.PI*2); ctx.fill(); // 거품 잔향
          ctx.restore();
          ctx.fillStyle = '#dff0ff'; ctx.beginPath(); ctx.moveTo(6, 0); ctx.lineTo(-4, -3); ctx.lineTo(-4, 3); ctx.closePath(); ctx.fill(); // 어뢰 본체
          ctx.restore();
        }
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        for (const e of ab.explosions) {
          const t = 1 - e.life / 14, a = e.life / 14;
          ctx.globalAlpha = a * 0.5; ctx.fillStyle = '#5599cc'; ctx.beginPath(); ctx.arc(e.x, e.y, e.r*t, 0, Math.PI*2); ctx.fill();
          ctx.globalAlpha = a; ctx.strokeStyle = '#ddeeff'; ctx.lineWidth = 2.5; ctx.beginPath(); ctx.arc(e.x, e.y, e.r*t, 0, Math.PI*2); ctx.stroke();
        }
        ctx.restore(); ctx.globalAlpha = 1;
      },
    },
    // 2. 솔라의 태양흑점
    sunspot: {
      name: '태양흑점', baseCost: 65, color: '#ffaa44', isGachaUnique: true,
      desc: lv => `타워 광역 폭발 · DMG ${9+lv*5} · 반경 ${90+lv*15}`,
      init(ab) { ab.cooldown = 60; ab.fx = 0; },
      tick(ab) {
        if (ab.fx > 0) ab.fx--;
        if (--ab.cooldown > 0) return;
        const radius = 90 + ab.level * 15;
        const dmg = 9 + ab.level * 5;   // 🆕 SR 승격 — 데미지 상향
        for (const e of state.enemies) {
          if (e.hp <= 0) continue;
          const [ex, ey] = enemyXY(e);
          if ((ex-CX)*(ex-CX) + (ey-CY)*(ey-CY) < radius*radius) {
            damageEnemy(e, dmg);
            spawnParticles(ex, ey, '#ffaa44', 3);
          }
        }
        ab.fx = 18;
        ab.cooldown = Math.max(50, 100 - ab.level * 4);
      },
      draw(ab) {
        if (ab.fx <= 0) return;
        const radius = 90 + ab.level * 15;
        const t = 1 - ab.fx / 18, a = ab.fx / 18;
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        // 태양 코어 글로우
        const g = ctx.createRadialGradient(CX, CY, 0, CX, CY, radius * t);
        g.addColorStop(0, `rgba(255,240,160,${a})`); g.addColorStop(0.5, `rgba(255,170,68,${a*0.5})`); g.addColorStop(1, 'rgba(255,120,40,0)');
        ctx.fillStyle = g; ctx.beginPath(); ctx.arc(CX, CY, radius * t, 0, Math.PI*2); ctx.fill();
        // 태양 광선 (방사)
        ctx.globalAlpha = a * 0.8; ctx.strokeStyle = '#ffd070'; ctx.lineWidth = 3; ctx.lineCap = 'round';
        for (let i = 0; i < 12; i++) { const ang = (i/12)*Math.PI*2 + state.t*0.02; const r1 = radius*t*0.75, r2 = radius*t*1.05;
          ctx.beginPath(); ctx.moveTo(CX+Math.cos(ang)*r1, CY+Math.sin(ang)*r1); ctx.lineTo(CX+Math.cos(ang)*r2, CY+Math.sin(ang)*r2); ctx.stroke(); }
        // 선행 링
        ctx.globalAlpha = a; ctx.strokeStyle = '#fff0c0'; ctx.lineWidth = 3; ctx.beginPath(); ctx.arc(CX, CY, radius*t, 0, Math.PI*2); ctx.stroke();
        ctx.restore(); ctx.globalAlpha = 1;
      },
    },
    // 3. 그래비타스의 인력장
    pullField: {
      name: '인력장', baseCost: 70, color: '#a070d0', isGachaUnique: true,
      desc: lv => `정지 인력장 · DMG ${3+lv*2}/주기 · 적 끌어모음`,
      init(ab) { ab.x = CX; ab.y = CY; ab.tickT = 16; ab.life = 0; },
      tick(ab) {
        ab.life--;
        if (ab.life <= 0) {
          // 적 평균 위치로 재배치
          const pool = state.enemies.filter(e => e.hp > 0);
          if (pool.length > 0) {
            let sx = 0, sy = 0;
            for (const e of pool) { const [ex, ey] = enemyXY(e); sx += ex; sy += ey; }
            ab.x = sx / pool.length; ab.y = sy / pool.length;
          } else { ab.x = CX; ab.y = CY; }
          ab.life = 200 + ab.level * 25;
        }
        const pullR = 140 + ab.level * 12;
        const dmg = 3 + ab.level * 2;   // 🆕 SR 승격 — 데미지 상향
        ab.tickT--;
        for (const e of state.enemies) {
          if (e.hp <= 0) continue;
          const [ex, ey] = enemyXY(e);
          const dx = ab.x - ex, dy = ab.y - ey;
          const dist = Math.hypot(dx, dy);
          if (dist < pullR && dist > 5) {
            const ps = (1 - dist / pullR) * 1.8;
            const newEx = ex + (dx/dist) * ps;
            const newEy = ey + (dy/dist) * ps;
            e.angle = Math.atan2(newEy - CY, newEx - CX);
            e.radius = Math.hypot(newEx - CX, newEy - CY);
            e.targetRadius = e.radius; e._xyT = -1; // 🚀 위치 메모 무효화
          }
        }
        if (ab.tickT <= 0) {
          ab.tickT = 16;
          for (const e of state.enemies) {
            if (e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            if ((ab.x-ex)*(ab.x-ex) + (ab.y-ey)*(ab.y-ey) < pullR*pullR * 0.6) {
              damageEnemy(e, dmg);
              spawnParticles(ex, ey, '#a070d0', 1);
            }
          }
        }
      },
      draw(ab) {
        const pullR = 140 + ab.level * 12;
        ctx.save(); ctx.translate(ab.x, ab.y);
        ctx.strokeStyle = 'rgba(160,112,208,0.18)'; ctx.lineWidth = 2; ctx.beginPath(); ctx.arc(0, 0, pullR, 0, Math.PI*2); ctx.stroke();
        ctx.restore();
        drawVoidField(ab.x, ab.y, pullR, '#a070d0', { core: '#e6c8ff', coreR: 20 });
      },
    },

    // ========== 🎰 가챠 R 조합 (3종) ==========
    frozenTorpedo: {
      name: '빙결어뢰', isCombo: true, baseCost: 150, color: '#88ccff',
      desc: lv => `${4+lv}발 유도 어뢰 · DMG ${11+lv*6} · 슬로우 + 광역`,
      init(ab) { ab.cooldown = 75; ab.torpedoes = []; ab.explosions = []; },
      tick(ab) {
        const dmg = 11 + ab.level * 6;   // 🆕 SR 조합 수준으로 상향
        const exR = 40 + ab.level * 6;
        const slowDur = 90 + ab.level * 12;
        for (const e of ab.explosions) e.life--;
        compactInPlace(ab.explosions, _alivePredLife);
        for (const t of ab.torpedoes) {
          t.life--;
          if (!t.target || t.target.hp <= 0) {
            let best = Infinity, tg = null;
            for (const e of state.enemies) {
              if (e.hp <= 0) continue;
              const [ex, ey] = enemyXY(e);
              const d2 = (t.x-ex)*(t.x-ex) + (t.y-ey)*(t.y-ey);
              if (d2 < best) { best = d2; tg = e; }
            }
            t.target = tg;
          }
          if (t.target) {
            const [tx, ty] = enemyXY(t.target);
            const curAng = Math.atan2(t.vy, t.vx);
            const wantAng = Math.atan2(ty - t.y, tx - t.x);
            let diff = wantAng - curAng;
            while (diff > Math.PI) diff -= Math.PI * 2;
            while (diff < -Math.PI) diff += Math.PI * 2;
            const c = Math.max(-0.13, Math.min(0.13, diff));
            const a = curAng + c;
            t.vx = Math.cos(a) * 4.5; t.vy = Math.sin(a) * 4.5;
          }
          t.x += t.vx; t.y += t.vy;
          for (const e of state.enemies) {
            if (e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            if ((t.x-ex)*(t.x-ex) + (t.y-ey)*(t.y-ey) < (e.size+5)*(e.size+5)) {
              for (const e2 of state.enemies) {
                if (e2.hp <= 0) continue;
                const [ex2, ey2] = enemyXY(e2);
                if ((t.x-ex2)*(t.x-ex2) + (t.y-ey2)*(t.y-ey2) < exR*exR) {
                  damageEnemy(e2, dmg);
                  e2.slowFrames = Math.max(e2.slowFrames || 0, slowDur);
                  spawnParticles(ex2, ey2, '#88ccff', 4);
                }
              }
              ab.explosions.push({x: t.x, y: t.y, r: exR, life: 16});
              t.life = 0;
              break;
            }
          }
          if ((t.x-CX)*(t.x-CX) + (t.y-CY)*(t.y-CY) > (ARENA_R+30)*(ARENA_R+30)) t.life = 0;
        }
        compactInPlace(ab.torpedoes, _alivePredLife);
        if (--ab.cooldown > 0) return;
        const n = 4 + ab.level;
        for (let i = 0; i < n; i++) {
          const ang = Math.random() * Math.PI * 2;
          ab.torpedoes.push({
            x: CX, y: CY,
            vx: Math.cos(ang) * 2.5, vy: Math.sin(ang) * 2.5,
            life: 180, target: null,
          });
        }
        ab.cooldown = Math.max(50, 95 - ab.level * 4);
      },
      draw(ab) {
        for (const t of ab.torpedoes) {
          const ang = Math.atan2(t.vy, t.vx);
          ctx.save(); ctx.translate(t.x, t.y); ctx.rotate(ang);
          // 서리 거품 잔향 + 글로우
          ctx.save(); ctx.globalCompositeOperation = 'lighter';
          ctx.drawImage(getGlowSprite('#88ccff'), -10, -8, 20, 16);
          ctx.fillStyle = 'rgba(200,235,255,0.5)'; ctx.beginPath(); ctx.arc(-8,0,2,0,7); ctx.arc(-12,1,1.5,0,7); ctx.fill();
          ctx.restore();
          // 어뢰 본체 (얼음빛)
          ctx.fillStyle = '#eaf5ff'; ctx.beginPath(); ctx.moveTo(6,0); ctx.lineTo(-4,-3); ctx.lineTo(-4,3); ctx.closePath(); ctx.fill();
          ctx.strokeStyle = 'rgba(160,210,255,0.9)'; ctx.lineWidth = 1; ctx.beginPath(); ctx.moveTo(2,0); ctx.lineTo(-3,0); ctx.stroke();
          ctx.restore();
        }
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        for (const e of ab.explosions) {
          const t = 1 - e.life / 16, a = Math.max(0, e.life / 16);
          // 한기 블룸 + 서리 링
          ctx.globalAlpha = a * 0.45;
          const g = ctx.createRadialGradient(e.x, e.y, 0, e.x, e.y, e.r*t);
          g.addColorStop(0, 'rgba(190,225,255,0.6)'); g.addColorStop(1, 'rgba(190,225,255,0)');
          ctx.fillStyle = g; ctx.beginPath(); ctx.arc(e.x, e.y, e.r*t, 0, Math.PI*2); ctx.fill();
          ctx.globalAlpha = a * 0.9; ctx.strokeStyle = '#cfeaff'; ctx.lineWidth = 2; ctx.beginPath(); ctx.arc(e.x, e.y, e.r*t, 0, Math.PI*2); ctx.stroke();
          // 얼음 결정 가시
          ctx.globalAlpha = a; ctx.strokeStyle = '#eaf6ff'; ctx.lineWidth = 1.4;
          for (let k=0;k<6;k++){ const aa=k*Math.PI/3 + t, len=e.r*t*0.9; ctx.beginPath(); ctx.moveTo(e.x,e.y); ctx.lineTo(e.x+Math.cos(aa)*len, e.y+Math.sin(aa)*len); ctx.stroke(); }
        }
        ctx.restore(); ctx.globalAlpha = 1;
      },
    },
    solarStorm: {
      name: '태양폭풍', isCombo: true, baseCost: 130, color: '#ff8844',
      desc: lv => `광역 폭발 + ${1+lv}곳 낙뢰 · DMG ${14+lv*7}`,
      init(ab) { ab.cooldown = 55; ab.fx = 0; ab.bolts = []; },
      tick(ab) {
        if (ab.fx > 0) ab.fx--;
        for (const b of ab.bolts) b.life--;
        compactInPlace(ab.bolts, _alivePredLife);
        if (--ab.cooldown > 0) return;
        const radius = 100 + ab.level * 15;
        // 🆕 SR 조합 수준 — 14+lv*7
        const dmg = 14 + ab.level * 7;
        // 광역
        for (const e of state.enemies) {
          if (e.hp <= 0) continue;
          const [ex, ey] = enemyXY(e);
          if ((ex-CX)*(ex-CX) + (ey-CY)*(ey-CY) < radius*radius) {
            damageEnemy(e, dmg);
            spawnParticles(ex, ey, '#ff8844', 3);
          }
        }
        // 낙뢰
        const strikes = 1 + ab.level;
        const pool = state.enemies.filter(e => e.hp > 0);
        for (let i = 0; i < strikes && pool.length > 0; i++) {
          const idx = Math.floor(Math.random() * pool.length);
          const target = pool.splice(idx, 1)[0];
          const [tx, ty] = enemyXY(target);
          damageEnemy(target, dmg * 1.5);
          ab.bolts.push({x: tx, y: ty, life: 12});
          spawnParticles(tx, ty, '#ffe070', 6);
        }
        ab.fx = 16;
        ab.cooldown = Math.max(40, 80 - ab.level * 3);
      },
      draw(ab) {
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        if (ab.fx > 0) {
          const radius = 100 + ab.level * 15, t = 1 - ab.fx / 16, a = ab.fx / 16;
          // 작열 충격파 블룸
          ctx.globalAlpha = a * 0.5;
          const g = ctx.createRadialGradient(CX, CY, 0, CX, CY, radius*t);
          g.addColorStop(0, 'rgba(255,230,140,0.6)'); g.addColorStop(0.6, 'rgba(255,136,68,0.25)'); g.addColorStop(1, 'rgba(255,100,40,0)');
          ctx.fillStyle = g; ctx.beginPath(); ctx.arc(CX, CY, radius*t, 0, Math.PI*2); ctx.fill();
          // 충격파 링 + 불꽃 스포크
          ctx.globalAlpha = a; ctx.strokeStyle = '#ffd070'; ctx.lineWidth = 3*(1-t*0.5);
          ctx.beginPath(); ctx.arc(CX, CY, radius*t, 0, Math.PI*2); ctx.stroke();
          ctx.lineWidth = 2; ctx.strokeStyle = '#ffaa55';
          for (let k=0;k<10;k++){ const aa=k*Math.PI/5+t, r1=radius*t*0.9, r2=radius*t*1.06; ctx.beginPath(); ctx.moveTo(CX+Math.cos(aa)*r1,CY+Math.sin(aa)*r1); ctx.lineTo(CX+Math.cos(aa)*r2,CY+Math.sin(aa)*r2); ctx.stroke(); }
        }
        // 들쭉날쭉 빛나는 낙뢰 (하늘→타겟, 결정적 지그재그)
        for (const b of ab.bolts) {
          const a = b.life / 12, seg = 9, amp = 9;
          const zig = (lw, col, al) => { ctx.globalAlpha = al; ctx.strokeStyle = col; ctx.lineWidth = lw; ctx.beginPath(); ctx.moveTo(b.x, 0);
            for (let s=1;s<=seg;s++){ const yy=b.y*s/seg, xx=b.x+Math.sin(s*1.8+b.x)*amp*(1-s/seg); ctx.lineTo(xx,yy); } ctx.stroke(); };
          zig(6, '#ffcc55', a*0.4); zig(3, '#ffe070', a*0.8); zig(1.4, '#fff8d0', a);
          // 착탄 섬광
          ctx.globalAlpha = a*0.6; ctx.fillStyle = '#fff4c0'; ctx.beginPath(); ctx.arc(b.x, b.y, 5*a, 0, 7); ctx.fill();
        }
        ctx.restore(); ctx.globalAlpha = 1;
      },
    },
    voidIceVortex: {
      name: '공허빙수렴', isCombo: true, baseCost: 160, color: '#aa88ff',
      desc: lv => `강력 인력장 · DMG ${7+lv*4}/주기 · 빙결 갱신`,
      init(ab) { ab.x = CX; ab.y = CY; ab.tickT = 12; ab.life = 0; },
      tick(ab) {
        ab.life--;
        if (ab.life <= 0) {
          const pool = state.enemies.filter(e => e.hp > 0);
          if (pool.length > 0) {
            let sx = 0, sy = 0;
            for (const e of pool) { const [ex, ey] = enemyXY(e); sx += ex; sy += ey; }
            ab.x = sx / pool.length; ab.y = sy / pool.length;
          } else { ab.x = CX; ab.y = CY; }
          ab.life = 180 + ab.level * 22;
        }
        const pullR = 170 + ab.level * 15;
        const dmg = 7 + ab.level * 4;   // 🆕 SR 조합 수준으로 상향
        const slowDur = 80;
        ab.tickT--;
        for (const e of state.enemies) {
          if (e.hp <= 0) continue;
          const [ex, ey] = enemyXY(e);
          const dx = ab.x - ex, dy = ab.y - ey;
          const dist = Math.hypot(dx, dy);
          if (dist < pullR && dist > 5) {
            const ps = (1 - dist / pullR) * 3;
            const newEx = ex + (dx/dist) * ps;
            const newEy = ey + (dy/dist) * ps;
            e.angle = Math.atan2(newEy - CY, newEx - CX);
            e.radius = Math.hypot(newEx - CX, newEy - CY);
            e.targetRadius = e.radius; e._xyT = -1; // 🚀 위치 메모 무효화
            e.slowFrames = Math.max(e.slowFrames || 0, slowDur);
          }
        }
        if (ab.tickT <= 0) {
          ab.tickT = 12;
          for (const e of state.enemies) {
            if (e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            if ((ab.x-ex)*(ab.x-ex) + (ab.y-ey)*(ab.y-ey) < pullR*pullR * 0.6) {
              damageEnemy(e, dmg);
              spawnParticles(ex, ey, '#aa88ff', 2);
            }
          }
        }
      },
      draw(ab) {
        const pullR = 170 + ab.level * 15;
        // 공허 에너지장 (서리 결정이 인플로우 역할 → 일반 점은 끔)
        drawVoidField(ab.x, ab.y, pullR, '#9a88ff', { core: '#e0d8ff', coreR: 20, particles: 0 });
        // 빨려드는 서리 결정 (작은 다이아 — 안쪽으로 스트리밍)
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        for (let k=0;k<8;k++){ const t=(state.t*0.013 + k/8)%1, r=(pullR*0.75)*(1-t)+10, pa=k*(Math.PI*2/8)+(1-t)*4;
          const px=ab.x+Math.cos(pa)*r, py=ab.y+Math.sin(pa)*r, ds=1.5+t*1.6;
          ctx.globalAlpha=0.35+t*0.55; ctx.fillStyle='#dcecff'; ctx.beginPath(); ctx.moveTo(px,py-ds);ctx.lineTo(px+ds*0.6,py);ctx.lineTo(px,py+ds);ctx.lineTo(px-ds*0.6,py);ctx.closePath(); ctx.fill(); }
        ctx.restore(); ctx.globalAlpha=1;
      },
    },

    // ========== 🎰 가챠 R 트리플 (3종) ==========
    deepSeaBarrage: {
      name: '심해폭격', isCombo: true, isTriple: true, baseCost: 240, color: '#3377cc',
      desc: lv => `${8+lv*2}발 거대 어뢰 · DMG ${20+lv*10} · 강슬로우 + 거대 폭발`,
      init(ab) { ab.cooldown = 100; ab.torpedoes = []; ab.explosions = []; },
      tick(ab) {
        const dmg = 20 + ab.level * 10;   // 🆕 SR 트리플 수준으로 상향
        const exR = 70 + ab.level * 10;
        const slowDur = 160;
        for (const e of ab.explosions) e.life--;
        compactInPlace(ab.explosions, _alivePredLife);
        for (const t of ab.torpedoes) {
          t.life--;
          if (!t.target || t.target.hp <= 0) {
            let best = -1, tg = null;  // 최강 적
            for (const e of state.enemies) {
              { const _s = e.isBoss ? e.hp + 1e9 : e.hp; if (_s > best) { best = _s; tg = e; } }
            }
            t.target = tg;
          }
          if (t.target) {
            const [tx, ty] = enemyXY(t.target);
            const curAng = Math.atan2(t.vy, t.vx);
            const wantAng = Math.atan2(ty - t.y, tx - t.x);
            let diff = wantAng - curAng;
            while (diff > Math.PI) diff -= Math.PI * 2;
            while (diff < -Math.PI) diff += Math.PI * 2;
            const c = Math.max(-0.16, Math.min(0.16, diff));
            const a = curAng + c;
            t.vx = Math.cos(a) * 5; t.vy = Math.sin(a) * 5;
          }
          t.x += t.vx; t.y += t.vy;
          for (const e of state.enemies) {
            if (e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            if ((t.x-ex)*(t.x-ex) + (t.y-ey)*(t.y-ey) < (e.size+6)*(e.size+6)) {
              for (const e2 of state.enemies) {
                if (e2.hp <= 0) continue;
                const [ex2, ey2] = enemyXY(e2);
                if ((t.x-ex2)*(t.x-ex2) + (t.y-ey2)*(t.y-ey2) < exR*exR) {
                  damageEnemy(e2, dmg);
                  e2.slowFrames = Math.max(e2.slowFrames || 0, slowDur);
                  spawnParticles(ex2, ey2, '#3377cc', 6);
                }
              }
              ab.explosions.push({x: t.x, y: t.y, r: exR, life: 20});
              shake(8, 8);
              t.life = 0;
              break;
            }
          }
          if ((t.x-CX)*(t.x-CX) + (t.y-CY)*(t.y-CY) > (ARENA_R+30)*(ARENA_R+30)) t.life = 0;
        }
        compactInPlace(ab.torpedoes, _alivePredLife);
        if (--ab.cooldown > 0) return;
        const n = 8 + ab.level * 2;
        for (let i = 0; i < n; i++) {
          const ang = Math.random() * Math.PI * 2;
          ab.torpedoes.push({
            x: CX, y: CY,
            vx: Math.cos(ang) * 2.5, vy: Math.sin(ang) * 2.5,
            life: 200, target: null,
          });
        }
        ab.cooldown = Math.max(80, 140 - ab.level * 4);
      },
      draw(ab) {
        for (const t of ab.torpedoes) {
          const ang = Math.atan2(t.vy, t.vx);
          ctx.save(); ctx.translate(t.x, t.y); ctx.rotate(ang);
          // 거품 잔향 + 글로우
          ctx.save(); ctx.globalCompositeOperation = 'lighter';
          ctx.drawImage(getGlowSprite('#4499dd'), -13, -10, 26, 20);
          ctx.fillStyle = 'rgba(170,221,255,0.5)'; ctx.beginPath(); ctx.arc(-10,0,2.5,0,7); ctx.arc(-15,1.5,1.8,0,7); ctx.arc(-13,-2,1.4,0,7); ctx.fill();
          ctx.restore();
          // 큰 어뢰 본체
          ctx.fillStyle = '#0e1726'; ctx.beginPath(); ctx.ellipse(0,0,8,4.2,0,0,7); ctx.fill();
          ctx.fillStyle = '#bfe4ff'; ctx.beginPath(); ctx.moveTo(8,0); ctx.lineTo(-5,-3.5); ctx.lineTo(-5,3.5); ctx.closePath(); ctx.fill();
          ctx.fillStyle = '#5aa8e0'; ctx.fillRect(-5,-1,9,2);
          ctx.restore();
        }
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        for (const e of ab.explosions) {
          const t = 1 - e.life / 20, a = Math.max(0, e.life / 20);
          // 물기둥 블룸
          ctx.globalAlpha = a * 0.5;
          const g = ctx.createRadialGradient(e.x, e.y, 0, e.x, e.y, e.r*t);
          g.addColorStop(0, 'rgba(180,225,255,0.7)'); g.addColorStop(0.5, 'rgba(70,150,220,0.3)'); g.addColorStop(1, 'rgba(70,150,220,0)');
          ctx.fillStyle = g; ctx.beginPath(); ctx.arc(e.x, e.y, e.r*t, 0, Math.PI*2); ctx.fill();
          // 2겹 물결 링
          ctx.globalAlpha = a * 0.9; ctx.strokeStyle = '#bfe4ff'; ctx.lineWidth = 3*(1-t*0.5);
          ctx.beginPath(); ctx.arc(e.x, e.y, e.r*t, 0, Math.PI*2); ctx.stroke();
          ctx.globalAlpha = a * 0.5; ctx.lineWidth = 2; ctx.beginPath(); ctx.arc(e.x, e.y, e.r*t*0.66, 0, Math.PI*2); ctx.stroke();
          // 물방울 비산
          ctx.globalAlpha = a; ctx.fillStyle = '#dff2ff';
          for (let k=0;k<8;k++){ const aa=k*Math.PI/4 + t*0.5, dr=e.r*t*(0.85+0.1*Math.sin(k*3)); ctx.beginPath(); ctx.arc(e.x+Math.cos(aa)*dr, e.y+Math.sin(aa)*dr, 2*(1-t)+0.6, 0, 7); ctx.fill(); }
        }
        ctx.restore(); ctx.globalAlpha = 1;
      },
    },
    stellarCollapse: {
      name: '항성붕괴', isCombo: true, isTriple: true, baseCost: 230, color: '#ff6633',
      desc: lv => `초거대 광역 + ${3+lv}곳 운석 · DMG ${26+lv*13}`,
      init(ab) { ab.cooldown = 130; ab.fx = 0; ab.meteors = []; ab.craters = []; },
      tick(ab) {
        if (ab.fx > 0) ab.fx--;
        for (const c of ab.craters) c.life--;
        compactInPlace(ab.craters, _alivePredLife);
        const dmg = 26 + ab.level * 13;   // 🆕 SR 트리플 수준으로 상향
        for (const m of ab.meteors) {
          m.t++;
          if (m.t >= m.fall) {
            const mR = 70 + ab.level * 8;
            for (const e of state.enemies) {
              if (e.hp <= 0) continue;
              const [ex, ey] = enemyXY(e);
              if ((m.x-ex)*(m.x-ex) + (m.y-ey)*(m.y-ey) < mR*mR) {
                damageEnemy(e, dmg);
                spawnParticles(ex, ey, '#ff6633', 5);
              }
            }
            ab.craters.push({x: m.x, y: m.y, r: mR, life: 22});
            shake(14, 10);
            m.done = true;
          }
        }
        compactInPlace(ab.meteors, _predNotDone);
        if (--ab.cooldown > 0) return;
        // 광역 폭발
        const radius = 200 + ab.level * 20;
        for (const e of state.enemies) {
          if (e.hp <= 0) continue;
          const [ex, ey] = enemyXY(e);
          if ((ex-CX)*(ex-CX) + (ey-CY)*(ey-CY) < radius*radius) {
            damageEnemy(e, dmg * 0.6);
            spawnParticles(ex, ey, '#ffaa66', 3);
          }
        }
        // 운석 낙하 예약 — TD: 적 위치 타격 / 클래식: 무작위
        const strikes = 3 + ab.level;
        const positions = tdDropPositions(strikes);
        for (let i = 0; i < positions.length; i++) {
          ab.meteors.push({x: positions[i].x, y: positions[i].y, t: -i * 8, fall: 40});
        }
        ab.fx = 20;
        ab.cooldown = Math.max(100, 180 - ab.level * 5);
      },
      draw(ab) {
        if (ab.fx > 0) {
          const radius = 200 + ab.level * 20, t = 1 - ab.fx / 20, a = ab.fx / 20;
          ctx.save(); ctx.globalCompositeOperation = 'lighter';
          // 항성 붕괴 충격파 블룸
          ctx.globalAlpha = a * 0.5;
          const g = ctx.createRadialGradient(CX, CY, 0, CX, CY, radius*t);
          g.addColorStop(0, 'rgba(255,235,150,0.6)'); g.addColorStop(0.5, 'rgba(255,102,51,0.28)'); g.addColorStop(1, 'rgba(255,80,30,0)');
          ctx.fillStyle = g; ctx.beginPath(); ctx.arc(CX, CY, radius*t, 0, Math.PI*2); ctx.fill();
          ctx.globalAlpha = a; ctx.strokeStyle = '#ffcc66'; ctx.lineWidth = 5*(1-t*0.6);
          ctx.beginPath(); ctx.arc(CX, CY, radius*t, 0, Math.PI*2); ctx.stroke();
          ctx.restore(); ctx.globalAlpha = 1;
        }
        for (const m of ab.meteors) {
          if (m.t < 0) continue;
          const progress = m.t / m.fall, my = m.y - (1 - progress) * 250, ms = 9 + progress * 6;
          // 착탄 예고링
          ctx.save(); ctx.globalAlpha = 0.2 + progress*0.4; ctx.strokeStyle = '#ff9a55'; ctx.lineWidth = 2;
          ctx.beginPath(); ctx.arc(m.x, m.y, 12+progress*16, 0, Math.PI*2); ctx.stroke(); ctx.restore();
          // 화염 꼬리 (가산)
          ctx.save(); ctx.globalCompositeOperation = 'lighter';
          const tg = ctx.createLinearGradient(m.x, my-50, m.x, my);
          tg.addColorStop(0, 'rgba(255,120,40,0)'); tg.addColorStop(1, 'rgba(255,200,90,0.7)');
          ctx.fillStyle = tg; ctx.beginPath(); ctx.moveTo(m.x-ms*0.7,my); ctx.lineTo(m.x+ms*0.7,my); ctx.lineTo(m.x+1.5,my-50); ctx.lineTo(m.x-1.5,my-50); ctx.closePath(); ctx.fill();
          ctx.globalAlpha = 0.9; ctx.drawImage(getGlowSprite('#ff8030'), m.x-ms*1.7, my-ms*1.7, ms*3.4, ms*3.4);
          ctx.restore();
          // 화구 본체 (달궈진 구체)
          const bg = ctx.createRadialGradient(m.x-ms*0.3, my-ms*0.3, 1, m.x, my, ms);
          bg.addColorStop(0, '#fff2c0'); bg.addColorStop(0.5, '#ff8a3a'); bg.addColorStop(1, '#5a1e0a');
          ctx.fillStyle = bg; ctx.beginPath(); ctx.arc(m.x, my, ms, 0, Math.PI*2); ctx.fill();
        }
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        for (const c of ab.craters) {
          const t = 1 - c.life / 22, a = Math.max(0, c.life / 22);
          ctx.globalAlpha = a * 0.5;
          const g = ctx.createRadialGradient(c.x, c.y, 0, c.x, c.y, c.r*t);
          g.addColorStop(0, 'rgba(255,224,128,0.7)'); g.addColorStop(0.5, 'rgba(255,102,51,0.3)'); g.addColorStop(1, 'rgba(255,102,51,0)');
          ctx.fillStyle = g; ctx.beginPath(); ctx.arc(c.x, c.y, c.r*t, 0, Math.PI*2); ctx.fill();
          ctx.globalAlpha = a * 0.9; ctx.strokeStyle = '#ffd070'; ctx.lineWidth = 3*(1-t*0.6); ctx.beginPath(); ctx.arc(c.x, c.y, c.r*t, 0, Math.PI*2); ctx.stroke();
          // 불씨
          ctx.globalAlpha = a; ctx.fillStyle = '#ffe080';
          for (let k=0;k<7;k++){ const aa=k*Math.PI*2/7+t, dr=c.r*t*0.8; ctx.beginPath(); ctx.arc(c.x+Math.cos(aa)*dr, c.y+Math.sin(aa)*dr, 2*(1-t)+0.7, 0, 7); ctx.fill(); }
        }
        ctx.restore(); ctx.globalAlpha = 1;
      },
    },
    // ========== 🎰 가챠 SR 캐릭터 고유 능력 (2종) ==========
    // 사쿠라의 벚꽃검 — 부채꼴 광역 검술 (전방 회전)
    sakuraSlash: {
      name: '벚꽃검', baseCost: 80, color: '#ff88bb', isGachaUnique: true,
      desc: lv => `[SR] 회전 부채꼴 베기 · DMG ${14+lv*8} · 범위 ${160+lv*18}`,
      init(ab) { ab.cooldown = 40; ab.fx = 0; ab.ang = 0; ab.petals = []; },
      tick(ab) {
        if (ab.fx > 0) ab.fx--;
        for (const p of ab.petals) { p.x += p.vx; p.y += p.vy; p.life--; p.rot += p.spin; }
        compactInPlace(ab.petals, _alivePredLife);
        if (--ab.cooldown > 0) return;
        const dmg = 14 + ab.level * 8;
        // ⭐ 별 퍼크: ★4 범위 +15%, ★7 범위 +추가 25%
        const range = (160 + ab.level * 18) * permaRangeMul('sakuraSlash');
        // ★2: 회전 속도 +10% (휘두름 각도 ↑)
        const swingDelta = Math.PI * 0.42 * (permaCdMul('sakuraSlash') === 1 ? 1 : 1/permaCdMul('sakuraSlash'));
        const halfArc = Math.PI / 3 * permaAoeMul('sakuraSlash');   // ★7: 부채꼴 각도 +25%
        const swingAng = ab.ang = (ab.ang + swingDelta) % (Math.PI * 2);
        for (const e of state.enemies) {
          if (e.hp <= 0) continue;
          const [ex, ey] = enemyXY(e);
          const dx = ex - CX, dy = ey - CY;
          const dist = Math.hypot(dx, dy);
          if (dist > range) continue;
          let eAng = Math.atan2(dy, dx);
          let diff = eAng - swingAng;
          while (diff > Math.PI) diff -= Math.PI * 2;
          while (diff < -Math.PI) diff += Math.PI * 2;
          if (Math.abs(diff) < halfArc) {
            damageEnemy(e, dmg);
            spawnParticles(ex, ey, '#ff88bb', 4);
          }
        }
        // 꽃잎 분사 — ★3/★6: 꽃잎 개수 추가
        const petalCount = 8 + permaCount('sakuraSlash');
        for (let i = 0; i < petalCount; i++) {
          const a = swingAng - halfArc + (halfArc * 2) * (i / Math.max(1, petalCount - 1));
          ab.petals.push({
            x: CX, y: CY,
            vx: Math.cos(a) * 3.5, vy: Math.sin(a) * 3.5,
            life: 30, rot: a, spin: 0.15,
          });
        }
        ab.fx = 14;
        // ★2: 쿨다운 -10%
        ab.cooldown = Math.max(20, Math.floor((55 - ab.level * 3) * permaCdMul('sakuraSlash')));
      },
      draw(ab) {
        if (ab.fx > 0) {
          const k = ab.fx / 14, t = 1 - k, rng = (160 + ab.level * 18) * (0.7 + t * 0.3), halfArc = Math.PI / 3;
          // 🌸 은은한 수채화 벚꽃 워시 (NORMAL 블렌드 — 부드럽게 번짐, 쨍하지 않게)
          ctx.save();
          const g = ctx.createRadialGradient(CX, CY, rng*0.25, CX, CY, rng);
          g.addColorStop(0, `rgba(255,205,228,${k*0.10})`); g.addColorStop(0.7, `rgba(255,160,200,${k*0.22})`); g.addColorStop(1, 'rgba(255,190,220,0)');
          ctx.fillStyle = g; ctx.beginPath(); ctx.moveTo(CX, CY); ctx.arc(CX, CY, rng, ab.ang - halfArc, ab.ang + halfArc); ctx.closePath(); ctx.fill();
          // 베는 궤적 — 가느다란 연분홍 호 (은은하게)
          ctx.globalAlpha = k * 0.5; ctx.strokeStyle = '#ffd0e6'; ctx.lineWidth = 2.5; ctx.lineCap = 'round';
          ctx.beginPath(); ctx.arc(CX, CY, rng*0.92, ab.ang - halfArc*0.85, ab.ang + halfArc*0.85); ctx.stroke();
          ctx.restore();
        }
        // 꽃잎 (실제 꽃잎 모양 — 부드러운 분홍, 살짝 흰 하이라이트)
        for (const p of ab.petals) {
          ctx.save(); ctx.translate(p.x, p.y); ctx.rotate(p.rot);
          ctx.globalAlpha = Math.min(0.92, p.life / 20);
          ctx.fillStyle = '#ffb6d6';
          ctx.beginPath(); ctx.moveTo(0, -3.5); ctx.quadraticCurveTo(3, 0, 0, 3.5); ctx.quadraticCurveTo(-3, 0, 0, -3.5); ctx.fill();
          ctx.globalAlpha *= 0.5; ctx.fillStyle = '#fff0f6';
          ctx.beginPath(); ctx.moveTo(0, -2); ctx.quadraticCurveTo(1.3, 0, 0, 2); ctx.quadraticCurveTo(-1.3, 0, 0, -2); ctx.fill();
          ctx.restore();
        }
        ctx.globalAlpha = 1;
      },
    },
    // 루나의 월광탄 — 관통 유도 초승달
    moonShot: {
      name: '월광탄', baseCost: 80, color: '#aaccff', isGachaUnique: true,
      desc: lv => `[SR] 관통 유도탄 · DMG ${14+lv*8} · ${4+lv}회 관통 + 광역`,
      init(ab) { ab.cooldown = 48; ab.bullets = []; ab.bursts = []; },
      tick(ab) {
        for (const b of ab.bursts) b.life--;
        compactInPlace(ab.bursts, _alivePredLife);
        const dmg = 14 + ab.level * 8;
        // ⭐ 별 퍼크: ★3/★6 관통 +1/+3, ★7 폭발 반경 +25%
        const pierceMax = 4 + ab.level + permaCount('moonShot');
        const burstR = (42 + ab.level * 5) * permaAoeMul('moonShot');
        const burstR2 = burstR * burstR;
        // 🛡 탄환 처리 — 죽은 탄환 즉시 스킵 + 모든 루프에 명시적 break 조건
        for (const b of ab.bullets) {
          if (b.life <= 0) continue;
          b.life--;
          if (!b.target || b.target.hp <= 0) {
            let best = Infinity, tg = null;
            for (const e of state.enemies) {
              if (e.hp <= 0 || b.hit.has(e)) continue;
              const [ex, ey] = enemyXY(e);
              const d2 = (b.x-ex)*(b.x-ex) + (b.y-ey)*(b.y-ey);
              if (d2 < best) { best = d2; tg = e; }
            }
            b.target = tg;
          }
          if (b.target) {
            const [tx, ty] = enemyXY(b.target);
            const dx = tx - b.x, dy = ty - b.y;
            // 🛡 적이 정확히 같은 위치(NaN 방어) — atan2(0,0)=0이지만 안전 가드
            const distSq = dx*dx + dy*dy;
            if (distSq < 0.01) {
              // 매우 가까움 — 직진 유지
            } else {
              const curAng = Math.atan2(b.vy, b.vx);
              const wantAng = Math.atan2(dy, dx);
              let diff = wantAng - curAng;
              if (!isFinite(diff)) diff = 0;
              // while 루프 → 클램프로 변경 (안전성 보장)
              diff = ((diff + Math.PI) % (Math.PI * 2) + Math.PI * 2) % (Math.PI * 2) - Math.PI;
              const c = Math.max(-0.14, Math.min(0.14, diff));
              const a = curAng + c;
              b.vx = Math.cos(a) * 5; b.vy = Math.sin(a) * 5;
            }
          }
          b.x += b.vx; b.y += b.vy;
          // 🛡 충돌 체크 — break로 즉시 종료
          let hit = false;
          for (const e of state.enemies) {
            if (hit) break;
            if (e.hp <= 0 || b.hit.has(e)) continue;
            const [ex, ey] = enemyXY(e);
            const hitR = e.size + 6;
            if ((b.x-ex)*(b.x-ex) + (b.y-ey)*(b.y-ey) < hitR*hitR) {
              damageEnemy(e, dmg);
              // 광역 폭발 — 주변 적도 60% 데미지 (탄환 직격점 기준)
              for (const e2 of state.enemies) {
                if (e2.hp <= 0 || e2 === e) continue;
                const [ex2, ey2] = enemyXY(e2);
                if ((b.x-ex2)*(b.x-ex2) + (b.y-ey2)*(b.y-ey2) < burstR2) {
                  damageEnemy(e2, dmg * 0.6);
                  spawnParticles(ex2, ey2, '#aaccff', 2);
                }
              }
              spawnParticles(ex, ey, '#aaccff', 5);
              ab.bursts.push({x: b.x, y: b.y, r: burstR, life: 14});
              b.hit.add(e);
              b.pierces++;
              b.target = null;
              if (b.pierces >= pierceMax) b.life = 0;
              hit = true;
            }
          }
          // 아레나 이탈
          if ((b.x-CX)*(b.x-CX) + (b.y-CY)*(b.y-CY) > (ARENA_R+30)*(ARENA_R+30)) b.life = 0;
        }
        compactInPlace(ab.bullets, _alivePredLife);
        if (--ab.cooldown > 0) return;
        if (ab.bullets.length >= 5) { ab.cooldown = 8; return; }
        // 🎯 첫 발사: 가장 가까운 적 방향으로 (랜덤 X) — 프리징 방지 + 적중률↑
        let fireAng;
        const initTarget = findNearestEnemy(ARENA_R + 50);
        if (initTarget) {
          const [tx, ty] = enemyXY(initTarget);
          fireAng = Math.atan2(ty - CY, tx - CX);
        } else {
          fireAng = Math.random() * Math.PI * 2;
        }
        ab.bullets.push({
          x: CX, y: CY,
          vx: Math.cos(fireAng) * 5, vy: Math.sin(fireAng) * 5,
          life: 180, target: initTarget || null, hit: new Set(), pierces: 0,
          sourceId: state.currentAbilityId || null,
        });
        // ★2: 쿨다운 -10%
        ab.cooldown = Math.max(25, Math.floor((55 - ab.level * 3) * permaCdMul('moonShot')));
      },
      draw(ab) {
        for (const b of ab.bullets) {
          const ang = Math.atan2(b.vy, b.vx);
          // 부드러운 달빛 잔광 (꼬리)
          ctx.save(); ctx.globalCompositeOperation = 'lighter';
          const tg = ctx.createLinearGradient(b.x - b.vx*4, b.y - b.vy*4, b.x, b.y);
          tg.addColorStop(0, 'rgba(170,200,255,0)'); tg.addColorStop(1, 'rgba(190,215,255,0.5)');
          ctx.strokeStyle = tg; ctx.lineWidth = 5; ctx.lineCap = 'round';
          ctx.beginPath(); ctx.moveTo(b.x - b.vx*4, b.y - b.vy*4); ctx.lineTo(b.x, b.y); ctx.stroke();
          ctx.restore();
          ctx.save(); ctx.translate(b.x, b.y); ctx.rotate(ang);
          ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.globalAlpha = 0.85; ctx.drawImage(getGlowSprite('#aaccff'), -12, -12, 24, 24); ctx.restore(); // 은은한 글로우
          ctx.fillStyle = '#eef4ff'; ctx.beginPath(); ctx.arc(0, 0, 6, 0, Math.PI*2); ctx.fill();   // 밝은 달
          ctx.fillStyle = '#1a1f2b'; ctx.beginPath(); ctx.arc(2.6, -0.4, 5, 0, Math.PI*2); ctx.fill();  // 초승달 그림자
          // 작은 별빛
          ctx.fillStyle = 'rgba(255,255,255,0.9)'; ctx.beginPath(); ctx.arc(-2.5, -2.5, 1.1, 0, 7); ctx.fill();
          ctx.restore();
        }
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        for (const e of ab.bursts) {
          const t = 1 - e.life / 14, a = Math.max(0, e.life / 14);
          // 은은한 달빛 링
          ctx.globalAlpha = a * 0.9; ctx.strokeStyle = '#cfe2ff'; ctx.lineWidth = 2.5 * (1 - t*0.5);
          ctx.beginPath(); ctx.arc(e.x, e.y, e.r * t, 0, Math.PI*2); ctx.stroke();
          // 부드러운 블룸
          ctx.globalAlpha = a * 0.5;
          const g = ctx.createRadialGradient(e.x, e.y, 0, e.x, e.y, e.r*t*0.9);
          g.addColorStop(0, 'rgba(200,220,255,0.5)'); g.addColorStop(1, 'rgba(200,220,255,0)');
          ctx.fillStyle = g; ctx.beginPath(); ctx.arc(e.x, e.y, e.r*t*0.9, 0, Math.PI*2); ctx.fill();
          // 반짝이는 다이아 별빛 4개
          ctx.globalAlpha = a; ctx.fillStyle = '#eaf2ff';
          for (let k=0;k<4;k++){ const aa=k*Math.PI/2 + t*0.6, dr=e.r*t*0.7, dx=e.x+Math.cos(aa)*dr, dy=e.y+Math.sin(aa)*dr, ds=2.2*(1-t);
            ctx.beginPath(); ctx.moveTo(dx,dy-ds); ctx.lineTo(dx+ds*0.5,dy); ctx.lineTo(dx,dy+ds); ctx.lineTo(dx-ds*0.5,dy); ctx.closePath(); ctx.fill(); }
        }
        ctx.restore(); ctx.globalAlpha = 1;
      },
    },

    // ========== 🎰 가챠 SSR 캐릭터 고유 능력 (2종) ==========
    // 아리아의 별의노래 — 광역 + 별 발사
    starSong: {
      name: '별의노래', baseCost: 95, color: '#ffe070', isGachaUnique: true,
      desc: lv => `[SSR] 광역 펄스 + 별 ${8+lv*2} · DMG ${20+lv*13} / ${10+lv*7}`,
      init(ab) { ab.cooldown = 55; ab.fx = 0; ab.stars = []; },
      tick(ab) {
        if (ab.fx > 0) ab.fx--;
        const starDmg = 10 + ab.level * 7;
        for (const s of ab.stars) {
          s.x += s.vx; s.y += s.vy; s.rot += 0.2; s.life--;
          for (const e of state.enemies) {
            if (e.hp <= 0 || s.hit.has(e)) continue;
            const [ex, ey] = enemyXY(e);
            if ((s.x-ex)*(s.x-ex) + (s.y-ey)*(s.y-ey) < (e.size+7)*(e.size+7)) {
              damageEnemy(e, starDmg);
              s.hit.add(e);
              spawnParticles(ex, ey, '#ffe070', 4);
            }
          }
          if ((s.x-CX)*(s.x-CX) + (s.y-CY)*(s.y-CY) > (ARENA_R+30)*(ARENA_R+30)) s.life = 0;
        }
        compactInPlace(ab.stars, _alivePredLife);
        if (--ab.cooldown > 0) return;
        // ⭐ 별 퍼크: ★4 펄스 반경 +15%, ★7 펄스 반경 +25% 추가
        const pulseR = (180 + ab.level * 18) * permaRangeMul('starSong');
        const pulseDmg = 20 + ab.level * 13;
        // 광역 펄스
        for (const e of state.enemies) {
          if (e.hp <= 0) continue;
          const [ex, ey] = enemyXY(e);
          if ((ex-CX)*(ex-CX) + (ey-CY)*(ey-CY) < pulseR*pulseR) {
            damageEnemy(e, pulseDmg);
            spawnParticles(ex, ey, '#ffe070', 3);
          }
        }
        // 별 발사 — ★3/★6: 별 개수 추가
        const n = 8 + ab.level * 2 + permaCount('starSong');
        const narrowSpread = Math.PI * 0.55;
        tdDirectionalFan(n, narrowSpread, (a) => {
          ab.stars.push({
            x: CX, y: CY,
            vx: Math.cos(a) * 4.5, vy: Math.sin(a) * 4.5,
            life: 110, rot: 0, hit: new Set(),
          });
        });
        ab.fx = 18;
        // ★2: 쿨다운 -10%
        ab.cooldown = Math.max(40, Math.floor((80 - ab.level * 4) * permaCdMul('starSong')));
      },
      draw(ab) {
        if (ab.fx > 0) {
          const pulseR = 180 + ab.level * 18;
          const t = 1 - ab.fx / 18, a = ab.fx / 18;
          ctx.save(); ctx.globalCompositeOperation = 'lighter';
          // 핑크→골드 아이돌 펄스 링
          ctx.globalAlpha = a; ctx.strokeStyle = '#ffd9f0'; ctx.lineWidth = 4 * (1 - t*0.5);
          ctx.beginPath(); ctx.arc(CX, CY, pulseR * t, 0, Math.PI*2); ctx.stroke();
          ctx.globalAlpha = a * 0.45;
          const g = ctx.createRadialGradient(CX, CY, 0, CX, CY, pulseR * t);
          g.addColorStop(0, 'rgba(255,240,180,0.5)'); g.addColorStop(0.6, 'rgba(255,150,210,0.2)'); g.addColorStop(1, 'rgba(255,150,210,0)');
          ctx.fillStyle = g; ctx.beginPath(); ctx.arc(CX, CY, pulseR * t, 0, Math.PI*2); ctx.fill();
          // 방사 반짝이 대시
          ctx.globalAlpha = a; ctx.strokeStyle = '#fff0c0'; ctx.lineWidth = 2;
          for (let k=0;k<12;k++){ const aa=k*Math.PI/6 + t, r1=pulseR*t*0.86, r2=pulseR*t*(0.96+ (k%2)*0.06);
            ctx.beginPath(); ctx.moveTo(CX+Math.cos(aa)*r1, CY+Math.sin(aa)*r1); ctx.lineTo(CX+Math.cos(aa)*r2, CY+Math.sin(aa)*r2); ctx.stroke(); }
          ctx.restore(); ctx.globalAlpha = 1;
        }
        for (const s of ab.stars) {
          ctx.save();
          ctx.translate(s.x, s.y);
          // 부드러운 별빛 글로우
          ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.globalAlpha = 0.7; ctx.drawImage(getGlowSprite('#ffe070'), -11, -11, 22, 22); ctx.restore();
          ctx.rotate(s.rot);
          // 5각 별 (골드)
          ctx.fillStyle = '#ffe070';
          ctx.beginPath();
          for (let k = 0; k < 5; k++) {
            const a1 = -Math.PI/2 + k * (Math.PI*2/5);
            const a2 = a1 + Math.PI/5;
            ctx.lineTo(Math.cos(a1) * 7, Math.sin(a1) * 7);
            ctx.lineTo(Math.cos(a2) * 3, Math.sin(a2) * 3);
          }
          ctx.closePath(); ctx.fill();
          // 반짝 십자 하이라이트
          ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.strokeStyle = 'rgba(255,255,255,0.95)'; ctx.lineWidth = 1.2;
          const tw = 2.5 + Math.sin(state.t*0.3 + s.x)*1.5;
          ctx.beginPath(); ctx.moveTo(-tw,0); ctx.lineTo(tw,0); ctx.moveTo(0,-tw); ctx.lineTo(0,tw); ctx.stroke();
          ctx.restore();
          ctx.restore();
        }
      },
    },
    // 미사키의 시공나비 — 궤도형 유도 나비
    timeButterfly: {
      name: '시공나비', baseCost: 95, color: '#cc88ff', isGachaUnique: true,
      desc: lv => `[SSR] 유도 나비 ${4+lv}마리 · DMG ${18+lv*10} · 강 슬로우 + 정지`,
      init(ab) { ab.butterflies = []; ab.spawnCD = 0; },
      tick(ab) {
        const dmg = 18 + ab.level * 10;
        // ⭐ 별 퍼크: ★5 슬로우/정지 지속 +25%
        const slowDur = Math.floor((110 + ab.level * 15) * permaEffMul('timeButterfly'));
        const stopDur = Math.floor((20 + ab.level * 3) * permaEffMul('timeButterfly'));
        // ★3/★6: 나비 마릿수 추가
        const targetCount = 4 + ab.level + permaCount('timeButterfly');
        // 부족하면 생성 — 더 빨리
        if (ab.butterflies.length < targetCount && --ab.spawnCD <= 0) {
          const ang = Math.random() * Math.PI * 2;
          ab.butterflies.push({
            x: CX + Math.cos(ang) * 30,
            y: CY + Math.sin(ang) * 30,
            vx: 0, vy: 0, target: null,
            phase: Math.random() * Math.PI * 2,
            cd: 0,
          });
          ab.spawnCD = 20;
        }
        for (const b of ab.butterflies) {
          if (b.cd > 0) b.cd--;
          // 타겟 추적
          if (!b.target || b.target.hp <= 0) {
            let best = Infinity, tg = null;
            for (const e of state.enemies) {
              if (e.hp <= 0) continue;
              const [ex, ey] = enemyXY(e);
              const d2 = (b.x-ex)*(b.x-ex) + (b.y-ey)*(b.y-ey);
              if (d2 < best) { best = d2; tg = e; }
            }
            b.target = tg;
          }
          b.phase += 0.15;
          if (b.target) {
            const [tx, ty] = enemyXY(b.target);
            const dx = tx - b.x, dy = ty - b.y;
            const dist = Math.hypot(dx, dy);
            const speed = 5;  // 3.5 → 5 (속도 ↑)
            b.vx = (dx / dist) * speed + Math.cos(b.phase) * 0.5;
            b.vy = (dy / dist) * speed + Math.sin(b.phase) * 0.5;
          } else {
            // 타워 주변 떠다님
            const dx = CX - b.x, dy = CY - b.y;
            const dist = Math.hypot(dx, dy) || 1;
            b.vx = (dx / dist) * 2 + Math.cos(b.phase) * 1;
            b.vy = (dy / dist) * 2 + Math.sin(b.phase) * 1;
          }
          b.x += b.vx; b.y += b.vy;
          // 충돌 — 공격 쿨다운 줄여 DPS ↑
          if (b.cd <= 0) {
            for (const e of state.enemies) {
              if (e.hp <= 0) continue;
              const [ex, ey] = enemyXY(e);
              if ((b.x-ex)*(b.x-ex) + (b.y-ey)*(b.y-ey) < (e.size+7)*(e.size+7)) {
                damageEnemy(e, dmg);
                e.slowFrames = Math.max(e.slowFrames || 0, slowDur);
                if (!e.isBoss) e.timeStopped = state.t + stopDur;
                else e.slowFrames = Math.max(e.slowFrames || 0, slowDur * 1.3); // 보스에겐 슬로우 강화
                spawnParticles(ex, ey, '#cc88ff', 5);
                b.cd = 12;  // 20 → 12 (공격 빈도 67% 증가)
                break;
              }
            }
          }
        }
      },
      draw(ab) {
        for (const b of ab.butterflies) drawTimeButterfly(b, '#cc88ff', 1);
      },
    },

    // ========== 🎰 가챠 SR 조합 (2종) ==========
    // 벚꽃검 + 검(sword) = 벚꽃폭풍 (SR sakura)
    sakuraStorm: {
      name: '벚꽃폭풍', isCombo: true, baseCost: 180, color: '#ff66aa',
      desc: lv => `[SR조합] 회전 ${3+Math.floor(lv/2)}검 · DMG ${15+lv*7} · 광역`,
      init(ab) { ab.ang = 0; ab.tickT = 8; },
      tick(ab) {
        ab.ang += 0.06;
        ab.tickT--;
        const range = 150 + ab.level * 15;
        const dmg = 15 + ab.level * 7;
        const blades = 3 + Math.floor(ab.level / 2);
        if (ab.tickT <= 0) {
          ab.tickT = 10;
          for (let k = 0; k < blades; k++) {
            const bAng = ab.ang + k * (Math.PI * 2 / blades);
            const halfArc = Math.PI / 5;
            for (const e of state.enemies) {
              if (e.hp <= 0) continue;
              const [ex, ey] = enemyXY(e);
              const dx = ex - CX, dy = ey - CY;
              const dist = Math.hypot(dx, dy);
              if (dist > range) continue;
              let eAng = Math.atan2(dy, dx);
              let diff = eAng - bAng;
              while (diff > Math.PI) diff -= Math.PI * 2;
              while (diff < -Math.PI) diff += Math.PI * 2;
              if (Math.abs(diff) < halfArc) {
                damageEnemy(e, dmg);
                spawnParticles(ex, ey, '#ff66aa', 3);
              }
            }
          }
        }
      },
      draw(ab) {
        const range = 150 + ab.level * 15;
        const blades = 3 + Math.floor(ab.level / 2);
        const halfArc = Math.PI / 5;
        // 부드러운 분홍 칼날 부채꼴 (수채화 워시 — NORMAL 블렌드)
        // 🚀 루프 불변 그라디언트 — ab에 (range, CX, CY) 키로 캐시
        if (!ab._bladeG || ab._bladeGK !== range + '|' + CX + '|' + CY) {
          ab._bladeG = ctx.createRadialGradient(CX, CY, range*0.2, CX, CY, range);
          ab._bladeG.addColorStop(0, 'rgba(255,150,195,0.05)'); ab._bladeG.addColorStop(0.7, 'rgba(255,102,170,0.26)'); ab._bladeG.addColorStop(1, 'rgba(255,180,215,0)');
          ab._bladeGK = range + '|' + CX + '|' + CY;
        }
        for (let k = 0; k < blades; k++) {
          const bAng = ab.ang + k * (Math.PI * 2 / blades);
          ctx.fillStyle = ab._bladeG;
          ctx.beginPath(); ctx.moveTo(CX, CY); ctx.arc(CX, CY, range, bAng - halfArc, bAng + halfArc); ctx.closePath(); ctx.fill();
          // 칼날 가장자리 — 가느다란 호
          ctx.globalAlpha = 0.4; ctx.strokeStyle = '#ffd0e6'; ctx.lineWidth = 2; ctx.lineCap = 'round';
          ctx.beginPath(); ctx.arc(CX, CY, range*0.95, bAng - halfArc*0.8, bAng + halfArc*0.8); ctx.stroke();
          ctx.globalAlpha = 1;
        }
        // 🌀 꽃잎 소용돌이 (실제 꽃잎 모양, 나선)
        const swirlN = 16;
        for (let k = 0; k < swirlN; k++) {
          const pa = ab.ang * 1.6 + k * (Math.PI * 2 / swirlN);
          const pr = 30 + ((k * 7 + state.t * 1.4) % 70);
          const px = CX + Math.cos(pa) * pr, py = CY + Math.sin(pa) * pr;
          ctx.save(); ctx.translate(px, py); ctx.rotate(pa + state.t * 0.05);
          ctx.globalAlpha = 0.85 * (1 - pr / 100);
          ctx.fillStyle = '#ffb0d8';
          ctx.beginPath(); ctx.moveTo(0, -3); ctx.quadraticCurveTo(2.5, 0, 0, 3); ctx.quadraticCurveTo(-2.5, 0, 0, -3); ctx.fill();
          ctx.restore();
        }
        ctx.globalAlpha = 1;
      },
    },
    // 월광탄 + 빙결(frost) = 월결화살 (SR luna)
    moonFrostArrow: {
      name: '월결화살', isCombo: true, baseCost: 180, color: '#88aaff',
      desc: lv => `[SR조합] 빙결 관통탄 · DMG ${14+lv*7} · ${4+lv}회 관통 + 슬로우`,
      init(ab) { ab.cooldown = 55; ab.bullets = []; ab.bursts = []; },
      tick(ab) {
        for (const b of ab.bursts) b.life--;
        compactInPlace(ab.bursts, _alivePredLife);
        const dmg = 14 + ab.level * 7;
        const pierceMax = 4 + ab.level;
        const burstR = 45 + ab.level * 5;
        const slowDur = 100 + ab.level * 10;
        // 🛡 탄환 처리 — 죽은 탄환 즉시 스킵 + 명시적 break
        for (const b of ab.bullets) {
          if (b.life <= 0) continue;
          b.life--;
          if (!b.target || b.target.hp <= 0) {
            let best = Infinity, tg = null;
            for (const e of state.enemies) {
              if (e.hp <= 0 || b.hit.has(e)) continue;
              const [ex, ey] = enemyXY(e);
              const d2 = (b.x-ex)*(b.x-ex) + (b.y-ey)*(b.y-ey);
              if (d2 < best) { best = d2; tg = e; }
            }
            b.target = tg;
          }
          if (b.target) {
            const [tx, ty] = enemyXY(b.target);
            const dx = tx - b.x, dy = ty - b.y;
            // 🛡 적이 매우 가까움 — NaN 방어
            if (dx*dx + dy*dy < 0.01) {
              // 직진 유지
            } else {
              const curAng = Math.atan2(b.vy, b.vx);
              const wantAng = Math.atan2(dy, dx);
              let diff = wantAng - curAng;
              if (!isFinite(diff)) diff = 0;
              // while → 클램프 (무한루프 방어)
              diff = ((diff + Math.PI) % (Math.PI * 2) + Math.PI * 2) % (Math.PI * 2) - Math.PI;
              const c = Math.max(-0.16, Math.min(0.16, diff));
              const a = curAng + c;
              b.vx = Math.cos(a) * 5.5; b.vy = Math.sin(a) * 5.5;
            }
          }
          b.x += b.vx; b.y += b.vy;
          // 🛡 충돌 체크 — break 보장
          let hit = false;
          for (const e of state.enemies) {
            if (hit) break;
            if (e.hp <= 0 || b.hit.has(e)) continue;
            const [ex, ey] = enemyXY(e);
            if ((b.x-ex)*(b.x-ex) + (b.y-ey)*(b.y-ey) < (e.size+7)*(e.size+7)) {
              for (const e2 of state.enemies) {
                if (e2.hp <= 0) continue;
                const [ex2, ey2] = enemyXY(e2);
                if ((b.x-ex2)*(b.x-ex2) + (b.y-ey2)*(b.y-ey2) < burstR*burstR) {
                  damageEnemy(e2, dmg * 0.7);
                  e2.slowFrames = Math.max(e2.slowFrames || 0, slowDur);
                  spawnParticles(ex2, ey2, '#88aaff', 3);
                }
              }
              damageEnemy(e, dmg * 0.3); // 직격 추가
              ab.bursts.push({x: ex, y: ey, r: burstR, life: 14});
              b.hit.add(e);
              b.pierces++;
              if (b.pierces >= pierceMax) b.life = 0;
              hit = true;
            }
          }
          if ((b.x-CX)*(b.x-CX) + (b.y-CY)*(b.y-CY) > (ARENA_R+30)*(ARENA_R+30)) b.life = 0;
        }
        compactInPlace(ab.bullets, _alivePredLife);
        if (--ab.cooldown > 0) return;
        if (ab.bullets.length >= 8) { ab.cooldown = 8; return; }  // 🛡 폭주 방지
        const shotN = 1 + Math.floor(ab.level / 3);
        // 🎯 초기 표적 방향으로 발사 (랜덤 X — 프리징 방지)
        const initTarget = findNearestEnemy(ARENA_R + 50);
        for (let k = 0; k < shotN; k++) {
          let fireAng;
          if (initTarget) {
            const [tx, ty] = enemyXY(initTarget);
            fireAng = Math.atan2(ty - CY, tx - CX) + (k - shotN/2) * 0.2;
          } else {
            fireAng = Math.random() * Math.PI * 2;
          }
          ab.bullets.push({
            x: CX, y: CY,
            vx: Math.cos(fireAng) * 3.5, vy: Math.sin(fireAng) * 3.5,
            life: 240, target: initTarget || null, hit: new Set(), pierces: 0,
            sourceId: state.currentAbilityId || null,
          });
        }
        ab.cooldown = Math.max(35, 70 - ab.level * 3);
      },
      draw(ab) {
        for (const b of ab.bullets) {
          const ang = Math.atan2(b.vy, b.vx);
          // 서리 달빛 잔광
          ctx.save(); ctx.globalCompositeOperation = 'lighter';
          const tg = ctx.createLinearGradient(b.x - b.vx*5, b.y - b.vy*5, b.x, b.y);
          tg.addColorStop(0, 'rgba(136,170,255,0)'); tg.addColorStop(1, 'rgba(190,225,255,0.5)');
          ctx.strokeStyle = tg; ctx.lineWidth = 5; ctx.lineCap = 'round';
          ctx.beginPath(); ctx.moveTo(b.x - b.vx*5, b.y - b.vy*5); ctx.lineTo(b.x, b.y); ctx.stroke();
          ctx.restore();
          ctx.save(); ctx.translate(b.x, b.y); ctx.rotate(ang);
          ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.globalAlpha = 0.8; ctx.drawImage(getGlowSprite('#9fc4ff'), -12, -12, 24, 24); ctx.restore();
          // 초승달 촉
          ctx.fillStyle = '#eaf3ff'; ctx.beginPath(); ctx.arc(0, 0, 6.5, 0, Math.PI * 2); ctx.fill();
          ctx.fillStyle = '#1a1f2b'; ctx.beginPath(); ctx.arc(2.4, -0.3, 5.4, 0, Math.PI * 2); ctx.fill();
          // 서리 결정 코어
          ctx.strokeStyle = 'rgba(220,240,255,0.9)'; ctx.lineWidth = 1.2;
          for (let k=0;k<3;k++){ const a=k*Math.PI/3; ctx.beginPath(); ctx.moveTo(-Math.cos(a)*4,-Math.sin(a)*4); ctx.lineTo(Math.cos(a)*4,Math.sin(a)*4); ctx.stroke(); }
          ctx.restore();
        }
        for (const e of ab.bursts) {
          const t = 1 - e.life / 14, a = Math.max(0, e.life / 14);
          ctx.save(); ctx.globalCompositeOperation = 'lighter';
          // 달빛+서리 링
          ctx.globalAlpha = a * 0.85; ctx.strokeStyle = '#bcd8ff'; ctx.lineWidth = 2.2;
          ctx.beginPath(); ctx.arc(e.x, e.y, e.r * t, 0, Math.PI*2); ctx.stroke();
          // 부드러운 한기 블룸
          ctx.globalAlpha = a * 0.45;
          const g = ctx.createRadialGradient(e.x, e.y, 0, e.x, e.y, e.r*t);
          g.addColorStop(0, 'rgba(180,215,255,0.6)'); g.addColorStop(1, 'rgba(180,215,255,0)');
          ctx.fillStyle = g; ctx.beginPath(); ctx.arc(e.x, e.y, e.r*t, 0, Math.PI*2); ctx.fill();
          // 얼음 결정 가시 6개
          ctx.globalAlpha = a; ctx.strokeStyle = '#eaf4ff'; ctx.lineWidth = 1.6;
          for (let k=0;k<6;k++){ const aa=k*Math.PI/3 + t, len=e.r*t*0.95;
            ctx.beginPath(); ctx.moveTo(e.x, e.y); ctx.lineTo(e.x+Math.cos(aa)*len, e.y+Math.sin(aa)*len); ctx.stroke(); }
          ctx.restore();
        }
        ctx.globalAlpha = 1;
      },
    },

    // ========== 🎰 가챠 SSR 조합 (2종) ==========
    // 별의노래 + 노바(nova) = 우주합창 (SSR aria)
    cosmicChorus: {
      name: '우주합창', isCombo: true, baseCost: 220, color: '#ffcc66',
      desc: lv => `[SSR조합] 광역+별 ${10+lv*2} · DMG ${20+lv*12} / ${10+lv*6}`,
      init(ab) { ab.cooldown = 70; ab.fx = 0; ab.stars = []; ab.rings = []; },
      tick(ab) {
        if (ab.fx > 0) ab.fx--;
        for (const r of ab.rings) r.life--;
        compactInPlace(ab.rings, _alivePredLife);
        const starDmg = 10 + ab.level * 6;
        for (const s of ab.stars) {
          s.x += s.vx; s.y += s.vy; s.rot += 0.25; s.life--;
          for (const e of state.enemies) {
            if (e.hp <= 0 || s.hit.has(e)) continue;
            const [ex, ey] = enemyXY(e);
            if ((s.x-ex)*(s.x-ex) + (s.y-ey)*(s.y-ey) < (e.size+9)*(e.size+9)) {
              damageEnemy(e, starDmg);
              s.hit.add(e);
              spawnParticles(ex, ey, '#ffcc66', 5);
            }
          }
          if ((s.x-CX)*(s.x-CX) + (s.y-CY)*(s.y-CY) > (ARENA_R+30)*(ARENA_R+30)) s.life = 0;
        }
        compactInPlace(ab.stars, _alivePredLife);
        if (--ab.cooldown > 0) return;
        const pulseR = 200 + ab.level * 20;
        const pulseDmg = 20 + ab.level * 12;
        for (const e of state.enemies) {
          if (e.hp <= 0) continue;
          const [ex, ey] = enemyXY(e);
          if ((ex-CX)*(ex-CX) + (ey-CY)*(ey-CY) < pulseR*pulseR) {
            damageEnemy(e, pulseDmg);
            spawnParticles(ex, ey, '#ffcc66', 4);
          }
        }
        ab.rings.push({r: pulseR, life: 22});
        // 별 발사 — 클래식: 360°, TD: 적 방향 cone
        const n = 10 + ab.level * 2;
        const narrowSpread = Math.PI * 0.55;
        tdDirectionalFan(n, narrowSpread, (a) => {
          ab.stars.push({
            x: CX, y: CY,
            vx: Math.cos(a) * 4.5, vy: Math.sin(a) * 4.5,
            life: 110, rot: 0, hit: new Set(),
          });
        });
        ab.fx = 22;
        ab.cooldown = Math.max(55, 100 - ab.level * 4);
      },
      draw(ab) {
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        for (const r of ab.rings) {
          const t = 1 - r.life / 22, a = Math.max(0, r.life / 22);
          // 합창 음파 — 3겹 조화 링 (핑크/골드)
          for (let layer=0; layer<3; layer++){
            const lr = r.r * t * (0.7 + layer*0.15);
            ctx.globalAlpha = a * (0.7 - layer*0.18);
            ctx.strokeStyle = layer===1 ? '#ffd9f0' : '#ffe070'; ctx.lineWidth = 4 - layer;
            ctx.beginPath(); ctx.arc(CX, CY, lr, 0, Math.PI*2); ctx.stroke();
          }
          ctx.globalAlpha = a * 0.4;
          const g = ctx.createRadialGradient(CX, CY, 0, CX, CY, r.r * t * 0.7);
          g.addColorStop(0, 'rgba(255,240,180,0.5)'); g.addColorStop(0.6, 'rgba(255,160,215,0.18)'); g.addColorStop(1, 'rgba(255,160,215,0)');
          ctx.fillStyle = g; ctx.beginPath(); ctx.arc(CX, CY, r.r * t * 0.7, 0, Math.PI*2); ctx.fill();
        }
        ctx.restore();
        for (const s of ab.stars) {
          ctx.save();
          ctx.translate(s.x, s.y);
          ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.globalAlpha = 0.7; ctx.drawImage(getGlowSprite('#ffcc66'), -12, -12, 24, 24); ctx.restore();
          ctx.rotate(s.rot);
          ctx.fillStyle = '#ffe070';
          ctx.beginPath();
          for (let k = 0; k < 5; k++) {
            const a1 = -Math.PI/2 + k * (Math.PI*2/5);
            const a2 = a1 + Math.PI/5;
            ctx.lineTo(Math.cos(a1) * 8, Math.sin(a1) * 8);
            ctx.lineTo(Math.cos(a2) * 4, Math.sin(a2) * 4);
          }
          ctx.closePath(); ctx.fill();
          ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.strokeStyle = 'rgba(255,255,255,0.9)'; ctx.lineWidth = 1.2;
          const tw = 3 + Math.sin(state.t*0.3 + s.x)*1.6;
          ctx.beginPath(); ctx.moveTo(-tw,0); ctx.lineTo(tw,0); ctx.moveTo(0,-tw); ctx.lineTo(0,tw); ctx.stroke();
          ctx.restore();
          ctx.restore();
        }
        ctx.globalAlpha = 1;
      },
    },
    // 시공나비 + 시간정지(timeStop) = 시간감옥 (SSR misaki)
    timePrison: {
      name: '시간감옥', isCombo: true, baseCost: 220, color: '#bb88ff',
      desc: lv => `[SSR조합] 강화 나비 ${4+lv}마리 · DMG ${16+lv*9} · 강정지`,
      init(ab) { ab.butterflies = []; ab.spawnCD = 0; },
      tick(ab) {
        const dmg = 16 + ab.level * 9;
        const slowDur = 120 + ab.level * 12;
        const stopDur = 25 + ab.level * 4;
        const targetCount = 4 + ab.level;
        if (ab.butterflies.length < targetCount && --ab.spawnCD <= 0) {
          const ang = Math.random() * Math.PI * 2;
          ab.butterflies.push({
            x: CX + Math.cos(ang) * 30,
            y: CY + Math.sin(ang) * 30,
            vx: 0, vy: 0, target: null,
            phase: Math.random() * Math.PI * 2,
            cd: 0,
          });
          ab.spawnCD = 25;
        }
        for (const b of ab.butterflies) {
          if (b.cd > 0) b.cd--;
          if (!b.target || b.target.hp <= 0) {
            let best = -1, tg = null;
            for (const e of state.enemies) {
              if (e.hp <= 0) continue;
              { const _s = e.isBoss ? e.hp + 1e9 : e.hp; if (_s > best) { best = _s; tg = e; } } // 최강 타겟 우선
            }
            b.target = tg;
          }
          b.phase += 0.18;
          if (b.target) {
            const [tx, ty] = enemyXY(b.target);
            const dx = tx - b.x, dy = ty - b.y;
            const dist = Math.hypot(dx, dy);
            const speed = 4.5;
            b.vx = (dx / dist) * speed + Math.cos(b.phase) * 0.6;
            b.vy = (dy / dist) * speed + Math.sin(b.phase) * 0.6;
          } else {
            const dx = CX - b.x, dy = CY - b.y;
            const dist = Math.hypot(dx, dy) || 1;
            b.vx = (dx / dist) * 2 + Math.cos(b.phase) * 1;
            b.vy = (dy / dist) * 2 + Math.sin(b.phase) * 1;
          }
          b.x += b.vx; b.y += b.vy;
          if (b.cd <= 0) {
            for (const e of state.enemies) {
              if (e.hp <= 0) continue;
              const [ex, ey] = enemyXY(e);
              if ((b.x-ex)*(b.x-ex) + (b.y-ey)*(b.y-ey) < (e.size+7)*(e.size+7)) {
                damageEnemy(e, dmg);
                e.slowFrames = Math.max(e.slowFrames || 0, slowDur);
                if (!e.isBoss) e.timeStopped = state.t + stopDur;
                else e.slowFrames = Math.max(e.slowFrames || 0, slowDur * 1.5); // 보스에겐 추가 슬로우
                spawnParticles(ex, ey, '#bb88ff', 5);
                b.cd = 15;
                break;
              }
            }
          }
        }
      },
      draw(ab) {
        // ⏰ 시간정지된 적 발밑에 시계 마법진 (성능 위해 최대 16개)
        const spin = state.t * 0.05; let _circles = 0;
        for (const e of state.enemies) {
          if (e.hp <= 0) continue;
          const stopped = e.timeStopped && e.timeStopped > state.t;
          if (!stopped) continue;
          const [ex, ey] = enemyXY(e);
          drawTimeCircle(ex, ey, (e.size || 10) + 10, spin, 0.5, '#c8a0ff');
          if (++_circles >= 16) break;
        }
        for (const b of ab.butterflies) drawTimeButterfly(b, '#bb88ff', 1.1);
      },
    },

    // ========== 🎰 가챠 SR 트리플 (2종) ==========
    // 벚꽃폭풍 + 회오리(tornado) = 벚꽃지옥 (SR sakura)
    sakuraInferno: {
      name: '벚꽃지옥', isCombo: true, isTriple: true, baseCost: 280, color: '#ff3388',
      desc: lv => `[SR트리플] 회전 ${5+Math.floor(lv/2)}검 폭풍 · DMG ${30+lv*15} · 광역`,
      init(ab) { ab.ang = 0; ab.tickT = 6; ab.petals = []; },
      tick(ab) {
        ab.ang += 0.10;
        ab.tickT--;
        const range = 180 + ab.level * 18;
        const dmg = 30 + ab.level * 15;
        const blades = 5 + Math.floor(ab.level / 2);
        for (const p of ab.petals) {
          p.x += p.vx; p.y += p.vy; p.life--; p.rot += p.spin;
        }
        compactInPlace(ab.petals, _alivePredLife);
        if (ab.tickT <= 0) {
          ab.tickT = 8;
          for (let k = 0; k < blades; k++) {
            const bAng = ab.ang + k * (Math.PI * 2 / blades);
            const halfArc = Math.PI / 4;
            for (const e of state.enemies) {
              if (e.hp <= 0) continue;
              const [ex, ey] = enemyXY(e);
              const dx = ex - CX, dy = ey - CY;
              const dist = Math.hypot(dx, dy);
              if (dist > range) continue;
              let eAng = Math.atan2(dy, dx);
              let diff = eAng - bAng;
              while (diff > Math.PI) diff -= Math.PI * 2;
              while (diff < -Math.PI) diff += Math.PI * 2;
              if (Math.abs(diff) < halfArc) {
                damageEnemy(e, dmg);
                spawnParticles(ex, ey, '#ff3388', 4);
              }
            }
            // 꽃잎 폭풍
            if (Math.random() < 0.3) {
              ab.petals.push({
                x: CX + Math.cos(bAng) * 40,
                y: CY + Math.sin(bAng) * 40,
                vx: Math.cos(bAng) * 4, vy: Math.sin(bAng) * 4,
                life: 50, rot: bAng, spin: 0.2,
              });
            }
          }
          shake(3, 4);
        }
      },
      draw(ab) {
        const range = 180 + ab.level * 18;
        const blades = 5 + Math.floor(ab.level / 2);
        const halfArc = Math.PI / 4;
        // 🌸 전체를 감싸는 부드러운 분홍 폭풍 워시 + 칼날 그라디언트
        // 🚀 루프 불변 — ab에 (range, CX, CY) 키로 캐시
        if (!ab._stormG || ab._stormGK !== range + '|' + CX + '|' + CY) {
          ab._stormG = ctx.createRadialGradient(CX, CY, range*0.15, CX, CY, range*1.02);
          ab._stormG.addColorStop(0, 'rgba(255,140,190,0.12)'); ab._stormG.addColorStop(0.65, 'rgba(255,80,150,0.10)'); ab._stormG.addColorStop(1, 'rgba(255,170,210,0)');
          ab._stormBladeG = ctx.createRadialGradient(CX, CY, range*0.18, CX, CY, range);
          ab._stormBladeG.addColorStop(0, 'rgba(255,120,175,0.06)'); ab._stormBladeG.addColorStop(0.7, 'rgba(255,51,136,0.30)'); ab._stormBladeG.addColorStop(1, 'rgba(255,150,195,0)');
          ab._stormGK = range + '|' + CX + '|' + CY;
        }
        ctx.fillStyle = ab._stormG; ctx.beginPath(); ctx.arc(CX, CY, range*1.02, 0, Math.PI*2); ctx.fill();
        // 칼날 부채꼴 (수채 그라데이션)
        for (let k = 0; k < blades; k++) {
          const bAng = ab.ang + k * (Math.PI * 2 / blades);
          ctx.fillStyle = ab._stormBladeG;
          ctx.beginPath(); ctx.moveTo(CX, CY); ctx.arc(CX, CY, range, bAng - halfArc, bAng + halfArc); ctx.closePath(); ctx.fill();
          // 검광 (가느다란 호 — 끝이 둥글게)
          ctx.globalAlpha = 0.55; ctx.strokeStyle = '#ffd0e6'; ctx.lineWidth = 2.2; ctx.lineCap = 'round';
          ctx.beginPath(); ctx.arc(CX, CY, range*0.93, bAng - halfArc*0.8, bAng + halfArc*0.8); ctx.stroke();
          ctx.globalAlpha = 1;
        }
        // 흩날리는 꽃잎 (실제 꽃잎 모양 + 흰 하이라이트)
        for (const p of ab.petals) {
          ctx.save(); ctx.translate(p.x, p.y); ctx.rotate(p.rot);
          ctx.globalAlpha = Math.min(0.95, p.life / 30);
          ctx.fillStyle = '#ff8cc0';
          ctx.beginPath(); ctx.moveTo(0, -4); ctx.quadraticCurveTo(3, 0, 0, 4); ctx.quadraticCurveTo(-3, 0, 0, -4); ctx.fill();
          ctx.globalAlpha *= 0.5; ctx.fillStyle = '#fff2f8';
          ctx.beginPath(); ctx.moveTo(0, -2); ctx.quadraticCurveTo(1.3, 0, 0, 2); ctx.quadraticCurveTo(-1.3, 0, 0, -2); ctx.fill();
          ctx.restore();
        }
        ctx.globalAlpha = 1;
      },
    },
    // 월결화살 + 미사일(missile) = 월광폭격 (SR luna)
    moonBombardment: {
      name: '월광폭격', isCombo: true, isTriple: true, baseCost: 290, color: '#6688ff',
      desc: lv => `[SR트리플] 낙하 월광탄 ${5+lv} · DMG ${35+lv*17} · 광역+슬로우`,
      init(ab) { ab.cooldown = 100; ab.shells = []; ab.craters = []; },
      tick(ab) {
        const dmg = 35 + ab.level * 17;
        const exR = 80 + ab.level * 10;
        const slowDur = 120;
        for (const c of ab.craters) c.life--;
        compactInPlace(ab.craters, _alivePredLife);
        for (const s of ab.shells) {
          s.t++;
          if (s.t >= s.fall) {
            for (const e of state.enemies) {
              if (e.hp <= 0) continue;
              const [ex, ey] = enemyXY(e);
              if ((s.x-ex)*(s.x-ex) + (s.y-ey)*(s.y-ey) < exR*exR) {
                damageEnemy(e, dmg);
                e.slowFrames = Math.max(e.slowFrames || 0, slowDur);
                spawnParticles(ex, ey, '#6688ff', 6);
              }
            }
            ab.craters.push({x: s.x, y: s.y, r: exR, life: 22});
            shake(8, 8);
            s.done = true;
          }
        }
        compactInPlace(ab.shells, _predNotDone);
        if (--ab.cooldown > 0) return;
        // TD: 적 위치 타격 / 클래식: 무작위
        const strikes = 5 + ab.level;
        const positions = tdDropPositions(strikes, { offset: 45 });
        for (let i = 0; i < positions.length; i++) {
          ab.shells.push({x: positions[i].x, y: positions[i].y, t: -i * 6, fall: 35});
        }
        ab.cooldown = Math.max(75, 140 - ab.level * 5);
      },
      draw(ab) {
        for (const s of ab.shells) {
          if (s.t < 0) continue;
          const progress = s.t / s.fall;
          const my = s.y - (1 - progress) * 260;
          // 착탄 예고링 (땅에 번지는 달빛)
          ctx.save();
          ctx.globalAlpha = 0.25 + progress * 0.45; ctx.strokeStyle = '#9fc0ff'; ctx.lineWidth = 2;
          ctx.beginPath(); ctx.arc(s.x, s.y, 14 + progress * 16, 0, Math.PI*2); ctx.stroke();
          ctx.globalAlpha = 0.12 + progress*0.18;
          const tgg = ctx.createRadialGradient(s.x, s.y, 0, s.x, s.y, 30+progress*16);
          tgg.addColorStop(0, 'rgba(160,195,255,0.6)'); tgg.addColorStop(1, 'rgba(160,195,255,0)');
          ctx.fillStyle = tgg; ctx.beginPath(); ctx.arc(s.x, s.y, 30+progress*16, 0, Math.PI*2); ctx.fill();
          ctx.restore();
          // 낙하 달빛 빔 꼬리
          ctx.save(); ctx.globalCompositeOperation = 'lighter';
          const tg = ctx.createLinearGradient(s.x, my - 40, s.x, my);
          tg.addColorStop(0, 'rgba(170,200,255,0)'); tg.addColorStop(1, 'rgba(200,225,255,0.55)');
          ctx.fillStyle = tg; ctx.fillRect(s.x - 3, my - 40, 6, 40);
          ctx.globalAlpha = 0.85; ctx.drawImage(getGlowSprite('#9fc4ff'), s.x-14, my-14, 28, 28);
          ctx.restore();
          // 초승달 탄두
          ctx.fillStyle = '#eaf3ff'; ctx.beginPath(); ctx.arc(s.x, my, 8, 0, Math.PI * 2); ctx.fill();
          ctx.fillStyle = '#1a1f2b'; ctx.beginPath(); ctx.arc(s.x + 2.4, my-0.3, 6.8, 0, Math.PI * 2); ctx.fill();
        }
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        for (const c of ab.craters) {
          const t = 1 - c.life / 22, a = Math.max(0, c.life / 22);
          // 달빛 충격파 링
          ctx.globalAlpha = a * 0.9; ctx.strokeStyle = '#bcd8ff'; ctx.lineWidth = 3 * (1-t*0.6);
          ctx.beginPath(); ctx.arc(c.x, c.y, c.r * t, 0, Math.PI*2); ctx.stroke();
          // 부드러운 블룸
          ctx.globalAlpha = a * 0.5;
          const g = ctx.createRadialGradient(c.x, c.y, 0, c.x, c.y, c.r*t);
          g.addColorStop(0, 'rgba(190,216,255,0.6)'); g.addColorStop(1, 'rgba(190,216,255,0)');
          ctx.fillStyle = g; ctx.beginPath(); ctx.arc(c.x, c.y, c.r*t, 0, Math.PI*2); ctx.fill();
          // 다이아 별빛
          ctx.globalAlpha = a; ctx.fillStyle = '#eaf4ff';
          for (let k=0;k<5;k++){ const aa=k*Math.PI*2/5 + t*0.5, dr=c.r*t*0.75, dx=c.x+Math.cos(aa)*dr, dy=c.y+Math.sin(aa)*dr, ds=3*(1-t);
            ctx.beginPath(); ctx.moveTo(dx,dy-ds); ctx.lineTo(dx+ds*0.5,dy); ctx.lineTo(dx,dy+ds); ctx.lineTo(dx-ds*0.5,dy); ctx.closePath(); ctx.fill(); }
        }
        ctx.restore(); ctx.globalAlpha = 1;
      },
    },

    // ========== 🎰 가챠 SSR 트리플 (2종) ==========
    // 우주합창 + 메테오(meteor) = 천체교향곡 (SSR aria)
    celestialSymphony: {
      name: '천체교향곡', isCombo: true, isTriple: true, baseCost: 320, color: '#ffaa00',
      desc: lv => `[SSR트리플] 초광역 + 운석 ${4+lv} · DMG ${45+lv*22}`,
      init(ab) { ab.cooldown = 130; ab.meteors = []; ab.craters = []; ab.fx = 0; ab.stars = []; },
      tick(ab) {
        if (ab.fx > 0) ab.fx--;
        for (const c of ab.craters) c.life--;
        compactInPlace(ab.craters, _alivePredLife);
        const dmg = 45 + ab.level * 22;
        const starDmg = 20 + ab.level * 12;
        for (const s of ab.stars) {
          s.x += s.vx; s.y += s.vy; s.rot += 0.3; s.life--;
          for (const e of state.enemies) {
            if (e.hp <= 0 || s.hit.has(e)) continue;
            const [ex, ey] = enemyXY(e);
            if ((s.x-ex)*(s.x-ex) + (s.y-ey)*(s.y-ey) < (e.size+10)*(e.size+10)) {
              damageEnemy(e, starDmg);
              s.hit.add(e);
              spawnParticles(ex, ey, '#ffaa00', 6);
            }
          }
          if ((s.x-CX)*(s.x-CX) + (s.y-CY)*(s.y-CY) > (ARENA_R+30)*(ARENA_R+30)) s.life = 0;
        }
        compactInPlace(ab.stars, _alivePredLife);
        for (const m of ab.meteors) {
          m.t++;
          if (m.t >= m.fall) {
            const mR = 90 + ab.level * 10;
            for (const e of state.enemies) {
              if (e.hp <= 0) continue;
              const [ex, ey] = enemyXY(e);
              if ((m.x-ex)*(m.x-ex) + (m.y-ey)*(m.y-ey) < mR*mR) {
                damageEnemy(e, dmg);
                spawnParticles(ex, ey, '#ffaa00', 7);
              }
            }
            ab.craters.push({x: m.x, y: m.y, r: mR, life: 26});
            shake(16, 12);
            m.done = true;
          }
        }
        compactInPlace(ab.meteors, _predNotDone);
        if (--ab.cooldown > 0) return;
        // 초광역 펄스
        const pulseR = 240 + ab.level * 22;
        for (const e of state.enemies) {
          if (e.hp <= 0) continue;
          const [ex, ey] = enemyXY(e);
          if ((ex-CX)*(ex-CX) + (ey-CY)*(ey-CY) < pulseR*pulseR) {
            damageEnemy(e, dmg * 0.5);
            spawnParticles(ex, ey, '#ffe070', 4);
          }
        }
        // 별 폭사 — 클래식: 360°, TD: 적 방향 cone
        const n = 14;
        const narrowSpread = Math.PI * 0.6;
        tdDirectionalFan(n, narrowSpread, (a) => {
          ab.stars.push({
            x: CX, y: CY,
            vx: Math.cos(a) * 5, vy: Math.sin(a) * 5,
            life: 120, rot: 0, hit: new Set(),
          });
        });
        // 운석 낙하 — 클래식: 아레나 내 무작위 / TD: 경로 위 적 위치에 정밀 타격
        const strikes = 4 + ab.level;
        if (tdIsDefense()) {
          // 살아있는 적 위치 풀에서 무작위 선택 (보스 우선)
          const pool = state.enemies.filter(e => e.hp > 0);
          if (pool.length > 0) {
            // 보스 가중치
            const weighted = [];
            for (const e of pool) {
              const w = e.isBoss ? 5 : 1;
              for (let k = 0; k < w; k++) weighted.push(e);
            }
            for (let i = 0; i < strikes; i++) {
              const target = weighted[Math.floor(Math.random() * weighted.length)];
              const [ex, ey] = enemyXY(target);
              // ±25px 오프셋 (분산 효과)
              const ox = (Math.random() - 0.5) * 50;
              const oy = (Math.random() - 0.5) * 50;
              ab.meteors.push({x: ex + ox, y: ey + oy, t: -i * 7, fall: 42});
            }
          }
        } else {
          for (let i = 0; i < strikes; i++) {
            const a = Math.random() * Math.PI * 2;
            const r = Math.random() * (ARENA_R - 30);
            ab.meteors.push({x: CX + Math.cos(a)*r, y: CY + Math.sin(a)*r, t: -i * 7, fall: 42});
          }
        }
        ab.fx = 24;
        ab.cooldown = Math.max(105, 180 - ab.level * 5);
      },
      draw(ab) {
        const star5 = (R, r) => { ctx.beginPath(); for (let k=0;k<5;k++){ const a1=-Math.PI/2+k*(Math.PI*2/5), a2=a1+Math.PI/5; ctx.lineTo(Math.cos(a1)*R,Math.sin(a1)*R); ctx.lineTo(Math.cos(a2)*r,Math.sin(a2)*r);} ctx.closePath(); };
        if (ab.fx > 0) {
          const pulseR = 240 + ab.level * 22, t = 1 - ab.fx / 24, a = ab.fx / 24;
          ctx.save(); ctx.globalCompositeOperation = 'lighter';
          // 웅장한 3겹 교향 링 (골드+핑크)
          for (let layer=0; layer<3; layer++){
            ctx.globalAlpha = a * (0.8 - layer*0.2); ctx.strokeStyle = layer===1?'#ffd9f0':'#ffe070'; ctx.lineWidth = 6 - layer*1.5;
            ctx.beginPath(); ctx.arc(CX, CY, pulseR * t * (0.7+layer*0.15), 0, Math.PI*2); ctx.stroke();
          }
          ctx.globalAlpha = a * 0.4;
          const g = ctx.createRadialGradient(CX, CY, 0, CX, CY, pulseR*t*0.7);
          g.addColorStop(0, 'rgba(255,240,180,0.5)'); g.addColorStop(0.6, 'rgba(255,160,215,0.2)'); g.addColorStop(1, 'rgba(255,160,215,0)');
          ctx.fillStyle = g; ctx.beginPath(); ctx.arc(CX, CY, pulseR*t*0.7, 0, Math.PI*2); ctx.fill();
          ctx.restore(); ctx.globalAlpha = 1;
        }
        for (const s of ab.stars) {
          ctx.save(); ctx.translate(s.x, s.y);
          ctx.save(); ctx.globalCompositeOperation='lighter'; ctx.globalAlpha=0.75; ctx.drawImage(getGlowSprite('#ffcc44'), -14, -14, 28, 28); ctx.restore();
          ctx.rotate(s.rot); ctx.fillStyle = '#ffe070'; star5(10, 5); ctx.fill();
          ctx.save(); ctx.globalCompositeOperation='lighter'; ctx.strokeStyle='rgba(255,255,255,0.9)'; ctx.lineWidth=1.3; const tw=3.5+Math.sin(state.t*0.3+s.x)*1.8;
          ctx.beginPath(); ctx.moveTo(-tw,0); ctx.lineTo(tw,0); ctx.moveTo(0,-tw); ctx.lineTo(0,tw); ctx.stroke(); ctx.restore();
          ctx.restore();
        }
        // 🌠 별똥별 (운석 대신 떨어지는 별)
        for (const m of ab.meteors) {
          if (m.t < 0) continue;
          const progress = m.t / m.fall, my = m.y - (1 - progress) * 280, ms = 11 + progress * 7;
          // 착탄 예고링
          ctx.save(); ctx.globalAlpha = 0.2 + progress*0.4; ctx.strokeStyle = '#ffd9a0'; ctx.lineWidth = 2;
          ctx.beginPath(); ctx.arc(m.x, m.y, 12+progress*16, 0, Math.PI*2); ctx.stroke(); ctx.restore();
          // 별똥별 꼬리
          ctx.save(); ctx.globalCompositeOperation = 'lighter';
          const tg = ctx.createLinearGradient(m.x, my-46, m.x, my);
          tg.addColorStop(0, 'rgba(255,224,112,0)'); tg.addColorStop(1, 'rgba(255,240,180,0.7)');
          ctx.fillStyle = tg; ctx.fillRect(m.x - 4, my - 46, 8, 46);
          ctx.globalAlpha = 0.85; ctx.drawImage(getGlowSprite('#ffcc44'), m.x-ms*1.6, my-ms*1.6, ms*3.2, ms*3.2);
          ctx.translate(m.x, my); ctx.rotate(progress*4); ctx.fillStyle = '#fff4c8'; star5(ms, ms*0.45); ctx.fill();
          ctx.restore();
        }
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        for (const c of ab.craters) {
          const t = 1 - c.life / 26, a = Math.max(0, c.life / 26);
          ctx.globalAlpha = a * 0.9; ctx.strokeStyle = '#ffe070'; ctx.lineWidth = 3.5*(1-t*0.6);
          ctx.beginPath(); ctx.arc(c.x, c.y, c.r * t, 0, Math.PI*2); ctx.stroke();
          ctx.globalAlpha = a * 0.45;
          const g = ctx.createRadialGradient(c.x, c.y, 0, c.x, c.y, c.r*t);
          g.addColorStop(0, 'rgba(255,235,160,0.6)'); g.addColorStop(1, 'rgba(255,200,150,0)');
          ctx.fillStyle = g; ctx.beginPath(); ctx.arc(c.x, c.y, c.r*t, 0, Math.PI*2); ctx.fill();
          // 별빛 스포크
          ctx.globalAlpha = a; ctx.strokeStyle = '#fff4c8'; ctx.lineWidth = 2;
          for (let k=0;k<8;k++){ const aa=k*Math.PI/4+t, len=c.r*t*0.9; ctx.beginPath(); ctx.moveTo(c.x,c.y); ctx.lineTo(c.x+Math.cos(aa)*len, c.y+Math.sin(aa)*len); ctx.stroke(); }
        }
        ctx.restore(); ctx.globalAlpha = 1;
      },
    },
    // 시간감옥 + 블랙홀(blackhole) = 영원의찰나 (SSR misaki) — 게임 최강
    eternalMoment: {
      name: '영원의찰나', isCombo: true, isTriple: true, baseCost: 340, color: '#9966ff',
      desc: lv => `[SSR트리플] 흡인+나비${6+lv} · DMG ${50+lv*25} · 정지 ${0.8+lv*0.1}s`,
      init(ab) {
        ab.x = CX; ab.y = CY; ab.tickT = 8; ab.life = 0;
        ab.butterflies = []; ab.spawnCD = 0; ab.stopT = 180;
      },
      tick(ab) {
        ab.life--;
        if (ab.life <= 0) {
          const pool = state.enemies.filter(e => e.hp > 0);
          if (pool.length > 0) {
            let sx = 0, sy = 0;
            for (const e of pool) { const [ex, ey] = enemyXY(e); sx += ex; sy += ey; }
            ab.x = sx / pool.length; ab.y = sy / pool.length;
          } else { ab.x = CX; ab.y = CY; }
          ab.life = 200 + ab.level * 25;
        }
        const pullR = 220 + ab.level * 22;
        const dmg = 50 + ab.level * 25;
        const butterflyDmg = 18 + ab.level * 10;
        const slowDur = 100;
        const targetCount = 6 + ab.level;
        // 흡인장 효과
        ab.tickT--;
        for (const e of state.enemies) {
          if (e.hp <= 0) continue;
          const [ex, ey] = enemyXY(e);
          const dx = ab.x - ex, dy = ab.y - ey;
          const dist = Math.hypot(dx, dy);
          if (dist < pullR && dist > 5) {
            const ps = (1 - dist / pullR) * 4.5;
            const newEx = ex + (dx/dist) * ps;
            const newEy = ey + (dy/dist) * ps;
            e.angle = Math.atan2(newEy - CY, newEx - CX);
            e.radius = Math.hypot(newEx - CX, newEy - CY);
            e.targetRadius = e.radius; e._xyT = -1; // 🚀 위치 메모 무효화
            e.slowFrames = Math.max(e.slowFrames || 0, slowDur);
          }
        }
        if (ab.tickT <= 0) {
          ab.tickT = 8;
          for (const e of state.enemies) {
            if (e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            if ((ab.x-ex)*(ab.x-ex) + (ab.y-ey)*(ab.y-ey) < pullR*pullR * 0.6) {
              damageEnemy(e, dmg);
              spawnParticles(ex, ey, '#9966ff', 3);
            }
          }
        }
        // 주기 정지
        ab.stopT--;
        if (ab.stopT <= 0) {
          ab.stopT = Math.max(140, 220 - ab.level * 8);
          const stopDur = Math.floor((0.8 + ab.level * 0.1) * 60);
          for (const e of state.enemies) {
            if (e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            if ((ab.x-ex)*(ab.x-ex) + (ab.y-ey)*(ab.y-ey) < pullR*pullR * 0.8) {
              e.slowFrames = Math.max(e.slowFrames || 0, stopDur);
              if (!e.isBoss) e.timeStopped = state.t + stopDur;
              else e.slowFrames = Math.max(e.slowFrames || 0, stopDur * 1.5);
              spawnParticles(ex, ey, '#ddccff', 4);
            }
          }
        }
        // 나비 유지
        if (ab.butterflies.length < targetCount && --ab.spawnCD <= 0) {
          const ang = Math.random() * Math.PI * 2;
          ab.butterflies.push({
            x: ab.x + Math.cos(ang) * 30,
            y: ab.y + Math.sin(ang) * 30,
            vx: 0, vy: 0, target: null,
            phase: Math.random() * Math.PI * 2,
            cd: 0,
          });
          ab.spawnCD = 20;
        }
        for (const b of ab.butterflies) {
          if (b.cd > 0) b.cd--;
          if (!b.target || b.target.hp <= 0) {
            let best = -1, tg = null;
            for (const e of state.enemies) {
              if (e.hp <= 0) continue;
              { const _s = e.isBoss ? e.hp + 1e9 : e.hp; if (_s > best) { best = _s; tg = e; } }
            }
            b.target = tg;
          }
          b.phase += 0.20;
          if (b.target) {
            const [tx, ty] = enemyXY(b.target);
            const dx = tx - b.x, dy = ty - b.y;
            const dist = Math.hypot(dx, dy);
            const speed = 5;
            b.vx = (dx / dist) * speed;
            b.vy = (dy / dist) * speed;
          } else {
            const dx = ab.x - b.x, dy = ab.y - b.y;
            const dist = Math.hypot(dx, dy) || 1;
            b.vx = (dx / dist) * 2;
            b.vy = (dy / dist) * 2;
          }
          b.x += b.vx; b.y += b.vy;
          if (b.cd <= 0) {
            for (const e of state.enemies) {
              if (e.hp <= 0) continue;
              const [ex, ey] = enemyXY(e);
              if ((b.x-ex)*(b.x-ex) + (b.y-ey)*(b.y-ey) < (e.size+8)*(e.size+8)) {
                damageEnemy(e, butterflyDmg);
                e.slowFrames = Math.max(e.slowFrames || 0, slowDur * 1.5);
                spawnParticles(ex, ey, '#bb88ff', 5);
                b.cd = 12;
                break;
              }
            }
          }
        }
      },
      draw(ab) {
        const pullR = 220 + ab.level * 22, spin = state.t * 0.04;
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        // 부드러운 흡인장 비네트
        const fg = ctx.createRadialGradient(ab.x, ab.y, pullR*0.2, ab.x, ab.y, pullR);
        fg.addColorStop(0, 'rgba(150,110,255,0.18)'); fg.addColorStop(0.7, 'rgba(120,90,230,0.08)'); fg.addColorStop(1, 'rgba(120,90,230,0)');
        ctx.fillStyle = fg; ctx.beginPath(); ctx.arc(ab.x, ab.y, pullR, 0, Math.PI*2); ctx.fill();
        // 시간 물결 (동심 리플)
        for (let i=0;i<3;i++){ const ph=(state.t*0.9 + i*60)%180, rr=pullR*(0.3+ph/180*0.65), fade=1-ph/180;
          ctx.globalAlpha = fade*0.25; ctx.strokeStyle='#c8a0ff'; ctx.lineWidth=1.5; ctx.beginPath(); ctx.arc(ab.x,ab.y,rr,0,Math.PI*2); ctx.stroke(); }
        ctx.restore();
        // 거대 시계 마법진 (2겹, 외곽 + 중간)
        drawTimeCircle(ab.x, ab.y, pullR*0.82, spin, 0.45, '#b48cf0');
        drawTimeCircle(ab.x, ab.y, pullR*0.5, -spin*1.3, 0.4, '#d0b0ff');
        // 빨려드는 시계룬 입자 (나선)
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        for (let k = 0; k < 16; k++) {
          const t = (state.t*0.02 + k/16) % 1, pr = 18 + (1-t) * (pullR*0.5 - 18), pa = state.t * 0.12 + k * (Math.PI*2/16) + (1-t)*3;
          ctx.globalAlpha = 0.3 + t*0.5; ctx.fillStyle = '#d8c0ff';
          const px = ab.x + Math.cos(pa)*pr, py = ab.y + Math.sin(pa)*pr;
          ctx.beginPath(); ctx.arc(px, py, 1.5 + t*1.5, 0, 7); ctx.fill();
        }
        ctx.restore();
        // 영원의 순간 코어 (깊은 보랏빛 + 글로우 테)
        ctx.fillStyle = '#1a0f2e'; ctx.beginPath(); ctx.arc(ab.x, ab.y, 15, 0, Math.PI*2); ctx.fill();
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        const cg = ctx.createRadialGradient(ab.x, ab.y, 6, ab.x, ab.y, 22);
        cg.addColorStop(0, 'rgba(200,160,255,0.7)'); cg.addColorStop(1, 'rgba(150,110,255,0)');
        ctx.fillStyle = cg; ctx.beginPath(); ctx.arc(ab.x, ab.y, 22, 0, Math.PI*2); ctx.fill();
        ctx.restore();
        // 나비
        for (const b of ab.butterflies) drawTimeButterfly(b, '#c79cff', 1.2);
      },
    },

    voidStop: {
      name: '공허정지', isCombo: true, isTriple: true, baseCost: 250, color: '#9966ff',
      desc: lv => `초강력 흡인장 + 주기 정지 · DMG ${14+lv*9}`,
      init(ab) { ab.x = CX; ab.y = CY; ab.tickT = 10; ab.life = 0; ab.stopT = 240; },
      tick(ab) {
        ab.life--;
        if (ab.life <= 0) {
          const pool = state.enemies.filter(e => e.hp > 0);
          if (pool.length > 0) {
            let sx = 0, sy = 0;
            for (const e of pool) { const [ex, ey] = enemyXY(e); sx += ex; sy += ey; }
            ab.x = sx / pool.length; ab.y = sy / pool.length;
          } else { ab.x = CX; ab.y = CY; }
          ab.life = 160 + ab.level * 20;
        }
        const pullR = 220 + ab.level * 20;
        const dmg = 14 + ab.level * 9;   // 🆕 SR 트리플 수준으로 상향
        ab.tickT--;
        for (const e of state.enemies) {
          if (e.hp <= 0) continue;
          const [ex, ey] = enemyXY(e);
          const dx = ab.x - ex, dy = ab.y - ey;
          const dist = Math.hypot(dx, dy);
          if (dist < pullR && dist > 5) {
            const ps = (1 - dist / pullR) * 4;
            const newEx = ex + (dx/dist) * ps;
            const newEy = ey + (dy/dist) * ps;
            e.angle = Math.atan2(newEy - CY, newEx - CX);
            e.radius = Math.hypot(newEx - CX, newEy - CY);
            e.targetRadius = e.radius; e._xyT = -1; // 🚀 위치 메모 무효화
            e.slowFrames = Math.max(e.slowFrames || 0, 50);
          }
        }
        if (ab.tickT <= 0) {
          ab.tickT = 10;
          for (const e of state.enemies) {
            if (e.hp <= 0) continue;
            const [ex, ey] = enemyXY(e);
            if ((ab.x-ex)*(ab.x-ex) + (ab.y-ey)*(ab.y-ey) < pullR*pullR * 0.6) {
              damageEnemy(e, dmg);
              spawnParticles(ex, ey, '#9966ff', 2);
            }
          }
        }
        // 주기 정지 (보스 제외, 약한 적만)
        ab.stopT--;
        if (ab.stopT <= 0) {
          ab.stopT = Math.max(180, 280 - ab.level * 10);
          const stopDur = Math.floor((1.2 + ab.level * 0.15) * 60);
          for (const e of state.enemies) {
            if (e.hp <= 0 || e.isBoss) continue;
            const [ex, ey] = enemyXY(e);
            if ((ab.x-ex)*(ab.x-ex) + (ab.y-ey)*(ab.y-ey) < pullR*pullR * 0.75) {
              e.slowFrames = Math.max(e.slowFrames || 0, stopDur);
              e.timeStopped = state.t + stopDur;
              spawnParticles(ex, ey, '#ddccff', 3);
            }
          }
        }
      },
      draw(ab) {
        const pullR = 220 + ab.level * 20, spin = state.t * 0.045;
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        const fg = ctx.createRadialGradient(ab.x, ab.y, pullR*0.2, ab.x, ab.y, pullR);
        fg.addColorStop(0, 'rgba(150,110,255,0.16)'); fg.addColorStop(0.7, 'rgba(120,90,230,0.07)'); fg.addColorStop(1, 'rgba(120,90,230,0)');
        ctx.fillStyle = fg; ctx.beginPath(); ctx.arc(ab.x, ab.y, pullR, 0, Math.PI*2); ctx.fill();
        ctx.restore();
        drawTimeCircle(ab.x, ab.y, pullR*0.78, spin, 0.4, '#b48cf0');
        // 빨려드는 룬 입자
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        for (let k = 0; k < 12; k++) {
          const t = (state.t*0.02 + k/12) % 1, pr = 16 + (1-t)*(pullR*0.45-16), pa = state.t*0.12 + k*(Math.PI*2/12) + (1-t)*3;
          ctx.globalAlpha = 0.3 + t*0.45; ctx.fillStyle = '#d8c0ff';
          ctx.beginPath(); ctx.arc(ab.x + Math.cos(pa)*pr, ab.y + Math.sin(pa)*pr, 1.4 + t*1.3, 0, 7); ctx.fill();
        }
        ctx.restore();
        ctx.fillStyle = '#1a0f2e'; ctx.beginPath(); ctx.arc(ab.x, ab.y, 13, 0, Math.PI*2); ctx.fill();
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        const cg = ctx.createRadialGradient(ab.x, ab.y, 5, ab.x, ab.y, 20);
        cg.addColorStop(0, 'rgba(200,160,255,0.65)'); cg.addColorStop(1, 'rgba(150,110,255,0)');
        ctx.fillStyle = cg; ctx.beginPath(); ctx.arc(ab.x, ab.y, 20, 0, Math.PI*2); ctx.fill();
        ctx.restore();
      },
    },

    // ═══════════════════════════════════════════════════════════════
    // ⭐ SSR 캐릭터 별 등급 해금 능력 (4★ / 8★ 히든)
    // ═══════════════════════════════════════════════════════════════

    // 🌟 aria 4★ — 천공의 메아리 (Celestial Echo) — 글로벌 주기 AoE
    celestialEcho: {
      name: '천공의메아리', isGachaUnique: true, isStarUnlock: true, baseCost: 360, color: '#fff080',
      desc: lv => `[4★히든] 모든 적에게 주기 광역 · DMG ${50+lv*30} · ${(4 - lv*0.2).toFixed(1)}s`,
      init(ab) { ab.cooldown = 60; ab.flashLife = 0; ab.flashR = 0; },
      tick(ab) {
        if (ab.flashLife > 0) { ab.flashLife--; ab.flashR += 18; }
        if (--ab.cooldown > 0) return;
        const dmg = 50 + ab.level * 30;
        for (const e of state.enemies) {
          if (e.hp <= 0) continue;
          damageEnemy(e, dmg);
          const [ex, ey] = enemyXY(e);
          spawnParticles(ex, ey, '#fff080', 4);
        }
        ab.flashLife = 24; ab.flashR = 30;
        shake(8, 6);
        ab.cooldown = Math.max(120, Math.floor((4 - ab.level * 0.2) * 60));
      },
      draw(ab) {
        if (ab.flashLife <= 0) return;
        const a = ab.flashLife / 24, cx = W/2, cy = H/2;
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        // 메아리치는 동심 황금 링 (3겹, 시차)
        for (let i=0;i<3;i++){
          const rr = ab.flashR - i*36; if (rr <= 0) continue;
          ctx.globalAlpha = a * (0.85 - i*0.22); ctx.strokeStyle = i===0 ? '#fff080' : '#ffd9f0'; ctx.lineWidth = (6 - i*1.5);
          ctx.beginPath(); ctx.arc(cx, cy, rr, 0, Math.PI*2); ctx.stroke();
        }
        // 중앙 부드러운 황금 블룸 (화면 채우기 대신)
        ctx.globalAlpha = a * 0.4;
        const g = ctx.createRadialGradient(cx, cy, 0, cx, cy, ab.flashR*0.7);
        g.addColorStop(0, 'rgba(255,240,160,0.55)'); g.addColorStop(0.6, 'rgba(255,170,210,0.18)'); g.addColorStop(1, 'rgba(255,170,210,0)');
        ctx.fillStyle = g; ctx.beginPath(); ctx.arc(cx, cy, ab.flashR*0.7, 0, Math.PI*2); ctx.fill();
        // 방사 별빛 다이아
        ctx.globalAlpha = a; ctx.fillStyle = '#fff4c8';
        for (let k=0;k<10;k++){ const aa=k*Math.PI/5, dr=ab.flashR*0.85, dx=cx+Math.cos(aa)*dr, dy=cy+Math.sin(aa)*dr, ds=3.5*a;
          ctx.beginPath(); ctx.moveTo(dx,dy-ds); ctx.lineTo(dx+ds*0.5,dy); ctx.lineTo(dx,dy+ds); ctx.lineTo(dx-ds*0.5,dy); ctx.closePath(); ctx.fill(); }
        ctx.restore(); ctx.globalAlpha = 1;
      },
    },

    // 🌟 aria 8★ — 세이렌의 송가 (Siren's Song) — 영구 슬로우 + DoT
    sirensSong: {
      name: '세이렌의송가', isGachaUnique: true, isStarUnlock: true, baseCost: 600, color: '#ff80c8',
      desc: lv => `[8★히든] 전체 슬로우 ${(35+lv*2)}% · DoT ${(8+lv).toFixed(1)}% maxHP/s`,
      init(ab) { ab.dotT = 0; },
      tick(ab) {
        // 영구 슬로우 (매 프레임 slowFrames 갱신)
        const slowDur = 6;   // 6프레임마다 갱신되므로 사실상 영구
        for (const e of state.enemies) {
          if (e.hp <= 0) continue;
          e.slowFrames = Math.max(e.slowFrames || 0, slowDur);
        }
        // DoT — 60프레임(1초)마다 maxHP의 일정% 데미지
        ab.dotT++;
        if (ab.dotT < 60) return;
        ab.dotT = 0;
        const dotPct = (0.08 + ab.level * 0.01);   // 8% + lv*1%
        const bossPct = dotPct * 0.4;
        for (const e of state.enemies) {
          if (e.hp <= 0 || e.maxHp <= 0) continue;
          const pct = e.isBoss ? bossPct : dotPct;
          const dmg = Math.max(1, Math.ceil(e.maxHp * pct));
          damageEnemy(e, dmg);
        }
      },
      draw(ab) {
        const cx = W/2, cy = H/2, t = state.t * 0.02;
        ctx.save();
        // 가장자리 오로라 비네트 (중앙 투명 — 플레이 영역 안 가림)
        const maxR = Math.hypot(W, H) / 2;
        const vg = ctx.createRadialGradient(cx, cy, maxR*0.45, cx, cy, maxR);
        const p1 = 0.07 + Math.sin(t)*0.03, p2 = 0.06 + Math.sin(t+1.5)*0.03, p3 = 0.07 + Math.sin(t+3)*0.03;
        vg.addColorStop(0, 'rgba(255,128,200,0)');
        vg.addColorStop(0.6, `rgba(200,140,255,${p2})`);
        vg.addColorStop(1, `rgba(255,128,200,${p1+p3})`);
        ctx.fillStyle = vg; ctx.fillRect(0, 0, W, H);
        // 은은한 노래 음파 — 천천히 퍼지는 동심 호 (additive)
        ctx.globalCompositeOperation = 'lighter';
        for (let i=0;i<3;i++){
          const ph = (state.t * 0.6 + i*70) % 210, rr = 60 + ph, fade = 1 - ph/210;
          ctx.globalAlpha = fade * 0.18; ctx.strokeStyle = i===1 ? '#c8a0ff' : '#ff9ad0'; ctx.lineWidth = 2;
          ctx.beginPath(); ctx.arc(cx, cy, rr, 0, Math.PI*2); ctx.stroke();
        }
        // 떠다니는 반짝임
        ctx.globalAlpha = 0.5;
        for (let k=0;k<7;k++){
          const a = t*0.5 + k*Math.PI*2/7, r = maxR*0.5 + Math.sin(state.t*0.03+k)*30;
          const sx = cx + Math.cos(a)*r, sy = cy + Math.sin(a)*r, tw = 0.4+0.6*Math.abs(Math.sin(state.t*0.08+k));
          ctx.globalAlpha = tw*0.6; ctx.fillStyle = '#fff0fa';
          ctx.beginPath(); ctx.moveTo(sx,sy-3); ctx.lineTo(sx+1.4,sy); ctx.lineTo(sx,sy+3); ctx.lineTo(sx-1.4,sy); ctx.closePath(); ctx.fill();
        }
        ctx.restore(); ctx.globalAlpha = 1;
      },
    },

    // 🌟 misaki 4★ — 시간의 굴레 (Temporal Loop) — 주기 위치 되감기
    temporalLoop: {
      name: '시간의굴레', isGachaUnique: true, isStarUnlock: true, baseCost: 360, color: '#c084ff',
      desc: lv => `[4★히든] ${(8 - lv*0.3).toFixed(1)}s마다 적 ${5+Math.floor(lv/2)}셀 되감기 · 보스 ${(12+lv)}% maxHP DMG`,
      init(ab) { ab.cooldown = 240; ab.flashLife = 0; },
      tick(ab) {
        if (ab.flashLife > 0) ab.flashLife--;
        if (--ab.cooldown > 0) return;
        const cells = 5 + Math.floor(ab.level / 2);
        const bossDmgPct = 0.12 + ab.level * 0.01;
        for (const e of state.enemies) {
          if (e.hp <= 0) continue;
          if (e.isBoss) {
            const dmg = Math.max(1, Math.ceil(e.maxHp * bossDmgPct));
            damageEnemy(e, dmg);
            const [ex, ey] = enemyXY(e);
            spawnParticles(ex, ey, '#c084ff', 8);
          } else {
            // path 되감기 — pathIdx 감소
            e.pathIdx = Math.max(0, (e.pathIdx || 0) - cells);
            e.pathT = 0;
            // 위치 재계산 (디펜스 모드만 — 표준 모드는 angle/radius 유지)
            if (state.mode === 'defense') {
              const map = getActiveTDMap();
              const paths = getMapPaths(map);
              const path = paths[e.pathId || 0] || paths[0];
              const cell = path[e.pathIdx] || path[0];
              const c = cellCenter(cell.col, cell.row);
              e.x = c.x; e.y = c.y; e._xyT = -1; // 🚀 위치 메모 무효화
            }
            const [ex, ey] = enemyXY(e);
            spawnParticles(ex, ey, '#c084ff', 3);
          }
        }
        ab.flashLife = 30;
        shake(10, 8);
        ab.cooldown = Math.max(180, Math.floor((8 - ab.level * 0.3) * 60));
      },
      draw(ab) {
        if (ab.flashLife <= 0) return;
        const a = ab.flashLife / 30, cx = W/2, cy = H/2;
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        // 되감기 시간 리플 (안쪽으로 수축하는 동심 링 — 회전 아님)
        for (let i = 0; i < 4; i++) {
          const ph = (state.t * 2.2 + i * 55) % 220, rr2 = 230 * (1 - ph/220), fade = (1 - ph/220) * a;
          if (rr2 < 4) continue;
          ctx.globalAlpha = fade * 0.5; ctx.strokeStyle = '#c8a0ff'; ctx.lineWidth = 2;
          ctx.beginPath(); ctx.arc(cx, cy, rr2, 0, Math.PI*2); ctx.stroke();
        }
        // 중앙 부드러운 블룸
        ctx.globalAlpha = a * 0.4;
        const g = ctx.createRadialGradient(cx, cy, 0, cx, cy, 150);
        g.addColorStop(0, 'rgba(200,150,255,0.5)'); g.addColorStop(1, 'rgba(192,132,255,0)');
        ctx.fillStyle = g; ctx.beginPath(); ctx.arc(cx, cy, 150, 0, Math.PI*2); ctx.fill();
        ctx.restore();
        // 중앙 시계 마법진
        drawTimeCircle(cx, cy, 90, -state.t*0.1, a*0.6, '#c8a0ff');
      },
    },

    // 🌟 misaki 8★ — 역설의 동결 (Paradox Freeze) — 주기 전체 동결 + 데미지 증폭
    paradoxFreeze: {
      name: '역설의동결', isGachaUnique: true, isStarUnlock: true, baseCost: 600, color: '#88ddff',
      desc: lv => `[8★히든] ${(12-lv*0.5).toFixed(1)}s마다 전체 동결 ${(2.5+lv*0.2).toFixed(1)}s · 동결 중 받는 DMG ×${(2.5+lv*0.1).toFixed(1)}`,
      init(ab) { ab.cooldown = 360; ab.freezeT = 0; ab.flashLife = 0; },
      tick(ab) {
        if (ab.flashLife > 0) ab.flashLife--;
        // 동결 진행 중 — 적에게 vulnerability 마커 유지
        if (ab.freezeT > 0) {
          ab.freezeT--;
          // 모든 적 정지
          for (const e of state.enemies) {
            if (e.hp <= 0) continue;
            if (e.isBoss) {
              e.slowFrames = Math.max(e.slowFrames || 0, Math.min(60, ab.freezeT));
            } else {
              e.slowFrames = Math.max(e.slowFrames || 0, ab.freezeT);
              e.timeStopped = state.t + 1;   // 매 프레임 갱신
            }
            e._paradoxVuln = true;   // 데미지 증폭 마커
          }
          if (ab.freezeT === 0) {
            // 동결 해제 — 마커 클리어
            for (const e of state.enemies) e._paradoxVuln = false;
          }
        }
        if (--ab.cooldown > 0) return;
        // 동결 발동
        const freezeDur = Math.floor((2.5 + ab.level * 0.2) * 60);
        ab.freezeT = freezeDur;
        ab.flashLife = 30;
        shake(15, 12);
        SFX.combo && SFX.combo();
        for (const e of state.enemies) {
          if (e.hp <= 0) continue;
          const [ex, ey] = enemyXY(e);
          spawnParticles(ex, ey, '#88ddff', 6);
        }
        ab.cooldown = Math.max(360, Math.floor((12 - ab.level * 0.5) * 60));
      },
      draw(ab) {
        const cx = W/2, cy = H/2;
        // 동결 중 — 푸른 시간정지 코팅 (가장자리 비네트 + 동결 시계진)
        if (ab.freezeT > 0) {
          const a = Math.min(1, ab.freezeT / 30);
          ctx.save();
          // 가장자리 비네트 (중앙 투명 → 플레이 영역 안 가림)
          const maxR = Math.hypot(W, H)/2;
          const vg = ctx.createRadialGradient(cx, cy, maxR*0.4, cx, cy, maxR);
          vg.addColorStop(0, 'rgba(136,221,255,0)'); vg.addColorStop(1, `rgba(150,225,255,${0.18*a})`);
          ctx.fillStyle = vg; ctx.fillRect(0, 0, W, H);
          // 가장자리 얼음 결정 (서리꽃)
          ctx.globalCompositeOperation = 'lighter'; ctx.strokeStyle = `rgba(210,242,255,${0.5*a})`; ctx.lineWidth = 1.5;
          for (let k=0;k<14;k++){ const a2=k*Math.PI*2/14, ex=cx+Math.cos(a2)*maxR*0.9, ey=cy+Math.sin(a2)*maxR*0.9, len=14+Math.sin(state.t*0.1+k)*4;
            ctx.save(); ctx.translate(ex,ey); ctx.rotate(a2);
            ctx.beginPath(); ctx.moveTo(0,0); ctx.lineTo(-len,0); ctx.moveTo(-len*0.5,0); ctx.lineTo(-len*0.7,-5); ctx.moveTo(-len*0.5,0); ctx.lineTo(-len*0.7,5); ctx.stroke(); ctx.restore(); }
          ctx.restore();
          // 동결 시계 마법진 (서서히 회전 — 시간 멈춤)
          drawTimeCircle(cx, cy, 130, state.t*0.012, a*0.4, '#a8e4ff');
        }
        // 발동 — 부드러운 방사형 섬광 (전체 흰 채우기 X)
        if (ab.flashLife > 0) {
          const a = ab.flashLife / 30, fr = (1 - a) * Math.min(W,H)*0.5 + 60;
          ctx.save(); ctx.globalCompositeOperation = 'lighter';
          const g = ctx.createRadialGradient(cx, cy, 0, cx, cy, fr);
          g.addColorStop(0, `rgba(220,245,255,${a*0.35})`); g.addColorStop(0.6, `rgba(150,220,255,${a*0.12})`); g.addColorStop(1, 'rgba(150,220,255,0)');
          ctx.fillStyle = g; ctx.beginPath(); ctx.arc(cx, cy, fr, 0, Math.PI*2); ctx.fill();
          ctx.restore();
        }
      },
    },

    // ═══════════════════════════════════════════════════════════════
    // ⭐ SR 캐릭터 별 등급 해금 능력 (SSR 보다 약하지만 쓸만함)
    // ═══════════════════════════════════════════════════════════════

    // 🌸 sakura 4★ — 꽃잎 폭풍 (Petal Storm) — 글로벌 회전 광역
    petalStorm: {
      name: '꽃잎폭풍', isGachaUnique: true, isStarUnlock: true, baseCost: 280, color: '#ff88bb',
      desc: lv => `[4★히든-SR] 5s마다 화면 전체에 회전 꽃잎 · DMG ${30+lv*15}`,
      init(ab) { ab.cooldown = 90; ab.fxLife = 0; ab.petals = []; },
      tick(ab) {
        if (ab.fxLife > 0) ab.fxLife--;
        // 꽃잎 움직임
        for (const p of ab.petals) {
          p.x += p.vx; p.y += p.vy; p.rot += 0.12; p.life--;
          for (const e of state.enemies) {
            if (e.hp <= 0 || p.hit.has(e)) continue;
            const [ex, ey] = enemyXY(e);
            if ((p.x-ex)*(p.x-ex) + (p.y-ey)*(p.y-ey) < (e.size+10)*(e.size+10)) {
              damageEnemy(e, 30 + ab.level * 15);
              p.hit.add(e);
              spawnParticles(ex, ey, '#ff88bb', 3);
            }
          }
        }
        compactInPlace(ab.petals, _alivePredLife);
        if (--ab.cooldown > 0) return;
        // 12개 꽃잎이 중앙에서 방사형으로 발사
        const count = 12;
        for (let i = 0; i < count; i++) {
          const ang = (i / count) * Math.PI * 2 + state.t * 0.02;
          ab.petals.push({
            x: W/2, y: H/2,
            vx: Math.cos(ang) * 4.5, vy: Math.sin(ang) * 4.5,
            rot: 0, life: 90, hit: new Set(),
          });
        }
        ab.fxLife = 20;
        ab.cooldown = Math.max(180, 300 - ab.level * 8);
      },
      draw(ab) {
        // 🌸 회전하는 5장 벚꽃 — 각 발사체가 한 송이 꽃
        for (const p of ab.petals) {
          ctx.save();
          ctx.translate(p.x, p.y); ctx.rotate(p.rot);
          const fade = Math.min(1, p.life / 30);
          // 살짝 번지는 분홍 후광
          ctx.globalAlpha = fade * 0.4;
          const hg = ctx.createRadialGradient(0, 0, 0, 0, 0, 11);
          hg.addColorStop(0, 'rgba(255,150,200,0.6)'); hg.addColorStop(1, 'rgba(255,150,200,0)');
          ctx.fillStyle = hg; ctx.beginPath(); ctx.arc(0, 0, 11, 0, Math.PI*2); ctx.fill();
          // 5장 꽃잎
          ctx.globalAlpha = fade;
          for (let i = 0; i < 5; i++) {
            ctx.save(); ctx.rotate(i * Math.PI * 2 / 5);
            ctx.fillStyle = '#ff9ccb';
            ctx.beginPath(); ctx.moveTo(0, 0); ctx.quadraticCurveTo(3.5, -5, 0, -8.5); ctx.quadraticCurveTo(-3.5, -5, 0, 0); ctx.fill();
            ctx.fillStyle = 'rgba(255,240,247,0.5)';
            ctx.beginPath(); ctx.moveTo(0, -1.5); ctx.quadraticCurveTo(1.6, -4.5, 0, -7); ctx.quadraticCurveTo(-1.6, -4.5, 0, -1.5); ctx.fill();
            ctx.restore();
          }
          // 꽃술
          ctx.fillStyle = '#ffe45e'; ctx.beginPath(); ctx.arc(0, 0, 2, 0, Math.PI * 2); ctx.fill();
          ctx.restore();
        }
        // 발사 순간 — 중앙에서 부드럽게 퍼지는 분홍 블룸 (전체 화면 채우기 X)
        if (ab.fxLife > 0) {
          const a = ab.fxLife / 20, br = (1 - a) * Math.min(W, H) * 0.4 + 40;
          ctx.save();
          const g = ctx.createRadialGradient(W/2, H/2, 0, W/2, H/2, br);
          g.addColorStop(0, `rgba(255,180,215,${a*0.22})`); g.addColorStop(0.7, `rgba(255,136,187,${a*0.10})`); g.addColorStop(1, 'rgba(255,136,187,0)');
          ctx.fillStyle = g; ctx.beginPath(); ctx.arc(W/2, H/2, br, 0, Math.PI*2); ctx.fill();
          ctx.restore();
        }
      },
    },

    // 🌸 sakura 8★ — 벚꽃 특이점 (Cherry Singularity) — 영구 잔잔한 광역 DoT
    cherrySingularity: {
      name: '벚꽃특이점', isGachaUnique: true, isStarUnlock: true, baseCost: 480, color: '#ff60a0',
      desc: lv => `[8★히든-SR] 영구 슬로우 15% · 1.5s마다 전체 ${(3+lv*0.5).toFixed(1)}% maxHP DoT`,
      init(ab) { ab.dotT = 0; ab.petalSpin = 0; },
      tick(ab) {
        ab.petalSpin += 0.03;
        // 영구 슬로우 (잔잔하게)
        for (const e of state.enemies) {
          if (e.hp <= 0) continue;
          e.slowFrames = Math.max(e.slowFrames || 0, 8);   // 약한 슬로우 (15% 효과)
        }
        ab.dotT++;
        if (ab.dotT < 90) return;   // 1.5s 마다
        ab.dotT = 0;
        const dotPct = 0.03 + ab.level * 0.005;
        const bossPct = dotPct * 0.5;
        for (const e of state.enemies) {
          if (e.hp <= 0 || e.maxHp <= 0) continue;
          const pct = e.isBoss ? bossPct : dotPct;
          const dmg = Math.max(1, Math.ceil(e.maxHp * pct));
          damageEnemy(e, dmg);
        }
      },
      draw(ab) {
        const cx = W/2, cy = H/2;
        ctx.save();
        // 잔잔한 분홍 안개 (중앙에서 은은하게 — 전체 채우기 대신 부드러운 방사형)
        const amb = 0.05 + 0.02 * Math.sin(state.t * 0.04);
        const fg = ctx.createRadialGradient(cx, cy, 0, cx, cy, Math.min(W, H) * 0.55);
        fg.addColorStop(0, `rgba(255,150,200,${amb})`); fg.addColorStop(0.6, `rgba(255,110,170,${amb*0.5})`); fg.addColorStop(1, 'rgba(255,150,200,0)');
        ctx.fillStyle = fg; ctx.beginPath(); ctx.arc(cx, cy, Math.min(W, H) * 0.55, 0, Math.PI*2); ctx.fill();
        // 🌀 꽃잎 소용돌이 — 두 겹 링이 반대로 천천히 회전
        const drawPetal = (px, py, rot, sc, al) => {
          ctx.save(); ctx.translate(px, py); ctx.rotate(rot); ctx.scale(sc, sc); ctx.globalAlpha = al;
          ctx.fillStyle = '#ffafd6';
          ctx.beginPath(); ctx.moveTo(0, -4); ctx.quadraticCurveTo(3, 0, 0, 4); ctx.quadraticCurveTo(-3, 0, 0, -4); ctx.fill();
          ctx.globalAlpha = al * 0.5; ctx.fillStyle = '#fff2f8';
          ctx.beginPath(); ctx.moveTo(0, -2); ctx.quadraticCurveTo(1.2, 0, 0, 2); ctx.quadraticCurveTo(-1.2, 0, 0, -2); ctx.fill();
          ctx.restore();
        };
        const rOut = Math.min(W, H) * 0.42, rIn = Math.min(W, H) * 0.27;
        for (let k = 0; k < 10; k++) {
          const a = ab.petalSpin + k * Math.PI * 2 / 10, wob = Math.sin(state.t * 0.05 + k) * 8;
          drawPetal(cx + Math.cos(a) * (rOut + wob), cy + Math.sin(a) * (rOut + wob), a + Math.PI/2, 1.1, 0.5);
        }
        for (let k = 0; k < 7; k++) {
          const a = -ab.petalSpin * 1.4 + k * Math.PI * 2 / 7, wob = Math.cos(state.t * 0.06 + k) * 6;
          drawPetal(cx + Math.cos(a) * (rIn + wob), cy + Math.sin(a) * (rIn + wob), -a, 0.9, 0.42);
        }
        // 중앙 벚꽃 만다라 (천천히 회전하는 한 송이)
        ctx.translate(cx, cy); ctx.rotate(ab.petalSpin * 0.5);
        const pulse = 1 + 0.06 * Math.sin(state.t * 0.06);
        for (let i = 0; i < 5; i++) {
          ctx.save(); ctx.rotate(i * Math.PI * 2 / 5); ctx.scale(pulse, pulse); ctx.globalAlpha = 0.6;
          ctx.fillStyle = '#ff9ccb';
          ctx.beginPath(); ctx.moveTo(0, 0); ctx.quadraticCurveTo(5, -8, 0, -14); ctx.quadraticCurveTo(-5, -8, 0, 0); ctx.fill();
          ctx.restore();
        }
        ctx.globalAlpha = 0.8; ctx.fillStyle = '#ffe45e'; ctx.beginPath(); ctx.arc(0, 0, 3.5, 0, Math.PI*2); ctx.fill();
        ctx.restore();
      },
    },

    // 🌙 luna 4★ — 월광 비 (Lunar Rain) — 주기 월광탄 낙하
    lunarRain: {
      name: '월광비', isGachaUnique: true, isStarUnlock: true, baseCost: 280, color: '#aaccff',
      desc: lv => `[4★히든-SR] 4s마다 ${5+Math.floor(lv/2)}개 월광탄 낙하 · DMG ${25+lv*12} · 광역`,
      init(ab) { ab.cooldown = 90; ab.shells = []; ab.craters = []; },
      tick(ab) {
        for (const c of ab.craters) c.life--;
        compactInPlace(ab.craters, _alivePredLife);
        const dmg = 25 + ab.level * 12;
        const exR = 55 + ab.level * 5;
        const slowDur = 60;
        for (const s of ab.shells) {
          s.t++;
          if (s.t >= 25) {
            for (const e of state.enemies) {
              if (e.hp <= 0) continue;
              const [ex, ey] = enemyXY(e);
              if ((s.x-ex)*(s.x-ex) + (s.y-ey)*(s.y-ey) < exR*exR) {
                damageEnemy(e, dmg);
                e.slowFrames = Math.max(e.slowFrames || 0, slowDur);
                spawnParticles(ex, ey, '#aaccff', 4);
              }
            }
            ab.craters.push({x: s.x, y: s.y, r: exR, life: 16});
            s.done = true;
          }
        }
        compactInPlace(ab.shells, _predNotDone);
        if (--ab.cooldown > 0) return;
        const strikes = 5 + Math.floor(ab.level / 2);
        // 살아있는 적 위치 우선 낙하, 적 없으면 무작위
        const pool = state.enemies.filter(e => e.hp > 0);
        for (let i = 0; i < strikes; i++) {
          let sx, sy;
          if (pool.length > 0) {
            const t = pool[Math.floor(Math.random() * pool.length)];
            const [tx, ty] = enemyXY(t);
            sx = tx + (Math.random() - 0.5) * 80;
            sy = ty + (Math.random() - 0.5) * 80;
          } else {
            sx = Math.random() * W;
            sy = Math.random() * H;
          }
          ab.shells.push({x: sx, y: sy, t: -i * 4});
        }
        ab.cooldown = Math.max(150, 240 - ab.level * 5);
      },
      draw(ab) {
        for (const s of ab.shells) {
          if (s.t < 0) continue;
          const progress = s.t / 25;
          const my = s.y - (1 - progress) * 200;
          // 착탄 예고 (땅에 번지는 은은한 빛)
          ctx.save();
          ctx.globalAlpha = 0.2 + progress * 0.3; ctx.strokeStyle = '#aaccff'; ctx.lineWidth = 1.5;
          ctx.beginPath(); ctx.arc(s.x, s.y, 8 + progress*9, 0, Math.PI*2); ctx.stroke();
          ctx.restore();
          // 달빛 잔광
          ctx.save(); ctx.globalCompositeOperation = 'lighter';
          const tg = ctx.createLinearGradient(s.x, my-26, s.x, my);
          tg.addColorStop(0, 'rgba(170,204,255,0)'); tg.addColorStop(1, 'rgba(200,224,255,0.5)');
          ctx.fillStyle = tg; ctx.fillRect(s.x-2.2, my-26, 4.4, 26);
          ctx.globalAlpha = 0.7; ctx.drawImage(getGlowSprite('#aaccff'), s.x-10, my-10, 20, 20);
          ctx.restore();
          // 초승달 본체
          ctx.fillStyle = '#eaf3ff'; ctx.beginPath(); ctx.arc(s.x, my, 6.5, 0, Math.PI*2); ctx.fill();
          ctx.fillStyle = '#1a1f2b'; ctx.beginPath(); ctx.arc(s.x + 2.2, my-0.3, 5.4, 0, Math.PI*2); ctx.fill();
        }
        ctx.save(); ctx.globalCompositeOperation = 'lighter';
        for (const c of ab.craters) {
          const t = 1 - c.life / 16, a = Math.max(0, c.life / 16);
          ctx.globalAlpha = a * 0.85; ctx.strokeStyle = '#bcd8ff'; ctx.lineWidth = 2;
          ctx.beginPath(); ctx.arc(c.x, c.y, c.r * t, 0, Math.PI*2); ctx.stroke();
          ctx.globalAlpha = a * 0.45;
          const g = ctx.createRadialGradient(c.x, c.y, 0, c.x, c.y, c.r*t);
          g.addColorStop(0, 'rgba(190,216,255,0.55)'); g.addColorStop(1, 'rgba(190,216,255,0)');
          ctx.fillStyle = g; ctx.beginPath(); ctx.arc(c.x, c.y, c.r*t, 0, Math.PI*2); ctx.fill();
        }
        ctx.restore();
        ctx.globalAlpha = 1;
      },
    },

    // 🌙 luna 8★ — 월식 관통 (Eclipse Piercer) — 거대 관통 월광탄
    eclipsePiercer: {
      name: '월식관통', isGachaUnique: true, isStarUnlock: true, baseCost: 480, color: '#6688ff',
      desc: lv => `[8★히든-SR] 6s마다 거대 관통 월광탄 · DMG ${80+lv*40} · ${10+lv}회 관통`,
      init(ab) { ab.cooldown = 100; ab.bullets = []; },
      tick(ab) {
        const dmg = 80 + ab.level * 40;
        const pierceMax = 10 + ab.level;
        const slowDur = 90;
        for (const b of ab.bullets) {
          if (b.life <= 0) continue;
          b.life--;
          // 직진 + 회전
          b.x += b.vx; b.y += b.vy;
          b.rot += 0.15;
          for (const e of state.enemies) {
            if (e.hp <= 0 || b.hit.has(e)) continue;
            const [ex, ey] = enemyXY(e);
            if ((b.x-ex)*(b.x-ex) + (b.y-ey)*(b.y-ey) < (e.size+18)*(e.size+18)) {
              damageEnemy(e, dmg);
              e.slowFrames = Math.max(e.slowFrames || 0, slowDur);
              spawnParticles(ex, ey, '#6688ff', 6);
              b.hit.add(e);
              b.pierces++;
              if (b.pierces >= pierceMax) b.life = 0;
            }
          }
          // 화면 밖 이탈
          if (b.x < -50 || b.x > W + 50 || b.y < -50 || b.y > H + 50) b.life = 0;
        }
        compactInPlace(ab.bullets, _alivePredLife);
        if (--ab.cooldown > 0) return;
        // 한 발 발사 — 가장 먼 적 방향 (관통 효율↑)
        let tg = null, best = -1;
        for (const e of state.enemies) {
          if (e.hp <= 0) continue;
          const [ex, ey] = enemyXY(e);
          const d2 = (ex - W/2)*(ex - W/2) + (ey - H/2)*(ey - H/2);
          if (d2 > best) { best = d2; tg = e; }
        }
        let ang;
        if (tg) {
          const [tx, ty] = enemyXY(tg);
          ang = Math.atan2(ty - H/2, tx - W/2);
        } else {
          ang = Math.random() * Math.PI * 2;
        }
        ab.bullets.push({
          x: W/2, y: H/2,
          vx: Math.cos(ang) * 6, vy: Math.sin(ang) * 6,
          rot: 0, life: 180, hit: new Set(), pierces: 0,
        });
        ab.cooldown = Math.max(240, 360 - ab.level * 8);
      },
      draw(ab) {
        for (const b of ab.bullets) {
          // 길게 끌리는 달빛 잔광
          ctx.save(); ctx.globalCompositeOperation = 'lighter';
          const tg = ctx.createLinearGradient(b.x - b.vx*9, b.y - b.vy*9, b.x, b.y);
          tg.addColorStop(0, 'rgba(150,185,255,0)'); tg.addColorStop(1, 'rgba(200,225,255,0.55)');
          ctx.strokeStyle = tg; ctx.lineWidth = 12; ctx.lineCap = 'round';
          ctx.beginPath(); ctx.moveTo(b.x - b.vx*9, b.y - b.vy*9); ctx.lineTo(b.x, b.y); ctx.stroke();
          ctx.restore();
          ctx.save(); ctx.translate(b.x, b.y);
          // 코로나 글로우 (일식 후광 — 로컬좌표 상수, 캐시)
          ctx.save(); ctx.globalCompositeOperation = 'lighter';
          if (!_eclipseCoronaG) { _eclipseCoronaG = ctx.createRadialGradient(0, 0, 8, 0, 0, 34); _eclipseCoronaG.addColorStop(0, 'rgba(210,228,255,0.85)'); _eclipseCoronaG.addColorStop(0.4, 'rgba(150,185,255,0.4)'); _eclipseCoronaG.addColorStop(1, 'rgba(150,185,255,0)'); }
          ctx.fillStyle = _eclipseCoronaG; ctx.beginPath(); ctx.arc(0, 0, 34, 0, Math.PI*2); ctx.fill();
          // 코로나 광선 (회전)
          ctx.strokeStyle = 'rgba(220,235,255,0.55)'; ctx.lineWidth = 2;
          for (let k=0;k<12;k++){ const a=b.rot*0.5 + k*Math.PI/6, r1=15, r2=15+ (k%2?14:9) + Math.sin(state.t*0.15+k)*3;
            ctx.beginPath(); ctx.moveTo(Math.cos(a)*r1, Math.sin(a)*r1); ctx.lineTo(Math.cos(a)*r2, Math.sin(a)*r2); ctx.stroke(); }
          ctx.restore();
          // 어두운 달 원반 (일식)
          ctx.fillStyle = '#0a0d18'; ctx.beginPath(); ctx.arc(0, 0, 13, 0, Math.PI * 2); ctx.fill();
          // 밝은 코로나 테두리
          ctx.save(); ctx.globalCompositeOperation = 'lighter';
          ctx.strokeStyle = 'rgba(225,238,255,0.95)'; ctx.lineWidth = 2.5; ctx.beginPath(); ctx.arc(0, 0, 13, 0, Math.PI*2); ctx.stroke();
          // 다이아몬드 링 하이라이트 (일식 끝의 빛점)
          const da = b.rot; ctx.fillStyle = '#ffffff'; ctx.beginPath(); ctx.arc(Math.cos(da)*13, Math.sin(da)*13, 3, 0, 7); ctx.fill();
          ctx.restore();
          ctx.restore();
        }
      },
    },
  };
  // ⭐ 별 해금 능력 매핑 — 캐릭터 4★ / 8★ 도달 시 해금
  const CHAR_STAR_UNLOCKS = {
    // SSR
    aria:   { 4: ['celestialEcho'],  8: ['sirensSong'] },
    misaki: { 4: ['temporalLoop'],   8: ['paradoxFreeze'] },
    // SR (SSR 보다 약하지만 쓸만함)
    sakura: { 4: ['petalStorm'],     8: ['cherrySingularity'] },
    luna:   { 4: ['lunarRain'],      8: ['eclipsePiercer'] },
  };
  // 별 등급으로 해금된 능력 목록
  function getStarUnlockedAbilities() {
    const ids = [];
    for (const charId of Object.keys(CHAR_STAR_UNLOCKS)) {
      const stars = getCharStars(charId);
      const unlocks = CHAR_STAR_UNLOCKS[charId];
      if (!unlocks) continue;
      if (stars >= 4 && unlocks[4]) ids.push(...unlocks[4]);
      if (stars >= 8 && unlocks[8]) ids.push(...unlocks[8]);
    }
    return ids;
  }
  const ALL_ABILITY_IDS = Object.keys(ABILITY_DEFS);
  const BASIC_ABILITY_IDS = ALL_ABILITY_IDS.filter(id => !ABILITY_DEFS[id].isCombo);
  // 🛡 v239 — 도감 업적용 "진짜 기본 능력만" (가챠/별해금 제외)
  //   기존 BASIC_ABILITY_IDS 는 isCombo만 제외해서 SR/SSR/별해금 능력까지 포함됨 → 도감 업적이 사실상 불가능
  const PURE_BASIC_ABILITY_IDS = ALL_ABILITY_IDS.filter(id => {
    const d = ABILITY_DEFS[id];
    return !d.isCombo && !d.isGachaUnique && !d.isStarUnlock;
  });
  // 🎰 카드 풀용 ID — 가챠 고유 능력 제외 (해당 캐릭터 startAbilities로만 획득 가능)
  // 도감/업적용 BASIC_ABILITY_IDS 와는 분리
  const RANDOM_POOL_IDS = BASIC_ABILITY_IDS.filter(id => !ABILITY_DEFS[id].isGachaUnique);

  // ===== 💎 유물 시스템 (Relics) =====
  // 보스 처치 시 확률적으로 등장. 한 게임 내 영구 효과. 등급 = common/rare/epic/legendary
  // 아이작/하데스/RoR 영감 — 등급 높을수록 참신하고 게임 체인저
  const RELIC_RARITY = {
    common:    { color: '#9aa3b3', glow: 'rgba(154,163,179,0.4)', label: '일반',  weight: 60 },
    rare:      { color: '#88aaff', glow: 'rgba(136,170,255,0.5)', label: '희귀',  weight: 28 },
    epic:      { color: '#c084ff', glow: 'rgba(192,132,255,0.6)', label: '영웅',  weight: 10 },
    legendary: { color: '#ffd479', glow: 'rgba(255,212,121,0.7)', label: '전설',  weight: 2  },
    // 🌌 v245 — ANCIENT: 가챠 전용 해금, 캐릭터 전용 인게임 드롭 (weight 0 → 일반 풀 제외)
    ancient:   { color: '#ff88ff', glow: 'rgba(255,136,255,0.95)', label: '고대', weight: 0  },
  };
  const RELIC_DROP_CHANCE = 0.40; // 보스 한 마리당 40% 확률로 등장
  const RELICS = {
    // ============================== COMMON (20개) — 위트 있는 이름, 흥미로운 조건 ==============================
    goldBag: { name: '구두쇠의 자루', icon: '💰', rarity: 'common',
