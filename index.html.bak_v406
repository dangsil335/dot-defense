      apply: (st) => { st.relicEffects.dragonStackPerBoss = 0.25; }, unlockBy: 'achievement:asc15' },

    // ============================== 🌌 ANCIENT (2개) — 가챠 전용 해금, 캐릭터 전용 ==============================
    // 🎵 Aria 전용 — 별·노래·벚꽃 계열 능력이 max 도달 시 각성
    ariaHarp: {
      name: '여신의 하프', icon: '🎵', rarity: 'ancient',
      isAncient: true, characterId: 'aria',
      // 관련 능력: starSong(시작) / celestialEcho(4★) / sirensSong(8★) / cosmicChorus(별의노래+노바 조합)
      triggerAbilities: ['starSong', 'celestialEcho', 'sirensSong', 'cosmicChorus'],
      desc: '🎵 Aria 전용 · ★별마다 강해짐.\n[기본] 데미지 +20% (Aria 시너지 +40%)\n[★4 각성 1] Aria 관련 능력 max 도달 시 — 데미지 +50%·적 슬로우 +10%\n[★8 각성 2] 관련 능력 2개 이상 max — 처치 시 음표 광역 폭발',
      apply: (st) => { applyAncientRelic(st, 'ariaHarp'); },
      unlockBy: 'ancient:ariaHarp',
    },
    // ⌛ Misaki 전용 — 시간·동결·차원 계열 능력이 max 도달 시 각성
    misakiHourglass: {
      name: '차원의 모래시계', icon: '⌛', rarity: 'ancient',
      isAncient: true, characterId: 'misaki',
      // 관련 능력: timeButterfly(시작) / temporalLoop(4★) / paradoxFreeze(8★) / timePrison(시공나비+시간정지 조합)
      triggerAbilities: ['timeButterfly', 'temporalLoop', 'paradoxFreeze', 'timePrison'],
      desc: '⌛ Misaki 전용 · ★별마다 강해짐.\n[기본] 적 속도 -15% (Misaki 시너지 -30%)\n[★4 각성 1] Misaki 관련 능력 max 도달 시 — 데미지 +40%·적 속도 -10%\n[★8 각성 2] 관련 능력 2개 이상 max — 30초마다 모든 적 3초 정지',
      apply: (st) => { applyAncientRelic(st, 'misakiHourglass'); },
      unlockBy: 'ancient:misakiHourglass',
    },
  };
  // 🌌 v245 — ANCIENT 매핑 & 헬퍼
  const ANCIENT_RELIC_IDS = ['ariaHarp', 'misakiHourglass'];
  const ANCIENT_RELIC_BY_CHAR = { aria: 'ariaHarp', misaki: 'misakiHourglass' };
  const ANCIENT_MAX_STARS = 8;
  function getAncientRelicStars(rid) {
    return (META.ancientRelics && META.ancientRelics[rid] && META.ancientRelics[rid].stars) || 0;
  }
  function setAncientRelicStars(rid, n) {
    META.ancientRelics = META.ancientRelics || {};
    META.ancientRelics[rid] = META.ancientRelics[rid] || { stars: 0 };
    META.ancientRelics[rid].stars = Math.min(ANCIENT_MAX_STARS, Math.max(0, n));
  }
  function isAncientUnlocked(rid) {
    return getAncientRelicStars(rid) >= 1;
  }
  // 고대 유물 적용 함수 — apply 에서 호출됨. 별 단계 + 캐릭터 시너지 자동 반영
  function applyAncientRelic(st, rid) {
    const stars = getAncientRelicStars(rid);
    const charId = st && st.selectedCharacter;
    const synergy = (ANCIENT_RELIC_BY_CHAR[charId] === rid);
    st.relicEffects.ancientStars = st.relicEffects.ancientStars || {};
    st.relicEffects.ancientStars[rid] = stars;
    st.relicEffects.ancientSynergy = st.relicEffects.ancientSynergy || {};
    st.relicEffects.ancientSynergy[rid] = synergy;
    st.relicEffects.ancientAwakened = st.relicEffects.ancientAwakened || {};
    if (rid === 'ariaHarp') {
      // 기본: 데미지 +20%/+40% (별마다 +5%/+8% 추가)
      const baseDmg = synergy ? (1.40 + stars * 0.08) : (1.20 + stars * 0.05);
      st.metaMods.dmgMul = (st.metaMods.dmgMul || 1) * baseDmg;
      // 각성 1단계 ready 표시 (실제 발동은 능력 max 시)
      st.relicEffects.ariaHarpReady1 = stars >= 4;
      st.relicEffects.ariaHarpReady2 = stars >= 8;
    } else if (rid === 'misakiHourglass') {
      // 기본: 적 속도 감소 (별마다 추가)
      const baseSpeedMul = synergy ? (0.70 - stars * 0.02) : (0.85 - stars * 0.01);
      st.relicEffects.enemySpeedMul *= Math.max(0.40, baseSpeedMul);
      st.relicEffects.misakiHourglassReady1 = stars >= 4;
      st.relicEffects.misakiHourglassReady2 = stars >= 8;
    }
  }
  // 각성 효과 발동 — 능력 max 도달 시 체크
  function checkAncientAwakening(maxedAbilityId) {
    if (!state || !state.activeRelics) return;
    for (const r of state.activeRelics) {
      if (!r.isAncient) continue;
      const trig = RELICS[r.id] && RELICS[r.id].triggerAbilities;
      if (!trig || !trig.includes(maxedAbilityId)) continue;
      // 카운트 (이번 게임에서 이 유물 관련 max 도달한 능력 개수)
      state.ancientMaxedCount = state.ancientMaxedCount || {};
      state.ancientMaxedCount[r.id] = state.ancientMaxedCount[r.id] || new Set();
      if (state.ancientMaxedCount[r.id].has(maxedAbilityId)) continue;
      state.ancientMaxedCount[r.id].add(maxedAbilityId);
      const count = state.ancientMaxedCount[r.id].size;
      const aw = state.relicEffects.ancientAwakened[r.id] || 0;
      // ★4 각성 1단계 — 첫 max 도달 시
      const ready1 = (r.id === 'ariaHarp' ? state.relicEffects.ariaHarpReady1 : state.relicEffects.misakiHourglassReady1);
      const ready2 = (r.id === 'ariaHarp' ? state.relicEffects.ariaHarpReady2 : state.relicEffects.misakiHourglassReady2);
      if (count >= 1 && ready1 && aw < 1) {
        activateAncientAwaken(r, 1);
        state.relicEffects.ancientAwakened[r.id] = 1;
      }
      // ★8 각성 2단계 — 두 개 이상 max
      if (count >= 2 && ready2 && aw < 2) {
        activateAncientAwaken(r, 2);
        state.relicEffects.ancientAwakened[r.id] = 2;
      }
    }
  }
  function activateAncientAwaken(relic, level) {
    if (relic.id === 'ariaHarp') {
      if (level === 1) {
        // 데미지 +50% + 적 속도 -10%
        state.metaMods.dmgMul *= 1.50;
        state.relicEffects.enemySpeedMul *= 0.90;
        toast(`🎵✨ 여신의 하프 · 천상의 화음 각성!`);
      } else if (level === 2) {
        // 처치 시 음표 폭발 (chainLightning + aoeDmgMul 추가)
        state.relicEffects.chainLightning = true;
        state.relicEffects.aoeDmgMul *= 1.30;
        toast(`🎵🌟 여신의 하프 · 영원한 합창 각성!`);
      }
    } else if (relic.id === 'misakiHourglass') {
      if (level === 1) {
        // 데미지 +40% + 적 속도 추가 감소
        state.metaMods.dmgMul *= 1.40;
        state.relicEffects.enemySpeedMul *= 0.85;
        toast(`⌛✨ 차원의 모래시계 · 시간의 정원 각성!`);
      } else if (level === 2) {
        // 30초마다 모든 적 3초 정지 (roundStartTimeStop 와 별개로 주기 작동)
        state.relicEffects.ancientPeriodicStop = true;
        state.relicEffects.ancientPeriodicStopTimer = 1800; // 60fps * 30s
        toast(`⌛🌟 차원의 모래시계 · 종말의 모래 각성!`);
      }
    }
    state.comboFlash = 60;
    state.comboFlashColor = '#ff88ff';
    if (typeof shake === 'function') shake(18, 24);
    if (typeof SFX !== 'undefined' && SFX.combo) SFX.combo();
  }
  const RELIC_IDS = Object.keys(RELICS);

  // 🖼 v247 — 유물 이미지 로더 (lazy preload + emoji 폴백)
  //   각 유물의 PNG 가 icons/relics/{rid}.png 에 있으면 자동 사용
  //   없거나 로드 실패 시 emoji (RELICS[rid].icon) 폴백
  const RELIC_IMG_CACHE = {};      // rid -> { img: Image, loaded: bool, failed: bool }
  function getRelicImage(rid) {
    if (RELIC_IMG_CACHE[rid]) return RELIC_IMG_CACHE[rid];
    const entry = { img: new Image(), loaded: false, failed: false };
    entry.img.onload  = () => { entry.loaded = true; };
    entry.img.onerror = () => { entry.failed = true; };
    entry.img.src = `./icons/relics/${rid}.png`;
    RELIC_IMG_CACHE[rid] = entry;
    return entry;
  }
  // 게임 시작 시 모든 유물 이미지 사전 로드 (백그라운드, 비동기)
  (function preloadRelicImages() {
    for (const rid of RELIC_IDS) getRelicImage(rid);
  })();

  // Canvas 용 헬퍼 — 이미지 로드됐으면 drawImage, 아니면 emoji 폴백
  function drawRelicIcon(ctxArg, rid, x, y, size, opts) {
    const entry = getRelicImage(rid);
    const o = opts || {};
    if (entry.loaded && !entry.failed) {
      ctxArg.drawImage(entry.img, x, y, size, size);
      return true;
    }
    // emoji 폴백
    const r = RELICS[rid];
    const emoji = (r && r.icon) || '?';
    ctxArg.font = `${o.emojiFontSize || Math.floor(size * 0.7)}px sans-serif`;
    const prevAlign = ctxArg.textAlign;
    const prevBase = ctxArg.textBaseline;
    ctxArg.textAlign = 'center';
    ctxArg.textBaseline = 'middle';
    if (o.color) ctxArg.fillStyle = o.color;
    ctxArg.fillText(emoji, x + size/2, y + size/2 + 1);
    ctxArg.textAlign = prevAlign;
    ctxArg.textBaseline = prevBase;
    return false;
  }

  // HTML 용 헬퍼 — <img> 태그 with emoji 폴백 (onerror)
  function getRelicImageHtml(rid, sizePx) {
    const r = RELICS[rid] || {};
    const emoji = r.icon || '?';
    const s = sizePx || 28;
    // 이미지 로드 실패 시 emoji 로 자동 교체
    return `<img src="./icons/relics/${rid}.png" alt="${rid}" `
         + `style="width:${s}px;height:${s}px;image-rendering:pixelated;object-fit:contain;" `
         + `onerror="this.outerHTML='<span style=&quot;font-size:${Math.floor(s*0.9)}px;&quot;>${emoji}</span>';" />`;
  }

  function isRelicUnlocked(rid) {
    const r = RELICS[rid];
    if (!r) return false;
    if (!r.unlockBy) return true;
    if (r.unlockBy.startsWith('achievement:')) {
      const achId = r.unlockBy.slice('achievement:'.length);
      const have = getUnlockedAchievements();
      return have.has(achId);
    }
    // 🌌 v245 — 고대 유물: 가챠로 별 1+ 모은 경우 해금
    if (r.unlockBy.startsWith('ancient:')) {
      const ancientId = r.unlockBy.slice('ancient:'.length);
      return isAncientUnlocked(ancientId);
    }
    return false;
  }
  function getDiscoveredRelics() {
    // 일반 유물 풀 — ancient 는 별도 시스템에서 처리되므로 항상 제외
    return RELIC_IDS.filter(id => !RELICS[id].isAncient && isRelicUnlocked(id));
  }

  // 보스 처치 시 호출 — 확률적으로 3개 유물 제안
  function rollRelicOffering() {
    if (!state) return null;
    // 💼 도굴꾼의 가방 — 유물 등장 확률 +25%
    const bonus = (state.relicEffects && state.relicEffects.relicChanceBonus) || 0;
    if (Math.random() > Math.min(0.95, RELIC_DROP_CHANCE + bonus)) return null; // 드롭 X
    const ownedSet = new Set((state.activeRelics || []).map(r => r.id));
    const pool = getDiscoveredRelics().filter(id => !ownedSet.has(id));
    // 🌟 v241 — 모든 유물 풀 컬렉션 → 스택 제안 (보유 유물 3개 중 1개 +1 스택)
    if (pool.length === 0) {
      if (!state.activeRelics || state.activeRelics.length === 0) return null;
      const ownedPool = state.activeRelics.slice();
      const offering = [];
      while (offering.length < 3 && ownedPool.length > 0) {
        const idx = Math.floor(Math.random() * ownedPool.length);
        offering.push(ownedPool.splice(idx, 1)[0].id);
      }
      // 같은 유물 3개도 가능 (보유 < 3개일 때 채워 넣음)
      while (offering.length < 3 && state.activeRelics.length > 0) {
        offering.push(state.activeRelics[Math.floor(Math.random() * state.activeRelics.length)].id);
      }
      return offering.length > 0 ? offering : null;
    }
    // 등급별 후보 분리
    const byRarity = { common: [], rare: [], epic: [], legendary: [] };
    for (const id of pool) byRarity[RELICS[id].rarity].push(id);
    // 3개 뽑기 — 각각 가중치 기반 등급 결정 후 그 등급에서 랜덤
    const offering = [];
    for (let i = 0; i < 3; i++) {
      const rarity = pickWeightedRarity();
      // 해당 등급 비어있으면 fallback 순서: legendary→epic→rare→common
      const order = [rarity, 'legendary', 'epic', 'rare', 'common'];
      let pick = null;
      for (const r of order) {
        const list = byRarity[r];
        if (!list || list.length === 0) continue;
        const idx = Math.floor(Math.random() * list.length);
        pick = list.splice(idx, 1)[0]; // 중복 방지
        break;
      }
      if (pick) offering.push(pick);
    }
    // 🌌 v245 — 고대 유물 주입 (극저 확률, 현재 캐릭터의 매칭 유물만)
    if (offering.length > 0) {
      const charId = state.selectedCharacter;
      const ancientId = ANCIENT_RELIC_BY_CHAR[charId];
      if (ancientId && isAncientUnlocked(ancientId) && !ownedSet.has(ancientId)) {
        // 기본 0.3% + 라운드 보너스 (최대 0.5% 추가)
        const roundBonus = Math.min(0.005, (state.round || 1) * 0.0001);
        if (Math.random() < (0.003 + roundBonus)) {
          // 3장 중 무작위 1장 교체 (운 좋으면 선택지에 등장)
          const slot = Math.floor(Math.random() * offering.length);
          offering[slot] = ancientId;
        }
      }
    }
    return offering.length > 0 ? offering : null;
  }
  function pickWeightedRarity() {
    // 메타 강화 "유물 감식" 보너스 적용 — 일반에서 차감, 고급들로 분배
    const boost = (state.metaMods && state.metaMods.relicRarityBoost) || 0;
    const per = boost / 3; // rare/epic/legendary 각각에 분배
    const w = {
      common:    Math.max(10, RELIC_RARITY.common.weight - boost),
      rare:      RELIC_RARITY.rare.weight + per,
      epic:      RELIC_RARITY.epic.weight + per,
      legendary: RELIC_RARITY.legendary.weight + per,
    };
    const total = w.common + w.rare + w.epic + w.legendary;
    let roll = Math.random() * total;
    for (const r of ['legendary', 'epic', 'rare', 'common']) {
      if (roll < w[r]) return r;
      roll -= w[r];
    }
    return 'common';
  }

  function acquireRelic(rid) {
    if (!state || !RELICS[rid]) return;
    const existing = (state.activeRelics || []).find(r => r.id === rid);
    // 🌟 v241 — 유물 스택 모드: 이미 보유 시 스택 +1 (모든 유물 모은 후 보스 처치 보상)
    if (existing) {
      existing.stacks = (existing.stacks || 0) + 1;
      // 글로벌 강화: 데미지 +3% + 골드 +3% (스택당)
      // 🛡 무한 지수 방지 — 총 50스택까지만 곱연산 (1.03^50 ≈ 4.4x). 그 이상은 골드/점수 인플레만 유발.
      state.relicStackTotal = (state.relicStackTotal || 0) + 1;
      if (state.relicStackTotal <= 50) {
        state.relicEffects.aoeDmgMul *= 1.03;
        state.metaMods.goldMul = (state.metaMods.goldMul || 1) * 1.03;
      }
      SFX.combo();
      state.comboFlash = 36;
      state.comboFlashColor = RELIC_RARITY[existing.rarity].color;
      toast(`💎 ${existing.icon} ${existing.name} 강화 +${existing.stacks}`);
      if (typeof renderPanel === 'function') renderPanel();
      return;
    }
    const r = { id: rid, ...RELICS[rid], stacks: 0 };
    state.activeRelics.push(r);
    try { RELICS[rid].apply(state); } catch (e) { console.warn('유물 적용 실패:', e); }
    SFX.combo();
    state.comboFlash = 30;
    state.comboFlashColor = RELIC_RARITY[r.rarity].color;
    toast(`💎 ${r.icon} ${r.name} 획득!`);
    // 💎 패널의 "유물 보기" 버튼 즉시 표시 갱신
    if (typeof renderPanel === 'function') renderPanel();
  }

  // ===== 🌟 v241 — 어센던트 카드 (Ascendant Cards) =====
  // 모든 능력 max + 슬롯 풀일 때 레벨업 카드 풀로 등장 (엔드리스 정체 해소)
  // 각각 무한 스택 — 같은 카드 반복 등장, 매번 +% 누적
  // ⚠ 게임에 실제 적용되는 필드만 사용 — rangeMul/cooldownMul 등은 state 선언만 있고 dead code
  const ASCENDANT_TYPES = [
    { id: 'asc_damage',   icon: '⚔', name: '신성한 일격', desc: '모든 데미지 +5%',  color: '#ff6677', apply: (st) => { st.metaMods.dmgMul = (st.metaMods.dmgMul || 1) * 1.05; } },
    { id: 'asc_might',    icon: '💪', name: '거인의 권능', desc: '주요 데미지 +5%',  color: '#ff8800', apply: (st) => { st.metaMods.dmgMul = (st.metaMods.dmgMul || 1) * 1.05; } },
    { id: 'asc_gold',     icon: '💰', name: '황금의 손길', desc: '획득 골드 +5%',    color: '#ffd479', apply: (st) => { st.metaMods.goldMul = (st.metaMods.goldMul || 1) * 1.05; } },
    { id: 'asc_killGold', icon: '🪙', name: '풍요의 시혜', desc: '처치당 +1 골드',   color: '#ffe070', apply: (st) => { st.relicEffects.killGoldBonus = (st.relicEffects.killGoldBonus || 0) + 1; } },
    // ⚠ v265 — asc_score(점수 +5%) 제거: 무한 스택 시 scoreMul 폭증 → 엔드리스 점수 인플레 직접 원인
    { id: 'asc_bossDmg',  icon: '👹', name: '거대 사냥꾼', desc: '보스 데미지 +8%',  color: '#aa88ff', apply: (st) => { st.metaMods.bossDmgMul = (st.metaMods.bossDmgMul || 1) * 1.08; } },
  ];
  const ASCENDANT_BY_ID = {};
  for (const a of ASCENDANT_TYPES) ASCENDANT_BY_ID[a.id] = a;

  // 모든 능력 max + 슬롯 풀 + 조합 없음 → 어센던트 카드 풀로 전환
  function shouldOfferAscendant() {
    if (!state || !state.tower) return false;
    if (state.mode === 'defense') {
      // TD: 새 패시브 없고 강화도 없으면 OK
      const ownedIds = new Set(state.tower.abilities.map(a => a.id));
      const allowed = getUnlockedAbilityIds();
      const hasNewPassive = [...allowed].some(id => ABILITY_DEFS[id] && ABILITY_DEFS[id].isPassive && !ownedIds.has(id));
      const hasUpgradable = state.tower.abilities.some(a => !isAtMax(a));
      return !hasNewPassive && !hasUpgradable;
    }
    // 서바이벌
    const aSlotsFree = activeCount() < maxActiveSlots();
    const pSlotsFree = passiveCount() < maxPassiveSlots();
    const hasUpgradable = state.tower.abilities.some(a => !isAtMax(a));
    const hasCombo = findAvailableCombos().length > 0;
    return !aSlotsFree && !pSlotsFree && !hasUpgradable && !hasCombo;
  }
  // 어센던트 카드 3장 생성 (중복 가능 — 무한 스택)
  function generateAscendantChoices() {
    const choices = [];
    for (let i = 0; i < 3; i++) {
      const t = ASCENDANT_TYPES[Math.floor(Math.random() * ASCENDANT_TYPES.length)];
      choices.push({ action: 'ascendant', id: t.id });
    }
    return choices;
  }

  // ===== 능력 태그 시스템 — 다중 라벨 (한 능력이 여러 태그를 가질 수 있음) =====
  const TAG_COLORS = {
    '광역':       '#ff9966',
    '다중공격':   '#7ad7ff',
    '관통':       '#88ffaa',
    '유도':       '#52e07a',
    '슬로우':     '#88ddff',
    '정지':       '#ffe080',
    '폭발':       '#ff7050',
    '연쇄':       '#88e0ff',
    '회전':       '#88ffe0',
    '빔':         '#ff66bb',
    '흡인':       '#a060d0',
    '단일':       '#ffaaaa',
    '단발':       '#cfd6e3',
    '최강적':     '#cc6666',
    '자율':       '#88aaff',
    '낙하':       '#ffe070',
    '즉사':       '#9966ff',
    '버프':       '#a0d8ff',
    '유틸':       '#ffd479',
    '영역':       '#aa88dd',
    '보호막제거': '#ffaaff',
  };
  const ABILITY_TAGS = {
    // 기본 액티브
    shot:          ['단발', '유도'],
    multi:         ['다중공격', '유도'],
    nova:          ['광역'],
    laser:         ['관통', '빔'],
    chain:         ['연쇄'],
    orbital:       ['회전', '영역'],
    scatter:       ['다중공격', '광역'],
    mortar:        ['광역', '폭발'],
    thunder:       ['다중공격', '낙하'],
    turret:        ['자율', '다중공격'],
    boomerang:     ['관통'],
    tornado:       ['영역', '광역'],
    beam:          ['회전', '빔', '광역'],
    sniper:        ['최강적', '단발'],
    frost:         ['광역', '슬로우'],
    missile:       ['다중공격', '유도', '폭발'],
    fire:          ['영역', '광역'],
    iceLance:      ['관통', '슬로우'],
    mine:          ['영역', '폭발'],
    drone:         ['자율', '유도'],
    meteor:        ['광역', '폭발', '낙하'],
    blackhole:     ['흡인', '영역'],
    sword:         ['회전', '광역'],
    starfall:      ['다중공격', '낙하'],
    timeStop:      ['광역', '정지'],
    clone:         ['자율'],
    magnet:        ['흡인', '폭발'],
    railgun:       ['관통', '빔'],
    fury:          ['버프'],
    reaper:        ['즉사', '버프'],
    plasmaArc:     ['다중공격', '연쇄'],
    gravityWell:   ['영역', '슬로우'],
    piercer:       ['관통'],
    echoBlast:     ['광역', '다중공격'],
    rocketSwarm:   ['다중공격', '폭발'],
    homingBlade:   ['단일'],
    stunBomb:      ['최강적', '정지'],
    purgeWave:     ['광역', '보호막제거'],
    // 패시브
    precision:     ['버프'],
    haste:         ['버프', '유틸'],
    frenzy:        ['버프'],
    vampiric:      ['유틸'],
    fortune:       ['유틸'],
    mastery:       ['버프'],
    scholar:       ['유틸'],
    ironwill:      ['버프', '최강적'],
    executioner:   ['버프'],
    resilience:    ['버프'],
    // 조합
    shotgunBurst:    ['다중공격', '폭발', '광역'],
    precisionBurst:  ['다중공격', '유도'],
    chainStorm:      ['연쇄', '낙하'],
    frostNova:       ['광역', '슬로우'],
    twinBeam:        ['회전', '빔', '광역'],
    stormOrbit:      ['회전', '영역', '슬로우'],
    steelBoomerang:  ['관통', '최강적'],
    missileTurret:   ['자율', '폭발', '다중공격'],
    frostfireSpear:  ['관통', '슬로우'],
    kamikazeDrone:   ['자율', '폭발'],
    cosmicCollapse:  ['흡인', '광역', '폭발'],
    swordRain:       ['회전', '낙하', '광역'],
    precisionShot:   ['단발'],
    rapidBarrage:    ['다중공격'],
    frenzyWave:      ['광역'],
    lootBomb:        ['광역', '유틸'],
    luckyChain:      ['연쇄', '유틸'],
    masteryOrbit:    ['회전', '영역'],
    scholarSnipe:    ['최강적', '단발'],
    resolveBoomerang:['최강적'],
    headshot:        ['단발'],
    pelletGun:       ['다중공격', '광역'],
    plasmaBeam:      ['빔', '광역', '회전'],
    voidField:       ['영역', '슬로우'],
    piercingChain:   ['관통', '연쇄'],
    echoStorm:       ['광역', '다중공격'],
    rocketBarrage:   ['다중공격', '폭발'],
    bladeStorm:      ['회전', '단일'],
    magneticStun:    ['흡인', '정지'],
    purgeShot:       ['빔', '보호막제거'],
    grandReaper:     ['즉사', '광역'],
    pyreShield:      ['영역', '광역'],
    // 트리플
    ultraGatling:    ['다중공격', '광역'],
    absoluteThunder: ['연쇄', '낙하', '슬로우'],
    elementalStorm:  ['광역', '슬로우'],
    fusionCannon:    ['다중공격', '유도', '폭발'],
    galaxyOrbit:     ['회전', '영역'],
    titanMissile:    ['폭발', '광역'],
    plasmaCataclysm: ['빔', '낙하'],
    voidNova:        ['영역', '슬로우', '폭발'],
    siegeBeam:       ['빔', '관통'],
    // 가챠 R 고유
    torpedo:         ['유도', '폭발', '다중공격'],
    sunspot:         ['광역'],
    pullField:       ['영역', '흡인'],
    // 가챠 R 조합
    frozenTorpedo:   ['유도', '폭발', '슬로우'],
    solarStorm:      ['광역', '낙하'],
    voidIceVortex:   ['영역', '흡인', '슬로우'],
    // 가챠 R 트리플
    deepSeaBarrage:  ['유도', '폭발', '슬로우'],
    stellarCollapse: ['광역', '낙하', '폭발'],
    voidStop:        ['영역', '흡인', '정지'],
    // 가챠 SR/SSR 고유
    sakuraSlash:     ['회전', '광역'],
    moonShot:        ['관통', '유도'],
    starSong:        ['광역', '다중공격'],
    timeButterfly:   ['유도', '슬로우', '정지'],
    // 가챠 SR 조합
    sakuraStorm:     ['회전', '광역', '다중공격'],
    moonFrostArrow:  ['관통', '유도', '슬로우'],
    // 가챠 SSR 조합
    cosmicChorus:    ['광역', '다중공격'],
    timePrison:      ['유도', '정지', '최강적'],
    // 가챠 SR 트리플
    sakuraInferno:   ['회전', '광역'],
    moonBombardment: ['낙하', '폭발', '슬로우'],
    // 가챠 SSR 트리플
    celestialSymphony: ['광역', '낙하', '폭발'],
    eternalMoment:   ['흡인', '정지', '영역'],
  };
  function getAbilityTags(id) { return ABILITY_TAGS[id] || []; }
  function tagChipHtml(tag) {
    const c = TAG_COLORS[tag] || '#888';
    return `<span class="ability-tag" style="color:${c}; border-color:${c}">${tag}</span>`;
  }

  // ===== 능력 아이콘 시스템 =====
  // 능력 ID ↔ 번호 매핑 (1번부터 순서대로)
  const ABILITY_ICON_ORDER = [
    'shot', 'multi', 'nova', 'laser', 'chain',
    'orbital', 'scatter', 'mortar', 'thunder', 'turret',
    'boomerang', 'tornado', 'beam', 'sniper', 'frost',
    'missile', 'fire', 'iceLance', 'mine', 'drone',
    'meteor', 'blackhole', 'sword', 'starfall', 'timeStop',
    'clone', 'magnet', 'railgun', 'fury', 'reaper',
    'plasmaArc', 'gravityWell', 'piercer', 'echoBlast', 'rocketSwarm',
    'homingBlade', 'stunBomb', 'purgeWave',
    'precision', 'haste', 'frenzy', 'vampiric', 'fortune',
    'mastery', 'scholar', 'ironwill', 'executioner', 'resilience',
    'shotgunBurst', 'precisionBurst', 'chainStorm', 'frostNova', 'twinBeam',
    'stormOrbit', 'steelBoomerang', 'missileTurret', 'frostfireSpear', 'kamikazeDrone',
    'cosmicCollapse', 'swordRain', 'precisionShot', 'rapidBarrage', 'frenzyWave',
    'lootBomb', 'luckyChain', 'masteryOrbit', 'scholarSnipe', 'resolveBoomerang',
    'headshot', 'pelletGun', 'plasmaBeam', 'voidField', 'piercingChain',
    'echoStorm', 'rocketBarrage', 'bladeStorm', 'magneticStun', 'purgeShot',
    'grandReaper', 'pyreShield',
    'ultraGatling', 'absoluteThunder', 'elementalStorm', 'fusionCannon', 'galaxyOrbit',
    'titanMissile', 'plasmaCataclysm', 'voidNova', 'siegeBeam',
    // 가챠 R (90-98) — PNG 없으면 자동 fallback (색박스+첫글자)
    'torpedo', 'sunspot', 'pullField',
    'frozenTorpedo', 'solarStorm', 'voidIceVortex',
    'deepSeaBarrage', 'stellarCollapse', 'voidStop',
    // 가챠 SR/SSR (99-110) — PNG 없으면 자동 fallback
    'sakuraSlash', 'moonShot', 'starSong', 'timeButterfly',
    'sakuraStorm', 'moonFrostArrow', 'cosmicChorus', 'timePrison',
    'sakuraInferno', 'moonBombardment', 'celestialSymphony', 'eternalMoment',
    // ⭐ SSR 별 해금 히든 능력 (111-114) — 4★/8★ 도달 시 해금
    'celestialEcho',   // 111 — aria 4★
    'sirensSong',          // 112 — aria 8★
    'temporalLoop',        // 113 — misaki 4★
    'paradoxFreeze',       // 114 — misaki 8★
    // ⭐ SR 별 해금 히든 능력 (115~118) — 4★/8★ 도달 시 해금
    'petalStorm',          // 115 — sakura 4★ — 꽃잎 폭풍
    'cherrySingularity',   // 116 — sakura 8★ — 벚꽃 특이점
    'lunarRain',           // 117 — luna 4★ — 월광비
    'eclipsePiercer',      // 118 — luna 8★ — 월식 관통
  ];
  const ABILITY_ICON_NUMBER = {};
  ABILITY_ICON_ORDER.forEach((id, i) => { ABILITY_ICON_NUMBER[id] = i + 1; });
  function getIconNumber(id) { return ABILITY_ICON_NUMBER[id] || null; }
  function getIconPath(id) {
    const n = getIconNumber(id);
    return n ? `./icons/abilities/${n}.png` : null;
  }

  // 이미지 캐시 + 사전 로드
  const abilityIconImages = {};   // id → Image | 'missing'
  function loadAbilityIcons() {
    for (const id of ABILITY_ICON_ORDER) {
      const path = getIconPath(id);
      if (!path) continue;
      const img = new Image();
      img.onload = () => { /* 로드 성공 */ };
      img.onerror = () => { abilityIconImages[id] = 'missing'; };
      img.src = path;
      abilityIconImages[id] = img;
    }
  }
  loadAbilityIcons();

  // ===== 🖼️ 캐릭터 이미지 로더 (검정 배경 → 투명 chroma key) =====
  // 검정 배경 PNG 받아서 알파 채널 자동 적용.
  // chroma key가 실패하면 (file:// CORS 등) 원본 이미지 그대로 사용 (검정 배경 보임).
  // 항상 SOMETHING이 보이도록 multi-tier fallback.
  const characterImages = {};        // charId → entry | 'loading' | 'missing'
  // entry shape: { img: HTMLImageElement, keyed: Canvas|null, src: string,
  //                dataUrl: string|null, w: number, h: number }
  const CHROMA_THRESHOLD = 30;
  const CHROMA_EDGE_BLEND = 60;

  function chromaKeyImage(img) {
    const c = document.createElement('canvas');
    c.width  = img.naturalWidth  || img.width;
    c.height = img.naturalHeight || img.height;
    const cx = c.getContext('2d');
    cx.drawImage(img, 0, 0);
    // getImageData가 tainted canvas (file://) 에서 throw하면 캐치
    const data = cx.getImageData(0, 0, c.width, c.height);
    const d = data.data;
    for (let i = 0; i < d.length; i += 4) {
      const sum = d[i] + d[i + 1] + d[i + 2];
      if (sum < CHROMA_THRESHOLD) {
        d[i + 3] = 0;
      } else if (sum < CHROMA_EDGE_BLEND) {
        const t = (sum - CHROMA_THRESHOLD) / (CHROMA_EDGE_BLEND - CHROMA_THRESHOLD);
        d[i + 3] = Math.round(d[i + 3] * t);
      }
    }
    cx.putImageData(data, 0, 0);
    return c;
  }

  function loadCharacterImage(charId) {
    if (characterImages[charId]) return;
    characterImages[charId] = 'loading';
    const img = new Image();
    const src = `./icons/characters/${charId}.png`;
    img.onload = () => {
      let keyed = null;
      let dataUrl = null;
      // 1단계: chroma key 시도
      try { keyed = chromaKeyImage(img); } catch (e) { keyed = null; }
      // 2단계: toDataURL 시도 (tainted canvas면 실패)
      if (keyed) {
        try { dataUrl = keyed.toDataURL('image/png'); }
        catch (e) { dataUrl = null; }
      }
      characterImages[charId] = {
        img, keyed, src, dataUrl,
        w: img.naturalWidth, h: img.naturalHeight,
      };
    };
    img.onerror = () => { characterImages[charId] = 'missing'; };
    img.src = src;
  }
  // 캔버스 그리기용: 키잉된 canvas 우선, 안되면 raw img (검정 배경 보임)
  function getCharacterImage(charId) {
    const v = characterImages[charId];
    if (!v || v === 'loading' || v === 'missing') return null;
    return v.keyed || v.img;
  }
  // HTML <img src>용: dataURL 우선, 안되면 원본 경로
  function getCharacterImageSrc(charId) {
    const v = characterImages[charId];
    if (!v || v === 'loading' || v === 'missing') return null;
    return v.dataUrl || v.src;
  }
  // 🆕 이름 앞 이모지 제거 — 캐릭터 이미지가 함께 표시될 땐 이모지가 중복이라 뗌 (예: "🌊 마린" → "마린")
  function charNameNoEmoji(name) {
    return String(name || '').replace(/^[\u{1F000}-\u{1FAFF}\u{2600}-\u{27BF}\u{2B00}-\u{2BFF}\u{FE0F}\u{200D}]+\s*/u, '');
  }
  function getCharacterImageMeta(charId) {
    const v = characterImages[charId];
    if (!v || v === 'loading' || v === 'missing') return null;
    return { w: v.w, h: v.h };
  }
  function preloadAllCharacterImages() {
    if (typeof CHARACTERS === 'undefined') return;
    for (const id of Object.keys(CHARACTERS)) loadCharacterImage(id);
  }

  // ===== 🖼️ 가챠 배너 이미지도 chroma key 처리 =====
  // file:// 환경에서는 toDataURL 실패 → 원본 src 유지 (검정 배경 그대로 보임)
  function processGachaBanner() {
    const bannerEl = document.getElementById('gacha-banner-img');
    if (!bannerEl) return;
    const probe = new Image();
    probe.onload = () => {
      try {
        const keyed = chromaKeyImage(probe);
        try {
          const dataUrl = keyed.toDataURL('image/png');
          bannerEl.src = dataUrl;
          bannerEl.style.background = 'transparent';
        } catch (e) {
          // toDataURL 실패 (tainted canvas) → 원본 src 유지
        }
      } catch (e) {
        // getImageData 실패 → 원본 src 유지
      }
    };
    probe.onerror = () => { /* gacha.png 없으면 HTML onerror가 fallback div 표시 */ };
    probe.src = `./icons/gacha.png?_k=${Date.now()}`;
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', processGachaBanner);
  } else {
    processGachaBanner();
  }

  // 캔버스용 아이콘 그리기 (이미지 있으면 그림, 없으면 fallback)
  function drawAbilityIcon(id, x, y, size) {
    const img = abilityIconImages[id];
    if (img && img !== 'missing' && img.complete && img.naturalWidth > 0) {
      ctx.drawImage(img, x, y, size, size);
    } else {
      drawIconPlaceholder(id, x, y, size);
    }
  }
  function drawIconPlaceholder(id, x, y, size) {
    const def = ABILITY_DEFS[id];
    if (!def) {
      ctx.fillStyle = '#2a2f3a';
      ctx.fillRect(x, y, size, size);
      return;
    }
    // 티어별 배경
    let bg = '#1a1f2b', borderC = def.color || '#5870a0';
    if (def.isTriple) bg = '#2a0c1c';
    else if (def.isCombo) bg = '#1a1428';
    else if (def.isPassive) bg = '#10182a';
    // 배경
    ctx.fillStyle = bg;
    ctx.fillRect(x, y, size, size);
    // 테두리
    ctx.strokeStyle = borderC;
    ctx.lineWidth = Math.max(1, size / 24);
    ctx.strokeRect(x + 1, y + 1, size - 2, size - 2);
    // 첫 글자 (1~2자)
    ctx.fillStyle = borderC;
    ctx.font = `bold ${Math.floor(size * 0.42)}px Jua, sans-serif`;
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    const label = (def.name || '?').substring(0, 2);
    ctx.fillText(label, x + size / 2, y + size / 2);
    ctx.textBaseline = 'alphabetic';
    ctx.textAlign = 'start';
  }

  // HTML 용 아이콘 (img 태그 + onerror fallback to placeholder div)
  function iconHtml(id, size = 28) {
    const num = getIconNumber(id);
    const def = ABILITY_DEFS[id];
    if (!num || !def) return '';
    const path = `./icons/abilities/${num}.png`;
    // tier에 따라 fallback 배경
    let fallbackBg = '#1a1f2b';
    if (def.isTriple) fallbackBg = '#2a0c1c';
    else if (def.isCombo) fallbackBg = '#1a1428';
    else if (def.isPassive) fallbackBg = '#10182a';
    const color = def.color || '#5870a0';
    const label = (def.name || '?').substring(0, 2);
    // onerror: img 숨기고 placeholder div 표시
    const phStyle = `width:${size}px;height:${size}px;background:${fallbackBg};border:1px solid ${color};color:${color};display:flex;align-items:center;justify-content:center;font-size:${Math.floor(size*0.42)}px;font-weight:bold;border-radius:3px;flex-shrink:0;`;
    const imgStyle = `width:${size}px;height:${size}px;flex-shrink:0;image-rendering:auto;`;
    return `<img class="ability-img-icon" src="${path}" style="${imgStyle}" onerror="this.outerHTML='<span class=\\'ability-img-fallback\\' style=\\'${phStyle.replace(/'/g, "\\'")}\\'>${label}</span>'"/>`;
  }

  // ===== 조합 레시피 =====
  // 두 기본 능력을 동시에 보유하면 자동으로 조합 능력으로 합쳐짐.
  const COMBO_RECIPES = [
    // ===== 트리플 (히든) — 콤보 + 기본 =====
    { parts: ['precisionBurst', 'scatter'],  combo: 'ultraGatling',    tier: 3 },
    { parts: ['chainStorm',     'frost'],    combo: 'absoluteThunder', tier: 3 },
    { parts: ['frostNova',      'fire'],     combo: 'elementalStorm',  tier: 3 },
    { parts: ['shotgunBurst',   'missile'],  combo: 'fusionCannon',    tier: 3 },
    { parts: ['stormOrbit',     'sword'],    combo: 'galaxyOrbit',     tier: 3 },
    { parts: ['steelBoomerang', 'missile'],  combo: 'titanMissile',    tier: 3 },
    // ===== 액티브 + 패시브 조합 (서로 다른 카테고리) =====
    { parts: ['shot',      'precision'], combo: 'precisionShot' },
    { parts: ['multi',     'haste'],     combo: 'rapidBarrage' },
    { parts: ['nova',      'frenzy'],    combo: 'frenzyWave' },
    { parts: ['mortar',    'vampiric'],  combo: 'lootBomb' },
    { parts: ['chain',     'fortune'],   combo: 'luckyChain' },
    { parts: ['orbital',   'mastery'],   combo: 'masteryOrbit' },
    { parts: ['sniper',    'scholar'],   combo: 'scholarSnipe' },
    { parts: ['boomerang', 'ironwill'],  combo: 'resolveBoomerang' },
    // ===== 액티브 2-콤보 (기본) =====
    { parts: ['scatter',   'mortar'],    combo: 'shotgunBurst' },
    { parts: ['shot',      'multi'],     combo: 'precisionBurst' },
    { parts: ['chain',     'thunder'],   combo: 'chainStorm' },
    { parts: ['nova',      'frost'],     combo: 'frostNova' },
    { parts: ['laser',     'beam'],      combo: 'twinBeam' },
    { parts: ['orbital',   'tornado'],   combo: 'stormOrbit' },
    { parts: ['boomerang', 'sniper'],    combo: 'steelBoomerang' },
    { parts: ['turret',    'missile'],   combo: 'missileTurret' },
    { parts: ['fire',      'iceLance'],  combo: 'frostfireSpear' },
    { parts: ['mine',      'drone'],     combo: 'kamikazeDrone' },
    { parts: ['meteor',    'blackhole'], combo: 'cosmicCollapse' },
    { parts: ['sword',     'starfall'],  combo: 'swordRain' },
    // ===== 대체 조합 (자유도) — 정상 조합이 없을 때 활성화 =====
    { parts: ['shot',      'sniper'],    combo: 'headshot' },
    { parts: ['multi',     'scatter'],   combo: 'pelletGun' },
    // ===== 신규 능력 조합 (8개 신규 + 2개 패시브 + 3개 트리플) =====
    { parts: ['plasmaArc',   'laser'],      combo: 'plasmaBeam' },
    { parts: ['gravityWell', 'frost'],      combo: 'voidField' },
    { parts: ['piercer',     'chain'],      combo: 'piercingChain' },
    { parts: ['echoBlast',   'nova'],       combo: 'echoStorm' },
    { parts: ['rocketSwarm', 'scatter'],    combo: 'rocketBarrage' },
    { parts: ['homingBlade', 'sword'],      combo: 'bladeStorm' },
    { parts: ['stunBomb',    'magnet'],     combo: 'magneticStun' },
    { parts: ['purgeWave',   'sniper'],     combo: 'purgeShot' },
    // 신규 패시브-액티브 조합
    { parts: ['executioner', 'reaper'],     combo: 'grandReaper' },
    { parts: ['resilience',  'fire'],       combo: 'pyreShield' },
    // 신규 트리플 (히든) — 조합 + 기본
    { parts: ['plasmaBeam',    'thunder'],  combo: 'plasmaCataclysm', tier: 3 },
    { parts: ['voidField',     'missile'],  combo: 'voidNova',        tier: 3 },
    { parts: ['piercingChain', 'railgun'],  combo: 'siegeBeam',       tier: 3 },
    // ===== 🎰 가챠 R 조합 (3종) =====
    { parts: ['torpedo',   'frost'],     combo: 'frozenTorpedo' },
    { parts: ['sunspot',   'thunder'],   combo: 'solarStorm' },
    { parts: ['pullField', 'frostNova'], combo: 'voidIceVortex' },
    // ===== 🎰 가챠 R 트리플 (히든) =====
    { parts: ['frozenTorpedo', 'missile'],  combo: 'deepSeaBarrage',  tier: 3 },
    { parts: ['solarStorm',    'meteor'],   combo: 'stellarCollapse', tier: 3 },
    { parts: ['voidIceVortex', 'timeStop'], combo: 'voidStop',        tier: 3 },
    // ===== 🎰 가챠 SR 조합 (2종) =====
    { parts: ['sakuraSlash', 'sword'],      combo: 'sakuraStorm' },
    { parts: ['moonShot',    'frost'],      combo: 'moonFrostArrow' },
    // ===== 🎰 가챠 SSR 조합 (2종) =====
    { parts: ['starSong',      'nova'],     combo: 'cosmicChorus' },
    { parts: ['timeButterfly', 'timeStop'], combo: 'timePrison' },
    // ===== 🎰 가챠 SR 트리플 (히든) =====
    { parts: ['sakuraStorm',    'tornado'], combo: 'sakuraInferno',     tier: 3 },
    { parts: ['moonFrostArrow', 'missile'], combo: 'moonBombardment',   tier: 3 },
    // ===== 🎰 가챠 SSR 트리플 (히든) =====
    { parts: ['cosmicChorus', 'meteor'],    combo: 'celestialSymphony', tier: 3 },
    { parts: ['timePrison',   'blackhole'], combo: 'eternalMoment',     tier: 3 },
    // ===== 🎰 레비나 (번개술사 SR) — 기본조합/4돌파/8돌파 =====
    { parts: ['stormBrand',  'stunBomb'],  combo: 'levinLash' },
    { parts: ['levinLash',   'tornado'],   combo: 'tempestVeil',    tier: 3 },
    { parts: ['tempestVeil', 'railgun'],   combo: 'stormSovereign', tier: 4 },
  ];
  // 다중 파트너 인덱스 — 한 능력이 여러 조합에 참여 가능
  const COMBO_PARTNERS = {};
  for (const r of COMBO_RECIPES) {
    for (let i = 0; i < r.parts.length; i++) {
      const me = r.parts[i];
      const other = r.parts[1 - i];
      if (!COMBO_PARTNERS[me]) COMBO_PARTNERS[me] = [];
      COMBO_PARTNERS[me].push({ partner: other, combo: r.combo, tier: r.tier || 2 });
    }
  }
  // 기존 단일 파트너 인덱스 (역호환) — 첫 번째 항목 사용
  const COMBO_PARTNER = {};
  for (const id in COMBO_PARTNERS) {
    COMBO_PARTNER[id] = COMBO_PARTNERS[id][0];
  }

  // 조합 자동 형성은 제거됨 (뱀파이어 서바이버즈 스타일)
  // 이제 조합은 두 재료가 모두 max 도달 시 다음 카드 모달에 '조합' 옵션으로 등장하며,
  // 플레이어가 그 카드를 선택할 때만 형성됨. (applyLevelUpChoice의 'combo' 액션 참고)
  function checkCombos() { return false; }

  // ===== 라운드 설정 =====
  // 일반: 30초간 1초에 1마리씩 (총 20마리). 다 잡으면 즉시 다음 라운드 + 보너스 점수.
  // 5라운드마다 보스 라운드: 잡몹 절반 + 보스 1마리.
  // 100라운드: 5라운드분 시간(150초) + 보스 3마리 + 잡몹 다수 (최종전).
  const MAX_ROUND = 100;
  // 🛡 자가치유 상한 — "정상 점수(억~조)"는 보존, "경(1e16)·해(1e20) 같은 익스플로잇"만 제거.
  //   정상 최대치(딥엔드리스/초월 ~수백억~수천억)와 익스플로잇은 자릿수가 완전히 다름.
  //   10조(1e13) = 정상 최대 추정치의 ~100배 위 / 경(1e16)의 1000배 아래 → 그 사이에 안전하게 선.
  const SCORE_SANE_CAP = 10000000000000;  // 10조 (= 10,000,000,000,000)
  // ♾ 엔드리스 모드 HP 배수 — R100 클리어 후 한 라운드마다 ×1.5 (기하급수)
  const ENDLESS_HP_MUL = 1.5;
  // 🏆 v262 — A: 엔드리스(R100+) 점수 패널티 — 낮은 난이도일수록 강하게 감쇠
  //   일반(승천0)으로 엔드리스 무한 파밍해도 승천/초월 정공법 점수를 못 넘게 함
  //   승천 0: ×0.30 / 승천 5: ×0.70 / 승천 9+: ×1.0 (패널티 없음)
  function endlessScorePenalty() {
    if (!state || (state.round || 0) <= MAX_ROUND) return 1;
    return Math.min(1, 0.30 + (state.ascension || 0) * 0.08);
  }
  // 능력 상향 보정 — 평균 빌드 DPS +20~30% 만큼 적 HP +8% 보정 (전 구간)
  const ABILITY_BUFF_HP_COMP = 1.08;
  function enemyHpFor(n) {
    // R1~25 지수 성장 (그대로 — 초반 큰 변화 없음), R26+ 가파르게 (베테랑 파워 대응)
    let base;
    if (n <= 25) base = Math.ceil(3 * Math.pow(1.35, n - 1));
    else {
      const baseR25 = Math.ceil(3 * Math.pow(1.35, 24));
      const d = n - 25;
      // 🛡 v259 — 중후반 곡선 강화: 선형 0.18 → 0.22, 2차 0.0035 → 0.005
      //   R50: ×7.7→×9.6 (+25%), R75: ×18.75→×22.4 (+20%), R100: ×34.2→×45.6 (+33%)
      base = Math.ceil(baseR25 * (1 + d * 0.22 + d * d * 0.005));
    }
    // ♾ 엔드리스: R100 이후 매 라운드 ×ENDLESS_HP_MUL (R101 = R100 × 1.5, R102 = R100 × 2.25, ...)
    if (n > MAX_ROUND) {
      const r100 = enemyHpFor(MAX_ROUND);  // R100 기준값 (이미 보정 포함)
      base = Math.ceil(r100 * Math.pow(ENDLESS_HP_MUL, n - MAX_ROUND));
      return base;  // 엔드리스는 r100에 이미 보정 포함이므로 추가 보정 X
    }
    return Math.ceil(base * ABILITY_BUFF_HP_COMP);
  }
  function roundConfig(n) {
    const baseHp = enemyHpFor(n);
    const isFinal = n === MAX_ROUND;
    const isBossNormal = n > 0 && n % 5 === 0 && !isFinal;
    // 승천 배수 적용 (state 가 있을 때만; 메뉴에서 호출 시엔 무시)
    const asc = (typeof state !== 'undefined' && state && state.asc) ? state.asc : {
      enemyHpMul: 1, bossHpMul: 1, enemySpeedMul: 1, enemyCountAdd: 0, roundTimeMul: 1,
      extraBossCount: 0, eliteEscorts: 0, extraBossRounds: false,
    };
    // 추가 보스 라운드 — Asc 13+ 에서 R10, 30, 50, 70, 90 에 보스
    const isExtraBoss = !isFinal && asc.extraBossRounds && !isBossNormal &&
                        (n === 10 || n === 30 || n === 50 || n === 70 || n === 90);
    const isBoss = isBossNormal || isExtraBoss;
    const mm = (typeof state !== 'undefined' && state && state.metaMods) ? state.metaMods : { roundTimeBonus: 0 };
    const relicEnemySpd = (typeof state !== 'undefined' && state && state.relicEffects && state.relicEffects.enemySpeedMul) || 1;
    const relicBossHp = (typeof state !== 'undefined' && state && state.relicEffects && state.relicEffects.bossHpMul) || 1;
    // 🏰 TD 밸런스 — 두 단계 적용
    //  • R1~4 초반: 타워 1~2개로 클리어 가능하게 적 수/HP 감소
    //  • R5+ 중·후반: TD는 진화가 콤보보다 저렴(1능력만 소모) → 적 HP/보스 HP 가중치 ↑
    //                  대신 적 수는 그대로 유지 (배치 공간 한정 고려)
    const isDefenseMode = (typeof state !== 'undefined' && state && state.mode === 'defense');
    let tdHpMul = 1, tdCountMul = 1, tdBossHpMul = 1;
    if (isDefenseMode) {
      if (!isBoss && !isFinal) {
        // 초반 약화
        if (n === 1)      { tdHpMul = 0.5;  tdCountMul = 0.4; }
        else if (n === 2) { tdHpMul = 0.6;  tdCountMul = 0.55; }
        else if (n === 3) { tdHpMul = 0.75; tdCountMul = 0.7; }
        else if (n === 4) { tdHpMul = 0.85; tdCountMul = 0.85; }
        // R5+ : 진화 비용 메리트 보상용 HP 가중치 (점진적 강화)
        else if (n <= 9)   tdHpMul = 1.20;  // R5~9
        else if (n <= 14)  tdHpMul = 1.30;  // R10~14
        else if (n <= 24)  tdHpMul = 1.35;  // R15~24
        else               tdHpMul = 1.40;  // R25+
      } else {
        // 보스/최종 보스: HP 가중치 (위치 제약으로 보스 키팅 어려움 보상)
        tdBossHpMul = 1.35;
      }
    }
    // 🛡 v259 — v251 엔드리스 +6%/round 롤백: enemyHpFor() 가 이미 R100+ 에서 ×1.5^(n-100) 가속 → 추가 보정 불필요 (이중 가속이라 너무 가팔라짐)
    // 🎁 이벤트/대박 보상 누적 보정 — 보상이 라운드마다 쌓여 후반이 쉬워지므로, 라운드 비례로 적·보스 HP 상향 (초반 그대로)
    const eventComp = 1 + Math.min(0.25, Math.max(0, n - 5) * 0.005);   // R5부터 +0.5%/R, 최대 +25% (적 누적·렉 완화 위해 하향)
    const hp = Math.ceil(baseHp * asc.enemyHpMul * tdHpMul * eventComp);
    const bossHp = Math.ceil(baseHp * (isFinal ? 13 : 10) * asc.bossHpMul * relicBossHp * tdBossHpMul * eventComp);
    const baseTime = isFinal ? 180 : 30;
    const duration = Math.max(15, Math.floor((baseTime + (mm.roundTimeBonus || 0)) * asc.roundTimeMul)) * FPS;
    const baseSpawn = isFinal ? 30 : (isBoss ? 10 : 20);
    // 보스 라운드 정예 적 + 일반 적 추가
    const eliteCount = isBoss ? (asc.eliteEscorts || 0) : 0;
    // 🏰 다중경로 맵 (twin/triple): 경로 수만큼 적 수 가중치 (per-path 부담 유지)
    // state.tdMapId 가 설정돼있으면 그것 기준, 없으면 ascension 기준 추정 (메뉴 미리보기 대응)
    let tdMultipathMul = 1;
    if (isDefenseMode && !isBoss && !isFinal) {
      let mapId = (typeof state !== 'undefined' && state && state.tdMapId) || null;
      if (!mapId && typeof state !== 'undefined' && state) {
        mapId = pickMapForAscension(state.ascension || 0);
      }
      // 경로 수 ↑ → 적 수 ↑ 단, per-path 부담은 줄이도록 (선형보다 약간 낮게)
      if (mapId === 'twin') tdMultipathMul = 1.35;       // 1.5 대신 1.35 (per-path ~67%)
      else if (mapId === 'triple') tdMultipathMul = 1.7; // 2.0 대신 1.7 (per-path ~57%)
    }
    const spawnCount = Math.max(1, Math.round((baseSpawn + eliteCount + (isFinal ? 0 : (asc.enemyCountAdd || 0))) * tdCountMul * tdMultipathMul));
    // 🏰 TD 골드 가중치 — 표준 모드 대비 ×3 (타워 30+개 유지 비용 보전)
    const tdGoldMul = isDefenseMode ? 3.0 : 1.0;
    return {
      duration,
      spawnCount,
      spawnInterval: isFinal ? 5 * FPS : (isBoss ? 2 * FPS : 1 * FPS),
      enemyHp:       hp,
      enemySpeed:    (0.008 + (n - 1) * 0.0005) * asc.enemySpeedMul * relicEnemySpd,
      // 일반 적 골드: 클래식 sqrt(hp)*0.03, TD sqrt(hp)*0.09 (3배)
      enemyGold:     Math.max(1, Math.ceil(Math.sqrt(hp) * 0.03 * tdGoldMul)),
      isBoss, isFinal, isExtraBoss,
      bossHp,
      // 보스 골드 — 클래식 sqrt(hp)*1.8, TD sqrt(hp)*5.4 (3배). isFinal: 클래식 4.5, TD 13.5
      bossGold:      Math.ceil(Math.sqrt(hp) * (isFinal ? 4.5 : 1.8) * tdGoldMul),
      // 보스 추가 개수 + 정예 정보 (planRound 에서 사용)
      extraBosses:  isBoss ? (asc.extraBossCount || 0) : 0,
      eliteCount,
    };
  }

  // ===== 게임 상태 =====
  let state, paused;
  function reset() {
    // 🏰 게임 모드 — 메뉴 → 모드 선택에서 결정
    // 'standard': 기존 — 적 한계 초과 시 패배
    // 'defense':  디펜스 — 적이 타워로 직진, 타워 HP 0 시 패배
    const gameMode = 'standard';   // 🚫 디펜스 모드 비활성화 — 항상 클래식 모드로 진행
    // 🔒 게임 시작 시 해금 검증 — 잠긴 캐릭터로 시작 못 하게 (조작 방지)
    try { if (!isCharUnlocked(selectedCharacter)) { selectedCharacter = 'standard'; META.selectedCharacter = 'standard'; } } catch (e) { selectedCharacter = 'standard'; }
    state = {
      mode: gameMode,
      // 🏰 디펜스 모드 전용 — 타워 체력
      towerHP:    gameMode === 'defense' ? 40 : 0,
      towerMaxHP: gameMode === 'defense' ? 40 : 0,
      tower: {
        abilities: [],     // [{id, level, cooldown, ...각 능력별 상태}]
        acquireCount: 0,   // 랜덤 능력 획득 누적 횟수 (비용 계산용)
      },
      enemies: [],
      bullets: [],
      particles: [],
      damageNumbers: [],   // 데미지 숫자 부유 효과
      comboFlash: 0,
      comboFlashColor: '#ffaa55',
      comboReveal: null,   // 콤보 형성 시 큰 카드
      shakeFrames: 0,      // 화면 흔들림 잔여 프레임
      shakeStrength: 0,
      kills: 0,            // 현재 레벨 진행도 처치 수
      totalKills: 0,       // 게임 전체 누적 처치 (업적용)
      luckyCount: 0,       // 럭키 카드 트리거 횟수 (업적용)
      playerLevel: 1,
      killsToNextLevel: 8,
      levelUpChoices: null, // 레벨업 선택 카드들 (활성 시 모달)
      rerollAvailable: false, // 이번 카드 모달에서 리롤 가능 여부 (강화소 구매 시 매 카드마다 1회)
      cardCost: 0,           // 카드 모달 표시용 비용 (UI)
      cardCostPaid: 0,       // 실제 차감된 골드 (취소 시 환불용)
      cardCancelable: false, // 카드 모달이 취소 가능한지 (랜덤 구매로 열렸을 때만)
      autoCardTimer: 0,      // 자동 카드 선택 카운트다운 (프레임)
      round: 1,
      roundFrame: 0,        // 현재 라운드 경과 프레임
      bossIntro: null,      // 🌌 v267 — 특수 보스 등장 연출 시퀀스 { special, frame, dur }
      pendingSpecialBoss: null,  // 다음 spawnBoss 에 적용할 특수 보스 id
      abilitySealUntil: 0,  // 사신 능력 봉인 종료 프레임
      spawnPlan: [],        // 이번 라운드에 남은 스폰 시점
      gold: 0,
      score: 0,
      gameOver: false,
      gameOverReason: '',
      gameWin: false,
      t: 0,
      // ♾ 엔드리스 모드 (R100 클리어 후 사용자 선택)
      endless: false,                // 엔드리스 진행 중 여부
      endlessOfferPending: false,    // R100 클리어 시 "계속하시겠습니까?" 모달 활성화
      // 📊 능력별 누적 데미지 (게임오버 후 통계용)
      abilityDamageStats: {},   // { abilityId: totalDamage }
      // 💎 유물 시스템
      activeRelics: [],           // [{id, name, icon, rarity, ...}] — 이번 게임 보유 유물
      selectedCharacter: selectedCharacter || 'standard',  // 🌌 v245 — 고대 유물 캐릭 매칭용
      relicOffering: null,        // 보스 처치 후 제안 UI 활성화 (null = 닫힘)
      relicEffects: {              // 유물이 작동시키는 효과들
        // 기본 스탯
        maxAliveAdd:         0,
        aoeRangeMul:         1,
        aoeDmgMul:           1,
        rangeMul:            1,
        cooldownMul:         1,
        explodeRadiusMul:    1,
        enhanceEffectMul:    1,
        passiveEffectMul:    1,
        enemySpeedMul:       1,
        bossHpMul:           1,
        executeBelow:        0,
        // 트리거
        autoGold:            false,
        bossKillResetCooldown: false,
        bossKillFreezeFrames:  0,    // 자비의 망토 — 보스 처치 시 적 정지 프레임
        bossKillGoldPerRound:  0,    // 자비의 망토 — 보스 처치 시 라운드×N 골드
        doubleEnhance:       false,
        doubleEnhanceCharges: 0,  // 복제기 충전 (5회 한정)
        bossStartStop:       0,
        roundStartTimeStop:  0,
        roundStartFreeUpgrade: false,
        roundStartFreeCard:  false,
        chainLightning:      false,
        // 카드 모달 (사용 안 함 - 수동 조작 회피)
        cardCount:           3,
        extraRerolls:        0,
        // 천둥의 신 (Epic)
        thunderGod:          false,
        thunderTimer:        0,
        // 보석 사냥꾼 (Rare)
        gemHunterChance:     0,
        // 슬롯
        bonusActiveSlot:     0,
        bonusPassiveSlot:    0,
        // 부활/스킵
        deathDefiance:       0,
        skipRoundCharges:    0,
        skipRoundBossCount:  0,
        bossesSlain:         0,
        // 누적 효과
        tombStackPerRound:   0,    // 라운드 클리어당 데미지 추가 (묘비의 화환)
        tombStackBonus:      0,    // 누적된 묘비 보너스
        killCountDmgRate:    0,    // 1000킬당 데미지 (사신의 손)
        goldEarnedDmgRate:   0,    // 1000골드당 데미지 (망자의 부적)
        goldEarnedTotal:     0,    // 누적 획득 골드
        darkPactBonus:       0,    // 한계 50% 미만 시 보너스
        fateScaleBonus:      0,    // 한계 50% 이상 시 보너스
        // 발동 시 골드
        killGoldBonus:       0,
        killGoldCritChance:  0,
        abilityUseGold:      0,
        abilityUseCounter:   0,    // 능력 발동 카운터 (트리거용)
        // 보스 처치 누적
        dragonStackPerBoss:  0,    // 보스당 데미지 누적 (차원 용)
        dragonStackBonus:    0,    // 누적된 용 보너스
        // 유물 등장 확률 보너스
        relicChanceBonus:    0,
      },
    };
    // 메타 강화 + 캐릭터 패시브 적용 (캐릭터는 골드/점수에는 영향 없음)
    const mods = getMetaMods();
    const char = CHARACTERS[selectedCharacter] || CHARACTERS.standard;
    const cp = char.passive;
    // 승천 난이도 적용
    state.ascension = getSelectedAscension();
    const asc = getAscensionMods(state.ascension);
    state.asc = asc;
    initBackground();   // 🌌 단계별 우주 배경 재구성 (기본/승천/초월 팔레트 반영)
    state.gold = Math.floor(mods.startGold * asc.startGoldMul);
    state.metaMods = {
      goldMul:    mods.goldMul,
      scoreMul:   mods.scoreMul,
      enhanceMul: mods.enhanceMul * (cp.enhanceMul || 1) * asc.enhanceMul,
      bossDmgMul: mods.bossDmgMul * (cp.bossDmgMul || 1),
      dmgMul:     cp.dmgMul || 1,
      dmgBoost:   mods.dmgBoost || 0,
      bossGoldMul: mods.bossGoldMul || 0,
      slowMul:    cp.slowMul || 1,
      levelUpMul: cp.levelUpMul || 1,
      levelUpFast: mods.levelUpFast || 0,
      slotMod:    cp.slotMod || 0,
      freeRolls:  mods.freeRolls,
      // 신규 메타 강화
      luckyChanceBonus:      mods.luckyChanceBonus || 0,
      superLuckyChanceBonus: mods.superLuckyChanceBonus || 0,
      comboPowerBonus:       mods.comboPowerBonus || 0,
      maxAliveBonus:         mods.maxAliveBonus || 0,
      startReroll:           mods.startReroll || 0,
      roundTimeBonus:        mods.roundTimeBonus || 0,
      relicRarityBoost:      mods.relicRarityBoost || 0,  // 유물 등급 가중치 (0~15)
      // 🏰 디펜스 모드 전용
      towerRegenLv:          mods.towerRegenLv || 0,
      towerArmor:            mods.towerArmor || 0,
      defenseSlowBonus:      mods.defenseSlowBonus || 0,
      defenseRevive:         mods.defenseRevive || 0,
    };
    // 🏰 디펜스 모드 (TD): 본진 HP + 타워 entity 배열
    if (state.mode === 'defense') {
      state.towerMaxHP = 40 + (mods.towerHPBonus || 0);   // 기본 40 (강화소 설명과 일치)
      state.towerHP = state.towerMaxHP;
      state.defenseReviveUsed = false;
      state.towers = [];   // 배치된 타워 entity 배열
      // 🏰 Phase 4: 승천별 다중경로 맵 — Asc 0~4: basic, 5~9: twin, 10+: triple
      state.tdMapId = pickMapForAscension(state.ascension || 0);
      state.tdNextPathId = 0;          // 다음 스폰 적의 path 인덱스 (라운드로빈)
      state.tdDrawCount = 0;           // 누적 타워 뽑기 횟수 (다음 뽑기 비용 계산용)
      state.tdSlotDraws = {};          // (구) 슬롯별 카드 캐시 — 미사용
      state.tdHeldCard = null;         // 🎴 현재 손에 들고있는 카드 (배치 대기)
      state.tdDrawCards = null;        // 🎴 뽑기 모달에 표시 중인 3장
      state.selectedSlot = null;       // 슬롯 선택 중 (배치 모달)
      state.selectedTower = null;      // 기존 타워 선택 중 (강화 모달)
      // 🏰 TD 시작 골드 — 타워 1~2개 배치 가능하도록 (메타/승천 시작 골드와 합산)
      state.gold = (state.gold || 0) + 300;
      // 🏰 TD Prep Phase — 첫 라운드는 Start 버튼 누를 때까지 적 스폰 정지
      state.tdPrepPhase = true;
      state.tdPrepRoundFrameLock = true;
    }
    // 메타 강화: 시작 점수 (승천 페널티 적용)
    if (mods.startScore) state.score = Math.floor(mods.startScore * asc.startScoreMul);
    state.character = selectedCharacter;
    // 캐릭터 시작 능력 부여 (R1 획득)
    for (const id of char.startAbilities) {
      const ab = { id, level: 1, acquiredRound: 1 };
      ABILITY_DEFS[id].init(ab);
      state.tower.abilities.push(ab);
      unlockAbility(id);
    }
    checkCombos();
    planRound();
    paused = false;
    // 시작 무료 레벨업 (메타 보너스) — 카드 모달로 선택 (각각 따로)
    state.pendingFreeRolls = state.metaMods.freeRolls || 0;
    if (state.pendingFreeRolls > 0) {
      // 🎬 v253 — 화면 페이드 인 (180ms) 끝난 후 카드 등장 — "띡" 끊김 방지
      setTimeout(() => {
        // 게임 상태 유효 + 게임 화면 + 카드 안 떠있을 때만
        if (state && !state.gameOver && currentScreen === 'game' && !state.levelUpChoices) {
          triggerFreeRollCard();
        }
      }, 350);
    }
  }

  // 무료 시작 카드 모달 띄우기 (pendingFreeRolls 줄여가며 반복)
  function triggerFreeRollCard() {
    if (state.pendingFreeRolls <= 0) return;
    const choices = generateLevelUpChoices();
    if (choices.length === 0) {
      state.pendingFreeRolls = 0;
      return;
    }
    state.levelUpChoices = choices;
    state.cardCost = 0;
    state.cardCostPaid = 0;
    state.cardCancelable = false;   // 무료 카드는 취소 불가 (강제 선택)
    state.rerollAvailable = false;
    state.isFreeRollCard = true;    // 표시용 플래그
    renderPanel();
  }

  // 라운드 진행 — 100라운드 이상이면 승리
  function advanceRound() {
    // 💎 직전 라운드 클리어 보너스 — 묘비의 화환 누적
    if (state.relicEffects && state.relicEffects.tombStackPerRound > 0) {
      state.relicEffects.tombStackBonus += state.relicEffects.tombStackPerRound;
    }
    // 🏰 디펜스 모드 (TD): 라운드 클리어 시 타워 HP 회복
    if (state.mode === 'defense' && state.towerHP > 0) {
      const towerRegen = state.metaMods.towerRegenLv || 0;
      if (towerRegen > 0) {
        const healed = Math.min(towerRegen, state.towerMaxHP - state.towerHP);
        if (healed > 0) {
          state.towerHP += healed;
          const map = getActiveTDMap();
          const last = map.core || (getMapPaths(map)[0].slice(-1)[0]);
          const lc = cellCenter(last.col, last.row);
          state.damageNumbers.push({
            x: lc.x, y: lc.y - 30, vy: -1.5,
            text: `+${healed} HP`, color: '#88ff88', life: 45, size: 14,
          });
        }
      }
    }
    state.round++;
    if (state.round > MAX_ROUND && !state.endless) {
      // ♾ R100 클리어 — 우선 승리 확정 (업적/랭킹용), 그 다음 엔드리스 진입 여부 물어봄
      state.gameWin = true;
      state.endlessOfferPending = true;
      paused = true;  // 선택 대기
      SFX.victory();
      return;
    }
    planRound();
    // 🧪🧪 [테스트용 토글] true 면 매 라운드 강제로 기습 이벤트(NPC 난입 컷인) 등장. 평소엔 false.
    //    false = 정상(저확률 상점 + 라운드 12% 기습 이벤트).
    const _TEST_EVENTS = false;
    if (_TEST_EVENTS && state.mode !== 'defense' && !state.gameOver && !state.levelUpChoices && state.round > 1) {
      if (typeof openAmbushEvent === 'function') openAmbushEvent();
    }
    // 🛒 특별 상점 — "운 좋은 만남". 낮은 확률 + 한 판 최대 4회 + 쿨다운 → 보통 2~4번, 많아야 4번만 등장.
    //    ⚙ 튜닝: 0.04(라운드당 확률) · 4(한 판 최대 횟수) · 4(최소 라운드 간격).
    if (!_TEST_EVENTS && state.mode !== 'defense' && !state.gameOver && !state.levelUpChoices && state.round >= 3 &&
        (state._shopCount || 0) < 4 &&
        (state.round - (state._lastShopRound || -99)) >= 4 && Math.random() < 0.02) {
      state._lastShopRound = state.round;
      state._shopCount = (state._shopCount || 0) + 1;
      if (typeof openShopCutin === 'function') openShopCutin(); else if (typeof openShop === 'function') openShop();
    }
    // ⚡ 라운드 랜덤 이벤트 (A) — 상점이 안 뜬 라운드에 12% 확률로 기습 이벤트(NPC 난입) 등장 (보스 이벤트와 별개, 쿨다운 2라운드)
    else if (!_TEST_EVENTS && state.mode !== 'defense' && !state.gameOver && !state.levelUpChoices && state.round >= 3 &&
        (state.round - (state._lastEventRound || -99)) >= 2 && Math.random() < 0.09) {
      state._lastEventRound = state.round;
      if (typeof openAmbushEvent === 'function') openAmbushEvent();
    }
    // 💎 유물 효과 — 라운드 시작 시 발동
    const re = state.relicEffects;
    if (re) {
      // 시간 멈춤의 시계: 라운드 시작 시 모든 적 정지
      if (re.roundStartTimeStop > 0) {
        for (const e of state.enemies) {
          if (e.hp <= 0) continue;
          e.slowFrames = Math.max(e.slowFrames || 0, re.roundStartTimeStop);
          if (!e.isBoss) e.timeStopped = state.t + re.roundStartTimeStop;
        }
        toast('⏰ 시간 멈춤');
      }
      // 🔮 별·예지 이벤트 — 1회성: 다음 라운드 시작 시 적 전부 정지 (소비)
      if (state._eventFreeze > 0) {
        for (const e of state.enemies) { if (e.hp <= 0) continue; e.slowFrames = Math.max(e.slowFrames || 0, state._eventFreeze); if (!e.isBoss) e.timeStopped = state.t + state._eventFreeze; }
        toast('🔮 예지 — 시간이 멈춘다');
        state._eventFreeze = 0;
      }
      // 빈티지 와인: 라운드 시작 시 무료 강화 1회 (가장 낮은 lv 능력)
      if (re.roundStartFreeUpgrade) {
        const owned = state.tower.abilities.filter(a => !isAtMax(a));
        if (owned.length > 0) {
          owned.sort((a, b) => a.level - b.level);
          owned[0].level++;
          toast(`🍷 무료 강화: ${ABILITY_DEFS[owned[0].id].name} +1`);
        }
      }
      // (신탁의 책 제거됨 — 천둥의 신으로 대체, 자동 발동)
    }
    // 💎 종말의 시계 — 다음 라운드 스킵 트리거 (시뮬레이션 보상 지급)
    if (state.skipNextRound) {
      state.skipNextRound = false;
      // 스킵되는 라운드의 자원을 시뮬레이션 — 실제 클리어 한 것과 동등한 보상
      const cfg2 = roundConfig(state.round);
      const mm = state.metaMods || { goldMul: 1, scoreMul: 1, bonusGoldMul: 0 };
      const simKills = cfg2.spawnCount;
      // 🛡 v257 — bonusGoldMul cap 동일 적용 (스킵 라운드 보상도 동일하게)
      const goldBonus = Math.min(3.0, mm.bonusGoldMul || 0);
      const goldEach = Math.ceil(cfg2.enemyGold * (mm.goldMul || 1) * (1 + goldBonus)) + Math.floor(mm.vampiricFlat || 0);   // 💉 v276 흡혈 고정분 포함
      const giveGold  = simKills * goldEach;
      const giveScore = Math.ceil(simKills * 10 * state.round * (mm.scoreMul || 1) * ((state.asc && state.asc.scoreReward) || 1) * endlessScorePenalty());
      state.gold  += giveGold;
      state.score += giveScore;
      state.totalKills = (state.totalKills || 0) + simKills;
      if (state.relicEffects) state.relicEffects.goldEarnedTotal = (state.relicEffects.goldEarnedTotal || 0) + giveGold;
      // 능력 레벨업 트리거를 위해 kills도 같이 증가 (시뮬 처치 = 진짜 처치로 간주)
      state.kills = (state.kills || 0) + simKills;
      toast(`⏳ 자동 클리어 보상 — +${giveGold}G, +${giveScore.toLocaleString()}점`);
      setTimeout(() => advanceRound(), 1000);
    }
  }
  function endGame(reason, win) {
    if (state.gameOver) return;
    state.gameOver = true;
    state.gameOverReason = reason;
    // ♾ 엔드리스 중 사망해도 R100 클리어 기록은 유지
    state.gameWin = !!win || !!state.gameWin;
    // 카드 모달이 떠있었다면 환불 + 클리어
    if (state.levelUpChoices) {
      if (state.cardCancelable && state.cardCostPaid > 0) {
        state.gold += state.cardCostPaid;
      }
      state.levelUpChoices = null;
      state.cardCost = 0;
      state.cardCostPaid = 0;
      state.cardCancelable = false;
      state.rerollAvailable = false;
    }
    shake(20, 15);
    if (win) SFX.victory(); else SFX.gameOver();
    state.totalTime = state.t;  // 게임 시간 (프레임)
    // 남은 골드 → 점수 환산 (G/10) — 강화 안 쓰고 남긴 골드 보상 (위로 보너스)
    // 🛡 유물 스택으로 골드가 지수 폭증 시 점수 인플레 방지 — 환산 점수 상한 100k
    state.goldRemaining = Math.max(0, state.gold || 0);
    state.goldBonusScore = Math.min(100000, Math.floor(state.goldRemaining / 10));
    if (state.goldBonusScore > 0) {
      state.score += state.goldBonusScore;
    }
    // 🏆 v262 — D: 난이도 클리어 보너스 (최종 점수 × 난이도 곱)
    //   scoreReward(처치당 곱)에 더해 최종 점수에도 난이도 곱 → 어려운 난이도가 항상 우위 보장
    //   승천1 ×1.1 / 승천15 ×2.5 / 초월15(asc30) ×4.0
    const _ascForBonus = state.ascension || 0;
    if (_ascForBonus > 0 && !state._diffBonusApplied) {
      state._diffBonusApplied = true;
      state.diffBonusMul = 1 + _ascForBonus * 0.10;
      state.scoreBeforeDiffBonus = state.score;
      state.score = Math.ceil(state.score * state.diffBonusMul);
    }
    // 🏆 v225 — 신기록 감지 (saveRecord 전에 캡처) + 결과 화면 애니메이션 시작 시각
    const prevBestScore = (META.records && META.records.length > 0)
      ? Math.max.apply(null, META.records.map(r => r.score || 0))
      : 0;
    state.isNewRecord = state.score > 0 && state.score > prevBestScore;
    state.gameOverAnimStart = (typeof performance !== 'undefined' && performance.now) ? performance.now() : Date.now();
    earnStardust();
    earnCrystals();
    recordCharUsage();        // 캐릭터 사용 라운드 기록
    checkAchievements();
    computeRewardData();       // 🎁 해금 보상 집계 (캐릭터/칭호/능력) + NEW 뱃지 카운트
    saveRecord();
    renderPanel();
    scheduleRewardSummary();   // 🎁 점수 연출 후 보상 패널 표시 (해금 있을 때만)
    // 🌐 글로벌 랭킹 자동 제출 (비동기)
    submitGlobalScore();
    // 🛡 v206 — 게임 종료 직후 META를 즉시 서버에 push (queueServerSync 디바운스 우회)
    //   사용자가 게임 종료 후 바로 로그아웃/탭 닫기 해도 진행도 손실 없게.
    if (typeof queueServerSync === 'function') queueServerSync(true);
  }

  // ===== 메타 프로그레션 (스타더스트 영구 통화) =====
  // 🔐 localStorage 난독화 — 캐주얼한 데이터 수정 방어
  //    완벽한 보호는 아니지만 (소스 노출됨) JSON 직접 편집은 차단
  //    실제 안티치트는 서버 sync_account_data의 델타 검증 (Supabase RPC) 에서 처리
  const META_KEY = '_dd_v2_4f7e';   // 위장된 키 이름 (이전 'dot-defense-meta')
  const META_KEY_OLD = 'dot-defense-meta';  // 마이그레이션용
  const _OBF_KEY = 'dd2026.x7Y3@k9F-pQz1';  // XOR 키 (단순 난독화)
  function _obfuscate(json) {
    let x = '';
    for (let i = 0; i < json.length; i++) {
      x += String.fromCharCode(json.charCodeAt(i) ^ _OBF_KEY.charCodeAt(i % _OBF_KEY.length));
    }
    // 유니코드 안전 base64
    return btoa(unescape(encodeURIComponent(x)));
  }
  function _deobfuscate(packed) {
    try {
      const x = decodeURIComponent(escape(atob(packed)));
      let json = '';
      for (let i = 0; i < x.length; i++) {
        json += String.fromCharCode(x.charCodeAt(i) ^ _OBF_KEY.charCodeAt(i % _OBF_KEY.length));
      }
      return json;
    } catch { return null; }
  }
  function _checksum(s) {
    // FNV-1a 32비트 해시 — 빠르고 짧음
    let h = 2166136261 >>> 0;
    for (let i = 0; i < s.length; i++) {
      h ^= s.charCodeAt(i);
      h = Math.imul(h, 16777619) >>> 0;
    }
    return h.toString(36);
  }
  // 저장 포맷: "<checksum>.<obfuscated_base64>"
  function _packMeta(obj) {
    const json = JSON.stringify(obj);
    return _checksum(json) + '.' + _obfuscate(json);
  }
  function _unpackMeta(packed) {
    if (!packed) return {};
    // 이전 평문 JSON 호환 (마이그레이션)
    if (packed.charAt(0) === '{') {
      try { return JSON.parse(packed); } catch { return {}; }
    }
    const sep = packed.indexOf('.');
    if (sep < 0) return {};
    const expected = packed.slice(0, sep);
    const obf = packed.slice(sep + 1);
    const json = _deobfuscate(obf);
    if (json === null) return {};
    if (_checksum(json) !== expected) {
      console.warn('⚠️ 데이터 무결성 검증 실패 — 변조 감지됨. 서버 데이터 시도 중...');
      // 실패 시 빈 객체 — 로그인되어 있으면 pullMetaFromServer로 복구됨
      return {};
    }
    try { return JSON.parse(json); } catch { return {}; }
  }
  let META = (function() {
    // 1) 새 키 (난독화 형식) 우선 시도
    try {
      const packed = localStorage.getItem(META_KEY);
      if (packed) {
        const data = _unpackMeta(packed);
        if (Object.keys(data).length > 0) return data;
      }
    } catch {}
    // 2) 이전 평문 키에서 마이그레이션
    try {
      const old = localStorage.getItem(META_KEY_OLD);
      if (old) {
        const obj = JSON.parse(old);
        // 새 키로 저장 후 이전 키 삭제
        try {
          localStorage.setItem(META_KEY, _packMeta(obj));
          localStorage.removeItem(META_KEY_OLD);
        } catch {}
        return obj;
      }
    } catch {}
    return {};
  })();
  // 🛡 마이그레이션 — 제거된 강화소 항목에 쓴 스타더스트 환불 (v198)
  //   wallHP / wallRegen / defenseRange 는 실제 게임 로직에 적용되지 않던 미구현 항목.
  //   강화소에서 제거하면서, 이미 구매한 사람한테 비용 그대로 돌려줌.
  (function refundDeprecatedUpgrades() {
    if (!META.upgrades) return;
    const REMOVED_COSTS = {
      wallHP:       lv => 200 * (lv + 1),
      wallRegen:    lv => 350 * (lv + 1),
      defenseRange: lv => 300 * (lv + 1),
    };
    let totalRefund = 0;
    const refundedIds = [];
    for (const rid in REMOVED_COSTS) {
      const lv = META.upgrades[rid] || 0;
      if (lv > 0) {
        for (let i = 0; i < lv; i++) totalRefund += REMOVED_COSTS[rid](i);
        refundedIds.push(rid);
        delete META.upgrades[rid];
      }
    }
    if (totalRefund > 0) {
      META.stardust = (META.stardust || 0) + totalRefund;
      META.stardustSpent = Math.max(0, (META.stardustSpent || 0) - totalRefund);
      META._pendingRefundMsg = `💰 미구현 항목 환불: ${totalRefund}★ (${refundedIds.join(', ')})`;
      try { localStorage.setItem(META_KEY, _packMeta(META)); } catch {}
    }
  })();
  // 🛡 데이터 정합성 catch-up (v202) — 로드 시 earned 카운터가 current보다 작으면 맞춤.
  //   서버 데이터 직접 수정 (Supabase 콘솔에서 stardust 등을 임의 변경) 후 sync 시
  //   merge가 잘못된 fallback을 쓰는 문제 방지.
  (function reconcileEarnedCounters() {
    const stardust = META.stardust || 0;
    const earned = META.stardustEarned || 0;
    const spent = META.stardustSpent || 0;
    // 정합성: earned - spent === stardust 가 이상적. 어긋나면 earned를 stardust+spent로 catch-up
    const expectedEarned = stardust + spent;
    if (expectedEarned > earned) META.stardustEarned = expectedEarned;
    // crystals도 동일하게
    const crystals = META.crystals || 0;
    const cEarned = META.crystalsEarned || 0;
    const cSpent = META.crystalsSpent || 0;
    const cExpected = crystals + cSpent;
    if (cExpected > cEarned) META.crystalsEarned = cExpected;
    try { localStorage.setItem(META_KEY, _packMeta(META)); } catch {}
  })();
  function saveMeta() {
    // 🕒 변경 시각 기록 — 다기기 동기화 시 "최근 변경" 판별용 (preferences 우선순위)
    META.metaUpdatedAt = Date.now();
    try { localStorage.setItem(META_KEY, _packMeta(META)); } catch {}
    // 🔐 계정 로그인 상태면 서버에도 동기화
    if (typeof queueServerSync === 'function') queueServerSync();
  }

  // ===== 🌐 Supabase 글로벌 랭킹 시스템 =====
  // ⚠ 아래 두 값을 Supabase 대시보드(Settings → API)에서 복사해 채우세요.
  //   비워두면 로컬 기록만 사용 (글로벌 랭킹 비활성).
  const SUPABASE_URL = 'https://lvbnxdncjhijbajuvbmv.supabase.co';
