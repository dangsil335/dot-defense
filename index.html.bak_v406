    ctx.restore();
  }
  // ☠ 종말·아바돈 — 가시 왕관 + 각진 본체 + 불타는 핵 + 세로 슬릿 눈 + 궤도 위성 눈 (전용 최종보스 외형)
  function drawAbaddonShape(ctx, s, fill, edge, eyeGlow, eyeColor) {
    const _t = (typeof state !== 'undefined' && state && state.t) || 0;
    const dark = darkenHex(fill, 0.5), edgeC = edge || darkenHex(fill, 0.65);
    const _e = (eyeColor || '#ff2a5a').replace('#', ''); const _en = parseInt(_e, 16); const ergb = `${(_en >> 16) & 255},${(_en >> 8) & 255},${_en & 255}`;
    const pulse = 1 + Math.sin(_t * 0.09) * 0.06;
    const glowI = (eyeGlow && eyeGlow > 0) ? Math.min(1.5, eyeGlow) : 1;
    // 외곽 회전 에너지 호 (가산)
    ctx.save(); ctx.globalCompositeOperation = 'lighter'; ctx.lineWidth = 2.4;
    for (let k = 0; k < 5; k++) { const a0 = -_t * 0.025 + k * (Math.PI * 2 / 5); ctx.strokeStyle = `rgba(${ergb},${0.26 * glowI})`; ctx.beginPath(); ctx.arc(0, 0, s * 1.6 * pulse, a0, a0 + 0.7); ctx.stroke(); }
    ctx.restore();
