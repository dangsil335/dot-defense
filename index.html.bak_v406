        choices: [
          { label: '재조합한다', desc: '능력 하나 희생 → 새 능력 2개', resolve() { return _evSacrificeRebirth(); } },
          { label: '거절한다', desc: '내 힘은 내 것', resolve() { return '악마가 혀를 찬다.'; } },
        ] }),
      () => ({ title: '😈 금단의 힘', text: '"거대한 것을 부수는 힘이다. 약간의 위험쯤은, 감수하겠지?"',
